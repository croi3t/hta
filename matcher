            patient.diseases.forEach(function (d) {
                var endStr = d.endDate ? formatDate(d.endDate) : '継続中';
                var outcome = d.outcome || (d.outcomeCode === '0' ? '継続中' : d.outcome);
                var meta = formatDate(d.startDate) + ' ～ ' + endStr;
