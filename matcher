            patient.injPeriods.forEach(function (p) {
                var matchClass = '';
                var matchInfo = '';
                if (p.matches && p.matches.length > 0) {
                    var best = p.matches.reduce(function (a, b) {
                        var rank = { full: 3, partial: 2, near: 1, none: 0 };
                        return rank[a.level] >= rank[b.level] ? a : b;
                    });
                    matchClass = 'matched-' + best.level;
                    matchInfo = ' → ' + best.disease.name + ' (' + getMatchLabelText(best.level) + ')';
                }
                var meta = formatDate(p.startDate) + ' ～ ' + formatDate(p.endDate);
                var recCount = p.records.length;
                var firstRec = p.records[0];
                var dose = getInjDose(firstRec);
                var unit = getInjUnit(firstRec);
                var dept = getDept(firstRec);
                if (dose) meta += ' | ' + dose + (unit || '');
                if (dept) meta += ' | ' + dept;
                meta += ' (' + recCount + '件)';
                html += '<div class="detail-item ' + matchClass + '">' +
                    '<div class="item-name">' + escHtml(p.drug) + '</div>' +
                    '<div class="item-meta">' + escHtml(meta) + '</div>';
                if (matchInfo) html += '<div class="item-meta" style="color:var(--green)">' + escHtml(matchInfo) + '</div>';
                html += '</div>';
            });
            html += '</div>';

            // Dx column
            html += '<div class="detail-col"><h4 class="dx-title">🏥 診断病名 (' + patient.diseases.length + '件)</h4>';
