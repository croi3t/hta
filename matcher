        // ===== CSV Export =====
        function exportCSV() {
            var BOM = '\uFEFF';
            var header = '患者ID,氏名,年齢,診療科,処方薬品,注射薬品,病名,マッチ状態\n';
            var body = filteredResult.map(function (p) {
                return [
                    '"' + p.id + '"',
                    '"' + p.name + '"',
                    '"' + p.age + '"',
                    '"' + p.dept + '"',
                    '"' + uniqueNames(p.rxPeriods).join('; ') + '"',
                    '"' + uniqueNames(p.injPeriods).join('; ') + '"',
                    '"' + uniqueDiseaseNames(p.diseases).join('; ') + '"',
                    '"' + getMatchLabelText(p.matchLevel) + '"'
                ].join(',');
            }).join('\n');
            var blob = new Blob([BOM + header + body], { type: 'text/csv;charset=utf-8' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url; a.download = 'patient_matching_result.csv';
            a.click();
            URL.revokeObjectURL(url);
        }

        // ===== Event Handlers =====
        function setupFileInput(inputId, cardId, infoId, dataKey) {
            var input = document.getElementById(inputId);
            var card = document.getElementById(cardId);
            var info = document.getElementById(infoId);

            input.addEventListener('change', function () {
                if (!this.files[0]) return;
                var file = this.files[0];
                readFileAsText(file, function (text) {
                    rawData[dataKey] = text;
                    var rows = parseCSV(text);
                    card.classList.add('loaded');
                    info.classList.remove('hidden');
                    info.textContent = '✓ ' + file.name + ' (' + (rows.length - 1) + ' 行)';
                    updateAnalyzeButton();
                });
            });

            // Drag & Drop
            card.addEventListener('dragover', function (e) { e.preventDefault(); card.classList.add('dragover'); });
            card.addEventListener('dragleave', function () { card.classList.remove('dragover'); });
            card.addEventListener('drop', function (e) {
                e.preventDefault(); card.classList.remove('dragover');
                if (e.dataTransfer.files.length > 0) {
                    input.files = e.dataTransfer.files;
                    input.dispatchEvent(new Event('change'));
                }
            });
        }

        function updateAnalyzeButton() {
            var hasRxOrInj = rawData.rx || rawData.inj;
            var hasDx = !!rawData.dx;
            document.getElementById('btn-analyze').disabled = !(hasRxOrInj && hasDx);
        }

        function init() {
            setupFileInput('file-rx', 'card-rx', 'info-rx', 'rx');
            setupFileInput('file-inj', 'card-inj', 'info-inj', 'inj');
            setupFileInput('file-dx', 'card-dx', 'info-dx', 'dx');

            document.getElementById('btn-analyze').addEventListener('click', function () {
                document.getElementById('loading').classList.remove('hidden');
                expandedPatientId = null;
                setTimeout(function () {
                    try {
                        runAnalysis();
                        renderSummary();
                        renderDeptFilter();
                        applyFilters();
                        document.getElementById('results-area').classList.remove('hidden');
                    } catch (e) {
                        alert('分析中にエラーが発生しました: ' + e.message);
                        console.error(e);
                    }
                    document.getElementById('loading').classList.add('hidden');
                }, 100);
            });

            // Search & filter
            document.getElementById('search-input').addEventListener('input', function () { applyFilters(); });
            document.getElementById('filter-dept').addEventListener('change', function () { applyFilters(); });

            // Match chips
            document.querySelectorAll('.match-chip').forEach(function (chip) {
                chip.addEventListener('click', function () {
                    document.querySelectorAll('.match-chip').forEach(function (c) { c.classList.remove('active'); });
                    this.classList.add('active');
                    activeMatchFilter = this.getAttribute('data-match');
                    applyFilters();
                });
            });

            // Sort
            document.querySelectorAll('.results-table thead th[data-col]').forEach(function (th) {
                th.addEventListener('click', function () {
                    var col = this.getAttribute('data-col');
                    if (col === 'rxDrugs' || col === 'injDrugs' || col === 'diseases') return; // no sort for name lists
                    if (sortState.col === col) { sortState.asc = !sortState.asc; }
                    else { sortState.col = col; sortState.asc = true; }
                    document.querySelectorAll('.results-table thead th').forEach(function (t) { t.classList.remove('sorted'); });
                    this.classList.add('sorted');
                    applyFilters();
                });
            });

            // Export
            document.getElementById('btn-export-csv').addEventListener('click', exportCSV);
        }

        document.addEventListener('DOMContentLoaded', init);
    </script>
</body>

</html>
