            // Rx column
            html += '<div class="detail-col"><h4 class="rx-title">💊 処方薬品 (' + patient.rxPeriods.length + '期間)</h4>';
            if (patient.rxPeriods.length === 0) html += '<div style="color:var(--text-muted);font-size:0.8rem;">データなし</div>';
            patient.rxPeriods.forEach(function (p) {
