                            <input type="text" id="ipt-med-adj-patient-search-2026" class="yr-form-control" style="width:180px; height:28px; font-size:12px; margin-right:5px;" placeholder="IDгҒҫгҒҹгҒҜеҗҚеүҚгӮ’е…ҘеҠӣ..." onkeypress="if(event.keyCode===13) searchPatientForMedAdj2026()">
                            <button class="yr-btn yr-btn-primary" style="font-size:11px; padding:3px 8px; margin-right:10px;" onclick="searchPatientForMedAdj2026()">жӨңзҙў</button>
