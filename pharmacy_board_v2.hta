                    <th width="100" style="cursor:pointer;" onclick="sortKarteLink('name')">ж°ҸеҗҚ в—Җв–¶</th>
                    <th width="70" style="cursor:pointer;" onclick="sortKarteLink('dept')">иЁәзҷӮз§‘ в—Җв–¶</th>
                    <th width="140" style="cursor:pointer;" onclick="sortKarteLink('disease')">дё»з—…еҗҚ в—Җв–¶</th>
