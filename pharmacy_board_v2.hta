    <!-- и–¬жӯҙгғ„гғјгғ«гӮҝгғ– (зӣҙжҺҘеҹӢгӮҒиҫјгҒҝ) -->
    <div id="tab-yakureki" class="tab-content">
        <div class="yr-container">
            <div id="yr-alertArea" class="yr-alert-info" style="display: none;"></div>
            <div class="yr-sticky-tabs" style="margin-bottom:0; border-bottom:2px solid #0d6efd;">
