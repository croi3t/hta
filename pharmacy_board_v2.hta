            "гғ©гғҷгғ—гғ©гӮҫгғјгғ«": "RPZ", "гӮЁгӮҪгғЎгғ—гғ©гӮҫгғјгғ«": "EPZ",
            "гғңгғҺгғ—гғ©гӮ¶гғі": "VPZ", "гӮҝгӮұгӮӯгғЈгғ–": "VPZ"
        };

        function lookupDrugAbbr(drugName) {
            var chk = document.getElementById('chk-use-abbr-dict');
            if (chk && !chk.checked) return null; // OFFгҒӘгӮүгӮ№гӮӯгғғгғ—
            
            // еҚҠи§’гӮ«гӮҝгӮ«гғҠгӮ’е…Ёи§’гҒ«еӨүжҸӣгҒ—гҒҰгҒӢгӮүиҫһжӣёеј•гҒҚ
            var fullName = drugName.replace(/[\uFF66-\uFF9F]/g, function(s) {
                var hk = "гғІгӮЎгӮЈгӮҘгӮ§гӮ©гғЈгғҘгғ§гғғгғјгӮўгӮӨгӮҰгӮЁгӮӘгӮ«гӮӯгӮҜгӮұгӮігӮөгӮ·гӮ№гӮ»гӮҪгӮҝгғҒгғ„гғҶгғҲгғҠгғӢгғҢгғҚгғҺгғҸгғ’гғ•гғҳгғӣгғһгғҹгғ гғЎгғўгғӨгғҰгғЁгғ©гғӘгғ«гғ¬гғӯгғҜгғігӮӣгӮң";
                var idx = s.charCodeAt(0) - 0xFF66;
                return idx >= 0 && idx < hk.length ? hk.charAt(idx) : s;
            });
            // жҝҒзӮ№гғ»еҚҠжҝҒзӮ№зөҗеҗҲпјҲгӮӣвҶ’жҝҒзӮ№гҖҒгӮңвҶ’еҚҠжҝҒзӮ№пјү
            fullName = fullName.replace(/([гӮ«гӮӯгӮҜгӮұгӮігӮөгӮ·гӮ№гӮ»гӮҪгӮҝгғҒгғ„гғҶгғҲгғҸгғ’гғ•гғҳгғӣ])гӮӣ/g, function(m, c) {
                var base = "гӮ«гӮӯгӮҜгӮұгӮігӮөгӮ·гӮ№гӮ»гӮҪгӮҝгғҒгғ„гғҶгғҲгғҸгғ’гғ•гғҳгғӣ";
                var daku = "гӮ¬гӮ®гӮ°гӮІгӮҙгӮ¶гӮёгӮәгӮјгӮҫгғҖгғӮгғ…гғҮгғүгғҗгғ“гғ–гғҷгғң";
                var i = base.indexOf(c);
                return i >= 0 ? daku.charAt(i) : m;
            }).replace(/([гғҸгғ’гғ•гғҳгғӣ])гӮң/g, function(m, c) {
                var base = "гғҸгғ’гғ•гғҳгғӣ";
                var han = "гғ‘гғ”гғ—гғҡгғқ";
                var i = base.indexOf(c);
                return i >= 0 ? han.charAt(i) : m;
            });
            for (var key in DRUG_ABBR_DICT) {
                if (DRUG_ABBR_DICT.hasOwnProperty(key)) {
                    if (drugName.indexOf(key) !== -1 || fullName.indexOf(key) !== -1) {
                        return DRUG_ABBR_DICT[key];
                    }
                }
            }
            return null;
        }

        function getFirst4HanKana(drugName) {
            // иЁҳеҸ·гӮ№гӮӯгғғгғ—: вҳ…пјҲиҰҒеұҠеҮәпјүпјҲиҰҒиЁұеҸҜпјүзӯүгӮ’йҷӨеҺ»
            var cleaned = drugName.replace(/^[\sгҖҖ]*/, '')
                .replace(/^вҳ…+/, '')
                .replace(/^[пјҲ(][^пјү)]*[пјү)]/, '')
                .replace(/^[\sгҖҖ]*/, '');
            if (!cleaned) return '';
            
            // еҚҠи§’гӮ«гӮҝгӮ«гғҠгҒ«еӨүжҸӣ
            var hk = toHankakuKana(cleaned);
            
            // е…Ҳй ӯ4ж–Үеӯ—гӮ’еҸ–еҫ—пјҲжҝҒзӮ№пҫһеҚҠжҝҒзӮ№пҫҹгҒҜеүҚгҒ®ж–Үеӯ—гҒЁгӮ»гғғгғҲгҒ§1ж–Үеӯ—жүұгҒ„пјү
            var chars = [];
            for (var i = 0; i < hk.length && chars.length < 4; i++) {
                var c = hk.charAt(i);
                // ж¬ЎгҒ®ж–Үеӯ—гҒҢжҝҒзӮ№гғ»еҚҠжҝҒзӮ№гҒ®е ҙеҗҲгҒҜгӮ»гғғгғҲгҒ§иҝҪеҠ 
                if (i + 1 < hk.length && (hk.charAt(i+1) === '\uFF9E' || hk.charAt(i+1) === '\uFF9F')) {
                    chars.push(c + hk.charAt(i+1));
                    i++;
                } else {
                    chars.push(c);
                }
            }
            return chars.join('');
        }
        
        function generateAbbreviation() {
            var input = document.getElementById('abbr-input');
            var resultEl = document.getElementById('abbr-result');
            var detailEl = document.getElementById('abbr-detail');
            if (!input || !resultEl) return;
            
            var text = input.value;
            if (!text.replace(/\s/g, '')) {
                resultEl.value = '';
                if (detailEl) detailEl.innerHTML = '';
                return;
            }
            
            var lines = text.split('\n');
            var drugNames = [];
            var seen = {};
            
            for (var i = 0; i < lines.length; i++) {
                var rawLine = lines[i];
                
                // вҳ…ж №жң¬дҝ®жӯЈ: еҲӨе®ҡгҒ®йӮӘйӯ”гҒ«гҒӘгӮӢпјҲеҗ‘пјүпјҲйә»пјүпјҲе…ҲпјүпјҲеҫҢпјүпјҲиҲ¬пјүзӯүгӮ’дёҖз•ӘжңҖеҲқгҒ«иЎҢгҒӢгӮүе®Ңе…ЁгҒ«ж¶ҲгҒ—еҺ»гӮӢ
                rawLine = rawLine.replace(/^([\sгҖҖ]*)[пјҲ\(](еҗ‘|йә»|еҠҮ|жҜ’|еҠҮгғ»еҗ‘|жҜ’гғ»еҗ‘|еҗ‘гғ»еҠҮ|е…Ҳ|еҫҢ|иҲ¬)[пјү\)]\s*/, '$1');
                
                var line = rawLine.replace(/^[\sгҖҖ]+/, '');
                if (!line) continue;
                
                var drugMatch = null;
                
                // гғ‘гӮҝгғјA: пјҲжҢҒеҸӮи–¬пјүи–¬е“ҒеҗҚ ж•°йҮҸTгҖҗ...гҖ‘пјҲи–¬жӯҙдҪңжҲҗгӮҝгғ–гҒ®е…ғгғҮгғјгӮҝеҪўејҸпјү
                if (/^пјҲжҢҒеҸӮи–¬пјү/.test(line)) {
                    drugMatch = line.replace(/^пјҲжҢҒеҸӮи–¬пјү/, '').replace(/\s+\d+.*$/, '').replace(/\s+гҖҗ.*$/, '').trim();
                }
                // гғ‘гӮҝгғјгғіB: гғҶгӮӯгӮ№гғҲж•ҙзҗҶжёҲгҒҝгҒ®еҪўејҸ - "ж•°еӯ—) и–¬е“ҒеҗҚж•°йҮҸ ж•°йҮҸT еҲҶX..." or "и–¬е“ҒеҗҚж•°йҮҸ ж•°йҮҸT еҲҶX..."
                else if (/^\d+\)\s*/.test(line)) {
                    var cleaned = line.replace(/^\d+\)\s*/, '');
                    drugMatch = cleaned.replace(/\s+\d+[TпјҙйҢ пҪ¶CпјЈеҢ…mlз®Ўжң¬жһҡиўӢg]+.*$/i, '').trim();
                    if (!drugMatch) drugMatch = cleaned.replace(/\s+еҲҶ\d.*$/, '').replace(/\s+\d+.*$/, '').trim();
                }
                // гғ‘гӮҝгғјгғіC: RpиЎҢгҒӘгҒ—гҒ§зӣҙжҺҘи–¬е“ҒеҗҚпјҲгғҶгӮӯгӮ№гғҲж•ҙзҗҶжёҲгҒҝгҒ§Rpз•ӘеҸ·гҒӘгҒ—пјү
                // и–¬е“ҒеҗҚ + ж•°йҮҸ + з”Ёжі•гҒ®гғ‘гӮҝгғјгғі
                else if (/^[^\sпјҲгҖҗRpеҲҶв—Ҷв—Үв–јв– вҳҶвҖ»]/.test(line) && /\d+[TпјҙйҢ пҪ¶CпјЈеҢ…mlз®Ўжң¬жһҡиўӢg]+/i.test(line)) {
                    drugMatch = line.replace(/\s+\d+[TпјҙйҢ пҪ¶CпјЈеҢ…mlз®Ўжң¬жһҡиўӢg]+.*$/i, '').trim();
                    if (!drugMatch) drugMatch = line.replace(/\s+\d+.*$/, '').trim();
                }
                // гғ‘гӮҝгғјгғіD: и–¬жӯҙдҪңжҲҗгӮҝгғ–гҒ®RpиЎҢгҒ®ж¬ЎиЎҢгҒ«гҒӮгӮӢи–¬е“ҒеҗҚиЎҢ
                // "гҖҖгҖҖи–¬е“ҒеҗҚйҢ XX ж•°йҮҸT ..."гҒ®гғ‘гӮҝгғјгғіпјҲе…Ҳй ӯгҒҢгӮ№гғҡгғјгӮ№гӮӨгғігғҮгғігғҲпјү
                else if (/^[\sгҖҖ]{2,}/.test(rawLine) && !/^[\sгҖҖ]*(и–¬еҠ№|йҷўеҶ…|йҷўеӨ–|гғ•гғӘгғј|еҲҶ\d|пјҲжҢҒеҸӮи–¬з”Ёжі•пјү)/.test(line)) {
                    if (/[йҢ пҪ¶гӮ«гғ—гӮ»гғ«ж•ЈйЎҶзІ’ж¶Іmg]+/.test(line) && !/Rp\d/.test(line)) {
                        drugMatch = line.replace(/\s+\d+[TпјҙйҢ пҪ¶CпјЈеҢ…mlз®Ўжң¬жһҡиўӢg]+.*$/i, '').replace(/\s+гҖҗ.*$/, '').trim();
                    }
                }
                // дёҚиҰҒгҒӘиЎҢпјҲйӣ»еӯҗгӮ«гғ«гғҶгҒ®и–¬еҠ№жғ…е ұгӮ„йҷўеҶ…жҺЎз”ЁзҠ¶ж…ӢгҖҒзӮ№ж»ҙгҒ®еҒҙз®ЎжҢҮзӨәгҒӘгҒ©пјүгӮ’гӮ№гӮӯгғғгғ—
                if (/^(и–¬еҠ№еҗҚз§°|йҷўеҶ…\(|зӮ№ж»ҙ жң«жўўеҒҙз®Ў)/.test(line) || /^[0-9пјҗ-пјҷ]+-[0-9пјҗ-пјҷ]+пјҡ/.test(line)) {
                    continue;
                }

                // гғ‘гӮҝгғјгғіE: гӮҝгғ–еҢәеҲҮгӮҠгҒ®йӣ»еӯҗгӮ«гғ«гғҶеҮҰж–№гғҮгғјгӮҝгҖҒгҒҫгҒҹгҒҜеҚҳгҒӘгӮӢзёҰ1еҲ—гҒ®гӮігғ”гғҡгғҶгӮӯгӮ№гғҲ
                if (!drugMatch) {
                    var abbrCols = rawLine.split('\t');
                    var abbrCol0 = (abbrCols[0] || '').replace(/^[0-9пјҗ-пјҷ]+[\sгҖҖ]+/, '').trim();
                    
                    if (!abbrCol0 || /^\[/.test(abbrCol0) || /^пјҲ/.test(abbrCol0) || /^\d+:\d+/.test(abbrCol0) || /mL\/жҷӮ/.test(rawLine) || /^(и–¬еҠ№|йҷўеҶ…|йҷўеӨ–|гғ•гғӘгғј|зӮ№ж»ҙ|йқҷжіЁ|зҡ®дёӢжіЁ|гҒқгҒ®д»–жіЁ|й–Ӣе§ӢжҷӮеҲ»|гӮӯгғғгғҲз”ҹйЈҹ|з”ҹйЈҹжіЁ|з”ҹзҗҶйЈҹеЎ©|иЎҖзі–|гӮҪгғӘгғҘгғјгӮІгғі|гӮҪгғӘгӮҝ)/.test(abbrCol0)) {
                        // skip
                    } else if (/^[0-9пјҗ-пјҷ]+$/.test(abbrCol0)) {
                        // cols[0]гҒҢз•ӘеҸ·гҒ®гҒҝгҒ®е ҙеҗҲгҖҒcols[1]гӮ’и–¬е“ҒеҗҚгҒЁгҒҷгӮӢ
                        abbrCol0 = (abbrCols[1] || '').trim();
                        if (abbrCol0 && !/^(и–¬еҠ№|йҷўеҶ…|йҷўеӨ–)/.test(abbrCol0)) drugMatch = abbrCol0;
                    } else if (abbrCols.length > 1) {
                        // cols[1]гҒҢж•°еҖӨгҒӘгӮүи–¬е“ҒиЎҢгҒЁгҒҝгҒӘгҒҷ
                        var abbrCol1 = (abbrCols[1] || '').trim();
                        if (/^[0-9пјҗ-пјҷ]/.test(abbrCol1) || /^[Tпјҙпј¶йҢ пҪ¶CпјЈеҢ…з®Ўжң¬жһҡиўӢгӮӯгғғгғҲ]/.test(abbrCol1)) {
                            drugMatch = abbrCol0;
                        }
                    } else {
                        // гӮҝгғ–еҢәеҲҮгӮҠгҒ§гӮӮгҒӘгҒҸгҖҒгҒ“гӮҢгҒҫгҒ§гҒ®гғ‘гӮҝгғјгғігҒ«гӮӮеҗҲиҮҙгҒ—гҒӘгҒ„гҖҢж–Үеӯ—еҲ—гҒ®гҒҝгҖҚгҒ®иЎҢгҒҜ
                        // гғҰгғјгӮ¶гғјгҒҢи–¬е“ҒеҗҚгҒ гҒ‘гӮ’зёҰгҒ«дёҰгҒ№гҒҰгӮігғ”гғҡгҒ—гҒҹгҒЁгҒҝгҒӘгҒ—гҒҰгҒқгҒ®гҒҫгҒҫжҺЎз”ЁгӮ’и©ҰгҒҝгӮӢ
                        if (abbrCol0.length > 2 && !/^(Rp|еҲҶ|в– |в—Ҷ|в–ј)/.test(abbrCol0)) {
                            drugMatch = abbrCol0.replace(/\s+\d+.*$/, '').trim(); // еҝөгҒ®гҒҹгӮҒеҫҢгӮҚгҒ®ж•°йҮҸгҒЈгҒҪгҒ„гҒ®гӮ’еүҠгӮӢ
                        }
                    }
                }
                
                if (!drugMatch) continue;
                // иЁҳеҸ·йҷӨеҺ»: вҳ…пјҲиҰҒеұҠеҮәпјүпјҲиҰҒиЁұеҸҜпјүзӯү + гҖҗз°Ўжҳ“жҮёжҝҒгҖ‘зӯүгҒ®жӢ¬еј§жіЁйҮҲ
                drugMatch = drugMatch.replace(/^вҳ…+/, '').replace(/^[пјҲ(]иҰҒ[^пјү)]*[пјү)]/, '').replace(/\s*[гҖҗ\[][^гҖ‘\]]*[гҖ‘\]]/g, '').replace(/^[\sгҖҖ]+/, '');
                
                // жҺҘй ӯиӘһгҒ®йҷӨеҺ»пјҲйә»гҖҒеҗ‘гҖҒеҠҮгҖҒжҜ’гҖҒеҗ„зЁ®гғЎгғјгӮ«гғјеҗҚгҒӘгҒ©пјү
                // вҖ»е…Ҳй ӯгҒ§ж—ўгҒ«ж¶ҲгҒ—гҒҰгҒ„гӮӢгҒ®гҒ§гҒ“гҒ“гҒҜдҝқйҷәгҒЁгҒ—гҒҰгҒ®еҮҰзҗҶгҒ«гҒӘгӮҠгҒҫгҒҷ
                drugMatch = drugMatch.replace(/^пјҲ(еҗ‘|йә»|еҠҮ|жҜ’|еҠҮгғ»еҗ‘|жҜ’гғ»еҗ‘|еҗ‘гғ»еҠҮ)пјү/, '');
                drugMatch = drugMatch.replace(/^\((еҗ‘|йә»|еҠҮ|жҜ’|еҠҮгғ»еҗ‘|жҜ’гғ»еҗ‘|еҗ‘гғ»еҠҮ)\)/, '');
                drugMatch = drugMatch.replace(/^(гғ„гғ гғ©|пҫӮпҫ‘пҫ—|гӮҜгғ©гӮ·гӮЁ|пҪёпҫ—пҪјпҪҙ|гӮӘгғјгӮ№гӮ®|пҪөпҪ°пҪҪпҪ·пҫһ|гӮігӮҝгғӯгғј|пҪәпҫҖпҫӣпҪ°|JG|гғ•гӮҪгғј|пҫҢпҪҝпҪ°|гғ•гӮЎгӮӨгӮ¶гғј|пҫҢпҪ§пҪІпҪ»пҫһпҪ°|гғһгӮӨгғ©гғі|пҫҸпҪІпҫ—пҫқ|гӮөгғҜгӮӨ|пҪ»пҫңпҪІ|гғҲгғјгғҜ|пҫ„пҪ°пҫң|гғҶгғҗ|пҫғпҫҠпҫһ|гӮўгғЎгғ«|пҪұпҫ’пҫҷ|ж—ҘеҢ»е·Ҙ|пј®пј°|NP|жӯҰз”°|гӮҝгӮұгғҖ|пҫҖпҪ№пҫҖпҫһ|жҳҺжІ»|Meiji|пҫ’пҪІпҪјпҫһ)/i, '');
                
                if (!drugMatch || drugMatch.length < 2) continue;
                
                // иҫһжӣёеј•гҒҚ вҶ’ гғһгғғгғҒгҒ—гҒӘгҒ‘гӮҢгҒ°е…Ҳй ӯ4ж–Үеӯ—еҚҠи§’гӮ«гӮҝгӮ«гғҠ
                var abbr = lookupDrugAbbr(drugMatch) || getFirst4HanKana(drugMatch);
                if (!abbr || seen[abbr]) continue;
                seen[abbr] = true;
                drugNames.push({ full: drugMatch, abbr: abbr, isTk: isTokuyaku(drugMatch) });
            }
            
            if (drugNames.length === 0) {
                resultEl.value = '';
                if (detailEl) detailEl.innerHTML = '<span style="color:#999;">и–¬еүӨеҗҚгҒҢжҠҪеҮәгҒ§гҒҚгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹ</span>';
                return;
            }
            
            // з•Ҙз§°зөҗжһңпјҲгӮ№гғҡгғјгӮ№еҢәеҲҮгӮҠ1иЎҢпјүвҶ’ textarea.valueгҒ«иЁӯе®ҡ
            var hlToggle = document.getElementById('set-tokuyaku-highlight');
            var highlightEnabled = hlToggle ? hlToggle.checked : true;
            
            var abbrLine = [];
            for (var j = 0; j < drugNames.length; j++) {
                abbrLine.push(drugNames[j].abbr);
            }
            resultEl.value = abbrLine.join(' ');
            
            // и©ізҙ°гғӘгӮ№гғҲ
            if (detailEl) {
                var dhtml = '';
                for (var k = 0; k < drugNames.length; k++) {
                    var tkMark = drugNames[k].isTk ? '<span style="color:#c62828; font-weight:bold; font-size:10px; border:1px solid #c62828; padding:0 3px; border-radius:3px; margin-right:4px;">и–¬з®Ў1</span>' : '';
                    dhtml += '<div style="padding:2px 0; border-bottom:1px dotted #ddd;">';
                    dhtml += tkMark + '<span style="color:#2e7d32; font-weight:bold; font-family:monospace;">' + drugNames[k].abbr + '</span>';
                    dhtml += ' вҶҗ ' + drugNames[k].full;
                    dhtml += '</div>';
                }
                detailEl.innerHTML = dhtml;
            }
        }
        
        function copyAbbrResult() {
            var el = document.getElementById('abbr-result');
            if (!el || !el.value) return;
            try {
                window.clipboardData.setData("Text", el.value);
                yrShowAlert("з•Ҙз§°гӮ’гӮігғ”гғјгҒ—гҒҫгҒ—гҒҹпјҒ");
            } catch(e) {
                yrShowAlert("гӮігғ”гғјгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹгҖӮ", "error");
            }
        }

        // ---------- еҹәжә–ж—ҘгӮ«гғ¬гғігғҖгғј ----------
        function yrShiftDate(days) {
            var input = document.getElementById('baseDate');
            if (!input || !input.value) return;
            var parts = input.value.split('-');
            if(parts.length < 3) return;
            
            var d = new Date(parseInt(parts[0],10), parseInt(parts[1],10)-1, parseInt(parts[2],10));
            d.setDate(d.getDate() + days);
            
            input.value = d.getFullYear() + '-' + ('0'+(d.getMonth()+1)).slice(-2) + '-' + ('0'+d.getDate()).slice(-2);
        }

        var yrCalYear = 0, yrCalMonth = 0;
        
        function toggleYrCalendar() {
            var popup = document.getElementById('yr-calendar-popup');
            if (popup.style.display === 'none' || !popup.style.display) {
                var cur = document.getElementById('baseDate').value;
                if (cur) {
                    var parts = cur.split('-');
                    yrCalYear = parseInt(parts[0], 10);
                    yrCalMonth = parseInt(parts[1], 10) - 1;
                } else {
                    var now = new Date();
                    yrCalYear = now.getFullYear();
                    yrCalMonth = now.getMonth();
                }
                yrCalRender();
                popup.style.display = 'block';
            } else {
                popup.style.display = 'none';
            }
        }
        
        function yrCalRender() {
            var title = document.getElementById('yr-cal-title');
            var body = document.getElementById('yr-cal-body');
            title.innerText = yrCalYear + 'е№ҙ ' + (yrCalMonth + 1) + 'жңҲ';
            
            var firstDay = new Date(yrCalYear, yrCalMonth, 1).getDay();
            var daysInMonth = new Date(yrCalYear, yrCalMonth + 1, 0).getDate();
            var today = new Date();
            var todayStr = today.getFullYear() + '-' + ('0'+(today.getMonth()+1)).slice(-2) + '-' + ('0'+today.getDate()).slice(-2);
            var selectedStr = document.getElementById('baseDate').value || '';
            
            var html = '';
            var day = 1;
            for (var row = 0; row < 6; row++) {
                if (day > daysInMonth) break;
                html += '<tr>';
                for (var col = 0; col < 7; col++) {
                    if ((row === 0 && col < firstDay) || day > daysInMonth) {
                        html += '<td style="padding:4px;"></td>';
                    } else {
                        var dateStr = yrCalYear + '-' + ('0'+(yrCalMonth+1)).slice(-2) + '-' + ('0'+day).slice(-2);
                        var bg = '';
                        var fc = '#333';
                        if (dateStr === selectedStr) { bg = 'background:#ffc107; font-weight:bold;'; fc = '#000'; }
                        else if (dateStr === todayStr) { bg = 'background:#e3f2fd;'; fc = '#0d6efd'; }
                        if (col === 0) fc = '#c62828';
                        if (col === 6) fc = '#1565c0';
                        html += '<td style="padding:4px; cursor:pointer; border-radius:3px; ' + bg + ' color:' + fc + ';" onclick="yrCalSelectDate(\'' + dateStr + '\')" onmouseover="this.style.backgroundColor=\'#fff3cd\'" onmouseout="this.style.backgroundColor=\'' + (dateStr === selectedStr ? '#ffc107' : (dateStr === todayStr ? '#e3f2fd' : '')) + '\'">' + day + '</td>';
                        day++;
                    }
                }
                html += '</tr>';
            }
            body.innerHTML = html;
        }
        
        function yrCalNavMonth(dir) {
            yrCalMonth += dir;
            if (yrCalMonth < 0) { yrCalMonth = 11; yrCalYear--; }
            if (yrCalMonth > 11) { yrCalMonth = 0; yrCalYear++; }
            yrCalRender();
        }
        
        function yrCalSelectDate(dateStr) {
            document.getElementById('baseDate').value = dateStr;
            document.getElementById('yr-calendar-popup').style.display = 'none';
        }
        
        function yrCalSetToday() {
            var t = new Date();
            var ds = t.getFullYear() + '-' + ('0'+(t.getMonth()+1)).slice(-2) + '-' + ('0'+t.getDate()).slice(-2);
            yrCalSelectDate(ds);
        }
        

        function yrSwitchTab(tabId, el) {
            // yr-nav-linkзөҢз”ұгҒ®е‘јгҒіеҮәгҒ—пјҲж—§ж–№ејҸдә’жҸӣпјү
            var navs = document.querySelectorAll('.yr-nav-link');
            for(var i=0; i<navs.length; i++) removeClass(navs[i], 'yr-active');
            if (el) addClass(el, 'yr-active');
            yrSwitchPane(tabId);
        }
        
        function yrSwitchTabInline(tabId, el) {
            // гғЎгӮӨгғігӮҝгғ–гғҗгғјеҶ…гҒ®гӮөгғ–гӮҝгғ–еҲҮжӣҝ
            var subs = document.querySelectorAll('#yr-subtabs-inline .yr-sub');
            for(var i=0; i<subs.length; i++) removeClass(subs[i], 'active');
            addClass(el, 'active');
            yrSwitchPane(tabId);
        }
        
        function yrSwitchPane(tabId) {
            var panes = document.querySelectorAll('.yr-tab-pane');
            for(var j=0; j<panes.length; j++) {
                removeClass(panes[j], 'yr-show');
                removeClass(panes[j], 'yr-active');
            }
            var targetPane = document.getElementById(tabId);
            addClass(targetPane, 'yr-show');
            addClass(targetPane, 'yr-active');

            if (tabId === 'yr-tab-macro' || tabId === 'yr-tab-settings' || tabId === 'yr-tab-abbr' || tabId === 'yr-tab-med-adj' || tabId === 'yr-tab-med-adj-2026') {
                document.getElementById('yr-main-controls').style.display = 'none';
            } else {
                document.getElementById('yr-main-controls').style.display = 'flex';
            }
        }

        function yrShowAlert(msg, type) {
            if (type === undefined) type = 'info';
            var alertArea = document.getElementById('yr-alertArea');
            alertArea.style.display = 'block';
            alertArea.style.backgroundColor = type === 'error' ? '#f8d7da' : '#cff4fc';
            alertArea.style.color = type === 'error' ? '#842029' : '#055160';
            alertArea.style.borderColor = type === 'error' ? '#f5c2c7' : '#b6effb';
            alertArea.innerHTML = msg;
            setTimeout(function() { alertArea.style.display = 'none'; }, 4000);
        }

        function yrSaveSettings() {
            if (!currentSystemId) return;
            try {
                // гғ•гӮЎгӮӨгғ«гӮ’й–ӢгҒҸгҒ®гҒҜгҒ“гҒ®1еӣһгҒ гҒ‘
                var data = myStorage._load();
                if (!data[currentSystemId]) data[currentSystemId] = {};
                var ud = data[currentSystemId];

                ud['set-halfwidth'] = document.getElementById('set-halfwidth').checked ? 'true' : 'false';
                
                var kanaFormatRadio = document.querySelector('input[name="set-kana-format"]:checked');
                if (kanaFormatRadio) ud['set-kana-format'] = kanaFormatRadio.value;
                
                ud['set-merge'] = document.getElementById('set-merge').checked ? 'true' : 'false';
                ud['set-softdelete'] = document.getElementById('set-softdelete').checked ? 'true' : 'false';
                ud['set-remove-form'] = document.getElementById('set-remove-form').checked ? 'true' : 'false';
                ud['set-remove-iv-words'] = document.getElementById('set-remove-iv-words').checked ? 'true' : 'false';
                ud['set-remove-salt'] = document.getElementById('set-remove-salt').checked ? 'true' : 'false';
                ud['set-remove-maker'] = document.getElementById('set-remove-maker').checked ? 'true' : 'false';
                ud['set-add-number'] = document.getElementById('set-add-number').checked ? 'true' : 'false';
                
                var chkAbbr = document.getElementById('chk-use-abbr-dict');
                if (chkAbbr) ud['set-abbr-dict'] = chkAbbr.checked ? 'true' : 'false';
                
                var hlToggle = document.getElementById('set-tokuyaku-highlight');
                if (hlToggle) ud['set-tokuyaku-highlight'] = hlToggle.checked ? 'true' : 'false';
                
                var incTiming = document.getElementById('includeTiming');
                if (incTiming) ud['set-timing'] = incTiming.value;
                
                // гғ•гӮЎгӮӨгғ«гҒёгҒ®жӣёгҒҚиҫјгҒҝгӮӮжңҖеҫҢгҒ«1еӣһгҒ гҒ‘
                myStorage._save(data);
            } catch(e) {}
        }

        function saveAbbrSetting() {
            var chk = document.getElementById('chk-use-abbr-dict');
            if (chk) {
                myStorage.setItem('set-abbr-dict', chk.checked ? 'true' : 'false');
            }
        }

        function formatText(str) {
            if (!str) return "";
            var res = str;
            if (document.getElementById('set-halfwidth').checked) {
                res = res.replace(/[пјЎ-пјәпҪҒ-пҪҡпјҗ-пјҷпјҺ]/g, function(s) { return String.fromCharCode(s.charCodeAt(0) - 0xFEE0); });
                res = res.replace(/гҖҖ/g, ' ');
            }

            var kanaFormatRadio = document.querySelector('input[name="set-kana-format"]:checked');
            var kanaFormat = kanaFormatRadio ? kanaFormatRadio.value : 'full';

            if (kanaFormat === 'full') {
                res = res.replace(kanaReg, function(match){return kanaMap[match];});
            } else if (kanaFormat === 'half') {
                res = res.replace(fullKanaReg, function(match){return fullToHalfMap[match];});
            }

            return res;
        }

        function cleanDrugName(nameStr) {
            var res = nameStr;
            if (document.getElementById('set-remove-form').checked) {
                res = res.replace(/й…ҚеҗҲйҢ |пјҜпјӨйҢ |ODйҢ |еҫҗж”ҫпјҜпјӨйҢ |еҫҗж”ҫODйҢ |гӮ«гғ—гӮ»гғ«еүӨ|гӮ«гғ—гӮ»гғ«|йҢ |гӮЁгӮӯгӮ№йЎҶзІ’|пҪҙпҪ·пҪҪйЎҶзІ’/g, '');
            }
            if (document.getElementById('set-remove-salt').checked) {
                res = res.replace(/еЎ©й…ёеЎ©|гғ•гғһгғ«й…ёеЎ©|гӮҜгӮЁгғій…ёеЎ©|гғһгғ¬гӮӨгғій…ёеЎ©|й…’зҹій…ёеЎ©|NaеЎ©|гғЎгӮ·гғ«й…ёеЎ©|пҫҢпҫҸпҫҷй…ёеЎ©|пҪёпҪҙпҫқй…ёеЎ©|пҫҸпҫҡпҪІпҫқй…ёеЎ©|пҫ’пҪјпҫҷй…ёеЎ©|пј®пҪҒеЎ©/g, '');
            }
            if (document.getElementById('set-remove-maker').checked) {
                res = res.replace(/гҖҢ.*?гҖҚ/g, '');
                // в–ј гғЎгғјгӮ«гғјеҗҚеүҠйҷӨгҒ«жӯҰз”°гғҶгғҗзӯүгӮ’иҝҪеҠ гҒ—гҖҒе…Ҳй ӯгғ»жң«е°ҫгҒ©гҒЎгӮүгҒ«гҒӮгҒЈгҒҰгӮӮж¶ҲгҒҷ
                res = res.replace(/^(гғ„гғ гғ©|пҫӮпҫ‘пҫ—|гӮҜгғ©гӮ·гӮЁ|пҪёпҫ—пҪјпҪҙ|гӮӘгғјгӮ№гӮ®|пҪөпҪ°пҪҪпҪ·пҫһ|гӮігӮҝгғӯгғј|пҪәпҫҖпҫӣпҪ°|JG|гғ•гӮҪгғј|пҫҢпҪҝпҪ°|гғ•гӮЎгӮӨгӮ¶гғј|пҫҢпҪ§пҪІпҪ»пҫһпҪ°|гғһгӮӨгғ©гғі|пҫҸпҪІпҫ—пҫқ|гӮөгғҜгӮӨ|пҪ»пҫңпҪІ|гғҲгғјгғҜ|пҫ„пҪ°пҫң|гғҶгғҗ|пҫғпҫҠпҫһ|гӮўгғЎгғ«|пҪұпҫ’пҫҷ|ж—ҘеҢ»е·Ҙ|пј®пј°|NP|жӯҰз”°|гӮҝгӮұгғҖ|пҫҖпҪ№пҫҖпҫһ|жӯҰз”°гғҶгғҗ|жҳҺжІ»|Meiji|пҫ’пҪІпҪјпҫһ)/i, '');
                res = res.replace(/(гғ„гғ гғ©|пҫӮпҫ‘пҫ—|гӮҜгғ©гӮ·гӮЁ|пҪёпҫ—пҪјпҪҙ|гӮӘгғјгӮ№гӮ®|пҪөпҪ°пҪҪпҪ·пҫһ|гӮігӮҝгғӯгғј|пҪәпҫҖпҫӣпҪ°|JG|гғ•гӮҪгғј|пҫҢпҪҝпҪ°|гғ•гӮЎгӮӨгӮ¶гғј|пҫҢпҪ§пҪІпҪ»пҫһпҪ°|гғһгӮӨгғ©гғі|пҫҸпҪІпҫ—пҫқ|гӮөгғҜгӮӨ|пҪ»пҫңпҪІ|гғҲгғјгғҜ|пҫ„пҪ°пҫң|гғҶгғҗ|пҫғпҫҠпҫһ|гӮўгғЎгғ«|пҪұпҫ’пҫҷ|ж—ҘеҢ»е·Ҙ|пј®пј°|NP|жӯҰз”°|гӮҝгӮұгғҖ|пҫҖпҪ№пҫҖпҫһ|жӯҰз”°гғҶгғҗ|жҳҺжІ»|Meiji|пҫ’пҪІпҪјпҫһ)$/i, '');
            }
            res = res.replace(/пјҡ|йҖҖйҷў|вҳ…|гҖҗиҲ¬гҖ‘/g, '');
            res = res.replace(/\(жҢҒеҸӮи–¬\)|пјҲжҢҒеҸӮи–¬пјү/g, '');
            res = res.replace(/[ гҖҖ]*е…Ҙйҷўз”Ё|[ гҖҖ]*е…Ҙйҷў/g, '');
            // в–ј гҖҗеҘ‘ж©ҹеӨ–/д»–йҷўгҖ‘гҒӘгҒ©гӮ’еј·еҲ¶зҡ„гҒ«е…ЁеүҠйҷӨ
            res = res.replace(/гҖҗ.*?гҖ‘/g, '');
            return res.trim();
        }

// ==========================================
        // е…ұйҖҡгғҶгӮӯгӮ№гғҲж•ҙзҗҶеҮҰзҗҶ (гғһгӮҜгғӯгғ»и–¬еүӨиӘҝж•ҙеҠ з®— дёЎз”Ё)
        // ==========================================
        function processMacroText(rawInput) {
            if (!rawInput) return "";
            var text = formatText(rawInput);
            
            text = text.replace(/([^\r\n])([ \t]*)(Rp\d+)/g, '$1\n$3');
            
            var addNumEl = document.getElementById('set-add-number');
            if (addNumEl && addNumEl.checked) {
                text = text.replace(/^[ \t]*Rp(\d+).*?[\r\n]+[ \t]*/gm, '$1) ');
            } else {
                text = text.replace(/^[ \t]*.*Rp\d+.*?$[\r\n]*/gm, '');
            }

            text = text.replace(/^[ \t]*.*(?:йҷўеӨ–|йҷўеҶ…)[\s\(].*\d{4}\/\d{2}\/\d{2}.*?$[\r\n]*/gm, '\nв—ҶеӨ–жқҘ\n');
            text = text.replace(/^[ \t]*.*\[?(?:е®ҡжңҹ|иҮЁжҷӮ|з·ҠжҖҘ|е®ҹж–ҪжёҲ|йҖҖйҷў)\]?.*\d{4}\/\d{2}\/\d{2}.*?$[\r\n]*/gm, '\nв—Үе…Ҙйҷў\n');
            text = text.replace(/^[ \t]*.*гҖҗжҢҒеҸӮи–¬гҖ‘.*жӨңиӘҚ.*?(?:\r?\n[^\r\n]*?)?\d{4}\/\d{2}\/\d{2}[^\r\n]*[\r\n]*/gm, '\nв–јжҢҒеҸӮи–¬жӨңиӘҚ\n');
            text = text.replace(/^[ \t]*.*гҖҗжҢҒеҸӮи–¬гҖ‘(?!.*жӨңиӘҚ).*?(?:\r?\n[^\r\n]*?)?\d{4}\/\d{2}\/\d{2}[^\r\n]*[\r\n]*/gm, '\nв– жҢҒеҸӮи–¬\n');


            text = text.replace(/^[ \t]*.*йҷўеҶ…[\(].*?$[\r\n]*/gm, '');
            text = text.replace(/^[ \t]*.*йҷўеҶ…жҺЎз”Ё.*?$[\r\n]*/gm, '');
            text = text.replace(/^[ \t]*.*и–¬еҠ№еҗҚз§°.*?$[\r\n]*/gm, '');
            text = text.replace(/^[ \t]*.*е®ҹж•°е…ҘеҠӣ.*?$[\r\n]*/gm, '');
            text = text.replace(/^[ \t]*.*еӨ–жқҘз”ЁжүӢиЎ“еүҚжӨңиӘҚ.*?$[\r\n]*/gm, '');
            text = text.replace(/^[ \t]*[^ \t]+[ гҖҖ]+[^ \t]+\(.*?[з§‘еӨ–]\).*?$[\r\n]*/gm, '');
            text = text.replace(/^[ \t]*.*No\.\d+.*?$[\r\n]*/gm, '');
            text = text.replace(/^[ \t]*.*йҷўеӨ–е°Ӯз”Ёи–¬.*?$[\r\n]*/gm, '');
            text = text.replace(/^[ \t]*\d{4}\/\d{2}\/\d{2}[ \t]*(?:жңқ|жҳј|еӨ•|зң еүҚ)?.*?$[\r\n]*/gm, '');

            text = text.replace(/(\nв–јжҢҒеҸӮи–¬жӨңиӘҚ\s*)+/g, '\nв–јжҢҒеҸӮи–¬жӨңиӘҚ\n');
            text = text.replace(/(\nв– жҢҒеҸӮи–¬\s*)+/g, '\nв– жҢҒеҸӮи–¬\n');
            text = text.replace(/(\nв—ҶеӨ–жқҘ\s*)+/g, '\nв—ҶеӨ–жқҘ\n');
            text = text.replace(/(\nв—Үе…Ҙйҷў\s*)+/g, '\nв—Үе…Ҙйҷў\n');


            text = text.replace(/гҖҢ.*?гҖҚ/g, '');
            text = text.replace(/гҖҗ.*?гҖ‘/g, '');
            text = text.replace(/ +[\d]+ж—ҘеҲҶ/g, '');
            text = text.replace(/пјҸ[\d]+ж—ҘеҲҶ/g, '');

            var removeKeywords = [
                '2020/', '2021/', '2022/', '2023/', '2024/', '2025/', '2026/',
                'жіЁе°„еҫҢ', 'й–Ӣе§Ӣж—Ҙ', 'з”Ёжі•еӨүжӣҙ', '\\[йҷўеӨ–\\]', 'иЎҖзі–[:пјҡ]',
                'и–¬еүӨеё«гҒ«гӮҲгӮӢжңҚз”ЁзҠ¶жіҒзўәиӘҚгҒҜжңӘе®ҹж–ҪгҒ§гҒҷ'
            ];
            var removeRegex = new RegExp('^[ \\t]*.*(' + removeKeywords.join('|') + ').*?$[\\r\\n]*', 'gm');
            text = text.replace(removeRegex, '');
            
            var textLines = text.split('\n');
            var detectingClinic = false;
            for (var k = 0; k < textLines.length; k++) {
                if (textLines[k].indexOf('в–јжҢҒеҸӮи–¬жӨңиӘҚ') !== -1 || textLines[k].indexOf('в– жҢҒеҸӮи–¬') !== -1) {

                        } else if (detectingClinic) {
                    if (textLines[k].match(/^[ \t]*Rp.?\d+/i) || textLines[k].match(/^[ \t]*[пјҲ\(]жҢҒеҸӮи–¬[пјү\)]/) || textLines[k].match(/^[ \t]*\d+\)/)) {
                        detectingClinic = false;
                    } else {
                        var tmpLine = textLines[k].trim();
                        if (tmpLine !== "" && !tmpLine.match(/^\d{4}\/\d{2}\/\d{2}/) && tmpLine.indexOf('в–ј') !== 0) {
                            textLines[k] = textLines[k].replace(/^([ \t]*)/, '$1в–ј');
                        }
                    }
                }
            }
            text = textLines.join('\n');
            
            var lines = text.split('\n');
            for (var i = 0; i < lines.length; i++) {
                if (lines[i].trim() !== "" && !lines[i].startsWith("в—Ҷ") && !lines[i].startsWith("в—Ү") && !lines[i].startsWith("в–ј") && !lines[i].startsWith("в– ")) {
                    lines[i] = cleanDrugName(lines[i]);
                }
            }
            text = lines.join('\n');
            
            text = text.replace(/\(жңқгғ»еӨ•\)/g, 'жңқеӨ•').replace(/\(жңқеӨ•\)/g, 'жңқеӨ•');
            text = text.replace(/\(жңқгғ»жҳј\)/g, 'жңқжҳј').replace(/\(жҳјгғ»еӨ•\)/g, 'жҳјеӨ•');
            text = text.replace(/\(жңқгғ»жҳјпҪҘеӨ•\)/g, 'жңқжҳјеӨ•');
            text = text.replace(/1еӣһйҮҸ\[/g, '1еӣһ');
            text = text.replace(/\[.*?\]/g, '');
            text = text.replace(/\]/g, '');
            text = text.replace(/^ +/gm, '');

            text = text.replace(/\[\$T\]\r?\n?/g, 'T ');
            text = text.replace(/\[\$C\]\r?\n?/g, 'C ');
            text = text.replace(/\[\$пҪ·пҪҜпҫ„\]\r?\n?/g, 'пҫ„ ');
            text = text.replace(/\[\$жң¬\]\r?\n?/g, 'жң¬ ');
            text = text.replace(/\[\$жһҡ\]\r?\n?/g, 'жһҡ ');
            text = text.replace(/\[\$иўӢ\]\r?\n?/g, 'иўӢ ');
            text = text.replace(/\[\$еҢ…\]\r?\n?/g, 'еҢ… ');
            text = text.replace(/\[\$еҷЁ\]\r?\n?/g, 'еҷЁ ');
            text = text.replace(/\[\$дҪҚ\]\r?\n?/g, 'дҪҚ ');
            text = text.replace(/\[\$з®ұ\]\r?\n?/g, 'з®ұ ');
            text = text.replace(/\[\$зј¶\]\r?\n?/g, 'зј¶ ');
            text = text.replace(/\[\$g\]\r?\n?/g, 'g ');
            text = text.replace(/\[\$l\]\r?\n?/g, 'l ');
            text = text.replace(/\[\$V\]\r?\n?/g, 'V ');
            text = text.replace(/пҫ…пҫ„пҫҳпҪіпҫ‘/g, 'Na');

            var mergeEl = document.getElementById('set-merge');
            if (mergeEl && mergeEl.checked) {
                var usageStarts = 'пјҲжҢҒеҸӮи–¬з”Ёжі•пјү|\\(жҢҒеҸӮи–¬з”Ёжі•\\)|еҲҶ\\d|1ж—Ҙ|пј‘ж—Ҙ|е°ұеҜқеүҚ|зң еүҚ|й “жңҚ|жҜҺйЈҹ|жңқеӨ•|жңқжҳј|жҳјеӨ•|з—ӣгҒ„|зҷәзҶұ|йҖұ\\d';
                var removeUnits = "еҖӢ|жһҡ|жң¬|иўӢ|з“¶|зӯ’|пҫҒпҪӯпҪ°пҫҢпҫһ|гғҒгғҘгғјгғ–|пҪ·пҪҜпҫ„|гӮӯгғғгғҲ|V|пј¶";
                var removeRegex = new RegExp('^(?![ \\tгҖҖ]*(?:' + usageStarts + '))([ \\tгҖҖ]*.*?)((?:\\d+(?:\\.\\d+)?)(?:' + removeUnits + '))\\s*[\\r\\n]+[ \\tгҖҖ]*', 'gim');
                text = text.replace(removeRegex, "$1 ");

                var mergeUnits = "йҢ |пҪ¶пҫҢпҫҹпҪҫпҫҷ|гӮ«гғ—гӮ»гғ«|еҢ…|ml|mL|mg|g|ж»ҙ|T|C|пјҙ|пјЈ|еӣһ|ж—ҘеҲҶ";
                var mergeRegex = new RegExp('^(?![ \\tгҖҖ]*(?:' + usageStarts + '))([ \\tгҖҖ]*.*?)((?:\\d+(?:\\.\\d+)?)(?:' + mergeUnits + '))\\s*[\\r\\n]+[ \\tгҖҖ]*', 'gim');
                text = text.replace(mergeRegex, "$1$2 ");
            }
            return text.replace(/\n\s*\n/g, '\n').trim();
        }

        // ==========================================
        // гӮҝгғ–в‘ў: гғҶгӮӯгӮ№гғҲж•ҙзҗҶ (гғһгӮҜгғӯ) еҮҰзҗҶжң¬дҪ“
        // ==========================================
        var macroSaveTimer = null; // вҳ…гҒ“гҒ®иЎҢгӮ’иҝҪеҠ 
        function yrRunMacro() {
            var rawInput = document.getElementById('macroInput').value;
            if (!rawInput) {
                document.getElementById('macroOutput').value = "";
                return;
            }

            // ж–°иЁӯгҒ—гҒҹе…ұйҖҡеҮҰзҗҶгӮ’е‘јгҒіеҮәгҒҷ
            var text = processMacroText(rawInput);
            document.getElementById('macroOutput').value = text;
            
            // вҳ…дҝ®жӯЈ: йҮҚгҒҹгҒ„гғ•гӮЎгӮӨгғ«дҝқеӯҳгӮ’1з§’йҒ…гӮүгҒӣгҒҰз”»йқўгҒ®гғ•гғӘгғјгӮәгӮ’йҳІгҒҗ
            clearTimeout(macroSaveTimer);
            macroSaveTimer = setTimeout(function() {
                saveMacroHistory(rawInput, text);
            }, 1000);
            
            // и–¬з®Ў1еҲӨе®ҡгғ‘гғҚгғ«жӣҙж–°
            var panel = document.getElementById('macro-tokuyaku-panel');
            var cache = getTokuyakuCache();
            if (panel && cache) {
                var tkLines = text.split('\n');
                var found = [];
                for (var li = 0; li < tkLines.length; li++) {
                    var tkLine = tkLines[li].replace(/^\d+\)\s*/, '').replace(/^[\sгҖҖ]+/, '');
                    if (!tkLine || /^[в—Ҷв—Үв–јв– ]/.test(tkLine)) continue;
                    var drugPart = tkLine.replace(/\s+\d.*$/, '').replace(/[\(пјҲ].*$/, '').trim();
                    if (drugPart.length < 2) continue;
                    var dpNorm = normalizeDrug(drugPart);
                    var dpRoot = extractDrugRoot(drugPart);
                    var matched = false;
                    for (var ti = 0; ti < cache.length; ti++) {
                        if (cache[ti].norm.indexOf(dpNorm) !== -1 || dpNorm.indexOf(cache[ti].norm) !== -1) {
                            matched = true; break;
                        }
                        if (dpRoot.length >= 3 && cache[ti].root.indexOf(dpRoot) === 0) {
                            matched = true; break;
                        }
                        if (cache[ti].root.length >= 3 && dpRoot.indexOf(cache[ti].root) === 0) {
                            matched = true; break;
                        }
                    }
                    if (matched) {
                        var dup = false;
                        for (var fi = 0; fi < found.length; fi++) { if (found[fi] === drugPart) dup = true; }
                        if (!dup) found.push(drugPart);
                    }
                }
                if (found.length > 0) {
                    panel.style.display = 'block';
                    panel.style.background = '#ffebee';
                    panel.style.color = '#c62828';
                    panel.innerHTML = 'в—Ҹ <b>и–¬еүӨз®ЎзҗҶжҢҮе°Һпј‘еҜҫиұЎ:</b> ' + found.join('гҖҒ');
                } else if (tkLines.length > 1) {
                    panel.style.display = 'block';
                    panel.style.background = '#e8f5e9';
                    panel.style.color = '#2e7d32';
                    panel.innerHTML = 'вң” и–¬з®Ўпј‘еҜҫиұЎи–¬еүӨгҒӘгҒ—';
                } else {
                    panel.style.display = 'none';
                }
            }
        }

        function yrCopyMacroResult() {
            var text = document.getElementById('macroOutput').value;
            if (!text) return;
            text = text.replace(/\r?\n/g, '\r\n'); // Windowsеҗ‘гҒ‘гҒ®ж”№иЎҢгӮігғјгғүпјҲ\r\nпјүеј·еҲ¶зҪ®жҸӣ
            try {
                window.clipboardData.setData("Text", text);
                yrShowAlert("ж•ҙзҗҶгҒ•гӮҢгҒҹгғҶгӮӯгӮ№гғҲгӮ’гӮігғ”гғјгҒ—гҒҫгҒ—гҒҹпјҒ");
            } catch(err) {
                yrShowAlert("гӮігғ”гғјгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹгҖӮ", "error");
            }
        }

        // ==========================================
        // еұҘжӯҙгғўгғјгғҖгғ«пјҲиҮӘеӢ•дҝқеӯҳгғ»дёҖиҰ§иЎЁзӨәпјүеҮҰзҗҶ
        // ==========================================
        function saveMacroHistory(rawText, outText) {
            if (!rawText) return;
            var historyArr = JSON.parse(myStorage.getItem('macroHistoryList') || '[]');

            if (historyArr.length > 0 && historyArr[0].raw === rawText) {
                return;
            }

            var now = new Date();
            var dateStr = now.toLocaleDateString('ja-JP');
            var timeStr = now.toLocaleTimeString('ja-JP');

            historyArr.unshift({
                datetime: dateStr + " " + timeStr,
                raw: rawText
            });

            if (historyArr.length > 50) {
                historyArr = historyArr.slice(0, 50);
            }

            myStorage.setItem('macroHistoryList', JSON.stringify(historyArr));
        }

        function yrOpenHistoryModal() {
            yrRenderHistoryList();
            document.getElementById('yr-historyModal').style.display = 'flex';
        }

        function yrCloseHistoryModal() {
            document.getElementById('yr-historyModal').style.display = 'none';
        }

        function yrRenderHistoryList() {
            var area = document.getElementById('yr-historyListArea');
            var historyArr = JSON.parse(myStorage.getItem('macroHistoryList') || '[]');

            if (historyArr.length === 0) {
                area.innerHTML = '<div class="text-center text-muted" style="padding:30px; font-size:1.1rem;">еӨүжҸӣеұҘжӯҙгҒҜгҒҫгҒ гҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ</div>';
                return;
            }

            var html = '';
            for(var index=0; index<historyArr.length; index++) {
                var item = historyArr[index];
                var safeRaw = (item.raw || "").replace(/</g, "&lt;").replace(/>/g, "&gt;");
                html += '<div class="yr-history-item"><div class="yr-history-header"><span class="yr-history-time">' + item.datetime + '</span><div><button class="btn btn-outline-secondary btn-sm" onclick="yrLoadHistoryItem(' + index + ')" style="background:white;">вң” е·ҰгҒ®е…ҘеҠӣж¬„гҒ«еҫ©е…ғ</button></div></div><textarea class="yr-history-textarea" readonly>' + safeRaw + '</textarea></div>';
            }
            area.innerHTML = html;
        }

        function yrLoadHistoryItem(index) {
            var historyArr = JSON.parse(myStorage.getItem('macroHistoryList') || '[]');
            if (historyArr[index]) {
                document.getElementById('macroInput').value = historyArr[index].raw;
                yrRunMacro();
                yrCloseHistoryModal();
                yrShowAlert("еұҘжӯҙгҒӢгӮүгғҮгғјгӮҝгӮ’еҫ©е…ғгҒ—гҖҒеӨүжҸӣгӮ’е®ҹиЎҢгҒ—гҒҫгҒ—гҒҹгҖӮ", "info");
            }
        }


        // ==========================================
        // гӮҝгғ–в‘ в‘Ў: и–¬жӯҙиҮӘеӢ•дҪңжҲҗ еҮҰзҗҶ
        // ==========================================

        // в–ј гғһгӮ№гӮҝгғјгғҒгӮ§гғғгӮҜгғңгғғгӮҜгӮ№гҒ«гӮҲгӮӢе…ЁйҒёжҠһ/и§ЈйҷӨгҒЁдёҖжӢ¬гғңгӮҝгғігҒ®иЎЁзӨәеҲ¶еҫЎ
        function yrToggleAllCheckboxes(source) {
            var checkboxes = document.querySelectorAll('.row-checkbox');
            var hasChecked = source.checked;
            for (var i = 0; i < checkboxes.length; i++) {
                var cb = checkboxes[i];
                if (!cb.disabled) {
                    cb.checked = hasChecked;
                }
            }
            yrUpdateMergeButtonVisibility(hasChecked);
        }

        // в–ј еҗ„иЎҢгҒ®гғҒгӮ§гғғгӮҜгғңгғғгӮҜгӮ№еӨүжӣҙжҷӮгҒ«дёҖжӢ¬гғңгӮҝгғігҒ®иЎЁзӨә/йқһиЎЁзӨәгӮ’еҲҮгӮҠжӣҝгҒҲ
        function yrOnRowCheckboxChange() {
            var checkboxes = document.querySelectorAll('.row-checkbox');
            var hasChecked = false;
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].checked) {
                    hasChecked = true;
                    break;
                }
            }
            yrUpdateMergeButtonVisibility(hasChecked);
        }

        // в–ј зөҗеҗҲгғңгӮҝгғігҒ®иЎЁзӨәеҲҮжӣҝеҮҰзҗҶ
        function yrUpdateMergeButtonVisibility(show) {
            var btn = document.getElementById('yr-btn-merge-checked');
            if (btn) {
                btn.style.display = show ? 'inline-block' : 'none';
            }
        }

        // е…ЁгӮ«гғҶгӮҙгғӘгӮ’еҜҫиұЎгҒ«гғҒгӮ§гғғгӮҜгҒ•гӮҢгҒҹиЎҢгӮ’дёҖжӢ¬зөұеҗҲпјҲгҖҮжҷӮй–“жҜҺгҒ®иҮӘеӢ•иЁҲз®—д»ҳгҒҚпјү
        function yrMergeCheckedRowsAcrossAll() {
            var allCheckboxes = document.querySelectorAll('.row-checkbox:checked');
            if (allCheckboxes.length < 2) {
                yrShowAlert("зөұеҗҲгҒҷгӮӢгҒ«гҒҜ2гҒӨд»ҘдёҠгҒ®иЎҢгӮ’йҒёжҠһгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ", "error");
                return;
            }

            // йҒёгҒ°гӮҢгҒҹиЎҢгҒҢгҒҷгҒ№гҒҰгҖҢеҗҢгҒҳгӮ«гғҶгӮҙгғӘгҒӢгҖҚгғҒгӮ§гғғгӮҜгҒҷгӮӢ
            var targetCat = allCheckboxes[0].getAttribute("data-cat");
            for(var c=1; c<allCheckboxes.length; c++) {
                if(allCheckboxes[c].getAttribute("data-cat") !== targetCat) {
                    yrShowAlert("з•°гҒӘгӮӢгӮ«гғҶгӮҙгғӘгҒ«гҒҫгҒҹгҒҢгҒЈгҒҰзөұеҗҲгҒҷгӮӢгҒ“гҒЁгҒҜгҒ§гҒҚгҒҫгҒӣгӮ“гҖӮ\n1гҒӨгҒ®иЎЁгҒ®дёӯгҒ§йҒёжҠһгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ", "error");
                    return;
                }
            }
            targetCat = parseInt(targetCat, 10);

            var selectedItems = [];
            for(var i=0; i<allCheckboxes.length; i++) {
                var id = allCheckboxes[i].value;
                for(var x=0; x<globalResults[targetCat].length; x++) {
                    if (globalResults[targetCat][x].id === id) {
                        selectedItems.push(globalResults[targetCat][x]);
                        break;
                    }
                }
            }

            if (selectedItems.length < 2) return;

            var firstItemName = selectedItems[0].name;
            var allSameName = true;
            for(var m=0; m<selectedItems.length; m++) {
                if(selectedItems[m].name !== firstItemName) allSameName = false;
            }

            // в‘  еҗҢгҒҳи–¬е“ҒеҗҚеҗҢеЈ«гҒ®е ҙеҗҲгҒҜж—§гғӯгӮёгғғгӮҜпјҲгҖҮжҷӮй–“жҜҺпјүгӮ’йҒ©з”Ё
            if (allSameName) {
                var count = selectedItems.length;
                var newInst = Math.floor(24 / count) + "жҷӮй–“жҜҺ";

                var baseItem = selectedItems[0];
                baseItem.inst = newInst;
                baseItem.fullText = (baseItem.dateStr ? baseItem.dateStr + " " : "")
                    + baseItem.name
                    + (baseItem.dose ? " " + baseItem.dose + baseItem.unit : "")
                    + " " + newInst;

                for (var i = 1; i < selectedItems.length; i++) {
                    selectedItems[i].deleted = true;
                }
                
                var masterCheckbox = document.querySelector('th input[type="checkbox"]');
                if (masterCheckbox) masterCheckbox.checked = false;

                renderTable();
                yrShowAlert(count + "гҒӨгҒ®иЎҢгӮ’гҖҢ" + newInst + "гҖҚгҒ«зөұеҗҲгҒ—гҒҫгҒ—гҒҹпјҒ", "info");
            
            // в‘Ў йҒ•гҒҶи–¬е“ҒеҗҚеҗҢеЈ«гҒ®е ҙеҗҲгҒҜж”№иЎҢгҒ—гҒҰзөҗеҗҲпјҲD&Dж–№ејҸгҒЁеҗҢгҒҳеҚҳзҙ”йҖЈзөҗпјү
            } else {
                if (!confirm("з•°гҒӘгӮӢеҗҚз§°гҒ®и–¬е“ҒгҒҢеҗ«гҒҫгӮҢгҒҰгҒ„гҒҫгҒҷгҖӮ\nгҒ“гҒ®гҒҫгҒҫгғҶгӮӯгӮ№гғҲгӮ’ж”№иЎҢгҒ—гҒҰзөҗеҗҲгҒ—гҒҫгҒҷгҒӢпјҹ")) {
                    return;
                }
                var sep = (targetCat === 1) ? "\n" : "\n";
                var combinedStr = "";
                for(var k=0; k<selectedItems.length; k++){
                    if(k>0) combinedStr += sep;
                    combinedStr += selectedItems[k].fullText;
                }
                
                var baseItemDiff = selectedItems[0];
                baseItemDiff.fullText = combinedStr;
                baseItemDiff.dose = "-";
                baseItemDiff.unit = "-";
                baseItemDiff.inst = "-";
                
                for(var n=1; n<selectedItems.length; n++){
                    selectedItems[n].deleted = true;
                }
                
                var masterCheckbox2 = document.querySelector('th input[type="checkbox"]');
                if (masterCheckbox2) masterCheckbox2.checked = false;

                renderTable();
                yrShowAlert("иЎҢгӮ’зөұеҗҲгҒ—гҒҫгҒ—гҒҹгҖӮ", "info");
            }
            
            yrUpdateMergeButtonVisibility(false); // еҮҰзҗҶе®ҢдәҶеҫҢгҒҜгғңгӮҝгғійқһиЎЁзӨәгҒ«гҒҷгӮӢ
        }

        // --- гғүгғ©гғғгӮ°пјҶгғүгғӯгғғгғ—гҒ«гӮҲгӮӢиЎҢзөұеҗҲ ---
        var yrDragSourceId = null;
        var yrDragSourceCat = null;

        // --- IEдә’жҸӣз”Ёclosestд»Јжӣҝ ---
        function yrGetClosestTr(el) {
            while (el) {
                if (el.tagName && el.tagName.toLowerCase() === 'tr') return el;
                el = el.parentNode;
            }
            return null;
        }

        function yrRowDragStart(e, cat, id) {
            yrDragSourceId = id;
            yrDragSourceCat = cat;
            e.dataTransfer.effectAllowed = 'move';
            
            // IEгҒҜ 'text/plain' гҒ§гҒҜгҒӘгҒҸ 'text' гӮ’жҢҮе®ҡгҒҷгӮӢеҝ…иҰҒгҒҢгҒӮгӮӢ
            try { e.dataTransfer.setData('text', id); } catch(ex){}
            
            e.target.style.opacity = '0.5';
        }

        function yrRowDragOver(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            
            var tr = yrGetClosestTr(e.target);
            if (tr && tr.getAttribute('draggable') === 'true') {
                tr.style.backgroundColor = '#e8f4f8';
                tr.style.outline = '2px dashed #0d6efd';
            }
        }

        function yrRowDragLeave(e) {
            var tr = yrGetClosestTr(e.target);
            if (tr) {
                tr.style.backgroundColor = '';
                tr.style.outline = '';
            }
        }

        function yrRowDrop(e, targetCat, targetId) {
            e.preventDefault();
            var tr = yrGetClosestTr(e.target);
            if (tr) {
                tr.style.backgroundColor = '';
                tr.style.outline = '';
            }
            
            // гғүгғ©гғғгӮ°е…ғгӮ’еӨүж•°гҒӢгӮүеҸ–еҫ—
            var sourceId = yrDragSourceId;
            var sourceCat = yrDragSourceCat;
            yrDragSourceId = null;
            yrDragSourceCat = null;

            if (!sourceId || sourceId === targetId) return;
            if (sourceCat !== targetCat) {
                yrShowAlert("з•°гҒӘгӮӢгӮ«гғҶгӮҙгғӘгҒ®иЎҢгҒҜзөұеҗҲгҒ§гҒҚгҒҫгҒӣгӮ“гҖӮ", "error");
                return;
            }

            var cat = targetCat;
            var sourceItem = null;
            var targetItem = null;
            
            // sourceгҒЁtargetгҒ®еҸ–еҫ—
            for (var i=0; i<globalResults[cat].length; i++) {
                if (globalResults[cat][i].id === sourceId) sourceItem = globalResults[cat][i];
                if (globalResults[cat][i].id === targetId) targetItem = globalResults[cat][i];
            }
            
            if (!sourceItem || !targetItem) return;

            // D&DжҷӮгҒ®зўәиӘҚгғҖгӮӨгӮўгғӯгӮ°гӮ’еүҠйҷӨпјҲеҚіжҷӮе®ҹиЎҢгҒҷгӮӢпјү
            
            // еҗҢеҗҚи–¬е“ҒгҒӢгҒ©гҒҶгҒӢгҒ®еҲӨе®ҡ
            if (sourceItem.name === targetItem.name) {
                // еҲқеӣһгҒ®зөҗеҗҲгҒӢгҖҒгҒҷгҒ§гҒ«зөҗеҗҲгҒ•гӮҢгҒҹгӮӮгҒ®гҒӢгӮ’еҲӨе®ҡгҒ—гҒҰгӮ«гӮҰгғігғҲз”Ёгғ—гғӯгғ‘гғҶгӮЈгӮ’дҪңгӮӢ
                var targetCount = targetItem.mergeCount || 1;
                var sourceCount = sourceItem.mergeCount || 1;
                var totalCount = targetCount + sourceCount;
                
                var newInst = Math.floor(24 / totalCount) + "жҷӮй–“жҜҺ";
                
                targetItem.inst = newInst;
                targetItem.fullText = (targetItem.dateStr ? targetItem.dateStr + " " : "")
                    + targetItem.name
                    + (targetItem.dose ? " " + targetItem.dose + targetItem.unit : "")
                    + " " + newInst;
                    
                targetItem.mergeCount = totalCount;
                
                // гғүгғӯгғғгғ—е…ғгӮ’еүҠйҷӨжүұгҒ„гҒ«гҒҷгӮӢ
                sourceItem.deleted = true;
                
                renderTable();
                yrShowAlert(totalCount + "гҒӨгҒ®иЎҢгӮ’гҖҢ" + newInst + "гҖҚгҒ«зөұеҗҲгҒ—гҒҫгҒ—гҒҹпјҒ", "info");

            } else {
                // з•°гҒӘгӮӢи–¬е“ҒеҗҚгҒ®е ҙеҗҲгҒҜеҚҳзҙ”зөҗеҗҲпјҲж”№иЎҢпјү
                var sep = (cat === 1) ? "\n" : (cat === 2 ? "\n" : "\n");
                var combinedStr = targetItem.fullText + sep + sourceItem.fullText;
                
                // гғҷгғјгӮ№иЎҢпјҲгғүгғӯгғғгғ—е…ҲпјүгӮ’жӣҙж–°
                targetItem.fullText = combinedStr;
                targetItem.dose = "-";
                targetItem.unit = "-";
                targetItem.inst = "-";
                
                // гғүгғӯгғғгғ—е…ғгӮ’еүҠйҷӨжүұгҒ„гҒ«гҒҷгӮӢ
                sourceItem.deleted = true;

                renderTable();
                yrShowAlert("иЎҢгӮ’зөұеҗҲгҒ—гҒҫгҒ—гҒҹгҖӮ", "info");
            }
        }


        function yrReadFromClipboard() {
            try {
                var text = window.clipboardData.getData("Text");
                if (!text || text.trim() === "") {
                    yrShowAlert("гӮҜгғӘгғғгғ—гғңгғјгғүгҒ«гғҶгӮӯгӮ№гғҲгғҮгғјгӮҝгҒҢгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ", "error");
                    return;
                }
                
                // иЎЁеҪўејҸгҒ®гӮігғ”гғјжҷӮгҒ«еҲ—еҢәеҲҮгӮҠ(гӮҝгғ–)гҒҢж¶ҲгҒҲгҒҰеҸ–еҫ—гҒ•гӮҢгӮӢHTAзү№жңүгҒ®зҸҫиұЎгҒ®жӨңзҹҘ
                var lines = text.split('\n');
                if (text.indexOf('\t') === -1 && lines.length > 2) {
                    yrShowAlert("гӮҜгғӘгғғгғ—гғңгғјгғүзӣҙжҺҘеҸ–еҫ—гҒ§гҒҜеҲ—гҒ®еҢәеҲҮгӮҠгҒҢеӨұгӮҸгӮҢгҒҰгҒ—гҒҫгҒ„гҒҫгҒҷгҖӮ<br>гҒҠжүӢж•°гҒ§гҒҷгҒҢгҖҒгӮҝгғ–в‘ЎгҒ®е…ҘеҠӣж¬„гҒёзӣҙжҺҘ иІјгӮҠд»ҳгҒ‘(Ctrl+V) гҒ—гҒҰ[и–¬жӯҙдҪңжҲҗ]гӮ’е®ҹиЎҢгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ", "warning");
                    document.getElementById('rawInput').value = text;
                    yrSwitchTab('yr-tab-data', document.querySelectorAll('.yr-nav-link')[1]);
                    return;
                }
                
                document.getElementById('rawInput').value = text;
                yrProcessData(text);
                yrSwitchTab('yr-tab-result', document.querySelector('.yr-nav-link'));
            } catch (err) {
                yrShowAlert("гӮҜгғӘгғғгғ—гғңгғјгғүгҒӢгӮүгҒ®иӘӯгҒҝиҫјгҒҝгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹгҖӮ<br>гӮҝгғ–в‘ЎгӮ’й–ӢгҒ„гҒҰгҖҒгғҶгӮӯгӮ№гғҲгӮЁгғӘгӮўгҒ«зӣҙжҺҘиІјгӮҠд»ҳгҒ‘(Ctrl+V)гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ", "error");
                yrSwitchTab('yr-tab-data', document.querySelectorAll('.yr-nav-link')[1]);
            }
        }

        function yrProcessData(rawData) {
            if (!rawData || rawData.trim() === "") return;

            var baseDateStr = document.getElementById('baseDate').value;
            if (!baseDateStr) {
                yrShowAlert("еҹәжә–ж—ҘгӮ’е…ҘеҠӣгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ", "error");
                return;
            }
            var baseDate = new Date(baseDateStr);
            var includeTiming = document.getElementById('includeTiming').value === "true";
            var isMergeEnabled = document.getElementById('set-merge').checked;

            globalResults = { 1: [], 2: [], 3: [] };
            currentSorts = { 1: 'default', 2: 'default', 3: 'default' };
            uniqueIdCounter = 0;

            var lines = rawData.split('\n');
            var maxDay = 0;

            for(var idxLine=0; idxLine<lines.length; idxLine++) { var line = lines[idxLine];
                var cols = line.split('\t');
                if (cols.length > 5 && (cols.length - 6) > maxDay) {
                    maxDay = cols.length - 6;
                }
            }

            var rDay = [], rDrug = [], rDose = [], rUnit = [], rInst = [];
            var rCat = [], rTm = [], rPRN = [], rIV = [], rPresc = [], rOrigIdx = [];
            var rSliding = [], rPeriOp = [], rIvTime = [];

            var curCategory = 1;
            var curTiming = "";
            var curPrescDay = -1;
            var currentIvBlockPeriOp = false;
            var curIvTimeStr = "";
            var curIvBlockFirstDay = -1;
            var curInjectTimeMark = "";

            for (var r = 0; r < lines.length; r++) {
                var rowStr = lines[r];
                if (!rowStr.trim()) continue;

                var cols = rowStr.replace(/\r/g, '').split('\t');

                // вҳ… 1еҲ—зӣ®гҒҢж•°еӯ—гҒ®гҒҝгҒ®е ҙеҗҲгҒҜеҲ—гӮ’гӮ·гғ•гғҲгҒ—гҒҰеүҠйҷӨгҒҷгӮӢпјҲNoд»ҳгӮігғ”гғјеҜҫзӯ–пјү
                if (cols.length > 1 && /^[0-9пјҗ-пјҷ]+$/.test(cols[0].trim())) {
                    cols.shift();
                }

                var rawName = cols[0] || "";
                // вҳ… гӮ»гғ«еҶ…гҒ®е…Ҳй ӯгҒ«гҖҢж•°еӯ—пјӢгӮ№гғҡгғјгӮ№гҖҚгҒҢгҒӮгӮӢе ҙеҗҲгӮӮеүҠйҷӨ
                rawName = rawName.replace(/^[0-9пјҗ-пјҷ]+[ гҖҖ]+/, '');

                var drugName = cleanDrugName(formatText(rawName.trim()));

                // cols[0]гҒҢз©әгҒ®е ҙеҗҲгҖҒд»–гҒ®гӮ«гғ©гғ гҒӢгӮүзӮ№ж»ҙ/йқҷжіЁзӯүгҒ®гғҳгғғгғҖгғјгӮ’жҺўгҒҷ
                if (!rawName) {
                    var foundIvHeader = false;
                    for (var ci = 1; ci < Math.min(cols.length, 6); ci++) {
                        var chk = formatText((cols[ci] || "").trim());
                        if (chk.indexOf("зӮ№ж»ҙ") === 0 || chk.indexOf("йқҷжіЁ") === 0 || chk.indexOf("зҡ®дёӢжіЁ") === 0 || chk.indexOf("гҒқгҒ®д»–жіЁ") === 0) {
                            drugName = chk;
                            rawName = chk;
                            foundIvHeader = true;
                            break;
                        }
                    }
                    if (!foundIvHeader) continue;
                }

                if (drugName.startsWith("[")) {
                    var tmpArr = drugName.substring(drugName.indexOf("]") + 1).split(" ");
                    curTiming = "";
                    if (tmpArr.length > 0) {
                        var lastWord = tmpArr[tmpArr.length - 1].trim().split("(")[0];
                        if (lastWord) curTiming = lastWord;
                        else if (tmpArr.length > 1) curTiming = tmpArr[1].trim().split("(")[0];
                    }

                    curPrescDay = -1;
                    for (var c = 1; c < cols.length; c++) {
                        var cell = cols[c].trim();
                        if (["в—Ҹ", "в—Ҝ", "в—Ӣ", "в—Һ", "в–І", "*"].indexOf(cell) !== -1) {
                            curPrescDay = c;
                            break;
                        }
                    }
                    continue;
                }

                if (drugName === "зӮ№ж»ҙ" || drugName.startsWith("зӮ№ж»ҙ ") || drugName.startsWith("зӮ№ж»ҙгҖҖ") ||
                    drugName === "йқҷжіЁ" || drugName.startsWith("йқҷжіЁ ") || drugName.startsWith("йқҷжіЁгҖҖ") ||
                    drugName === "зҡ®дёӢжіЁ" || drugName.startsWith("зҡ®дёӢжіЁ ") || drugName.startsWith("зҡ®дёӢжіЁгҖҖ") ||
                    drugName === "гҒқгҒ®д»–жіЁ" || drugName.startsWith("гҒқгҒ®д»–жіЁ ") || drugName.startsWith("гҒқгҒ®д»–жіЁгҖҖ")) {

                    curCategory = 3;
                    curPrescDay = -1;
                    currentIvBlockPeriOp = false;
                    curIvTimeStr = "";
                    curIvBlockFirstDay = -1;
                    curInjectTimeMark = "";

                    for (var c = 1; c < cols.length; c++) {
                        var cell = cols[c].trim();
                        if (["в—Ҹ", "в—Ҝ", "в—Ӣ", "в—Һ", "в–І", "*"].indexOf(cell) !== -1) {
                            curPrescDay = c;
                            break;
                        }
                    }

                    var blockHasPeriOp = false;
                    for (var pr = r + 1; pr < lines.length; pr++) {
                        if (lines[pr].trim() === "" || lines[pr].startsWith("[")) break;
                        var pCols = lines[pr].replace(/\r/g, '').split('\t');
                        var prName = formatText(pCols[0] || "").trim();

                        if (prName === "зӮ№ж»ҙ" || prName.startsWith("зӮ№ж»ҙ ") ||
                            prName === "йқҷжіЁ" || prName.startsWith("йқҷжіЁ ") ||
                            prName === "зҡ®дёӢжіЁ" || prName.startsWith("зҡ®дёӢжіЁ ") ||
                            prName === "гҒқгҒ®д»–жіЁ" || prName.startsWith("гҒқгҒ®д»–жіЁ ")) break;

                        for (var pc = 5; pc < pCols.length; pc++) {
                            if (["в—Ҹ", "в—Ҝ", "в—Ӣ", "в—Һ", "в–І", "*"].indexOf(pCols[pc].trim()) !== -1) {
                                if (curIvBlockFirstDay === -1 || (pc - 5) < curIvBlockFirstDay) {
                                    curIvBlockFirstDay = pc - 5;
                                }
                            }
                        }

                        if (prName && prName.indexOf("й–Ӣе§ӢжҷӮеҲ»") === -1 && prName.match(/^[0-9]+:[0-9]+/) === null && prName.indexOf("mL/жҷӮ") === -1 && prName.indexOf("гӮӯгғғгғҲз”ҹйЈҹ") === -1 && prName.indexOf("йқҷжіЁз”Ё") === -1 && prName.indexOf("гӮҪгғӘгӮҝ") === -1 && prName.indexOf("гӮўгӮ»гғӘгӮӘ") === -1 && prName.indexOf("з”ҹзҗҶйЈҹеЎ©ж¶І") === -1 && prName.indexOf("иЎҖзі–") === -1) {
                            if (/(Ope|ope|её°е®Ө|жҢҒеҸӮ|жҠңйҮқ|гғ«гғјгғҲ|гҒӢгӮү|гҒҫгҒ§|д»ҘйҷҚ|жүӢиЎ“|иЎ“еүҚ|иЎ“еҫҢ)/i.test(prName)) {
                                blockHasPeriOp = true;
                            }
                        }
                    }
                    currentIvBlockPeriOp = blockHasPeriOp;
                    continue;
                }

                if (curCategory === 3) {
                    var timeMatch = drugName.match(/^([0-9]+):([0-9]+)(?:[ гҖҖ]+<(.*?)>)?/);
                    if (timeMatch && drugName.indexOf("mL/жҷӮ") === -1 && drugName.indexOf("еҚҳдҪҚ") === -1) {
                        curIvTimeStr = drugName.split(/[ гҖҖ]+/)[0].trim();
                        var hh = parseInt(timeMatch[1], 10);
                        var mark = timeMatch[3];

                        if (mark) {
                            if (mark.indexOf("жңқ") !== -1) curInjectTimeMark = "жңқ";
                            else if (mark.indexOf("жҳј") !== -1) curInjectTimeMark = "жҳј";
                            else if (mark.indexOf("еӨ•") !== -1) curInjectTimeMark = "еӨ•";
                            else if (mark.indexOf("зң ") !== -1) curInjectTimeMark = "зң еүҚ";
                            else curInjectTimeMark = mark;
                        } else {
                            if (hh >= 5 && hh <= 10) curInjectTimeMark = "жңқ";
                            else if (hh >= 11 && hh <= 15) curInjectTimeMark = "жҳј";
                            else if (hh >= 16 && hh <= 20) curInjectTimeMark = "еӨ•";
                            else curInjectTimeMark = "зң еүҚ";
                        }
                        continue;
                    } else if (drugName.match(/^[0-9]+:[0-9]+[ гҖҖ]*пҪһ/)) {
                        curIvTimeStr = drugName.split("пҪһ")[0].trim();
                        continue;
                    } else if (drugName.indexOf("й–Ӣе§ӢжҷӮеҲ»жҢҮе®ҡз„ЎгҒ—") !== -1) {
                        curIvTimeStr = cleanDrugName(formatText(cols[0].trim()));
                        continue;
                    }
                }

                if (rawName.startsWith("гҖҖ") || rawName.startsWith(" ")) continue;
                if (drugName.indexOf("пҪһ") !== -1 || drugName === "й–Ӣе§ӢжҷӮеҲ»жҢҮе®ҡз„ЎгҒ—" || drugName.indexOf("иЎҖзі–:") !== -1 || drugName.indexOf("иЎҖзі–пјҡ") !== -1 || drugName.match(/^[0-9]+:[0-9]+[ гҖҖ]+[0-9]+[ гҖҖ]+еӣһ/)) continue;
                if (drugName.indexOf("жүӢиЎ“е®ӨжҢҒеҸӮ") !== -1 || drugName.indexOf("йҷўеҶ…") !== -1 || drugName.indexOf("и–¬еҠ№еҗҚз§°") !== -1 || drugName.indexOf("еӨ•йЈҹеҫҢгҒ«еӨүжӣҙеҸҜ") !== -1 || drugName.indexOf("е®ҹж•°е…ҘеҠӣ") !== -1 || drugName.indexOf("еӨ–жқҘз”ЁжүӢиЎ“еүҚжӨңиӘҚ") !== -1 || drugName.indexOf("и–¬еүӨеё«гҒ«гӮҲгӮӢжңҚз”ЁзҠ¶жіҒзўәиӘҚгҒҜжңӘе®ҹж–ҪгҒ§гҒҷ") !== -1) continue;

                if (curCategory === 1) {
                    var isBroughtIn = false;
                    for (var peekR = r + 1; peekR <= r + 5 && peekR < lines.length; peekR++) {
                        var pLine = lines[peekR].replace(/\r/g, '');
                        if (!pLine.trim()) continue; // з©әиЎҢгҒҜгӮ№гӮӯгғғгғ—
                        var pCols = pLine.split('\t');
                        // е…ЁеҲ—гӮ’зөҗеҗҲгҒ—гҒҰгҖҢи–¬еҠ№еҗҚз§°гҖҚгҖҢйҷўеҶ…гҖҚгӮ’жӨңзҙў
                        var pJoined = pCols.join(' ');
                        if (pJoined.indexOf("и–¬еҠ№еҗҚз§°") !== -1 || pJoined.indexOf("йҷўеҶ…") !== -1 || pJoined.indexOf("йҷўеӨ–е°Ӯз”Ё") !== -1) {
                            isBroughtIn = true; break;
                        }
                        // ж¬ЎгҒ®и–¬е“ҒиЎҢпјҲе…Ҳй ӯгҒҢе…Ёи§’/еҚҠи§’гӮ№гғҡгғјгӮ№гҒ§гҒӘгҒ„пјқж–°гҒ—гҒ„и–¬еүӨпјүгҒ«еҲ°йҒ”гҒ—гҒҹгӮүзөӮдәҶ
                        var pVal = pCols[0] || "";
                        if (pVal && !pVal.startsWith("гҖҖ") && !pVal.startsWith(" ")) break;
                    }
                    if (isBroughtIn) curCategory = 2;
                }

                var isSliding = false;
                for (var peekR = r + 1; peekR <= r + 8 && peekR < lines.length; peekR++) {
                    var pCols = lines[peekR].replace(/\r/g, '').split('\t');
                    var pVal = pCols[0] ? formatText(pCols[0].trim()) : "";
                    if (pVal.indexOf("иЎҖзі–:") !== -1 || pVal.indexOf("иЎҖзі–пјҡ") !== -1 || pVal.indexOf("гҒ®жҷӮ") !== -1) {
                        isSliding = true;
                        break;
                    }
                    if (pVal && !pVal.startsWith(" ") && !pVal.startsWith("гҖҖ") && pVal.indexOf("иЎҖзі–") === -1) {
                        break;
                    }
                }

                var dDose = formatText(cols[1] ? cols[1].trim() : "");
                var dUnit = formatText(cols[2] ? cols[2].trim() : "");
                var dInst = formatText(cols[4] ? cols[4].trim() : "");
                var isPRN = dInst.indexOf("й “з”Ё") !== -1;
                var isIV = (curCategory === 3 || dInst.indexOf("йқҷжіЁ") !== -1 || dInst.indexOf("зӮ№ж»ҙ") !== -1 || dInst.indexOf("зҡ®дёӢжіЁ") !== -1 || dInst === "");

                var extractedComment = "";
                if (isIV && currentIvBlockPeriOp) {
                    for (var offset = -2; offset <= 2; offset++) {
                        var targetIdx = r + offset;
                        if (targetIdx >= 0 && targetIdx < lines.length && targetIdx !== r) {
                            var tCols = lines[targetIdx].replace(/\r/g, '').split('\t');
                            var tName = tCols[0] ? formatText(tCols[0].trim()) : "";
                            if (tName && tName.startsWith("[") === false && tName.startsWith("зӮ№ж»ҙ") === false && tName.startsWith("йқҷжіЁ") === false && tName.startsWith("зҡ®дёӢжіЁ") === false && tName.indexOf("й–Ӣе§ӢжҷӮеҲ»") === -1 && tName.indexOf("mL/жҷӮ") === -1 && tName.match(/^[0-9]+:[0-9]+/) === null && tName.indexOf("гӮӯгғғгғҲз”ҹйЈҹ") === -1 && tName.indexOf("йқҷжіЁз”Ё") === -1 && tName.indexOf("з”ҹзҗҶйЈҹеЎ©ж¶І") === -1) {
                                if (/(Ope|ope|её°е®Ө|жҢҒеҸӮ|жҠңйҮқ|гғ«гғјгғҲ|гҒӢгӮү|гҒҫгҒ§|д»ҘйҷҚ|жүӢиЎ“|иЎ“еүҚ|иЎ“еҫҢ)/i.test(tName)) {
                                    extractedComment = tName.replace(/^[в‘ в‘Ўв‘ўв‘Јв‘Өв‘Ҙв‘Ұв‘§в‘Ёв‘©]/, '').trim();
                                    break;
                                }
                            }
                        }
                    }
                }

                if (isSliding) {
                    dDose = "";
                    dUnit = "";
                } else if (isIV && dUnit.indexOf("еҚҳдҪҚ") !== -1 && curInjectTimeMark) {
                    dDose = curInjectTimeMark + dDose;
                    dInst = "";
                }

                for (var c = 5; c < cols.length; c++) {
                    var cellVal = cols[c].trim();
                    if (cellVal === "*") isPRN = true;
                    if (["в—Ҹ", "в—Ҝ", "в—Ӣ", "в—Һ", "в–І", "*"].indexOf(cellVal) !== -1) {
                        var dayIdx = c - 5;
                        rDay.push(dayIdx);
                        rDrug.push(drugName);
                        rDose.push(dDose);
                        rUnit.push(dUnit);
                        rInst.push(extractedComment ? extractedComment : dInst);
                        rCat.push(curCategory);
                        rTm.push(curTiming);
                        rPRN.push(isPRN);
                        rIV.push(isIV);
                        rPresc.push(curPrescDay);
                        rOrigIdx.push(r);
                        rSliding.push(isSliding);
                        rPeriOp.push(isIV && currentIvBlockPeriOp && (dayIdx === curIvBlockFirstDay));
                        rIvTime.push(curIvTimeStr);
                    }
                }
            }

            var insulinMap = {};
            var toRemove = {};
            for (var i = 0; i < rDay.length; i++) {
                if (rIV[i] && rUnit[i].indexOf("еҚҳдҪҚ") !== -1 && !rSliding[i] && !rPeriOp[i]) {
                    var key = rDay[i] + "|" + rDrug[i];
                    if (insulinMap.hasOwnProperty(key)) {
                        var firstIdx = insulinMap[key];
                        rDose[firstIdx] += " " + rDose[i];
                        toRemove[i] = true;
                    } else {
                        insulinMap[key] = i;
                    }
                }
            }

            var dictProf = {};
            var dictOngoing = {};
            var dictOrigIdx = {};

            for (var i = 0; i < rDay.length; i++) {
                if (toRemove[i]) continue;

                var compInst = rInst[i];

                if (rIV[i]) {
                    var specKey = rDrug[i] + "|" + rDose[i] + "|" + rUnit[i] + "|" + rDay[i];

                    if (rSliding[i]) {
                        compInst = "гӮӨгғігӮ№гғӘгғігӮ№гғ©гӮӨгғҮгӮЈгғігӮ°";
                    } else if (rPeriOp[i]) {
                        compInst = rInst[i];
                    } else if (rUnit[i].indexOf("еҚҳдҪҚ") === -1) {
                        var t = rIvTime[i] || "";
                        var c = rInst[i] || "";

                        if (c === "йқҷжіЁ" || c === "зӮ№ж»ҙ" || c === "зҡ®дёӢжіЁ" || c === "гҒқгҒ®д»–жіЁ") {
                            c = "";
                        }

                        if (t && c && t.indexOf(c) === -1 && c.indexOf(t) === -1) {
                            compInst = t + " " + c;
                        } else if (t && c && t.indexOf(c) !== -1) {
                            compInst = t;
                        } else if (t && c && c.indexOf(t) !== -1) {
                            compInst = c;
                        } else {
                            compInst = t || c;
                        }
                    }
                }

                var pKeyArray = [rCat[i], rDrug[i], rDose[i], rUnit[i], compInst, rTm[i], rPRN[i], rPeriOp[i], rSliding[i]];
                if (!isMergeEnabled) {
                    pKeyArray.push(rOrigIdx[i]);
                }
                var pKey = pKeyArray.join('\t');

                if (!dictOrigIdx.hasOwnProperty(pKey)) dictOrigIdx[pKey] = rOrigIdx[i];

                if (rDay[i] === 0) {
                    if (!dictOngoing.hasOwnProperty(pKey)) {
                        dictOngoing[pKey] = (rPresc[i] === -1);
                    }
                }

                if (!dictProf.hasOwnProperty(pKey)) {
                    // new Array(maxDay + 2).fill(false) гҒ®Polyfillд»ЈгӮҸгӮҠ
                    var emptyArr = [];
                    for(var fn=0; fn < maxDay + 2; fn++) emptyArr.push(false);
                    dictProf[pKey] = emptyArr;
                }
                dictProf[pKey][rDay[i]] = true;
            }

            // MapгҒ®forEachгӮ’ObjectгҒ®for...inгғ«гғјгғ—гҒ«еӨүжӣҙ
            for (var k in dictProf) {
                if (!dictProf.hasOwnProperty(k)) continue;
                var arrD = dictProf[k];
                var pStr = k.split('\t');
                var cat = parseInt(pStr[0]);
                var name = pStr[1];
                var dose = pStr[2];
                var unit = pStr[3];
                var inst = pStr[4];
                var timing = pStr[5];
                var isPrnFlag = pStr[6] === "true";
                var isPeriOpFlag = pStr[7] === "true";
                var origIdx = dictOrigIdx[k];

                var isOngoingFromPast = dictOngoing.hasOwnProperty(k) ? dictOngoing[k] : false;

                var blocks = [];
                var inBlock = false;
                var bStart = 0;

                for (var d = 0; d <= maxDay + 1; d++) {
                    if (arrD[d] && !inBlock) {
                        bStart = d; inBlock = true;
                    } else if (!arrD[d] && inBlock) {
                        blocks.push([bStart, d - 1]); inBlock = false;
                    }
                }

                var dateStr = "";
                var firstStartDay = blocks.length > 0 ? blocks[0][0] : 999;

                for(var idxB=0; idxB<blocks.length; idxB++) { var blk = blocks[idxB];
                    var bS = blk[0];
                    var bE = blk[1];
                    var isThisBlockOngoing = (bS === 0 && isOngoingFromPast);

                    if (isPrnFlag) {
                        var prnDate = "";
                        if (!isThisBlockOngoing) {
                            var d = new Date(baseDate); d.setDate(d.getDate() + bS);
                            prnDate = (d.getMonth() + 1) + "/" + d.getDate() + "-";
                        }
                        if (prnDate) {
                            dateStr = dateStr === "" ? prnDate : dateStr + "гҖҒ" + prnDate;
                        }
                    } else {
                        var sD = new Date(baseDate); sD.setDate(sD.getDate() + bS);
                        var eD = new Date(baseDate); eD.setDate(eD.getDate() + bE);
                        var sTxt = (sD.getMonth() + 1) + "/" + sD.getDate();
                        var eTxt = (eD.getMonth() + 1) + "/" + eD.getDate();
                        var isOngoing = (bE === maxDay);

                        if (includeTiming && cat !== 3 && timing !== "") {
                            sTxt += timing;
                            var eTm = "";
                            var match = inst.match(/[пјҲ(]([^)пјү]+)[)пјү]/);
                            if (match) {
                                var uArr = match[1].replace(/пјҢ/g, 'гғ»').replace(/гҖҒ/g, 'гғ»').split('гғ»');
                                var sIdx = uArr.indexOf(timing);
                                if (sIdx >= 0) {
                                    eTm = uArr[(sIdx - 1 + uArr.length) % uArr.length];
                                }
                            }
                            if (eTm !== "") eTxt += eTm;

                            if (isThisBlockOngoing) {
                                sTxt = isOngoing ? "-" : "-" + eTxt;
                            } else {
                                if (isOngoing) sTxt += "-";
                                else if (bS === bE) {
                                    if (eTm !== "" && timing !== eTm) sTxt += "-" + eTxt;
                                } else {
                                    sTxt += "-" + eTxt;
                                }
                            }
                        } else {
                            if (isThisBlockOngoing) {
                                sTxt = isOngoing ? "-" : "-" + eTxt;
                            } else {
                                if (isOngoing) sTxt += "-";
                                else if (bS !== bE) sTxt += "-" + eTxt;
                            }
                        }

                        dateStr = dateStr === "" ? sTxt : dateStr + "пјҢ" + sTxt;
                    }
                }

                if (isPeriOpFlag && dateStr.indexOf("-") !== -1) {
                    dateStr = dateStr.split("-")[0];
                }

                var originalInst = "";
                for(var oKey in dictOrigIdx){
                     if (dictOrigIdx.hasOwnProperty(oKey) && dictOrigIdx[oKey] === origIdx) {
                         originalInst = oKey.split('\t')[4];
                     }
                }

                var displayInst = inst || originalInst;
                var fullText = (dateStr ? dateStr + " " : "") + name + (dose ? " " + dose + unit : "") + (displayInst ? " " + displayInst : "");

                var itemId = "row_" + uniqueIdCounter++;

                globalResults[cat].push({
                    id: itemId,
                    dateStr: dateStr, name: name, dose: dose, unit: unit, inst: displayInst, fullText: fullText,
                    origIdx: origIdx, firstStartDay: firstStartDay
                });
            } // Object for...in loop гҒ®зөӮз«Ҝ

            if (document.getElementById('set-remove-iv-words') && document.getElementById('set-remove-iv-words').checked) {
                var ivWordsRegex = /гғҗгӮӨгӮўгғ«з”Ё|пҫҠпҫһпҪІпҪұпҫҷз”Ё|гӮўгғігғ—гғ«з”Ё|пҪұпҫқпҫҢпҫҹпҫҷз”Ё|гғӯгғғгӮҜз”Ё|пҫӣпҪҜпҪёз”Ё/;
                for (var c = 1; c <= 3; c++) {
                    globalResults[c] = globalResults[c].filter(function(item) {
                        var txt = (item.name || '') + ' ' + (item.fullText || '');
                        return !ivWordsRegex.test(txt);
                    });
                }
            }

            if (globalResults[1].length === 0 && globalResults[2].length === 0 && globalResults[3].length === 0) {
                yrShowAlert("и©ІеҪ“гҒҷгӮӢгғҮгғјгӮҝгҒҢиҰӢгҒӨгҒӢгӮҠгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹгҖӮ", "error");
            } else {
                yrShowAlert("и–¬жӯҙгҒ®дҪңжҲҗгҒҢе®ҢдәҶгҒ—гҒҫгҒ—гҒҹпјҒ", "info");
            }

            renderTable();
        }

function renderTable() {
    var tbody = document.querySelector('#yr-resultTable tbody');
    tbody.innerHTML = "";
    var tokuyakuCount = 0;
    var highlightEnabled = document.getElementById('set-tokuyaku-highlight') && document.getElementById('set-tokuyaku-highlight').checked;
    
    var createHeader = function(cat, title, cssClass) {
        if (globalResults[cat].length === 0) return;
        var tr = document.createElement('tr');
        tr.className = cssClass;
        var currentVal = currentSorts[cat];
        
        var h = [];
        h.push('<td colspan="7"><div class="yr-cat-header"><span class="yr-cat-title">гҖҗ ' + title + ' гҖ‘</span>');
        h.push('<span style="font-size:11px; color:#666; margin-left:10px;">вҖ» д»–гҒ®иЎҢгӮ’гғүгғ©гғғгӮ°пјҶгғүгғӯгғғгғ—гҒ§йҮҚгҒӯгӮӢгҒЁзөұеҗҲгҒ•гӮҢгҒҫгҒҷ</span>');
        h.push('<div style="display: flex; gap: 10px; align-items: center;"><select class="yr-form-select" style="width:auto;" onchange="sortCategory(' + cat + ', this.value)">');
        h.push('<option value="default" ' + (currentVal === 'default' ? 'selected' : '') + '>в–ј дёҰгҒіжӣҝгҒҲ (е…ғгҒ®й Ҷ)</option>');
        h.push('<option value="date_asc" ' + (currentVal === 'date_asc' ? 'selected' : '') + '>ж—Ҙд»ҳ (еҸӨгҒ„й Ҷ)</option>');
        h.push('<option value="date_desc" ' + (currentVal === 'date_desc' ? 'selected' : '') + '>ж—Ҙд»ҳ (ж–°гҒ—гҒ„й Ҷ)</option>');
        h.push('<option value="name_asc" ' + (currentVal === 'name_asc' ? 'selected' : '') + '>и–¬е“ҒеҗҚ (жҳҮй Ҷ пҪұ-пҫқ)</option>');
        h.push('<option value="name_desc" ' + (currentVal === 'name_desc' ? 'selected' : '') + '>и–¬е“ҒеҗҚ (йҷҚй Ҷ пҫқ-пҪұ)</option>');
        h.push('</select></div></div></td>');
        tr.innerHTML = h.join('');
        tbody.appendChild(tr);
    };

    var createRows = function(cat) {
        for(var m=0; m<globalResults[cat].length; m++){
            var item = globalResults[cat][m];
            var tr = document.createElement('tr');
            var isDeleted = item.deleted;
            var isTk = isDeleted ? false : isTokuyaku(item.name);
            var tkStyle = isTk ? 'color:#c62828; font-weight:bold;' : 'font-weight: bold; color: #2c3e50;';
            if (isTk) tokuyakuCount++;
            if (isDeleted) tr.style.cssText = 'text-decoration:line-through; opacity:0.4; background:#f9f9f9;';
            
            var delBtnTitle = isDeleted ? 'еҫ©её°' : 'гҒ“гҒ®иЎҢгӮ’йҷӨеӨ–';
            var delBtnStyle = isDeleted ? 'yr-btn-success-sm' : 'yr-btn-danger-sm';
            var delBtnIcon = isDeleted ? '&#8634;' : '&#10006;';
            
            var dragAttrs = isDeleted ? '' : ' draggable="true" ondragstart="yrRowDragStart(event, ' + cat + ', \'' + item.id + '\')" ondragover="yrRowDragOver(event)" ondragleave="yrRowDragLeave(event)" ondrop="yrRowDrop(event, ' + cat + ', \'' + item.id + '\')" title="йҮҚгҒӯгҒҰзөұеҗҲ" style="cursor: grab;"';
            
            var rowH = [];
            rowH.push('<td class="yr-text-center"' + dragAttrs + '>' + item.dateStr + '</td>');
            rowH.push('<td style="' + tkStyle + '"' + dragAttrs + '>' + (isTk ? '&#128308; ' : '') + item.name + '</td>');
            rowH.push('<td class="yr-text-center"' + dragAttrs + '>' + item.dose + '</td>');
            rowH.push('<td class="yr-text-center"' + dragAttrs + '>' + item.unit + '</td>');
            rowH.push('<td' + dragAttrs + '>' + item.inst + '</td>');
            rowH.push('<td class="yr-text-center"><input type="checkbox" class="row-checkbox" value="' + item.id + '" data-cat="' + cat + '" onchange="yrOnRowCheckboxChange()"' + (isDeleted ? ' disabled' : '') + '></td>');
            rowH.push('<td class="yr-text-center"><button class="' + delBtnStyle + '" onclick="yrDeleteRow(' + cat + ', \'' + item.id + '\')" title="' + delBtnTitle + '">' + delBtnIcon + '</button></td>');
            rowH.push('<td style="padding: 0;"><div class="yr-editable-cell" contenteditable="' + (isDeleted ? 'false' : 'true') + '" onfocus="document.execCommand(\'selectAll\',false,null)" onblur="updateText(' + cat + ', \'' + item.id + '\', this.innerText)" onkeydown="handleEnter(event, this)">' + item.fullText + '</div></td>');
            tr.innerHTML = rowH.join('');
            tbody.appendChild(tr);
        }
    };

    createHeader(1, 'еҶ…жңҚи–¬', 'yr-cat-oral');
    createRows(1);
    createHeader(2, 'жҢҒеҸӮи–¬', 'yr-cat-injection');
    createRows(2);
    createHeader(3, 'зӮ№ж»ҙгғ»жіЁе°„', 'yr-cat-external');
    createRows(3);
    
    var summaryEl = document.getElementById('yr-tokuyaku-summary');
    if (!summaryEl) {
        summaryEl = document.createElement('div');
        summaryEl.id = 'yr-tokuyaku-summary';
        summaryEl.style.cssText = 'font-size:12px; margin-bottom:5px; padding:4px 8px; border-radius:4px;';
        var tbl = document.getElementById('yr-resultTable');
        if (tbl) tbl.parentNode.insertBefore(summaryEl, tbl);
    }
    var totalItems = globalResults[1].length + globalResults[2].length + globalResults[3].length;
    if (totalItems > 0 && highlightEnabled && tokuyakuCount > 0) {
        summaryEl.style.display = 'block';
        summaryEl.style.background = '#ffebee';
        summaryEl.style.color = '#c62828';
        summaryEl.innerHTML = 'в—Ҹ <b>и–¬еүӨз®ЎзҗҶжҢҮе°Һпј‘еҜҫиұЎ: ' + tokuyakuCount + 'д»¶</b> / е…Ё' + totalItems + 'д»¶';
    } else if (totalItems > 0 && highlightEnabled) {
        summaryEl.style.display = 'block';
        summaryEl.style.background = '#e8f5e9';
        summaryEl.style.color = '#2e7d32';
        summaryEl.innerHTML = 'вң” и–¬з®Ўпј‘еҜҫиұЎи–¬еүӨгҒӘгҒ— (е…Ё' + totalItems + 'д»¶)';
    } else {
        summaryEl.style.display = 'none';
    }

    if (tbody.innerHTML === "") {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted" style="padding: 30px;">гғҮгғјгӮҝгҒҢгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ</td></tr>';
    }
}
        function sortCategory(cat, sortType) {
            currentSorts[cat] = sortType;
            var arr = globalResults[cat];

            if (sortType === 'default') {
                arr.sort(function(a, b) { return a.origIdx - b.origIdx; });
            } else if (sortType === 'date_asc') {
                arr.sort(function(a, b) { return a.firstStartDay - b.firstStartDay || a.name.localeCompare(b.name, 'ja') || a.origIdx - b.origIdx; });
            } else if (sortType === 'date_desc') {
                arr.sort(function(a, b) { return b.firstStartDay - a.firstStartDay || a.name.localeCompare(b.name, 'ja') || a.origIdx - b.origIdx; });
            } else if (sortType === 'name_asc') {
                arr.sort(function(a, b) { return a.name.localeCompare(b.name, 'ja') || a.firstStartDay - b.firstStartDay || a.origIdx - b.origIdx; });
            } else if (sortType === 'name_desc') {
                arr.sort(function(a, b) { return b.name.localeCompare(a.name, 'ja') || a.firstStartDay - b.firstStartDay || a.origIdx - b.origIdx; });
            }
            renderTable();
        }

        function updateText(cat, id, newText) {
            var item = null; for(var kz=0;kz<globalResults[cat].length;kz++){if(globalResults[cat][kz].id===id) item=globalResults[cat][kz];}
            if (item) {
                item.fullText = newText.replace(/\r?\n/g, "");
            }
        }

        function handleEnter(e, el) {
            if (e.key === 'Enter') {
                e.preventDefault();
                el.blur();
            }
        }

        function yrDeleteRow(cat, id) {
            var useSoftDelete = document.getElementById('set-softdelete') && document.getElementById('set-softdelete').checked;
            for (var kz = 0; kz < globalResults[cat].length; kz++) {
                if (globalResults[cat][kz].id === id) {
                    if (useSoftDelete) {
                        globalResults[cat][kz].deleted = !globalResults[cat][kz].deleted;
                    } else {
                        globalResults[cat].splice(kz, 1);
                    }
                    break;
                }
            }
            renderTable();
        }

        function yrCopyResultTable() {
            var copyText = "";

            var appendText = function(cat) {
                if (globalResults[cat].length > 0) {
                    for(var i2=0; i2<globalResults[cat].length; i2++) { var item = globalResults[cat][i2];
                        if (!item.deleted) copyText += item.fullText + "\r\n";
                    }
                }
            };

            if (globalResults[1].length > 0) copyText += "гҖҗеҶ…жңҚгғ»еӨ–з”ЁзӯүгҖ‘\r\n";
            appendText(1);
            if (globalResults[2].length > 0) copyText += "гҖҗжҢҒеҸӮи–¬гҖ‘\r\n";
            appendText(2);
            if (globalResults[3].length > 0) copyText += "гҖҗзӮ№ж»ҙгҖ‘\r\n";
            appendText(3);

            if (copyText === "") {
                yrShowAlert("гӮігғ”гғјгҒҷгӮӢгғҮгғјгӮҝгҒҢгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ", "error");
                return;
            }

            try {
                window.clipboardData.setData("Text", copyText);
                yrShowAlert("дҪңжҲҗгҒ•гӮҢгҒҹи–¬жӯҙгғҶгӮӯгӮ№гғҲгӮ’гӮҜгғӘгғғгғ—гғңгғјгғүгҒ«гӮігғ”гғјгҒ—гҒҫгҒ—гҒҹпјҒ<br>гӮ«гғ«гғҶзӯүгҒ®е…ҘеҠӣж¬„гҒ«гҒқгҒ®гҒҫгҒҫиІјгӮҠд»ҳгҒ‘(Ctrl+V)гҒ§гҒҚгҒҫгҒҷгҖӮ");
            } catch(err) {
                yrShowAlert("гӮігғ”гғјгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹгҖӮ", "error");
            }
        }

        function yrInit() {
            // еҹәжә–ж—Ҙ (baseDate) гҒ®еҲқжңҹеҢ–: еҪ“ж—Ҙ-3ж—ҘгӮ’иЁӯе®ҡ
            var today = new Date();
            today.setDate(today.getDate() - 3);
            var dateStr = today.getFullYear() + '-' + ('0' + (today.getMonth() + 1)).slice(-2) + '-' + ('0' + today.getDate()).slice(-2);
            var bDateInput = document.getElementById('baseDate');
            if (bDateInput) bDateInput.value = dateStr;

            // иЁӯе®ҡгҒ®гғӯгғјгғүгҒЁеҸҚжҳ 

            if (document.getElementById('set-halfwidth'))
                document.getElementById('set-halfwidth').checked = myStorage.getItem('set-halfwidth') !== 'false';
            
            if (document.getElementById('set-merge'))
                document.getElementById('set-merge').checked = myStorage.getItem('set-merge') !== 'false';
            
            if (document.getElementById('set-softdelete'))
                document.getElementById('set-softdelete').checked = myStorage.getItem('set-softdelete') !== 'false';
            
            if (document.getElementById('set-remove-form'))
                document.getElementById('set-remove-form').checked = myStorage.getItem('set-remove-form') !== 'false';
            
            if (document.getElementById('set-remove-iv-words'))
                document.getElementById('set-remove-iv-words').checked = myStorage.getItem('set-remove-iv-words') !== 'false';
            
            if (document.getElementById('set-remove-salt'))
                document.getElementById('set-remove-salt').checked = myStorage.getItem('set-remove-salt') !== 'false';
            
            if (document.getElementById('set-remove-maker'))
                document.getElementById('set-remove-maker').checked = myStorage.getItem('set-remove-maker') !== 'false';
            
            if (document.getElementById('set-add-number'))
                document.getElementById('set-add-number').checked = myStorage.getItem('set-add-number') === 'true';

            var abbrDictSetting = myStorage.getItem('set-abbr-dict');
            if (abbrDictSetting !== null) {
                var chk = document.getElementById('chk-use-abbr-dict');
                if(chk) chk.checked = (abbrDictSetting === 'true');
            }
            
            var hlToggle = document.getElementById('set-tokuyaku-highlight');
            if(hlToggle) {
                hlToggle.checked = myStorage.getItem('set-tokuyaku-highlight') !== 'false';
            }

            var kanaFormat = myStorage.getItem('set-kana-format');
            if (kanaFormat) {
                var radio = document.querySelector('input[name="set-kana-format"][value="' + kanaFormat + '"]');
                if (radio) radio.checked = true;
            } else {
                var oldFullkana = myStorage.getItem('set-fullkana');
                if (oldFullkana === 'false') {
                    var rNone = document.querySelector('input[name="set-kana-format"][value="none"]');
                    if (rNone) rNone.checked = true;
                } else {
                    var rFull = document.querySelector('input[name="set-kana-format"][value="full"]');
                    if (rFull) rFull.checked = true;
                }
            }

            var timingSetting = myStorage.getItem('set-timing');
            if (timingSetting !== null) {
                var incTm = document.getElementById('includeTiming');
                if (incTm) incTm.value = timingSetting;
            } else {
                var incTm2 = document.getElementById('includeTiming');
                if (incTm2) incTm2.value = 'false'; // гғҮгғ•гӮ©гғ«гғҲгҖҢгҒӘгҒ—гҖҚ
            }

            // гғ•гӮ©гғігғҲгӮөгӮӨгӮәиЁӯе®ҡгҒ®иӘӯгҒҝиҫјгҒҝ
            var boardFontSize = myStorage.getItem('boardFontSize') || 'small';
            var selBoardFont = document.getElementById('sel-global-fontsize');
            if (selBoardFont) selBoardFont.value = boardFontSize;
            removeClass(document.body, "font-medium");
            removeClass(document.body, "font-large");
            if (boardFontSize === "medium") addClass(document.body, "font-medium");
            else if (boardFontSize === "large") addClass(document.body, "font-large");

            // еҲқжңҹйҒёжҠһз—…жЈҹгҒ®иЁӯе®ҡ
            // гғҰгғјгӮ¶гғјиЁӯе®ҡгҒҢгҒӮгӮҢгҒ°жңҖеҲқгҒ®з—…жЈҹгӮ’йҒёжҠһгҖҒгҒӘгҒ‘гӮҢгҒ°гғҮгғ•гӮ©гғ«гғҲгӮ’гғҶгӮ№гғҲз—…жЈҹ(99)гҒ«иЁӯе®ҡ
            var activeCodes = (appData.settings && appData.settings.activeWardCodes) || [];
            if (activeCodes.length > 0) {
                currentWard = activeCodes[0];
            } else {
                currentWard = "99";
            }
            renderWardTabs();
            applyWardTabs();
        }
/**
 * и–¬жӯҙгғ»и–¬еүӨж•ҙзҗҶз”ЁгҒ®гӮігӮўгғҶгӮӯгӮ№гғҲж•ҙеҪўй–ўж•°
 * е…Ёи§’иӢұж•°еӯ—гӮ’еҚҠи§’гҒ«еӨүжҸӣгҒ—гҖҒдёҚиҰҒгҒӘиЁҳеҸ·гӮ„з©әзҷҪгӮ’ж•ҙзҗҶгҒ—гҒҫгҒҷгҖӮ
 */
function yrFormatTextCore(text, keepIndentation) {
    if (!text) return "";
    var s = text;
    // е…Ёи§’иӢұж•°еӯ—гғ»иЁҳеҸ·гӮ’еҚҠи§’гҒ«еӨүжҸӣ
    s = s.replace(/[пјҒ-пҪһ]/g, function(m) {
        return String.fromCharCode(m.charCodeAt(0) - 0xFEE0);
    });
    // е…Ёи§’гӮ№гғҡгғјгӮ№гӮ’еҚҠи§’гҒ«зҪ®жҸӣ
    s = s.replace(/гҖҖ/g, " ");
    
    // гӮӨгғігғҮгғігғҲдҝқжҢҒиЁӯе®ҡгҒҢгҒӘгҒ„е ҙеҗҲгҒҜе…ЁдҪ“гӮ’гғҲгғӘгғ гҒ—гҒӨгҒӨйҖЈз¶ҡгӮ№гғҡгғјгӮ№гӮ’1гҒӨгҒ«гҒҷгӮӢ
    if (!keepIndentation) {
        s = s.replace(/ +/g, " ");
        s = s.trim();
    } else {
        // гӮӨгғігғҮгғігғҲдҝқжҢҒгҒ®е ҙеҗҲ: еҗ„иЎҢгҒ®жң«е°ҫгҒ®гҒҝгғҲгғӘгғ 
        var lines = s.split(/\r\n|\r|\n/);
        for(var i=0; i<lines.length; i++) {
            lines[i] = lines[i].replace(/\s+$/, "");
        }
        s = lines.join("\n").replace(/^\s+/, ""); // е…Ҳй ӯгҒ®з©әж”№иЎҢгҒӘгҒ©гҒҜж¶ҲгҒҷгҒҢгӮӨгғігғҮгғігғҲгҒҜе®ҲгӮӢ
    }
    
    // ж”№иЎҢгӮігғјгғүгҒ®зөұдёҖпјҲCRLFпјү
    return s.replace(/\n/g, "\r\n");
}

// ---------- и–¬еүӨиӘҝж•ҙеҠ з®—гғ„гғјгғ« гғӯгӮёгғғгӮҜ ----------
var medAdjState = { input: [], output: [] };
var manualMedAdjLinks = {};

/**
 * и–¬еүӨгғҶгӮӯгӮ№гғҲгҒ®и§ЈжһҗпјҲгӮӨгғігғҮгғігғҲж·ұеәҰгғ»гӮӯгғјгғҜгғјгғүгҒ«гӮҲгӮӢйҷӨеӨ–еҲӨе®ҡпјү
 */
function parseMedText(text) {
    if(!text) return [];
    var config = (appData.settings && appData.settings.medAdjConfig) || { useIndentation: true, autoExcludeHospital: true };
    var customKeywords = (appData.settings && appData.settings.medAdjExclusionKeywords) || [];
    var baseExcludeKeywords = ["еӨ–з”Ё", "гғҶгғјгғ—", "гғ‘гғғгғ—", "зӮ№зңј", "зӮ№иҖі", "зӮ№йј»", "еқҗеүӨ", "еқҗи–¬", "и»ҹиҶҸ", "гӮҜгғӘгғјгғ ", "гғӯгғјгӮ·гғ§гғі", "еҗёе…Ҙ", "пҪҙпҪұпҫӣпҪҝпҫһпҫҷ", "й “жңҚ", "й “з”Ё", "еӣһеҲҶ", "жҢҒеҸӮи–¬з”Ёжі•", "гғ—гғӯгғҡгғҲ", "гғҸгғғгӮ«жІ№", "гғ¬гӮ№гӮҝгғҹгғі", "ијёж¶І", "зӮ№ж»ҙ", "йқҷжіЁ", "зҡ®дёӢжіЁ", "жіЁе°„", "гғҜгӮ»гғӘгғі", "гғ’гғ«гғүгӮӨгғү", "гғҳгғ‘гғӘгғі", "з”ҹйЈҹ", "пј®пјі", "NS", "жіЁ", "пјЎ", "з“¶", "з®Ў", "иҝҪеҠ ", "жҷӮ", "дёҚзң ", "зң гӮҢгҒӘгҒ„"];
    var allExcludeKeywords = baseExcludeKeywords.concat(customKeywords);

    // гӮӨгғігғҮгғігғҲгӮ’дҝқжҢҒгҒ—гҒҰж•ҙеҪў
    var cleanedText = yrFormatTextCore(text, true);
    var lines = cleanedText.split('\n');
    var drugs = [];
    
    var lastBaseLevel = -1;
    var lastUsageLevel = -1;

    function getIndentLevel(s) {
        var m = s.match(/^([ ]*)/);
        return m ? m[1].length : 0;
    }

    // вҳ…дҝ®жӯЈ: еҚҳдҪҚгҒ®еүҚгҒ®гӮ№гғҡгғјгӮ№гӮ’д»»ж„ҸгҒ«гҒ—гҖҒиЎҢе…ЁдҪ“гҒӢгӮүжңҖеҫҢгҒ®ж•°йҮҸгғ»еҚҳдҪҚгғҡгӮўгӮ’жҠҪеҮәгҒҷгӮӢ
    var units = "йҢ |пҪ¶пҫҢпҫҹпҪҫпҫҷ|гӮ«гғ—гӮ»гғ«|еҢ…|ml|mL|mg|g|ж»ҙ|T|C|пјҙ|пјЈ|жң¬|жһҡ|иўӢ|з“¶|зӯ’|гғҰгғӢгғғгғҲ|еҚҳдҪҚ|V|пј¶|з®Ў|еҖӢ|пҫҒпҪӯпҪ°пҫҢпҫһ|гғҒгғҘгғјгғ–";
    var drugRegex = new RegExp("^(.*?)[\\sгҖҖ]*(\\d+(?:\\.\\d+)?)[\\sгҖҖ]*(" + units + ")(.*)$", "i");

    for(var i=0; i<lines.length; i++) {
        var rawLine = lines[i];
        var level = getIndentLevel(rawLine);
        var line = rawLine.trim();
        if(!line) continue;

        if (config.autoExcludeHospital) {
            if (/^[в—Ҷв—Үв–јв– ]/.test(line)) continue;
            if (/^\d+-\d+.*(з—…йҷў|гӮҜгғӘгғӢгғғгӮҜ|еҢ»йҷў|гӮ»гғігӮҝгғј)/.test(line)) continue;
        }

        if (/^Rp\.?\d*/i.test(line)) {
            lastBaseLevel = level;
            lastUsageLevel = -1;
            continue;
        }

        var drugMatch = line.match(drugRegex);
        if (drugMatch) {
            var rawDrugName = drugMatch[1].trim();
            
            // вҳ…дҝ®жӯЈ: гғһгӮҜгғӯж©ҹиғҪгҒ§д»ҳдёҺгҒ•гӮҢгӮӢ "1) " гӮ„ "12) " гҒӘгҒ©гҒ®йҖЈз•ӘгӮ’еүҠйҷӨ
            rawDrugName = rawDrugName.replace(/^\d+\)[\sгҖҖ]*/, '');
            
            var qty = drugMatch[2];
            var unit = drugMatch[3];

            var drugName = rawDrugName;
            drugName = drugName.replace(/\(жҢҒеҸӮи–¬\)|пјҲжҢҒеҸӮи–¬пјү/g, '');
            drugName = drugName.replace(/гҖҢ.*?гҖҚ/g, '');
            drugName = drugName.replace(/гҖҗ.*?гҖ‘/g, '');
            drugName = drugName.replace(/вҳ…|пјҡ|гҖҗиҲ¬гҖ‘/g, '');
            drugName = drugName.trim();

            var isExcluded = false;
            var rLine = line.replace(/ /g, "").replace(/гҖҖ/g, "");
            for(var k=0; k<allExcludeKeywords.length; k++) {
                if(rLine.indexOf(allExcludeKeywords[k]) !== -1) {
                    isExcluded = true;
                    break;
                }
            }

            drugs.push({
                name: drugName,
                qty: qty,
                unit: unit,
                raw: line,
                isExcluded: isExcluded,
                checked: true,
                status: "",
                level: level
            });
            lastBaseLevel = level;
            lastUsageLevel = -1;
            continue;
        }

        var usageRegex = /(еҲҶ\d|еӣһ|йЈҹеҫҢ|йЈҹеүҚ|е°ұеҜқеүҚ|зң еүҚ|ж—Ҙ\d|жҷӮ|жңҚз”Ё|еЎ—еёғ|иІјд»ҳ)/;
        if (usageRegex.test(line)) {
            lastUsageLevel = level;
            continue;
        }

        if (config.useIndentation) {
            // вҳ…дҝ®жӯЈ: гғһгӮҜгғӯеҮҰзҗҶгҒ«гӮҲгӮҠRpгӮ„гӮӨгғігғҮгғігғҲгҒҢж¶Ҳж»…гҒ—гҒҰгҒ„гӮӢе ҙеҗҲгҖҒиӘӨеҲӨе®ҡгҒ§ж¶ҲгҒҲгӮӢгҒ®гӮ’йҳІгҒҗ
            if (lastBaseLevel !== -1) {
                var base = (lastUsageLevel !== -1) ? lastUsageLevel : lastBaseLevel;
                if (level > base) {
                    continue;
                }
            }
        }
    }
    return drugs;
}

function getDrugNameBase(raw) {
    var cleanRaw = raw.replace(/^\d+\)[\sгҖҖ]*/, ''); // "1) " гӮ’ж¶ҲгҒҷ
    var match = cleanRaw.match(/^([^\dпјҗ-пјҷ(пјҲ]+)/);
    return match ? match[1].trim() : cleanRaw;
}

function getStdForm(raw) {
    var s = raw.replace(/^\d+\)[\sгҖҖ]*/, ''); // "1) " гӮ’ж¶ҲгҒҷ
    s = s.replace(/[\s\tгҖҖ]*[0-9пјҗ-пјҷ]+ж—Ҙ(еҲҶ|з”Ё)?/g, "").trim();
    s = s.replace(/гғҹгғӨBM(?:еҮҰж–№|зҙ°зІ’|йҢ )?(?:20[mM][gG])?/gi, "гғҹгғӨBM");
    return s;
}

function searchPatientForMedAdj() {
    var query = document.getElementById('ipt-med-adj-patient-search').value.trim();
    var resultArea = document.getElementById('med-adj-patient-result');
    if (!query) {
        resultArea.innerHTML = "";
        return;
    }

    var bestMatch = null;
    var patients = DataManager.appData.patients || {};
    
    // е…Ёз—…жЈҹгӮ’жЁӘж–ӯжӨңзҙў
    for (var wardId in patients) {
        var list = patients[wardId];
        if (!list) continue;
        for (var i = 0; i < list.length; i++) {
            var p = list[i];
            // жҜ”ијғз”ЁгҒ«IDгҒЁж°ҸеҗҚгӮ’жӯЈиҰҸеҢ–
            var normPid = (p.id || "").replace(/^0+/, "");
            var normQuery = query.replace(/^0+/, "");
            var normPname = (p.name || "").replace(/[\sгҖҖ]/g, "");
            var normQname = query.replace(/[\sгҖҖ]/g, "");
            if (normPid === normQuery || (normPname.indexOf(normQname) !== -1)) {
                bestMatch = p;
                if (normPid === normQuery) break; // IDе®Ңе…ЁдёҖиҮҙгҒӘгӮүеҚізөӮдәҶ
            }
        }
        if (bestMatch && bestMatch.id === query) break;
    }

    if (bestMatch) {
        var days = parseInt(bestMatch.daysInHosp, 10);
        if (isNaN(days)) {
            resultArea.innerHTML = "<b>" + escapeHtml(bestMatch.name) + "</b> (еңЁйҷўж—Ҙж•°дёҚжҳҺ)";
            return;
        }

        var today = new Date();
        today.setHours(0,0,0,0);
        // е…Ҙйҷўж—Ҙ = д»Ҡж—Ҙ - (еңЁйҷўж—Ҙж•° - 1)
        var admitDate = new Date(today.getTime());
        admitDate.setDate(today.getDate() - (days - 1));
        
        // еҹәжә–ж—Ҙ = е…Ҙйҷўж—Ҙ - 28ж—Ҙ
        var baseDate = new Date(admitDate.getTime());
        baseDate.setDate(admitDate.getDate() - 28);
        
        function fmt(d) {
            return (d.getMonth() + 1) + "/" + d.getDate();
        }

        resultArea.innerHTML = "<span style='color:#2980b9; font-weight:bold;'>" + escapeHtml(bestMatch.name) + "</span> гҒ•гӮ“ " +
                               "е…Ҙ:" + fmt(admitDate) + " <span style='color:#666;'>(еңЁйҷў" + days + "ж—Ҙ)</span> вҶ’ " +
                               "<b>28ж—ҘеүҚ: <span style='color:#e74c3c;'>" + fmt(baseDate) + "</span></b> " +
                               "<span style='font-size:11px; color:#666;'>(" + fmt(baseDate) + "гӮҲгӮҠд»ҘеүҚгҒӢгӮүдҪҝз”ЁгҒ—гҒҰгҒ„гӮӢи–¬гҒҢеҜҫиұЎгҒ§гҒҷ)</span>";
    } else {
        resultArea.innerHTML = "<span style='color:#999;'>иҰӢгҒӨгҒӢгӮҠгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹ</span>";
    }
}

function calcMedAdj(skipFormat) {
    var inBox = document.getElementById('med-adj-in');
    var outBox = document.getElementById('med-adj-out');
    
    // вҳ…дҝ®жӯЈ: ж•ҙзҗҶгҒӮгӮҠпјҲв–¶ жҜ”ијғгғ»еҲӨе®ҡ в–¶пјүгҒ®е ҙеҗҲгҒҜгҖҒгғҶгӮӯгӮ№гғҲж•ҙзҗҶгӮҝгғ–гҒЁе®Ңе…ЁгҒ«еҗҢгҒҳгҖҢprocessMacroTextгҖҚгӮ’йҖҡгҒҷ
    if (!skipFormat) {
        inBox.value = processMacroText(inBox.value);
        outBox.value = processMacroText(outBox.value);
    }

    var txtIn = inBox.value;
    var txtOut = outBox.value;
    
    var inDrugs = parseMedText(txtIn);
    var outDrugs = parseMedText(txtOut);
    
    if (medAdjState.input && medAdjState.input.length === inDrugs.length) {
        for(var i=0; i<inDrugs.length; i++) {
            if(inDrugs[i].raw === medAdjState.input[i].raw) {
                inDrugs[i].checked = medAdjState.input[i].checked;
            }
        }
    }
    
    var matchedOut = {};
    var matchedIn = {};
    
    // 1. ж—Ҙж•°йҒ•гҒ„гӮ’иЁұе®№гҒ—гҒҹгҖҢз¶ҷз¶ҡгҖҚгҒ®еҲӨе®ҡ
    for(var i=0; i<inDrugs.length; i++) {
        if(inDrugs[i].isExcluded) continue;
        var stdIn = getStdForm(inDrugs[i].raw);
        for(var j=0; j<outDrugs.length; j++) {
            if(outDrugs[j].isExcluded || matchedOut[j]) continue;
            var stdOut = getStdForm(outDrugs[j].raw);
            if(stdIn === stdOut) {
                inDrugs[i].status = "з¶ҷз¶ҡ";
                outDrugs[j].status = "з¶ҷз¶ҡ";
                outDrugs[j].inRef = i;
                inDrugs[i].outRef = j;
                matchedIn[i] = true;
                matchedOut[j] = true;
                break;
            }
        }
    }
    
    // 2. з”ЁйҮҸеӨүжӣҙгҒ®еҲӨе®ҡ
    for(var i=0; i<inDrugs.length; i++) {
        if(inDrugs[i].isExcluded || matchedIn[i]) continue;
        var inBase = getDrugNameBase(inDrugs[i].raw);
        for(var j=0; j<outDrugs.length; j++) {
            if(outDrugs[j].isExcluded || matchedOut[j]) continue;
            var outBase = getDrugNameBase(outDrugs[j].raw);
            if(inBase.length > 2 && inBase === outBase) {
                inDrugs[i].status = "еӨүжӣҙеүҚ";
                outDrugs[j].status = "з”ЁйҮҸеӨүжӣҙ";
                outDrugs[j].inRef = i;
                inDrugs[i].outRef = j;
                matchedIn[i] = true;
                matchedOut[j] = true;
                break;
            }
        }
    }
    
    // 3. дёӯжӯўгғ»иҝҪеҠ гҒ®еҲӨе®ҡ
    for(var i=0; i<inDrugs.length; i++) {
        if(!inDrugs[i].isExcluded && !matchedIn[i]) inDrugs[i].status = "дёӯжӯў";
    }
    for(var j=0; j<outDrugs.length; j++) {
        if(!outDrugs[j].isExcluded && !matchedOut[j]) { outDrugs[j].status = "иҝҪеҠ "; outDrugs[j].inRef = -1; }
    }

    // 4. жүӢеӢ•зҙҗд»ҳгҒ‘жғ…е ұгҒ®еҸҚжҳ  (еҶҚе®ҡзҫ©гҒ—гҒҹй–ўж•°з”Ё)
    for (var j = 0; j < outDrugs.length; j++) {
        if (outDrugs[j].status === "иҝҪеҠ " && manualMedAdjLinks[outDrugs[j].raw]) {
            var targetInRaw = manualMedAdjLinks[outDrugs[j].raw];
            for (var i = 0; i < inDrugs.length; i++) {
                if (inDrugs[i].status === "дёӯжӯў" && inDrugs[i].raw === targetInRaw) {
                    inDrugs[i].status = "жүӢеӢ•зҙҗд»ҳ(з¶ҷз¶ҡ)";
                    outDrugs[j].status = "жүӢеӢ•зҙҗд»ҳ(з¶ҷз¶ҡ)";
                    inDrugs[i].outRef = j;
                    outDrugs[j].inRef = i;
                    matchedIn[i] = true;
                    matchedOut[j] = true;
                    break;
                }
            }
        }
    }
    
    medAdjState.input = inDrugs;
    medAdjState.output = outDrugs;
    renderMedAdjResult();
}

function renderMedAdjResult() {
    var addedList = [];
    var discontList = [];
    var inD = medAdjState.input;
    var outD = medAdjState.output;
    var tbody = document.getElementById("med-adj-tbody");
    var html = "";
    var baseCount = 0;
    var outCount = 0;
    
    for(var i=0; i<inD.length; i++) {
        if(inD[i].isExcluded) continue;
        if(inD[i].checked) baseCount++;
        var statColor = "#666";
        var outHtml = "";
        
        if(inD[i].status === "з¶ҷз¶ҡ" || inD[i].status === "жүӢеӢ•зҙҗд»ҳ(з¶ҷз¶ҡ)") {
            statColor = "#0d6efd";
            outHtml = escapeHtml(outD[inD[i].outRef].raw);
            if (inD[i].status === "жүӢеӢ•зҙҗд»ҳ(з¶ҷз¶ҡ)") {
                var btn1 = ' <button class="yr-btn-danger-sm" style="margin-left:10px;" ';
                var btn2 = 'onclick="unlinkMedAdjDrug(\'' + escapeHtml(outD[inD[i].outRef].raw).replace(/'/g, "\\'") + '\')">и§ЈйҷӨ</button>';
                outHtml += btn1 + btn2;
            }
        } else if(inD[i].status === "еӨүжӣҙеүҚ" || inD[i].status === "йҷўеҶ…жҺЎз”ЁзӯүгҒёеӨүжӣҙ") {
            statColor = (inD[i].status === "йҷўеҶ…жҺЎз”ЁзӯүгҒёеӨүжӣҙ") ? "#20c997" : "#fd7e14";
            outHtml = escapeHtml(outD[inD[i].outRef].raw);
            if (inD[i].status === "йҷўеҶ…жҺЎз”ЁзӯүгҒёеӨүжӣҙ") {
                var btn1 = ' <button class="yr-btn-danger-sm" style="margin-left:10px;" ';
                var btn2 = 'onclick="unlinkMedAdjDrug(\'' + escapeHtml(outD[inD[i].outRef].raw).replace(/'/g, "\\'") + '\')">и§ЈйҷӨ</button>';
                outHtml += btn1 + btn2;
            }
        } else if(inD[i].status === "дёӯжӯў") {
            statColor = "#dc3545";
            outHtml = '<span style="color:#aaa;">(гҒӘгҒ—)</span>';
        }
        
        var dragAttrs = "";
        if (inD[i].status === "дёӯжӯў") {
            dragAttrs += ' ondragover="event.preventDefault(); this.style.backgroundColor=\'#e8f4f8\';" ';
            dragAttrs += 'ondragleave="this.style.backgroundColor=\'\'" ';
            dragAttrs += 'ondrop="event.preventDefault(); this.style.backgroundColor=\'\'; var d=event.dataTransfer.getData(\'text\'); if(d&&d.indexOf(\'medadj_out_\')===0){ linkMedAdjDrugs(' + i + ', d); }"';
        }
        
        html += '<tr class="yr-row-regular" ' + dragAttrs + '>';
        html += '<td style="text-align:center;"><input type="checkbox" onchange="toggleMedAdjInCheck('+i+')" '+(inD[i].checked?'checked':'')+' title="4йҖұй–“д»ҘдёҠз¶ҷз¶ҡгҒ—гҒҰгҒ„гӮӢе ҙеҗҲгҒҜгғҒгӮ§гғғгӮҜ"></td>';
        html += '<td>' + escapeHtml(inD[i].raw) + '</td>';
        
        var isToggleable = (inD[i].outRef !== undefined && inD[i].outRef !== -1);
        var toggleStyle = isToggleable ? ' cursor:pointer; text-decoration:underline;' : '';
        var toggleAttr = isToggleable ? ' onclick="toggleMedAdjStatus(' + i + ')" title="гӮҜгғӘгғғгӮҜгҒ§жүӢеӢ•еҲҮжӣҝ"' : '';
        
        html += '<td style="text-align:center; font-weight:bold; color:'+statColor+';' + toggleStyle + '"' + toggleAttr + '>' + inD[i].status.replace("еӨүжӣҙеүҚ","з”ЁйҮҸеӨүжӣҙ") + '</td>';
        html += '<td>' + outHtml + '</td>';
        html += '</tr>';
    }
    
    for(var j=0; j<outD.length; j++) {
        if(outD[j].isExcluded) continue;
        outCount++;
        if(outD[j].status === "иҝҪеҠ ") {
            var tr1 = '<tr class="yr-row-brought-in" draggable="true" ';
            var tr2 = 'ondragstart="event.dataTransfer.setData(\'text\', \'medadj_out_\' + ' + j + ')" ';
            var tr3 = 'style="cursor:grab;" title="гғүгғ©гғғгӮ°гҒ—гҒҰзҙҗд»ҳгҒ‘">';
            html += tr1 + tr2 + tr3;
            html += '<td style="text-align:center;">-</td>';
            html += '<td style="color:#aaa;">(гҒӘгҒ—)</td>';
            html += '<td style="text-align:center; font-weight:bold; color:#198754;">иҝҪеҠ </td>';
            html += '<td>' + escapeHtml(outD[j].raw) + '</td>';
            html += '</tr>';
        }
    }
    
    var exHtml = "";
    for(var i=0; i<inD.length; i++) {
        if(inD[i].isExcluded) {
            exHtml += '<tr style="color:#aaa;"><td style="text-align:center;">-</td><td>' + escapeHtml(inD[i].raw) + ' (йҷӨеӨ–)</td><td>-</td><td>-</td></tr>';
        }
    }
    for(var j=0; j<outD.length; j++) {
        if(outD[j].isExcluded && outD[j].status !== "з¶ҷз¶ҡ" && outD[j].status !== "з”ЁйҮҸеӨүжӣҙ") {
            exHtml += '<tr style="color:#aaa;"><td style="text-align:center;">-</td><td>-</td><td>-</td><td>' + escapeHtml(outD[j].raw) + ' (йҷӨеӨ–)</td></tr>';
        }
    }
    if (exHtml !== "") {
        html += '<tr><td colspan="4" style="background:#f0f0f0;font-weight:bold;text-align:center;">--- з®—е®ҡеҜҫиұЎеӨ– (еӨ–з”Ёгғ»й “жңҚгғ»йқһи–¬еүӨиЎҢзӯү) ---</td></tr>' + exHtml;
    }
    
    tbody.innerHTML = html;
    for(var j=0; j<outD.length; j++) {
        if(outD[j].status === "иҝҪеҠ " && !outD[j].isExcluded) addedList.push(escapeHtml(outD[j].raw));
    }
    for(var i=0; i<inD.length; i++) {
        if(inD[i].status === "дёӯжӯў" && !inD[i].isExcluded) discontList.push(escapeHtml(inD[i].raw));
    }
    
    var listsHtml = "";
    if(addedList.length > 0 || discontList.length > 0) {
        listsHtml += "<div style='display:flex; gap:15px; margin-top:15px; margin-bottom:15px;'>";
        listsHtml += "<div style='flex:1; background:#fff; border:1px solid #f5c2c7; border-radius:4px; padding:8px;'>";
        listsHtml += "<div style='font-size:13px; font-weight:bold; color:#dc3545; border-bottom:1px dashed #f5c2c7; padding-bottom:4px; margin-bottom:6px;'>дёӯжӯўгҒ•гӮҢгҒҹи–¬ (" + discontList.length + ")</div>";
        listsHtml += "<ul style='margin:0; padding-left:20px; font-size:12px; line-height:1.4;'>";
        if (discontList.length === 0) listsHtml += "<li style='color:#999; list-style:none; margin-left:-20px;'>гҒӘгҒ—</li>";
        else for(var d=0; d<discontList.length; d++) listsHtml += "<li>" + discontList[d] + "</li>";
        listsHtml += "</ul></div>";
        listsHtml += "<div style='flex:1; background:#fff; border:1px solid #badbcc; border-radius:4px; padding:8px;'>";
        listsHtml += "<div style='font-size:13px; font-weight:bold; color:#198754; border-bottom:1px dashed #badbcc; padding-bottom:4px; margin-bottom:6px;'>иҝҪеҠ гҒ•гӮҢгҒҹи–¬ (" + addedList.length + ")</div>";
        listsHtml += "<ul style='margin:0; padding-left:20px; font-size:12px; line-height:1.4;'>";
        if (addedList.length === 0) listsHtml += "<li style='color:#999; list-style:none; margin-left:-20px;'>гҒӘгҒ—</li>";
        else for(var a=0; a<addedList.length; a++) listsHtml += "<li>" + addedList[a] + "</li>";
        listsHtml += "</ul></div></div>";
    }
    
    var diff = baseCount - outCount;
    var summaryEl = document.getElementById("med-adj-summary");
    if (!summaryEl) return;
    var resMsg = "гғҷгғјгӮ№гғ©гӮӨгғі <span style='font-size:24px;'>" + baseCount + "</span> зЁ®йЎһ вҶ’ йҖҖйҷўжҷӮ <span style='font-size:24px;'>" + outCount + "</span> зЁ®йЎһ пјҲ" + (diff>=0?"-":"+") + Math.abs(diff) + "зЁ®йЎһпјү";
    var hasBaselineChange = false;
    var hasAddition = (addedList.length > 0);
    for(var i=0; i<inD.length; i++) {
        if(!inD[i].isExcluded && (inD[i].status === "еӨүжӣҙеүҚ" || inD[i].status === "дёӯжӯў" || inD[i].status === "йҷўеҶ…жҺЎз”ЁзӯүгҒёеӨүжӣҙ")) {
            hasBaselineChange = true;
        }
    }
    var req3Check = document.getElementById("chk-med-adj-req3");
    var isAddValid = req3Check && req3Check.checked;
    var hasAnyChange = hasBaselineChange || (hasAddition && isAddValid);
    
    var req3Container = document.getElementById("req3-container");
    if (req3Container) {
        if (hasAddition && !hasBaselineChange && baseCount >= 6) {
            req3Container.style.display = "block";
        } else {
            req3Container.style.display = "none";
            if (req3Check) req3Check.checked = false;
        }
    }
    
    var isOneYearRule = document.getElementById("chk-med-adj-1year") && document.getElementById("chk-med-adj-1year").checked;
    var prevCountEl = document.getElementById("ipt-med-adj-prev-count");
    var prevCount = prevCountEl ? (parseInt(prevCountEl.value, 10) || 0) : 0;
    
    var meet150Points = false;
    if (isOneYearRule) {
        if (prevCount > 0 && (prevCount - outCount) >= 2) meet150Points = true;
    } else {
        if (diff >= 2) meet150Points = true;
    }
    
    if (baseCount >= 6) {
        if (!hasAnyChange) {
            var reasonTxt = (hasAddition && !isAddValid) ? "иҝҪеҠ и–¬гҒҢеҪ“и©ІеҮҰж–№гҒ®иҰӢзӣҙгҒ—гҒ«й–ўйҖЈгҒҷгӮӢгӮӮгҒ®гҒ§гҒҜгҒӘгҒ„гҒҹгӮҒиҰҒд»¶жңӘйҒ”гҒ§гҒҷгҖӮ" : "гғҷгғјгӮ№гғ©гӮӨгғігҒ«пјҲеҪ“и©ІеҮҰж–№пјүеӨүжӣҙгҒҢгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ";
            summaryEl.innerHTML = "<span style='color:#dc3545'>вқҢ з®—е®ҡдёҚеҸҜ</span><div style='font-size:12px;font-weight:bold;margin-top:4px;'>вҖ»" + reasonTxt + "</div><div style='margin-top:8px; margin-bottom:8px;'>" + resMsg + "</div>" + listsHtml;
            summaryEl.style.backgroundColor = "#f8d7da";
            summaryEl.style.color = "#842029";
            summaryEl.style.border = "2px solid #f5c2c7";
        } else if (meet150Points) {
            var methodMsg = isOneYearRule ? "вҖ»еүҚеӣһз®—е®ҡжҷӮ(" + prevCount + "зЁ®йЎһ)гҒӢгӮү2зЁ®йЎһд»ҘдёҠжёӣе°‘" : "вҖ»2зЁ®йЎһд»ҘдёҠгҒ®жёӣе°‘гӮ’йҒ”жҲҗ";
            summaryEl.innerHTML = "<span style='color:#198754'>вң… 250зӮ№ з®—е®ҡеҸҜиғҪ (и©•дҫЎ100зӮ№ + еҠ з®—150зӮ№)</span><div style='font-size:12px;font-weight:normal;margin-top:4px;'>" + methodMsg + "</div><div style='margin-top:8px; margin-bottom:8px;'>" + resMsg + "</div>" + listsHtml;
            summaryEl.style.backgroundColor = "#d1e7dd";
            summaryEl.style.color = "#0f5132";
            summaryEl.style.border = "2px solid #badbcc";
        } else {
            summaryEl.innerHTML = "<span style='color:#0d6efd'>вң… 100зӮ№ гҒ®гҒҝз®—е®ҡеҸҜиғҪ (з·ҸеҗҲи©•дҫЎеҠ з®—)</span><div style='font-size:12px;font-weight:normal;margin-top:4px;'>вҖ»еҮҰж–№еҶ…е®№гҒ®еӨүжӣҙ(дёӯжӯў/з”ЁйҮҸеӨүжӣҙ/й–ўйҖЈгҒҷгӮӢиҝҪеҠ )гҒҜгҒӮгӮҠгҒҫгҒҷгҒҢгҖҒ2зЁ®йЎһд»ҘдёҠгҒ®жёӣе°‘иҰҒд»¶гӮ’жәҖгҒҹгҒ—гҒҫгҒӣгӮ“</div><div style='margin-top:8px; margin-bottom:8px;'>" + resMsg + "</div>" + listsHtml;
            summaryEl.style.backgroundColor = "#cff4fc";
            summaryEl.style.color = "#055160";
            summaryEl.style.border = "2px solid #b6effb";
        }
    } else {
        summaryEl.innerHTML = "<span style='color:#dc3545'>вқҢ з®—е®ҡдёҚеҸҜ</span><br><span style='font-size:14px;font-weight:normal;'>" + resMsg + " пјҲгғҷгғјгӮ№гғ©гӮӨгғігҒҢ6зЁ®йЎһжңӘжәҖгҒ§гҒҷпјү</span>" + listsHtml;
        summaryEl.style.backgroundColor = "#f8d7da";
        summaryEl.style.color = "#842029";
        summaryEl.style.border = "2px solid #f5c2c7";
    }
    
    var panel = document.getElementById("med-adj-result-panel");
    if (panel) panel.style.display = "block";
}

function toggleMedAdjInCheck(idx) {
    medAdjState.input[idx].checked = !medAdjState.input[idx].checked;
    calcMedAdj(true);
}

function copyMedAdjResult() {
    var inD = medAdjState.input;
    var outD = medAdjState.output;
    var baseCount = 0; var outCount = 0;
    var txt = "гҖҗйҖҖйҷўжҷӮи–¬еүӨиӘҝж•ҙеҠ з®— еҲӨе®ҡгҖ‘\n";
    
    var changes = [];
    for(var i=0; i<inD.length; i++) {
        if(!inD[i].isExcluded && inD[i].checked) baseCount++;
        if(!inD[i].isExcluded && inD[i].status === "дёӯжӯў") changes.push("[дёӯжӯў] " + inD[i].raw);
        if(!inD[i].isExcluded && inD[i].status === "еӨүжӣҙеүҚ") changes.push("[з”ЁйҮҸеӨүжӣҙ/еҲҮжӣҝ] " + inD[i].raw + " -> " + outD[inD[i].outRef].raw);
    }
    for(var j=0; j<outD.length; j++) {
        if(!outD[j].isExcluded) outCount++;
        if(!outD[j].isExcluded && outD[j].status === "иҝҪеҠ ") changes.push("[иҝҪеҠ ] " + outD[j].raw);
    }
    
    var diff = baseCount - outCount;
    txt += "гғҷгғјгӮ№гғ©гӮӨгғі: " + baseCount + "зЁ®йЎһ вҶ’ йҖҖйҷўжҷӮ: " + outCount + "зЁ®йЎһ (" + (diff>=0?"-":"+") + Math.abs(diff) + "зЁ®йЎһ)\n";
    
    var hasAnyChange = changes.length > 0;
    
    if (baseCount >= 6) {
        if (diff >= 2) {
            txt += "еҲӨе®ҡ: гҖҗ250зӮ№гҖ‘з®—е®ҡиҰҒд»¶гӮ’жәҖгҒҹгҒҷ (и©•дҫЎ100зӮ№ + еҠ з®—150зӮ№)\n";
        } else if (hasAnyChange) {
            txt += "еҲӨе®ҡ: гҖҗ100зӮ№гҖ‘з®—е®ҡиҰҒд»¶гӮ’жәҖгҒҹгҒҷ (и©•дҫЎ100зӮ№гҒ®гҒҝ)\n";
        } else {
            txt += "еҲӨе®ҡ: з®—е®ҡжқЎд»¶жңӘйҒ” (еӨүжӣҙгҒӘгҒ—)\n";
        }
    } else {
        txt += "еҲӨе®ҡ: з®—е®ҡжқЎд»¶жңӘйҒ” (гғҷгғјгӮ№6зЁ®йЎһжңӘжәҖ)\n";
    }
    
    txt += "------------------------\n";
    if (changes.length > 0) {
        txt += changes.join("\n");
    } else {
        txt += "еӨүжӣҙгғ»иҝҪеҠ гғ»дёӯжӯўгҒ•гӮҢгҒҹеҶ…жңҚи–¬гҒӘгҒ—";
    }
    
    try {
        window.clipboardData.setData('Text', txt);
        yrShowAlert('еҲӨе®ҡзөҗжһңгӮ’гӮҜгғӘгғғгғ—гғңгғјгғүгҒ«гӮігғ”гғјгҒ—гҒҫгҒ—гҒҹгҖӮ', 'success');
    } catch(e) {
        yrShowAlert('гӮігғ”гғјгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹгҖӮ', 'error');
    }
}

function linkMedAdjDrugs(inIdx, data) {
    if (!data || data.indexOf('medadj_out_') !== 0 || data.indexOf('medadj_out_2026_') === 0) return;
    var outIdx = parseInt(data.replace('medadj_out_', ''), 10);
    if (isNaN(outIdx)) return;
    var inRaw = medAdjState.input[inIdx].raw;
    var outRaw = medAdjState.output[outIdx].raw;
    manualMedAdjLinks[outRaw] = inRaw;
    calcMedAdj(true);
}

function unlinkMedAdjDrug(outRaw) {
    if (manualMedAdjLinks[outRaw]) {
        delete manualMedAdjLinks[outRaw];
        calcMedAdj(true);
    }
}

function toggleMedAdjStatus(inIdx) {
    if (!medAdjState.input[inIdx]) return;
    var p = medAdjState.input[inIdx];
    if (p.outRef === undefined || p.outRef === -1) return; // зҙҗд»ҳгҒ„гҒҰгҒ„гҒӘгҒ„иЎҢпјҲдёӯжӯўгҒӘгҒ©пјүгҒҜз„ЎиҰ–

    var out = medAdjState.output[p.outRef];
    if (p.status === "еӨүжӣҙеүҚ" || p.status === "йҷўеҶ…жҺЎз”ЁзӯүгҒёеӨүжӣҙ") {
        p.status = "з¶ҷз¶ҡ";
        out.status = "з¶ҷз¶ҡ";
    } else if (p.status === "з¶ҷз¶ҡ" || p.status === "жүӢеӢ•зҙҗд»ҳ(з¶ҷз¶ҡ)") {
        p.status = "еӨүжӣҙеүҚ";
        out.status = "з”ЁйҮҸеӨүжӣҙ";
    }
    renderMedAdjResult();
}
// ---------- и–¬еүӨиӘҝж•ҙеҠ з®—(2026е№ҙж”№е®ҡзүҲ) еҲӨе®ҡгғӯгӮёгғғгӮҜ ----------
var medAdjState2026 = { input: [], output: [] };
var manualMedAdjLinks2026 = {};

function searchPatientForMedAdj2026() {
    var query = document.getElementById('ipt-med-adj-patient-search-2026').value.trim();
    var resultArea = document.getElementById('med-adj-patient-result-2026');
    if (!query) {
        resultArea.innerHTML = "";
        return;
    }

    var bestMatch = null;
    var patients = DataManager.appData.patients || {};
    // е…Ёз—…жЈҹгӮ’жЁӘж–ӯжӨңзҙў
    for (var wardId in patients) {
        var list = patients[wardId];
        if (!list) continue;
        for (var i = 0; i < list.length; i++) {
            var p = list[i];
            // жҜ”ијғз”ЁгҒ«IDгҒЁж°ҸеҗҚгӮ’жӯЈиҰҸеҢ–
            var normPid = (p.id || "").replace(/^0+/, "");
            var normQuery = query.replace(/^0+/, "");
            var normPname = (p.name || "").replace(/[\sгҖҖ]/g, "");
            var normQname = query.replace(/[\sгҖҖ]/g, "");
            if (normPid === normQuery || (normPname.indexOf(normQname) !== -1)) {
                bestMatch = p;
                if (normPid === normQuery) break; // IDе®Ңе…ЁдёҖиҮҙгҒӘгӮүеҚізөӮдәҶ
            }
        }
        if (bestMatch && bestMatch.id === query) break;
    }

    if (bestMatch) {
        var days = parseInt(bestMatch.daysInHosp, 10);
        if (isNaN(days)) {
            resultArea.innerHTML = "<b>" + escapeHtml(bestMatch.name) + "</b> (еңЁйҷўж—Ҙж•°дёҚжҳҺ)";
            return;
        }

        var today = new Date();
        today.setHours(0,0,0,0);
        // е…Ҙйҷўж—Ҙ = д»Ҡж—Ҙ - (еңЁйҷўж—Ҙж•° - 1)
        var admitDate = new Date(today.getTime());
        admitDate.setDate(today.getDate() - (days - 1));
        
        // еҹәжә–ж—Ҙ = е…Ҙйҷўж—Ҙ - 28ж—Ҙ
        var baseDate = new Date(admitDate.getTime());
        baseDate.setDate(admitDate.getDate() - 28);
        
        function fmt(d) {
            return (d.getMonth() + 1) + "/" + d.getDate();
        }

        resultArea.innerHTML = "<span style='color:#2980b9; font-weight:bold;'>" + escapeHtml(bestMatch.name) + "</span> гҒ•гӮ“ " +
                               "е…Ҙ:" + fmt(admitDate) + " <span style='color:#666;'>(еңЁйҷў" + days + "ж—Ҙ)</span> вҶ’ " +
                               "<b>28ж—ҘеүҚ: <span style='color:#e74c3c;'>" + fmt(baseDate) + "</span></b> " +
                               "<span style='font-size:11px; color:#666;'>(" + fmt(baseDate) + "гӮҲгӮҠд»ҘеүҚгҒӢгӮүдҪҝз”ЁгҒ—гҒҰгҒ„гӮӢи–¬гҒҢеҜҫиұЎгҒ§гҒҷ)</span>";
    } else {
        resultArea.innerHTML = "<span style='color:#999;'>иҰӢгҒӨгҒӢгӮҠгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹ</span>";
    }
}

function linkMedAdjDrugs2026(inIdx, outData) {
    if (outData.indexOf('medadj_out_2026_') !== 0) return;
    var outIdx = parseInt(outData.replace('medadj_out_2026_', ''), 10);
    var inD = medAdjState2026.input;
    var outD = medAdjState2026.output;
    
    if (inD[inIdx] && outD[outIdx]) {
        manualMedAdjLinks2026[outD[outIdx].raw] = inD[inIdx].raw;
        calcMedAdj2026(true);
    }
}

function unlinkMedAdjDrug2026(outRaw) {
    if (manualMedAdjLinks2026[outRaw]) {
        delete manualMedAdjLinks2026[outRaw];
        calcMedAdj2026(true);
    }
}

function toggleMedAdjStatus2026(inIdx) {
    var inD = medAdjState2026.input;
    var outD = medAdjState2026.output;
    if (inD[inIdx] && inD[inIdx].outRef !== undefined) {
        var outIdx = inD[inIdx].outRef;
        if (inD[inIdx].status === "з¶ҷз¶ҡ") {
            inD[inIdx].status = "з”ЁйҮҸеӨүжӣҙ";
            outD[outIdx].status = "з”ЁйҮҸеӨүжӣҙ";
        } else if (inD[inIdx].status === "з”ЁйҮҸеӨүжӣҙ") {
            inD[inIdx].status = "з¶ҷз¶ҡ";
            outD[outIdx].status = "з¶ҷз¶ҡ";
        }
        renderMedAdjResult2026();
    }
}

function calcMedAdj2026(skipFormat) {
    var inBox = document.getElementById('med-adj-in-2026');
    var outBox = document.getElementById('med-adj-out-2026');
    if (!skipFormat) {
        inBox.value = processMacroText(inBox.value);
        outBox.value = processMacroText(outBox.value);
    }
    var inDrugs = parseMedText(inBox.value);
    var outDrugs = parseMedText(outBox.value);
    
    if (medAdjState2026.input && medAdjState2026.input.length === inDrugs.length) {
        for(var i=0; i<inDrugs.length; i++) {
            if(inDrugs[i].raw === medAdjState2026.input[i].raw) inDrugs[i].checked = medAdjState2026.input[i].checked;
        }
    }
    
    var matchedOut = {};
    var matchedIn = {};
    for(var i=0; i<inDrugs.length; i++) {
        if(inDrugs[i].isExcluded) continue;
        var stdIn = getStdForm(inDrugs[i].raw);
        for(var j=0; j<outDrugs.length; j++) {
            if(outDrugs[j].isExcluded || matchedOut[j]) continue;
            var stdOut = getStdForm(outDrugs[j].raw);
            if(stdIn === stdOut) {
                inDrugs[i].status = "з¶ҷз¶ҡ";
                outDrugs[j].status = "з¶ҷз¶ҡ";
                outDrugs[j].inRef = i;
                inDrugs[i].outRef = j;
                matchedIn[i] = true;
                matchedOut[j] = true;
                break;
            }
        }
    }
    for(var i=0; i<inDrugs.length; i++) {
        if(inDrugs[i].isExcluded || matchedIn[i]) continue;
        var inBase = getDrugNameBase(inDrugs[i].raw);
        for(var j=0; j<outDrugs.length; j++) {
            if(outDrugs[j].isExcluded || matchedOut[j]) continue;
            var outBase = getDrugNameBase(outDrugs[j].raw);
            if(inBase.length > 2 && inBase === outBase) {
                inDrugs[i].status = "з”ЁйҮҸеӨүжӣҙ";
                outDrugs[j].status = "з”ЁйҮҸеӨүжӣҙ";
                outDrugs[j].inRef = i;
                inDrugs[i].outRef = j;
                matchedIn[i] = true;
                matchedOut[j] = true;
                break;
            }
        }
    }
    for(var i=0; i<inDrugs.length; i++) if(!inDrugs[i].isExcluded && !matchedIn[i]) inDrugs[i].status = "дёӯжӯў";
    for(var j=0; j<outDrugs.length; j++) if(!outDrugs[j].isExcluded && !matchedOut[j]) { outDrugs[j].status = "иҝҪеҠ "; outDrugs[j].inRef = -1; }
    
    for (var j = 0; j < outDrugs.length; j++) {
        if (outDrugs[j].status === "иҝҪеҠ " && manualMedAdjLinks2026[outDrugs[j].raw]) {
            var targetInRaw = manualMedAdjLinks2026[outDrugs[j].raw];
            for (var i = 0; i < inDrugs.length; i++) {
                if (inDrugs[i].status === "дёӯжӯў" && inDrugs[i].raw === targetInRaw) {
                    inDrugs[i].status = "йҷўеҶ…жҺЎз”ЁзӯүгҒёеӨүжӣҙ";
                    outDrugs[j].status = "йҷўеҶ…жҺЎз”ЁзӯүгҒёеӨүжӣҙ";
                    inDrugs[i].outRef = j;
                    outDrugs[j].inRef = i;
                    matchedIn[i] = true;
                    matchedOut[j] = true;
                    break;
                }
            }
        }
    }
    medAdjState2026.input = inDrugs;
    medAdjState2026.output = outDrugs;
    renderMedAdjResult2026();
}

function renderMedAdjResult2026() {
    var addedList = [];
    var discontList = [];
    var inD = medAdjState2026.input;
    var outD = medAdjState2026.output;
    var tbody = document.getElementById("med-adj-tbody-2026");
    var html = "";
    var baseCount = 0;
    var outCount = 0;
    
    for(var i=0; i<inD.length; i++) {
        if(inD[i].isExcluded) continue;
        if(inD[i].checked) baseCount++;
        var statColor = "#666";
        var outHtml = "";
        if(inD[i].status === "з¶ҷз¶ҡ") {
            statColor = "#0d6efd";
            outHtml = escapeHtml(outD[inD[i].outRef].raw);
        } else if(inD[i].status === "з”ЁйҮҸеӨүжӣҙ" || inD[i].status === "йҷўеҶ…жҺЎз”ЁзӯүгҒёеӨүжӣҙ") {
            statColor = (inD[i].status === "йҷўеҶ…жҺЎз”ЁзӯүгҒёеӨүжӣҙ") ? "#20c997" : "#fd7e14";
            outHtml = escapeHtml(outD[inD[i].outRef].raw);
            if (inD[i].status === "йҷўеҶ…жҺЎз”ЁзӯүгҒёеӨүжӣҙ") {
                var btn1 = ' <button class="yr-btn-danger-sm" style="margin-left:10px;" ';
                var btn2 = 'onclick="unlinkMedAdjDrug2026(\'' + escapeHtml(outD[inD[i].outRef].raw).replace(/'/g, "\\'") + '\')">и§ЈйҷӨ</button>';
                outHtml += btn1 + btn2;
            }
        } else if(inD[i].status === "дёӯжӯў") {
            statColor = "#dc3545";
            outHtml = '<span style="color:#aaa;">(гҒӘгҒ—)</span>';
        }
        
        var dragAttrs = "";
        if (inD[i].status === "дёӯжӯў") {
            dragAttrs += ' ondragover="event.preventDefault(); this.style.backgroundColor=\'#fce4ec\';" ';
            dragAttrs += 'ondragleave="this.style.backgroundColor=\'\'" ';
            dragAttrs += 'ondrop="event.preventDefault(); this.style.backgroundColor=\'\'; var d=event.dataTransfer.getData(\'text\'); if(d&&d.indexOf(\'medadj_out_\')===0){ linkMedAdjDrugs2026(' + i + ', d); }"';
        }
        
        html += '<tr class="yr-row-regular" ' + dragAttrs + '>';
        html += '<td style="text-align:center;"><input type="checkbox" onchange="toggleMedAdjInCheck2026('+i+')" '+(inD[i].checked?'checked':'')+' title="4йҖұй–“д»ҘдёҠз¶ҷз¶ҡгҒ—гҒҰгҒ„гӮӢе ҙеҗҲгҒ®гҒҝгғҒгӮ§гғғгӮҜ"></td>';
        html += '<td>' + escapeHtml(inD[i].raw) + '</td>';
        
        var isToggleable = (inD[i].outRef !== undefined && inD[i].outRef !== -1);
        var toggleStyle = isToggleable ? ' cursor:pointer; text-decoration:underline;' : '';
        var toggleAttr = isToggleable ? ' onclick="toggleMedAdjStatus2026(' + i + ')" title="гӮҜгғӘгғғгӮҜгҒ§жүӢеӢ•еҲҮжӣҝ"' : '';
        
        html += '<td style="text-align:center; font-weight:bold; color:'+statColor+';' + toggleStyle + '"' + toggleAttr + '>' + inD[i].status + '</td>';
        html += '<td>' + outHtml + '</td>';
        html += '</tr>';
    }
    
    for(var j=0; j<outD.length; j++) {
        if(outD[j].isExcluded) continue;
        outCount++;
        if(outD[j].status === "иҝҪеҠ ") {
            var tr1 = '<tr class="yr-row-brought-in" draggable="true" ';
            var tr2 = 'ondragstart="event.dataTransfer.setData(\'text\', \'medadj_out_2026_\' + ' + j + ')" ';
            var tr3 = 'style="cursor:grab;" title="гғүгғ©гғғгӮ°гҒ—гҒҰзҙҗд»ҳгҒ‘">';
            html += tr1 + tr2 + tr3;
            html += '<td style="text-align:center;">-</td>';
            html += '<td style="color:#aaa;">(гҒӘгҒ—)</td>';
            html += '<td style="text-align:center; font-weight:bold; color:#198754;">иҝҪеҠ </td>';
            html += '<td>' + escapeHtml(outD[j].raw) + '</td>';
            html += '</tr>';
        }
    }
    tbody.innerHTML = html;
    for(var j=0; j<outD.length; j++) if(outD[j].status === "иҝҪеҠ " && !outD[j].isExcluded) addedList.push(escapeHtml(outD[j].raw));
    for(var i=0; i<inD.length; i++) if(inD[i].status === "дёӯжӯў" && !inD[i].isExcluded) discontList.push(escapeHtml(inD[i].raw));
    
    var diff = baseCount - outCount;
    var summaryEl = document.getElementById("med-adj-summary-2026");
    var resMsg = "гғҷгғјгӮ№гғ©гӮӨгғі <span style='font-size:24px;'>" + baseCount + "</span> зЁ®йЎһ вҶ’ йҖҖйҷўжҷӮ <span style='font-size:24px;'>" + outCount + "</span> зЁ®йЎһ ( " + (diff>=0?"-":"+") + Math.abs(diff) + "зЁ®йЎһ )";
    var hasBaselineChange = false;
    for(var i=0; i<inD.length; i++) if(!inD[i].isExcluded && (inD[i].status === "з”ЁйҮҸеӨүжӣҙ" || inD[i].status === "дёӯжӯў" || inD[i].status === "йҷўеҶ…жҺЎз”ЁзӯүгҒёеӨүжӣҙ")) hasBaselineChange = true;
    
    var isAddValid = document.getElementById("chk-med-adj-req3-2026") && document.getElementById("chk-med-adj-req3-2026").checked;
    var hasAnyChange = hasBaselineChange || (addedList.length > 0 && isAddValid);
    var req4 = document.getElementById("chk-med-adj-req4-2026").checked;
    
    if (baseCount >= 6 && hasAnyChange && req4) {
        var isOneYearRule = document.getElementById("chk-med-adj-1year-2026").checked;
        var prevCount = parseInt(document.getElementById("ipt-med-adj-prev-count-2026").value, 10) || 0;
        var meet150 = isOneYearRule ? (prevCount - outCount >= 2) : (diff >= 2);
        
        if (meet150) resMsg += "<br><span style='color:#c2185b;'>вңЁ йҖҖйҷўжҷӮи–¬еүӨиӘҝж•ҙеҠ з®— (310зӮ№: 160+150) еҜҫиұЎиҰӢиҫјгҒҝ</span>";
        else resMsg += "<br><span style='color:#c2185b;'>вңЁ и–¬еүӨз·ҸеҗҲи©•дҫЎиӘҝж•ҙеҠ з®— (160зӮ№) еҜҫиұЎиҰӢиҫјгҒҝ</span>";
    } else if (baseCount >= 6 && hasAnyChange && !req4) {
        resMsg += "<br><span style='color:#999; font-size:14px;'>вҡ пёҸ иҰҒд»¶пјҡеӨ–йғЁйҖЈжҗәпјҲи–¬еұҖзӯүпјүгҒ®жғ…е ұе…ұжңүгҒҢеҝ…иҰҒгҒ§гҒҷ</span>";
    } else if (baseCount < 6 && baseCount > 0) {
        resMsg += "<br><span style='color:#666; font-size:14px;'>(гғҷгғјгӮ№гғ©гӮӨгғі6зЁ®йЎһжңӘжәҖгҒ®гҒҹгӮҒз®—е®ҡеҜҫиұЎеӨ–)</span>";
    }
    summaryEl.innerHTML = resMsg;
    summaryEl.style.backgroundColor = (baseCount >= 6 && hasAnyChange && req4) ? "#fce4ec" : "#eee";
    document.getElementById("med-adj-result-panel-2026").style.display = "block";
    document.getElementById("req3-container-2026").style.display = (baseCount >= 6 && !hasBaselineChange && addedList.length > 0) ? "block" : "none";
}

function toggleMedAdjInCheck2026(idx) {
    medAdjState2026.input[idx].checked = !medAdjState2026.input[idx].checked;
    renderMedAdjResult2026();
}

function copyMedAdjResult2026() {
    var inD = medAdjState2026.input;
    var outD = medAdjState2026.output;
    var req1 = document.getElementById("chk-med-adj-req1-2026").checked;
    var req2 = document.getElementById("chk-med-adj-req2-2026").checked;
    var req4 = document.getElementById("chk-med-adj-req4-2026").checked;
    
    var baseCount = 0; var outCount = 0;
    for(var i=0; i<inD.length; i++) if(!inD[i].isExcluded && inD[i].checked) baseCount++;
    for(var j=0; j<outD.length; j++) if(!outD[j].isExcluded) outCount++;

    var txt = "гҖҗйҖҖйҷўжҷӮи–¬еүӨиӘҝж•ҙеҠ з®—(26е№ҙж”№е®ҡзүҲ) еҲӨе®ҡгҖ‘\n";
    txt += "гғ»гғҷгғјгӮ№гғ©гӮӨгғі(4wз¶ҷз¶ҡ): " + baseCount + " зЁ®йЎһ\n";
    txt += "гғ»йҖҖйҷўжҷӮеҮҰж–№: " + outCount + " зЁ®йЎһ\n";
    txt += "------------------------\n";
    var changes = [];
    for(var i=0; i<inD.length; i++) {
        if(inD[i].isExcluded) continue;
        if(inD[i].status === "з”ЁйҮҸеӨүжӣҙ") changes.push("гғ»" + inD[i].raw + " вҶ’ з”ЁйҮҸеӨүжӣҙ");
        else if(inD[i].status === "дёӯжӯў") changes.push("гғ»" + inD[i].raw + " вҶ’ дёӯжӯў");
        else if(inD[i].status === "йҷўеҶ…жҺЎз”ЁзӯүгҒёеӨүжӣҙ") changes.push("гғ»" + inD[i].raw + " вҶ’ йҷўеҶ…жҺЎз”Ёи–¬зӯүгҒёеӨүжӣҙ");
    }
    for(var j=0; j<outD.length; j++) {
        if(outD[j].isExcluded) continue;
        if(outD[j].status === "иҝҪеҠ ") changes.push("гғ»" + outD[j].raw + " (иҝҪеҠ )");
    }
    if (changes.length > 0) txt += changes.join("\n") + "\n";
    else txt += "еӨүжӣҙгғ»иҝҪеҠ гғ»дёӯжӯўгҒ•гӮҢгҒҹеҶ…жңҚи–¬гҒӘгҒ—\n";
    
    txt += "\n[е®ҹж–ҪиҰҒд»¶]\n";
    txt += "гғ»зҷӮйӨҠдёҠеҝ…иҰҒгҒӘжҢҮе°Һ: " + (req1 ? "е®ҹж–ҪжёҲ" : "жңӘе®ҹж–Ҫ") + "\n";
    txt += "гғ»еӨҡиҒ·зЁ®йҖЈжҗә/е…ұжңү: " + (req2 ? "е®ҹж–ҪжёҲ" : "жңӘе®ҹж–Ҫ") + "\n";
    txt += "гғ»и–¬еұҖзӯүгҒёгҒ®жғ…е ұйҖЈжҗә: " + (req4 ? "е®ҹж–ҪжёҲ" : "жңӘе®ҹж–Ҫ") + "\n";
    
    var diff = baseCount - outCount;
    var isOneYearRule = document.getElementById("chk-med-adj-1year-2026").checked;
    var prevCount = parseInt(document.getElementById("ipt-med-adj-prev-count-2026").value, 10) || 0;
    
    var hasBaselineChange = false;
    var hasAddition = false;
    for(var i=0; i<inD.length; i++) if(!inD[i].isExcluded && (inD[i].status === "з”ЁйҮҸеӨүжӣҙ" || inD[i].status === "дёӯжӯў" || inD[i].status === "йҷўеҶ…жҺЎз”ЁзӯүгҒёеӨүжӣҙ")) hasBaselineChange = true;
    for(var j=0; j<outD.length; j++) if(outD[j].status === "иҝҪеҠ " && !outD[j].isExcluded) hasAddition = true;
    var isAddValid = document.getElementById("chk-med-adj-req3-2026") && document.getElementById("chk-med-adj-req3-2026").checked;
    
    var hasAnyChange = hasBaselineChange || (hasAddition && isAddValid);
    txt += "\n[еҲӨе®ҡзөҗжһң]\n";
    if (baseCount >= 6 && hasAnyChange && req4) {
        var meet150 = isOneYearRule ? (prevCount - outCount >= 2) : (diff >= 2);
        if (meet150) txt += "вңЁ йҖҖйҷўжҷӮи–¬еүӨиӘҝж•ҙеҠ з®—(310зӮ№) з®—е®ҡиҰӢиҫјгҒҝ\n(иӘҝж•ҙеҠ з®—160зӮ№ + еҠ з®—150зӮ№)\n";
        else txt += "вңЁ и–¬еүӨз·ҸеҗҲи©•дҫЎиӘҝж•ҙеҠ з®—(160зӮ№) з®—е®ҡиҰӢиҫјгҒҝ\n";
    } else {
        txt += "еҠ з®—з®—е®ҡиҰҒд»¶гӮ’жәҖгҒҹгҒ—гҒҫгҒӣгӮ“\n";
        if (baseCount < 6) txt += "вҖ»е…ҘйҷўеүҚгҒ®з¶ҷз¶ҡи–¬еүӨ6зЁ®йЎһд»ҘдёҠгҒҢеҝ…иҰҒгҒ§гҒҷ\n";
        if (!hasAnyChange) txt += "вҖ»еҮҰж–№еҶ…е®№гҒ®еӨүжӣҙпјҲдёӯжӯўгғ»з”ЁйҮҸеӨүжӣҙгғ»иҝҪеҠ зӯүпјүгҒҢеҝ…иҰҒгҒ§гҒҷ\n";
        if (!req4) txt += "вҖ»и–¬еұҖзӯүгҒёгҒ®ж–ҮжӣёгҒ«гӮҲгӮӢжғ…е ұйҖЈжҗәгҒҢеҝ…иҰҒгҒ§гҒҷ\n";
    }

    try {
        window.clipboardData.setData('Text', txt);
        yrShowAlert('26е№ҙж”№е®ҡзүҲгҒ®еҲӨе®ҡзөҗжһңгӮ’гӮігғ”гғјгҒ—гҒҫгҒ—гҒҹгҖӮ', 'success');
    } catch(e) { yrShowAlert('гӮігғ”гғјгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹгҖӮ', 'error'); }
}

function changeBoardFontSize() {
    var sel = document.getElementById("sel-global-fontsize");
    if (!sel) return;
    var size = sel.value;
    
    removeClass(document.body, "font-medium");
    removeClass(document.body, "font-large");
    if (size === "medium") addClass(document.body, "font-medium");
    else if (size === "large") addClass(document.body, "font-large");
    
    // гғӯгғјгӮ«гғ«гӮ№гғҲгғ¬гғјгӮёй ҳеҹҹгҒёдҝқеӯҳ
    try { myStorage.setItem('boardFontSize', size); } catch(e){}
}

function changeSharedFontSize() {
    var sel = document.getElementById("sel-fontsize");
    if (!sel) return;
    var size = sel.value;
    var editor = document.getElementById("note-editor-rich");
    if(editor) editor.style.fontSize = size;
}

function changeSharedFontFamily() {
    var sel = document.getElementById("sel-fontfamily");
    if (!sel) return;
    var font = sel.value;
    var editor = document.getElementById("note-editor-rich");
    if(editor) editor.style.fontFamily = font;
}

// и–¬жӯҙгғ„гғјгғ«еҲқжңҹеҢ– (еҹәжә–ж—ҘзӯүгҒ®еҲқжңҹеҢ–еҮҰзҗҶеҗ«гӮҖ)
// yrInit(); // вҳ… window.onloadеҶ…гҒ«з§»еӢ•гҒ—гҒҫгҒ—гҒҹ

// е…ЁжӮЈиҖ…йҒёжҠһз”ЁгҒ®й–ўж•°пјҲгӮЁгғ©гғји§Јж¶Ҳпјү
function toggleAllPatientsSelect(checked) {
    var checkboxes = document.querySelectorAll('.pat-select');
    for (var i = 0; i < checkboxes.length; i++) checkboxes[i].checked = checked;
}

// гӮ«гӮ№гӮҝгғ гӮҝгғ–гҒ®зҠ¶ж…ӢгӮ’дҝқжҢҒгҒҷгӮӢеӨүж•°
var currentFilterTag = ""; 
var currentFilterScope = "all"; // "all" гҒҫгҒҹгҒҜ "personal"

// вҳ…дҝ®жӯЈ: гғӯгӮ°гӮӨгғідёӯгҒ®гғҰгғјгӮ¶гғје°Ӯз”ЁгҒ®гӮ«гӮ№гӮҝгғ гӮҝгғ–гҒ®гҒҝгӮ’жҸҸз”»гҒҷгӮӢ
function renderCustomTabsUI() {
    var container = document.getElementById("sub-tabs-container");
    if (!container) return;
    
    // еҹәжң¬гҒ®з—…жЈҹгӮҝгғ–гӮ’жҸҸз”»
    var activeCodes = (appData.settings && appData.settings.activeWardCodes) || ["99"];
    var html = "";
    for (var i = 0; i < activeCodes.length; i++) {
        var code = activeCodes[i];
        var name = getWardName(code);
        var activeClass = (code === currentWard && currentFilterTag === "") ? " active" : "";
        html += '<div class="sub-tab' + activeClass + '" style="position:relative; padding-right:25px;" onclick="currentFilterTag=\'\'; switchWard(\'' + code + '\')">' + name + '</div>';
    }
    container.innerHTML = html;
    
    // жңӘгғӯгӮ°гӮӨгғіжҷӮгҒҜеҖӢдәәз”ЁгӮ«гӮ№гӮҝгғ гӮҝгғ–гҒ®иӘӯгҒҝиҫјгҒҝгӮ’гӮ№гӮӯгғғгғ—гҒ—гҒҰзөӮдәҶ
    if (!currentSystemId) return;
    
    // вҳ…дҝ®жӯЈ: гғӯгӮ°гӮӨгғігғҰгғјгӮ¶гғјеҖӢдәәгҒ®гӮ«гӮ№гӮҝгғ гӮҝгғ–й…ҚеҲ—гӮ’е®үе…ЁгҒ«еҸ–еҫ—
    if (!appData.settings.userCustomTabs) appData.settings.userCustomTabs = {};
    if (!appData.settings.userCustomTabs[currentSystemId]) appData.settings.userCustomTabs[currentSystemId] = [];
    var customTabs = appData.settings.userCustomTabs[currentSystemId];
    
    for (var i = 0; i < customTabs.length; i++) {
        var tabObj = customTabs[i];
        if (typeof tabObj === "string") { tabObj = { tag: tabObj, scope: "all" }; }
        
        var tName = tabObj.tag;
        var tScope = tabObj.scope || "all";
        var scopeLabel = (tScope === "personal") ? "(еҖӢдәә)" : "";
        
        var btn = document.createElement("div");
        var isActive = (currentFilterTag === tName && currentFilterScope === tScope) ? " active" : "";
        btn.className = "sub-tab" + isActive;
        
        if (tScope === "personal") {
            btn.style.cssText = "position:relative; padding-right:25px; background-color:#e8f4f8; color:#007bff; border-color:#007bff;";
        } else {
            btn.style.cssText = "position:relative; padding-right:25px; background-color:#fce4ec; color:#c2185b; border-color:#f8bbd0;";
        }
        
        btn.innerHTML = escapeHtml(tName) + '<span style="font-size:9px; font-weight:normal; opacity:0.7;">' + scopeLabel + '</span>' +
            '<span class="tab-close-btn" onclick="event.stopPropagation(); removeCustomTab(\'' + escapeHtml(tName) + '\', \'' + tScope + '\')" ' +
            'style="position:absolute; right:5px; top:50%; margin-top:-8px; font-size:10px; cursor:pointer;">&times;</span>';
        
        (function(tag, scope) {
            btn.onclick = function() {
                currentFilterTag = tag;
                currentFilterScope = scope;
                renderCustomTabsUI();
                renderPatients();
            };
        })(tName, tScope);
        
        container.appendChild(btn);
    }
}

function getAvailableTags() {
    var tagCounts = {};
    for (var w in appData.patients) {
        var wList = appData.patients[w];
        if (!wList) continue;
        for (var i = 0; i < wList.length; i++) {
            var p = wList[i];
            var combinedMemo = (p.memo || "") + " " + ((p.personalMemos && p.personalMemos[currentSystemId]) ? p.personalMemos[currentSystemId] : "");
            var match = combinedMemo.match(/(#[^\sгҖҖ#]+)/g);
            if (match) {
                var uniqueTags = {};
                for (var j = 0; j < match.length; j++) uniqueTags[match[j]] = true;
                for (var t in uniqueTags) {
                    tagCounts[t] = (tagCounts[t] || 0) + 1;
                }
            }
        }
    }
    var sortedTags = [];
    for (var tag in tagCounts) sortedTags.push({ tag: tag, count: tagCounts[tag] });
    sortedTags.sort(function(a, b) { return b.count - a.count; });
    return sortedTags;
}

// гғўгғјгғҖгғ«гҒӢгӮүе…ЁдҪ“/еҖӢдәәгӮ’йҒёгӮ“гҒ§гӮҝгғ–гӮ’дҪңжҲҗпјҲгӮЁгғ©гғјдҝ®жӯЈзүҲпјү
function createNewCustomTab() {
    var tags = getAvailableTags();
    
    var html = '<div style="background:white; padding:20px; border-radius:8px; width:360px; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">';
    html += '<h3 style="margin-top:0; font-size:15px; border-bottom:2px solid #0d6efd; padding-bottom:5px;">жҠҪеҮәгӮҝгғ–гҒ®ж–°иҰҸдҪңжҲҗ</h3>';
    
    // гғ©гӮёгӮӘгғңгӮҝгғігҒ«IDгӮ’д»ҳдёҺгҒ—гҒҰе®үе…ЁгҒ«еҲӨе®ҡгҒ§гҒҚгӮӢгӮҲгҒҶгҒ«гҒҷгӮӢ
    html += '<div style="margin-bottom:12px; background:#f8f9fa; padding:8px; border-radius:4px; font-size:12px;">';
    html += '<b>рҹ”Қ жӨңзҙўгҒҷгӮӢгғЎгғўгҒ®зҜ„еӣІ:</b><br>';
    html += '<label style="cursor:pointer; margin-right:15px;"><input type="radio" name="rad-tag-scope" id="rad-scope-all" value="all" checked> е…Ёе“ЎгҒ®е…ұжңүгғЎгғў</label>';
    html += '<label style="cursor:pointer;"><input type="radio" name="rad-tag-scope" id="rad-scope-personal" value="personal"> иҮӘеҲҶгҒ®еҖӢдәәгғЎгғў</label>';
    html += '</div>';
    
    // гғ•гғӘгғје…ҘеҠӣгӮЁгғӘгӮў
    html += '<div style="display:flex; gap:5px; margin-bottom:15px;">';
    html += '<input type="text" id="ipt-custom-tag-manual" placeholder="ж–°гӮҝгӮ°гӮ’иҮӘз”ұе…ҘеҠӣ (дҫӢ: #NST)" style="flex:1; padding:6px; border:1px solid #ccc; border-radius:3px; font-size:12px;" onkeypress="if(event.keyCode===13){ var v=this.value; if(v) addCustomTabFromModal(v); }">';
    html += '<button class="btn" style="background:#0d6efd; padding:4px 12px;" onclick="var v=document.getElementById(\'ipt-custom-tag-manual\').value; if(v) addCustomTabFromModal(v);">иҝҪеҠ </button>';
    html += '</div>';

    // е®ҹзёҫгғӘгӮ№гғҲгӮЁгғӘгӮў
    html += '<div style="font-size:11px; color:#666; margin-bottom:4px;">в–ј зҸҫеңЁдҪҝз”ЁгҒ•гӮҢгҒҰгҒ„гӮӢгӮҝгӮ°дёҖиҰ§ (гӮҜгғӘгғғгӮҜгҒ§йҒёжҠһ)</div>';
    html += '<div style="max-height:180px; overflow-y:auto; border:1px solid #eee; border-radius:3px; margin-bottom:15px; background:#fff;">';
    
    if (tags.length === 0) {
        html += '<div style="padding:10px; color:#999; text-align:center; font-size:12px;">дҪҝз”ЁдёӯгҒ®гӮҝгӮ°гҒҢгҒӮгӮҠгҒҫгҒӣгӮ“</div>';
    } else {
        for (var i = 0; i < tags.length; i++) {
            // onclickгҒ®дёӯгҒ®иӨҮйӣ‘гҒӘеҮҰзҗҶгӮ’еүҠйҷӨгҒ—гҖҒгӮҝгӮ°еҗҚгҒ гҒ‘гӮ’й–ўж•°гҒ«жёЎгҒҷ
            html += '<div style="padding:6px 10px; border-bottom:1px solid #eee; cursor:pointer; display:flex; justify-content:space-between; align-items:center; font-size:12px;" onmouseover="this.style.background=\'#f0f0f0\'" onmouseout="this.style.background=\'white\'" onclick="addCustomTabFromModal(\'' + escapeHtml(tags[i].tag) + '\')">';
            html += '<span class="memo-tag" style="color:#007bff;">' + escapeHtml(tags[i].tag) + '</span> <span style="font-size:10px; color:#999;">е…ұз”Ёеҗ«гӮҖд»¶ж•°: ' + tags[i].count + 'еҗҚ</span></div>';
        }
    }
    html += '</div>';
    html += '<button class="btn" onclick="closeCustomTabModal()" style="width:100%; background:#ccc; color:#333; padding:5px 0;">гӮӯгғЈгғігӮ»гғ«</button></div>';
    
    var modal = document.createElement("div");
    modal.id = "modal-add-custom-tab";
    modal.style.cssText = "position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); display:flex; justify-content:center; align-items:center; z-index:3000;";
    modal.innerHTML = html;
    document.body.appendChild(modal);
    setTimeout(function(){ document.getElementById('ipt-custom-tag-manual').focus(); }, 100);
}

function closeCustomTabModal() {
    var modal = document.getElementById("modal-add-custom-tab");
    if (modal) modal.parentNode.removeChild(modal);
}

// гғўгғјгғҖгғ«гҒӢгӮүгҒ®е‘јгҒіеҮәгҒ—гӮ’еҸ—гҒ‘еҸ–гӮӢй–ўж•°пјҲгӮЁгғ©гғјдҝ®жӯЈзүҲпјү
function addCustomTabFromModal(tagName) {
    // гӮ№гӮігғјгғ—гҒ®еҲӨе®ҡгҒҜгҖҒHTMLгҒ®зө„гҒҝз«ӢгҒҰжҷӮгҒ§гҒҜгҒӘгҒҸгҒ“гҒ“гҒ§зӣҙжҺҘHTMLиҰҒзҙ гӮ’иӘӯгҒҝеҸ–гҒЈгҒҰиЎҢгҒҶ
    var scope = "all";
    var radPersonal = document.getElementById("rad-scope-personal");
    if (radPersonal && radPersonal.checked) {
        scope = "personal";
    }
    
    closeCustomTabModal();
    if (!tagName || tagName.trim() === "") return;
    tagName = tagName.trim();
    if (tagName.indexOf("#") !== 0) tagName = "#" + tagName; 
    
    if (!currentSystemId) {
        alert("гӮҝгғ–гӮ’иҝҪеҠ гҒҷгӮӢгҒ«гҒҜгғӯгӮ°гӮӨгғігҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ");
        return;
    }
    
    if (!appData.settings.userCustomTabs) appData.settings.userCustomTabs = {};
    if (!appData.settings.userCustomTabs[currentSystemId]) appData.settings.userCustomTabs[currentSystemId] = [];
    var userTabs = appData.settings.userCustomTabs[currentSystemId];
    
    // йҮҚиӨҮгғҒгӮ§гғғгӮҜ (гӮҝгӮ°еҗҚгҒЁгӮ№гӮігғјгғ—гҒ®дёЎж–№гҒҢдёҖиҮҙгҒҷгӮӢгҒӢ)
    var isDuplicate = false;
    for (var i = 0; i < userTabs.length; i++) {
        var t = userTabs[i];
        if (t && typeof t === "object" && t.tag === tagName && t.scope === scope) isDuplicate = true;
    }
    
    if (!isDuplicate) {
        userTabs.push({ tag: tagName, scope: scope });
    }
    
    // вҳ…иҝҪеҠ : гӮҝгғ–й…ҚеҲ—гҒҢжӣҙж–°гҒ•гӮҢгҒҹгҒ®гҒ§гғҲгғ©гғігӮ¶гӮҜгӮ·гғ§гғігӮ’зҷәиЎҢ
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("UPDATE_CUSTOM_TABS", {
            userId: currentSystemId,
            tabs: userTabs
        });
    }

    currentFilterTag = tagName;
    currentFilterScope = scope;
    renderCustomTabsUI();
    renderPatients();
}

// вҳ…дҝ®жӯЈ: гӮҝгғ–гҒ®еүҠйҷӨеҜҫиұЎгӮ’гғҰгғјгӮ¶гғјеҖӢдәәгҒ®й ҳеҹҹгҒ«еӨүжӣҙ
function removeCustomTab(tagName, scope) {
    if (!confirm("гӮҝгғ–гҖҢ" + tagName + "гҖҚгӮ’еүҠйҷӨгҒ—гҒҫгҒҷгҒӢпјҹ")) return;
    
    if (currentSystemId && appData.settings && appData.settings.userCustomTabs && appData.settings.userCustomTabs[currentSystemId]) {
        var userTabs = appData.settings.userCustomTabs[currentSystemId];
        for (var i = 0; i < userTabs.length; i++) {
            var t = userTabs[i];
            if (t && t.tag === tagName && t.scope === scope) {
                userTabs.splice(i, 1);
                break;
            }
        }

        // вҳ…иҝҪеҠ : гӮҝгғ–еүҠйҷӨеҫҢгҒ«гӮӮгғҲгғ©гғігӮ¶гӮҜгӮ·гғ§гғігӮ’зҷәиЎҢ
        if (typeof DataManager !== "undefined") {
            DataManager.appendTransaction("UPDATE_CUSTOM_TABS", {
                userId: currentSystemId,
                tabs: userTabs
            });
        }
    }
    if (currentFilterTag === tagName && currentFilterScope === scope) { currentFilterTag = ""; }
    renderCustomTabsUI();
    renderPatients();
}

// гӮҝгӮ°жӨңзҙўз”Ёгғ•гӮЈгғ«гӮҝгғј
var currentFilterTag = ""; // еҲқжңҹеҢ–
function filterByTag(tagName) {
    currentFilterTag = tagName;
    renderPatients();
}

function showTagSuggest(textarea, event) {
    if (event && (event.key === "Shift" || event.key === "Control" || event.key === "Alt" || (event.keyCode >= 37 && event.keyCode <= 40))) return;
    
    var val = textarea.value;
    var cursor = textarea.selectionStart;
    if (typeof cursor !== 'number') return;
    var textBefore = val.substring(0, cursor);
    var match = textBefore.match(/#([^\s#]*)$/);

    var suggestBox = document.getElementById("tag-suggest-box");
    if (!suggestBox) {
        suggestBox = document.createElement("div");
        suggestBox.id = "tag-suggest-box";
        suggestBox.style.position = "absolute";
        suggestBox.style.zIndex = "9999";
        suggestBox.style.background = "#fff";
        suggestBox.style.border = "1px solid #0d6efd";
        suggestBox.style.boxShadow = "0 2px 8px rgba(0,0,0,0.2)";
        suggestBox.style.padding = "4px";
        suggestBox.style.borderRadius = "4px";
        suggestBox.style.display = "none";
        document.body.appendChild(suggestBox);
    }

    if (match) {
        var prefix = match[1];
        
        // вҳ…дҝ®жӯЈ: гғҸгғјгғүгӮігғјгғүгҒ§гҒҜгҒӘгҒҸгҖҒе®ҹйҡӣгҒ®дҪҝз”Ёе®ҹзёҫдёҠдҪҚ15гҒӨгӮ’еҸ–еҫ—
        var sortedTags = getAvailableTags();
        var tags = [];
        for (var t = 0; t < Math.min(15, sortedTags.length); t++) {
            tags.push(sortedTags[t].tag);
        }
        
        var suggestions = tags.filter(function(t) { return t.indexOf("#" + prefix) === 0; });
        
        if (suggestions.length > 0) {
            var rect = textarea.getBoundingClientRect();
            // HTA/IEдә’жҸӣгҒ®гӮ№гӮҜгғӯгғјгғ«йҮҸеҸ–еҫ—
            var scrollX = window.pageXOffset || document.documentElement.scrollLeft || document.body.scrollLeft || 0;
            var scrollY = window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop || 0;
            
            suggestBox.style.top = (rect.bottom + scrollY + 2) + "px";
            suggestBox.style.left = (rect.left + scrollX) + "px";
            
            var html = "";
            for (var i = 0; i < suggestions.length; i++) {
                html += '<div style="cursor:pointer; padding:4px 8px; color:#0d6efd; font-size:12px; font-weight:bold; border-bottom:1px dotted #ccc;" onmouseover="this.style.background=\'#e1f5fe\'" onmouseout="this.style.background=\'transparent\'" onclick="insertTagSuggest(this, \'' + suggestions[i] + '\')">' + suggestions[i] + '</div>';
            }
            suggestBox.innerHTML = html;
            suggestBox.activeTextarea = textarea;
            suggestBox.matchStart = cursor - match[0].length;
            suggestBox.matchEnd = cursor;
            suggestBox.style.display = "block";
            return;
        }
    }
    suggestBox.style.display = "none";
}

function insertTagSuggest(elem, tag) {
    var suggestBox = document.getElementById("tag-suggest-box");
    if (suggestBox && suggestBox.activeTextarea) {
        var ta = suggestBox.activeTextarea;
        var val = ta.value;
        ta.value = val.substring(0, suggestBox.matchStart) + tag + " " + val.substring(suggestBox.matchEnd);
        suggestBox.style.display = "none";
        
        // вҳ…дҝ®жӯЈ: гғҮгғјгӮҝдҝқеӯҳгҒЁгҖҒиҰӢгҒҹзӣ®гҒ®еҚіжҷӮеҲҮгӮҠжӣҝгҒҲгӮ’еј·еҲ¶е®ҹиЎҢ
        if (ta.onchange) ta.onchange(); 
        ta.style.display = "none";
        var dispDiv = ta.previousSibling;
        if (dispDiv) {
            dispDiv.style.display = "block";
            dispDiv.innerHTML = escapeHtml(ta.value || "").replace(/(#[^\sгҖҖ#]+)/g, '<span class="memo-tag">$1</span>') || '<span style="color:#999;">гғЎгғў...</span>';
        }
    }
}

</script>
<div id="footer-status-bar" style="position:fixed; bottom:0; left:0; width:100%; height:22px; background:#f8f9fa; border-top:1px solid #ddd; font-size:10px; color:#666; display:flex; align-items:center; padding:0 10px; z-index:99999; box-sizing:border-box;">
    <div style="flex-grow:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
        гғҮгғјгӮҝжүҖеңЁ: <span id="data-path-display">иӘӯгҒҝиҫјгҒҝдёӯ...</span>
    </div>
    <div id="sync-status" style="margin-left:15px; font-weight:bold; color:#27ae60;">
        еҗҢжңҹжӯЈеёё
    </div>
</div>
<div id="tag-suggest-box" style="position:absolute; background:#fff; border:1px solid #ccc; display:none; z-index:999; padding:5px;"></div>
</body>
</html>















