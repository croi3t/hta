    var baseUrl = 'http://10.5.171.42:8082/karte/';
    var url = '';
    
    switch(type) {
        case 'karte':
            url = baseUrl + 'kanja_ichiran/kanja_link_controller.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&section_code=';
            break;
        case 'kentai_karte':
            url = baseUrl + 'kentai_kekka_karte.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&section_code=0000023&kentai_disp_flgs=&disp_kekka_start_date=' + todayStr + '&disp_kekka_end_date=&disp_zoom=80&disp_kensu_count=30';
            break;
        case 'kentai_menu':
            url = baseUrl + 'kentai_kekka_menu.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&section_code=0000023&kentai_disp_flgs=&disp_kekka_start_date=' + todayStr + '&disp_kekka_end_date=&disp_zoom=80&disp_kensu_count=30';
            break;
        case 'vital_karte':
            var vs = new Date(today); vs.setDate(today.getDate() - 6);
            var ve = new Date(today); ve.setDate(today.getDate() + 3);
            var vsStr = vs.getFullYear() + '/' + ('0'+(vs.getMonth()+1)).slice(-2) + '/' + ('0'+vs.getDate()).slice(-2);
            var veStr = ve.getFullYear() + '/' + ('0'+(ve.getMonth()+1)).slice(-2) + '/' + ('0'+ve.getDate()).slice(-2);
            url = baseUrl + 'vital/vital_karte.php?kanja_id=' + kanjaId + '&start_date=' + vsStr + '&end_date=' + veStr + '&user_id=' + userId + '&disp_order_ichiran_kubun=1&disp_noorder_flg=0&disp_contents_flgtbl=123&disp_zoom=100&section_code=0000002';
            break;
        case 'vital_menu':
            var vs2 = new Date(today); vs2.setDate(today.getDate() - 6);
            var ve2 = new Date(today); ve2.setDate(today.getDate() + 3);
            var vs2Str = vs2.getFullYear() + '/' + ('0'+(vs2.getMonth()+1)).slice(-2) + '/' + ('0'+vs2.getDate()).slice(-2);
            var ve2Str = ve2.getFullYear() + '/' + ('0'+(ve2.getMonth()+1)).slice(-2) + '/' + ('0'+ve2.getDate()).slice(-2);
            url = baseUrl + 'vital/vital_menu.php?kanja_id=' + kanjaId + '&start_date=' + vs2Str + '&end_date=' + ve2Str + '&user_id=' + userId + '&disp_order_ichiran_kubun=1&disp_noorder_flg=0&disp_contents_flgtbl=123&disp_zoom=100&section_code=0000002';
            break;
        case 'document_menu':
            url = baseUrl + 'document_menu.php?kanja_id=' + kanjaId + '&start_date=&end_date=&hakkou_date=&user_id=' + userId + '&section_code=&disp_flgs=0/0/1/0/0/0/1/0/0/0/1&document_code=100000032&order_kind_code_str=&disp_title_flg=&document_title=';
            break;
        case 'document_karte':
            url = baseUrl + 'document_karte.php?kanja_id=' + kanjaId + '&start_date=&end_date=&hakkou_date=&user_id=' + userId + '&section_code=&disp_flgs=0/0/1/0/0/0/1/0/0/0/1&document_code=100000032&order_kind_code_str=&disp_title_flg=&document_title=';
            break;
        case 'allergy_menu':
            url = baseUrl + 'allergy_menu.php?start_flag=1&kanja_id=' + kanjaId + '&start_date=&end_date=&hakkou_date=&user_id=' + userId + '&section_code=&document_code=100000004&disp_selectsection=&range_date=180/0/0/0&disp_zoom=100';
            break;
        case 'allergy_karte':
            url = baseUrl + 'allergy_karte.php?start_flag=1&kanja_id=' + kanjaId + '&start_date=&end_date=&hakkou_date=&user_id=' + userId + '&section_code=&document_code=100000004&disp_selectsection=&range_date=180/0/0/0&disp_zoom=100';
            break;
        case 'shohou_s':
            url = baseUrl + 'search/search_order.php?kana_name=&search_code=1&user_id=' + userId + '&kanja_id=' + kanjaId;
            break;
        case 'shohou_d':
            url = baseUrl + 'karte.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&order_search_flg=1&order_search_code=1&order_search_name=#top';
            break;
        case 'kentai_s':
            url = baseUrl + 'search/search_order.php?kana_name=&search_code=3&user_id=' + userId + '&kanja_id=' + kanjaId;
            break;
        case 'kentai_d':
            url = baseUrl + 'karte.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&order_search_flg=1&order_search_code=3&order_search_name=#top';
            break;
        case 'chuusha_s':
            url = baseUrl + 'search/search_order.php?kana_name=&search_code=4&user_id=' + userId + '&kanja_id=' + kanjaId;
            break;
        case 'chuusha_d':
            url = baseUrl + 'karte.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&order_search_flg=1&order_search_code=4&order_search_name=#top';
            break;
        case 'ope_record':
            var pTarget = findPatientById(kanjaId);
            var hospDays = pTarget ? parseInt(pTarget.daysInHosp, 10) : 0;
            var rDays = (!isNaN(hospDays) && hospDays > 0) ? (hospDays + 3) : 20;
            url = baseUrl + 'karte.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&order_kind_code_str=0091,1091&kijun_date=' + todayStr + '&range_date=' + rDays + '/7/1/1&disp_selectsection=0000021&disp_selectukind=1,2,3&document_code=700360003,730360001&multi_kind=1#top';
            break;

    }
    
    if (!url) return;
    
    try {
        var wsh = new ActiveXObject('WScript.Shell');
        try {
            wsh.Run('msedge "' + url + '"');
        } catch(e1) {
            try {
                wsh.Run('chrome "' + url + '"');
            } catch(e2) {
                var shellApp = new ActiveXObject('Shell.Application');
                shellApp.ShellExecute(url, '', '', 'open', 1);
            }
        }
    } catch(e) {
        alert('URLгҒ®иө·еӢ•гҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹ: ' + e.message);
    }
}

