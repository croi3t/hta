// 譛邨ら｢ｺ隱肴律譎ゑｼ医Ο繝ｼ繧ｫ繝ｫ繝・・繧ｿ逕ｨ・・
var lastSeenTimestamp = new Date().getTime(); // 蛻晄悄蛟､繧堤樟蝨ｨ譎ょ綾縺ｫ縺励※繝ｭ繧ｰ繧､繝ｳ蜑阪・譁ｰ逹騾夂衍繧帝亟縺・
var lastAlertedTodoCount = -1; // 閾ｪ蛻・ｮ帙※騾夂衍縺ｮ驥崎､・亟豁｢逕ｨ
var snoozeList = {};           // 譛滄剞騾夂衍縺ｮ繧ｹ繝後・繧ｺ邂｡逅・畑
var lastAssigneeHtml = "";     // ToDo菴懈･ｭ閠・Μ繧ｹ繝医・繧ｭ繝｣繝・す繝･

// ---------- 繧ｿ繝門・繧頑崛縺・----------
function switchTab(tabId) {
    if (tabId === "tab-notes") {
        var tabBtn = document.getElementById("tab-btn-notes");
        if (tabBtn) removeClass(tabBtn, "tab-updated");
        var ta = document.getElementById("sharedTextArea");
        if (ta) removeClass(ta, "text-updated");
    }
    if (tabId === "tab-history") {
        var tabBtn = document.getElementById("tab-btn-history");
        if (tabBtn) removeClass(tabBtn, "tab-updated");
    }
    if (tabId === "tab-todo") {
        var tabBtn = document.getElementById("tab-btn-todo");
        if (tabBtn) removeClass(tabBtn, "tab-updated");
    }
    lastSeenTimestamp = new Date().getTime(); // 迴ｾ蝨ｨ縺ｮ譎ょ綾繧定ｨ倬鹸

    var tabs = document.querySelectorAll('.tab');
    var contents = document.querySelectorAll('.tab-content');
    
    for (var i = 0; i < tabs.length; i++) {
        if(tabs[i]) removeClass(tabs[i], 'active');
    }
    for (var i = 0; i < contents.length; i++) {
        if(contents[i]) removeClass(contents[i], 'active');
    }
    
    // 驕ｸ謚槭＆繧後◆繧ｿ繝悶°繧画眠逹騾夂衍繧ｯ繝ｩ繧ｹ繧呈ｶ医☆
    var selectedTabBtn = document.getElementById('tab-btn-' + tabId.replace('tab-',''));
    if(selectedTabBtn) {
        addClass(selectedTabBtn, 'active');
        removeClass(selectedTabBtn, 'tab-updated'); // 髢九＞縺溽椪髢薙↓騾夂衍豸医☆
    }
    
    addClass(document.getElementById(tabId), 'active');

    if(tabId === 'tab-todo') renderTodos();
    if(tabId === 'tab-history') renderHistory();
    if(tabId === 'tab-notes') renderNotes();
    if(tabId === 'tab-kartelink') renderKarteLinks();
}

function switchWard(wardCode) {
    currentFilterTag = ""; // 逞・｣溘ｒ蛻・ｊ譖ｿ縺医◆譎ゅ・繝輔ぅ繝ｫ繧ｿ繝ｼ繧偵Μ繧ｻ繝・ヨ縺吶ｋ
    currentWard = wardCode;
    renderCustomTabsUI(); // 繧ｫ繧ｹ繧ｿ繝繧ｿ繝悶ｒ蜷ｫ繧√※蜀肴緒逕ｻ
    renderPatients();
    
    // 笆ｼ 縺薙・1陦後ｒ霑ｽ蜉縺励※縲∫羅譽溷・繧頑崛縺域凾縺ｫ蜈･髯｢莠亥ｮ壹ｂ蜀榊叙蠕励＆縺帙ｋ
    fetchAdmissionSchedule();

    // 繧ｫ繝ｫ繝・ink繧ｿ繝悶′陦ｨ遉ｺ荳ｭ縺ｪ繧画ぅ閠・ｸ隕ｧ繧よ峩譁ｰ縺吶ｋ
    var klTab = document.getElementById('tab-kartelink');
    if (klTab && klTab.className.indexOf('active') !== -1) {
        renderKarteLinks();
    }
}

function switchNoteWard(wardCode) {
    currentWard = wardCode;
    renderWardTabs();
    renderNotes();
}

// 逞・｣溘さ繝ｼ繝峨°繧牙錐蜑阪ｒ蜿門ｾ励☆繧九・繝ｫ繝代・
function getWardName(code) {
    for (var i = 0; i < ALL_WARDS.length; i++) {
        if (ALL_WARDS[i].code === code) return ALL_WARDS[i].name;
    }
    return code;
}

function getTodayString() {
    var now = new Date();
    return now.getFullYear() + "/" + ("0" + (now.getMonth() + 1)).slice(-2) + "/" + ("0" + now.getDate()).slice(-2);
}

// 繧ｵ繝悶ち繝悶ｒ蜍慕噪縺ｫ謠冗判
// 繧ｵ繝悶ち繝悶ｒ蜍慕噪縺ｫ謠冗判
// 繧ｵ繝悶ち繝悶ｒ蜍慕噪縺ｫ謠冗判
function renderWardTabs() {
    var activeCodes = (appData.settings && appData.settings.activeWardCodes) || ["99"];
    var containers = ["sub-tabs-container", "note-sub-tabs-container", "kl-sub-tabs-container"];
    for (var c = 0; c < containers.length; c++) {
        var container = document.getElementById(containers[c]);
        if (!container) continue;
        var html = "";
        for (var i = 0; i < activeCodes.length; i++) {
            var code = activeCodes[i];
            var name = getWardName(code);
            var activeClass = (code === currentWard) ? " active" : "";
            var isKL = (containers[c] === "kl-sub-tabs-container");
            var klClass = isKL ? " kl-ward-btn" : "";
            var onclick = (containers[c] === "note-sub-tabs-container") ? "switchNoteWard" : "switchWard";
            var closeBtnColor = (code === currentWard) ? "rgba(255,255,255,0.8)" : "#999";
            
            // 笘・ｿｮ豁｣: 繧ｨ繝・ぅ繧ｿ縺ｮ閾ｪ蜍墓隼陦後〒繧ｨ繝ｩ繝ｼ縺瑚ｵｷ縺阪↑縺・ｈ縺・∫ｴｰ縺九￥譁・ｭ怜・繧堤ｹ九＄螳牙・縺ｪ譖ｸ縺肴婿縺ｫ螟画峩
            html += '<div class="sub-tab' + klClass + activeClass + '" ';
            html += 'style="position:relative; padding-right:25px;" ';
            html += 'onclick="' + onclick + '(\'' + code + '\')">';
            html += name;
            html += '<span class="tab-close-btn" ';
            html += 'onclick="event.stopPropagation(); removeWard(\'' + code + '\')" ';
            html += 'style="position:absolute; right:5px; top:50%; margin-top:-8px; font-size:10px; color:' + closeBtnColor + '; cursor:pointer;">&times;</span>';
            html += '</div>';
        }
        container.innerHTML = html;
    }
}
// +繝懊ち繝ｳ縺ｯ蟶ｸ譎り｡ｨ遉ｺ・亥宛蠕｡縺ｪ縺暦ｼ・

// 逞・｣溘・霑ｽ蜉繝ｻ蜑企勁
function showAddWardModal() {
    var activeCodes = appData.settings.activeWardCodes || [];
    var html = '<div style="background:white; padding:20px; border-radius:8px; width:300px;">';
    html += '<h3>陦ｨ遉ｺ縺吶ｋ逞・｣溘ｒ霑ｽ蜉</h3><div style="max-height:300px; overflow-y:auto; margin-bottom:15px;">';
    for (var i = 0; i < ALL_WARDS.length; i++) {
        var w = ALL_WARDS[i];
        var alreadyActive = false;
        for (var j = 0; j < activeCodes.length; j++) if (activeCodes[j] === w.code) alreadyActive = true;
        
        if (!alreadyActive) {
            html += '<div style="padding:10px; border-bottom:1px solid #eee; cursor:pointer;" onclick="addWard(\'' + w.code + '\')">' + w.name + '</div>';
        }
    }
    html += '</div><button class="btn" onclick="closeAddWardModal()" style="width:100%;">繧ｭ繝｣繝ｳ繧ｻ繝ｫ</button></div>';
    
    var modal = document.createElement("div");
    modal.id = "modal-add-ward";
    modal.style.position = "fixed";
    modal.style.top = "0"; modal.style.left = "0"; modal.style.width = "100%"; modal.style.height = "100%";
    modal.style.background = "rgba(0,0,0,0.5)";
    modal.style.display = "flex"; modal.style.justifyContent = "center"; modal.style.alignItems = "center";
    modal.style.zIndex = "3000";
    modal.innerHTML = html;
    document.body.appendChild(modal);
}

function closeAddWardModal() {
    var modal = document.getElementById("modal-add-ward");
    if (modal) modal.parentNode.removeChild(modal);
}

function addWard(code) {
    if (!appData.settings.activeWardCodes) appData.settings.activeWardCodes = [];
    appData.settings.activeWardCodes.push(code);
    closeAddWardModal();
    currentWard = code;
    //  繧貞他縺ｰ縺ｪ縺・ 繧ｻ繝・す繝ｧ繝ｳ荳ｭ縺ｮ荳譎りｿｽ蜉縺ｮ縺ｿ
    renderWardTabs();
    if (typeof TodoUI !== "undefined") TodoUI.renderSubTabs(); // ToDo繧ｿ繝悶ｂ蜷梧悄
    if (document.getElementById("tab-patients").className.indexOf("active") !== -1) renderPatients();
    else if (document.getElementById("tab-notes").className.indexOf("active") !== -1) renderNotes();
}

function removeWard(code) {
    var codes = appData.settings.activeWardCodes || [];
    if (codes.length <= 1) { alert("譛菴弱〒繧・縺､縺ｮ逞・｣溘ｒ陦ｨ遉ｺ縺吶ｋ蠢・ｦ√′縺ゅｊ縺ｾ縺吶・); return; }
    
    var newCodes = [];
    for (var i = 0; i < codes.length; i++) {
        if (codes[i] !== code) newCodes.push(codes[i]);
    }
    appData.settings.activeWardCodes = newCodes;
    if (currentWard === code) currentWard = newCodes[0];

    renderWardTabs();
    if (typeof TodoUI !== "undefined") TodoUI.renderSubTabs(); // ToDo繧ｿ繝悶ｂ蜷梧悄
    if (document.getElementById("tab-patients").className.indexOf("active") !== -1) renderPatients();
    else if (document.getElementById("tab-notes").className.indexOf("active") !== -1) renderNotes();
}

// ---------- 蜈ｱ騾壹Θ繝ｼ繝・ぅ繝ｪ繝・ぅ ----------
function escapeHtml(str) {
    if (!str) return "";
    return str.replace(/[&<>"']/g, function(m) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m];
    });
}



function hasClass(el, name) {
    if (!el) return false;
    if (el.classList) return el.classList.contains(name);
    return new RegExp("(^|\\s)" + name + "(\\s|$)").test(el.className);
}

function addClass(el, name) {
    if (!el) return;
    if (el.classList) el.classList.add(name);
    else if (!hasClass(el, name)) el.className += " " + name;
}

function removeClass(el, name) {
    if (!el) return;
    if (el.classList) el.classList.remove(name);
    else el.className = el.className.replace(new RegExp("(^|\\s)" + name + "(\\s|$)", "g"), "$1").replace(/\s\s+/g, " ").trim();
}

// ---------- 繝輔ぃ繧､繝ｫ謫堺ｽ・(FileSystemObject / Utf8 / JSON) ----------
var fso = null;
function initFSO() {
    if (fso) return true;
    try {
        fso = new ActiveXObject("Scripting.FileSystemObject");
        return true;
    } catch (e) {
        alert("FileSystemObject縺ｮ蛻晄悄蛹悶↓螟ｱ謨励＠縺ｾ縺励◆縲・E縺ｮ險ｭ螳壹〒ActiveX繧呈怏蜉ｹ縺ｫ縺励※縺上□縺輔＞縲・);
        return false;
    }
}

function saveTextUtf8(path, text) {
    var maxRetries = 10; // 譛螟ｧ10蝗・邏・遘・繝ｪ繝医Λ繧､
    for (var i = 0; i < maxRetries; i++) {
        try {
            var stream = new ActiveXObject("ADODB.Stream");
            stream.Type = 2; stream.Charset = "UTF-8";
            stream.Open(); stream.WriteText(text);
            stream.SaveToFile(path, 2); stream.Close();
            return true;
        } catch (e1) {
            try {
                if (!fso) initFSO();
                var ts = fso.OpenTextFile(path, 2, true, -1);
                ts.Write(text);
                ts.Close();
                return true;
            } catch (e2) {
                // 繝ｭ繝・け縺輔ｌ縺ｦ縺・ｋ蝣ｴ蜷医・200ms蠕・ｩ溘＠縺ｦ蜀崎ｩｦ陦・
                var start = new Date().getTime();
                while (new Date().getTime() < start + 200);
            }
        }
    }
    return false;
}

function loadTextUtf8(path) {
    var maxRetries = 3;
    var lastError = null;
    for (var i = 0; i < maxRetries; i++) {
        try {
            // 笘・ｿｽ蜉: 繝阪ャ繝医Ρ繝ｼ繧ｯ繝峨Λ繧､繝悶・蜿､縺・く繝｣繝・す繝･繧定ｲｫ騾壹☆繧九◆繧√∝挨蜷阪さ繝斐・繧剃ｽ懊▲縺ｦ縺九ｉ隱ｭ繧
            if (!fso) initFSO();
            var tempPath = path + "." + new Date().getTime() + ".tmp";
            fso.CopyFile(path, tempPath, true); // 繧ｳ繝斐・縺吶ｋ縺薙→縺ｧ蠑ｷ蛻ｶ逧・↓繧ｵ繝ｼ繝舌・縺ｮ譛譁ｰ螳滉ｽ薙ｒ蜿門ｾ・
            
            var stream = new ActiveXObject("ADODB.Stream");
            stream.Type = 2; // text
            stream.Charset = "utf-8";
            stream.Open();
            stream.LoadFromFile(tempPath);
            var text = stream.ReadText();
            stream.Close();
            
            // 隱ｭ縺ｿ邨ゅｏ縺｣縺滉ｸ譎ゅヵ繧｡繧､繝ｫ繧呈祉髯､
            try { fso.DeleteFile(tempPath); } catch(e) {}
            
            return text;
        } catch(e) {
            lastError = e;
            // 繝阪ャ繝医Ρ繝ｼ繧ｯ迸ｬ譁ｭ蟇ｾ遲・ 遏ｭ縺・ｾ・ｩ溷ｾ後↓繝ｪ繝医Λ繧､
            var start = new Date().getTime();
            while (new Date().getTime() < start + 100); 
        }
    }
    throw lastError;
}

function stringifyData(obj) {
    if (typeof JSON !== 'undefined' && JSON.stringify) {
        return JSON.stringify(obj);
    }
    if (obj === null) return "null";
    var type = typeof obj;
    if (type === "number") return obj;
    if (type === "boolean") return obj;
    if (type === "string") return '"' + obj.replace(/"/g, '\\"') + '"';
    if (obj instanceof Array) {
        var res = [];
        for (var i = 0; i < obj.length; i++) res.push(stringifyData(obj[i]));
        return "[" + res.join(",") + "]";
    }
    if (type === "object") {
        var res = [];
        for (var k in obj) {
            if (obj.hasOwnProperty(k)) res.push('"' + k + '":' + stringifyData(obj[k]));
        }
        return "{" + res.join(",") + "}";
    }
    return '""';
}

function parseData(str) {
    if (!str) return null;
    try {
        if (typeof JSON !== 'undefined' && JSON.parse) {
            return JSON.parse(str);
        }
        return eval("(" + str + ")");
    } catch (e) { return null; }
}

// ---------- 繝・・繧ｿ豌ｸ邯壼喧 (5繝輔ぃ繧､繝ｫ蛻・牡繝ｻ螳悟・蜷梧悄迚・ ----------

function getDataDir() {
    if (!initFSO()) return "";
    var dataDir = SHARED_DATA_PATH;
    // 繝輔か繝ｫ繝縺後↑縺・ｴ蜷医・菴懈・繧定ｩｦ縺ｿ繧具ｼ・繝峨Λ繧､繝冶・菴薙′譛ｪ謗･邯壹↑繧牙､ｱ謨励☆繧具ｼ・
    try {
        if (!fso.FolderExists(dataDir)) fso.CreateFolder(dataDir);
    } catch(e) { return ""; }
    return dataDir;
}

function getJsonPath(cat) {
    return fso.BuildPath(getDataDir(), cat + ".json");
}

function readJsonFile(cat) {
    try {
        var p = getJsonPath(cat);
        if (!fso.FileExists(p)) return null;
        return parseData(loadTextUtf8(p));
    } catch(e) { return null; }
}

function writeJsonFile(cat, obj) {
    try {
        return saveTextUtf8(getJsonPath(cat), stringifyData(obj));
    } catch(e) { return false; }
}

function loadDiskData() {
    var disk = {
        patients: {}, wardNotes: {},
        todos: [], history: [],
        settings: { 
            adminIds: ["16622", "17049", "17494", "17701", "17702", "3107", "17397", "17050", "16623", "17496", "3429", "17626"], 
            activeWardCodes: ["99"] 
        },
        users: {}, yrSettings: {}, announcement: "",
        admissionSchedule: [], dischargedArchive: []
    };
    var loadSuccessCount = 0;
    var fatalError = false;

    // 蛟句挨繝輔ぃ繧､繝ｫ縺ｮ隱ｭ縺ｿ霎ｼ縺ｿ繝倥Ν繝代・
    function safeRead(cat) {
        try {
            var p = getJsonPath(cat);
            if (!fso.FileExists(p)) return null;
            var txt = loadTextUtf8(p);
            if (txt === null || txt === "") return null;
            var data = parseData(txt);
            if (data) loadSuccessCount++;
            return data;
        } catch(e) {
            fatalError = true;
            return null;
        }
    }


    // 騾壼ｸｸ縺ｮ繝輔ぃ繧､繝ｫ隱ｭ縺ｿ霎ｼ縺ｿ
    var pat = safeRead("patients") || {};
    if (pat.patients) {
        disk.patients = pat.patients;
    } else {
        var patKeys = ["patientsWard1","patientsWard2","patientsWard3"];
        for (var i = 0; i < patKeys.length; i++) {
            var k = patKeys[i];
            if (pat[k] instanceof Array) disk[k] = pat[k];
        }
    }
    if (pat.admissionSchedule instanceof Array) disk.admissionSchedule = pat.admissionSchedule;

    var todos = safeRead("todos");
    if (todos instanceof Array) disk.todos = todos;

    var hist = safeRead("history");
    if (hist instanceof Array) disk.history = hist;

    var notes = safeRead("notes") || {};
    if (notes.wardNotes) {
        disk.wardNotes = notes.wardNotes;
    } else {
        disk.wardNotes = notes;
    }

    var settings = safeRead("settings") || {};
    for (var sk in settings) {
        if (settings.hasOwnProperty(sk)) disk.settings[sk] = settings[sk];
    }
    if (disk.settings.users) disk.users = disk.settings.users;
    else if (disk.users) disk.settings.users = disk.users;
    
    if (settings.yrSettings) disk.yrSettings = settings.yrSettings;
    else {
        var yrSet = safeRead("yrSettings");
        if (yrSet) disk.yrSettings = yrSet;
    }
    if (settings.announcement !== undefined) disk.announcement = settings.announcement;

    // 隱ｭ縺ｿ霎ｼ縺ｿ邨先棡縺ｮ蛻､螳・
    if (loadSuccessCount === 0 && !fatalError) {
        // 險ｭ螳壹ｂ謔｣閠・ｂ荳縺､繧りｪｭ繧√↑縺九▲縺滂ｼ医°縺､繧ｨ繝ｩ繝ｼ繧ょ・縺ｦ縺・↑縺・ｼ牙ｴ蜷医・縲・
        // 繝輔か繝ｫ繝縺檎ｩｺ縺九√≠繧九＞縺ｯ繝代せ縺碁俣驕輔▲縺ｦ縺・ｋ蜿ｯ閭ｽ諤ｧ縲・
        // 縺薙％縺ｧ縺ｯ遨ｺ縺ｮ螳滉ｽ薙→縺励※謇ｱ縺・′縲《aveData 蛛ｴ縺ｮ繧ｬ繝ｼ繝峨〒逋ｽ邏吩ｸ頑嶌縺阪ｒ髦ｲ縺舌・
    }
    if (fatalError) {
        disk._isLoadFailed = true; 
    }

    return disk;
}

function saveDiskData(data) {
    if (!initFSO()) return false;
    var ok = true;

    // 譌･谺｡繝舌ャ繧ｯ繧｢繝・・縺ｮ螳溯｡・(1譌･1蝗・
    checkAndCreateBackup(data);

    // 謔｣閠・ョ繝ｼ繧ｿ (蜈ｨ逞・｣溷・)
    var patData = { 
        patients: data.patients || {},
        admissionSchedule: data.admissionSchedule || [],
        dischargedArchive: data.dischargedArchive || []
    };
    if (!writeJsonFile("patients", patData)) ok = false;

    // ToDo
    if (!writeJsonFile("todos", data.todos || [])) ok = false;

    // 繝弱・繝・
    if (!writeJsonFile("notes", { wardNotes: data.wardNotes || {} })) ok = false;
    
    // 縲占ｿｽ蜉縲台ｿ晏ｭ伜燕縺ｫannouncement・医♀遏･繧峨○・峨→yrSettings繧痴ettings縺ｮ荳ｭ縺ｫ譬ｼ邏阪☆繧・
    if (!data.settings) data.settings = {};
    if (data.announcement !== undefined) data.settings.announcement = data.announcement;
    if (data.yrSettings !== undefined) data.settings.yrSettings = data.yrSettings;

    // 險ｭ螳・
    if (!writeJsonFile("settings", data.settings || {})) ok = false;
    // 螻･豁ｴ
    if (!writeJsonFile("history", data.history || [])) ok = false;

    // 螟画鋤螻･豁ｴ繝ｻ繝ｦ繝ｼ繧ｶ繝ｼ蛟句挨險ｭ螳壹ｒ蟆ら畑繝輔ぃ繧､繝ｫ縺ｨ縺励※繧ゆｿ晏ｭ・
    if (!writeJsonFile("yrSettings", data.yrSettings || {})) ok = false;

    return ok;

}

function checkAndCreateBackup(data) {
    try {
        var today = getTodayString(); // e.g. "2026/03/28" 
        if (!data.settings) data.settings = {};
        var last = data.settings.lastBackupDate || "";
        if (last === today) return;

        var backupDirRoot = fso.BuildPath(SHARED_DATA_PATH, "backup");
        if (!fso.FolderExists(backupDirRoot)) fso.CreateFolder(backupDirRoot);
        
        var dateDirName = today.replace(/\//g, "");
        var targetDir = fso.BuildPath(backupDirRoot, dateDirName);
        if (!fso.FolderExists(targetDir)) fso.CreateFolder(targetDir);
        
        var files = ["patients.json", "settings.json", "todos.json", "notes.json", "history.json", "yrSettings.json"];
        for(var i=0; i<files.length; i++) {
            var src = getJsonPath(files[i].replace(".json", ""));
            if (fso.FileExists(src)) {
                fso.CopyFile(src, fso.BuildPath(targetDir, files[i]), true);
            }
        }
        data.settings.lastBackupDate = today;
    } catch(e) {}
}

function applyWardTabs() {
    // 笘・ｿｮ豁｣: ToDo繧ｿ繝悶ｒ譌ｧ莉墓ｧ倥・繧ｳ繝ｼ繝峨〒荳頑嶌縺咲ｴ螢翫＠縺ｦ縺・◆蜃ｦ逅・ｒ蜈ｨ蜑企勁縲・
    // 譌ｧ莉墓ｧ倥・繝懊ち繝ｳ鄒､繧帝撼陦ｨ遉ｺ縺ｫ縺吶ｋ縺縺代・讖溯・縺ｫ螟画峩・・oDo遲峨・繧ｿ繝悶・蟆ら畑UI繝｢繧ｸ繝･繝ｼ繝ｫ縺ｫ莉ｻ縺帙ｋ・・
    for (var j = 1; j <= 10; j++) {
        var b = document.getElementById('btn-ward-' + j);
        var k = document.getElementById('kl-btn-ward-' + j);
        var n = document.getElementById('note-btn-ward-' + j);
        if (b) b.style.display = "none";
        if (k) k.style.display = "none";
        if (n) n.style.display = "none";
    }
}

// 繝槭・繧ｸ逕ｨ繝倥Ν繝代・
function mergeArrayById(baseList, diskList, myList, mergeFunc) {
    var baseMap = {}, myMap = {}, diskMap = {};
    function populateMap(arr, map) {
        for (var i = 0; i < arr.length; i++) {
            if (arr[i] && arr[i].id) map[arr[i].id] = arr[i];
        }
    }
    populateMap(baseList || [], baseMap);
    populateMap(myList || [], myMap);
    populateMap(diskList || [], diskMap);

    var allIds = {};
    for (var id in baseMap) allIds[id] = true;
    for (var id in myMap)   allIds[id] = true;
    for (var id in diskMap) allIds[id] = true;

    var mergedList = [];
    for (var id in allIds) {
        var b = baseMap[id], m = myMap[id], d = diskMap[id];
        var t = mergeFunc(b, d, m);
        if (t) mergedList.push(t);
    }
    return mergedList;
}

function mergePatients(b, d, m) {
    if (!m && b) return null; // 閾ｪ蛻・′蜑企勁
    if (m && !b) return m;    // 閾ｪ蛻・′霑ｽ蜉
    if (!m && !b) return d;   // 縺ｩ縺｡繧峨ｂ譁ｰ隕擾ｼ井ｻ紋ｺｺ縺瑚ｿｽ蜉・・
    // 繝輔ぅ繝ｼ繝ｫ繝峨＃縺ｨ縺ｫ繝槭・繧ｸ
    if (m.status !== b.status) {
        d.status = m.status;
        d.statusAuthor = m.statusAuthor; // 繧ｹ繝・・繧ｿ繧ｹ螟画峩縺ｫ莨ｴ縺・ｮ滓命閠・ｂ譖ｴ譁ｰ
    } else if (m.statusAuthor !== b.statusAuthor) {
        d.statusAuthor = m.statusAuthor; // 繧ｹ繝・・繧ｿ繧ｹ縺悟酔縺倥〒繧ょｮ滓命閠・′螟峨ｏ繧句ｴ蜷医↓蛯吶∴繧・
    }

    if (m.chkPrescription !== b.chkPrescription) d.chkPrescription = m.chkPrescription;
    if (m.alertLevel !== b.alertLevel) d.alertLevel = m.alertLevel;
    if (m.memoAuthor !== b.memoAuthor) d.memoAuthor = m.memoAuthor;
    if (m.memoAuthors && m.memoAuthors.length !== (b.memoAuthors || []).length) d.memoAuthors = m.memoAuthors;
    
    if (m.bloodDate !== b.bloodDate) d.bloodDate = m.bloodDate;
    if (m.bloodDetail !== b.bloodDetail) d.bloodDetail = m.bloodDetail;

    var myMemoChanged = (m.memo !== b.memo);
    var diskMemoChanged = (d.memo !== b.memo);

    if (myMemoChanged && diskMemoChanged && d.memo !== m.memo) {
        // 閾ｪ蛻・ｂ莉紋ｺｺ繧ょ酔譎ゅ↓逡ｰ縺ｪ繧句､画峩繧偵＠縺溷ｴ蜷茨ｼ育ｫｶ蜷茨ｼ峨・謾ｹ陦後＠縺ｦ荳｡譁ｹ谿九☆
        var dm = (d.memo || "").trim(), mm = (m.memo || "").trim();
        d.memo = (dm && mm) ? (mm + "\n" + dm) : (mm !== "" ? mm : dm);
    } else if (myMemoChanged) {
        // 閾ｪ蛻・□縺代′螟画峩縺励◆・亥炎髯､縺励※遨ｺ谺・↓縺励◆蝣ｴ蜷医ｂ縺薙％繧帝壹ｋ・・
        d.memo = m.memo;
    }
    if (!d.personalMemos) d.personalMemos = {};
    var bPM = b.personalMemos || {}, mPM = m.personalMemos || {};
    for (var pmk in mPM) {
        if (mPM.hasOwnProperty(pmk) && mPM[pmk] !== bPM[pmk]) d.personalMemos[pmk] = mPM[pmk];
    }
    return d;
}

function mergeTodos(b, d, m) {
    if (!m && b) return null;
    if (m && !b) return m;
    if (!m && !b) return d;
    if (m.done !== b.done) d.done = m.done;
    if (m.deleted !== b.deleted) d.deleted = m.deleted;
    if (m.text !== b.text) d.text = m.text;
    if (m.deadline !== b.deadline) d.deadline = m.deadline;
    if (m.assignee !== b.assignee) d.assignee = m.assignee;
    if (m.reminderOffset !== b.reminderOffset) d.reminderOffset = m.reminderOffset;
    if (m.notifyOnDone !== b.notifyOnDone) d.notifyOnDone = m.notifyOnDone;
    if (m.alerted && !b.alerted) d.alerted = m.alerted;
    if (m.doneAlerted && !b.doneAlerted) d.doneAlerted = m.doneAlerted;
    if (m.archived !== b.archived) d.archived = m.archived;
    return d;
}

function mergeWardNotes(b, d, m) {
    if (!m && b) return null;
    if (m && !b) return m;
    if (!m && !b) return d;
    if (m.title !== b.title) d.title = m.title;
    if (m.content !== b.content) d.content = m.content;
    if (m.author !== b.author) d.author = m.author;
    if (m.updatedAt !== b.updatedAt) d.updatedAt = m.updatedAt;
    return d;
}

function perform3WayMerge(baseData, diskData, myData) {
    if (!myData) return diskData || {};
    if (!diskData) return myData;
    if (!baseData) baseData = {};
    var result = {};
    try {
        // 1. 謔｣閠・Μ繧ｹ繝・(蜍慕噪逞・｣溘く繝ｼ蟇ｾ蠢・
        result.patients = {};
        var allPWardCodes = {};
        if (diskData.patients) for (var c1 in diskData.patients) allPWardCodes[c1] = true;
        if (myData.patients)   for (var c2 in myData.patients)   allPWardCodes[c2] = true;
        if (baseData.patients) for (var c3 in baseData.patients) allPWardCodes[c3] = true;
        for (var wk in allPWardCodes) {
            result.patients[wk] = mergeArrayById(
                (baseData.patients||{})[wk], (diskData.patients||{})[wk], (myData.patients||{})[wk], mergePatients
            );
        }

        // 2. ToDo
        result.todos = mergeArrayById(baseData.todos, diskData.todos, myData.todos, mergeTodos);

        // 3. 繝弱・繝・(蜍慕噪逞・｣溘く繝ｼ蟇ｾ蠢・
        result.wardNotes = {};
        var allNWardCodes = {};
        if (diskData.wardNotes) for (var n1 in diskData.wardNotes) allNWardCodes[n1] = true;
        if (myData.wardNotes)   for (var n2 in myData.wardNotes)   allNWardCodes[n2] = true;
        if (baseData.wardNotes) for (var n3 in baseData.wardNotes) allNWardCodes[n3] = true;
        for (var nwk in allNWardCodes) {
            result.wardNotes[nwk] = mergeArrayById(
                (baseData.wardNotes||{})[nwk], (diskData.wardNotes||{})[nwk], (myData.wardNotes||{})[nwk], mergeWardNotes
            );
        }

        // 4. 螻･豁ｴ
        var myHist = (myData.history instanceof Array) ? myData.history : [];
        var diskHist = (diskData.history instanceof Array) ? diskData.history : [];
        var combo = myHist.concat(diskHist);
        var seen = {}; var resHist = [];
        for (var i = 0; i < combo.length; i++) {
            if (combo[i] && combo[i].id && !seen[combo[i].id]) {
                seen[combo[i].id] = true;
                resHist.push(combo[i]);
            }
        }
        result.history = resHist;

        // 5. 縺昴・莉・
        // settings (逞・｣溯ｨｭ螳夂ｭ・ 繧偵・繝ｭ繝代ユ繧｣縺斐→縺ｫ繝槭・繧ｸ
        result.settings = diskData.settings || {};
        if (myData.settings) {
            for (var sk in myData.settings) {
                if (myData.settings.hasOwnProperty(sk)) result.settings[sk] = myData.settings[sk];
            }
        }
        // users 縺ｯ settings 縺ｮ荳ｭ縺ｨ螟悶∽ｸ｡譁ｹ繧貞酔譛・
        result.settings.users = myData.users || diskData.users || result.settings.users || {};
        result.users = result.settings.users;

        // 縲蝉ｿｮ豁｣縲代♀遏･繧峨○縺ｮ繝槭・繧ｸ・亥炎髯､繝ｻ遨ｺ谺・喧縺ｸ縺ｮ蟇ｾ蠢懶ｼ・
        var bAnn = baseData.announcement || "";
        var dAnn = diskData.announcement || "";
        var mAnn = (myData.announcement !== undefined) ? myData.announcement : "";
        if (mAnn !== bAnn) {
            result.announcement = mAnn; // 閾ｪ蛻・′螟画峩縺励◆蝣ｴ蜷医・閾ｪ蛻・・繝・・繧ｿ繧貞━蜈・
        } else {
            result.announcement = dAnn; // 閾ｪ蛻・′螟画峩縺励※縺・↑縺・ｴ蜷医・繧ｵ繝ｼ繝舌・縺ｮ譛譁ｰ繝・・繧ｿ繧貞渚譏
        }

        // yrSettings (螟画鋤螻･豁ｴ遲・ 繧偵Θ繝ｼ繧ｶ繝ｼID縺斐→縺ｫ繝槭・繧ｸ
        result.yrSettings = diskData.yrSettings || {};
        if (myData.yrSettings) {
            for (var uid in myData.yrSettings) {
                if (myData.yrSettings.hasOwnProperty(uid)) result.yrSettings[uid] = myData.yrSettings[uid];
            }
        }


        result.admissionSchedule = mergeArrayById(baseData.admissionSchedule, diskData.admissionSchedule, myData.admissionSchedule, mergePatients);

        // 笘・ｿｮ豁｣: 騾髯｢繧｢繝ｼ繧ｫ繧､繝悶ｒ繧ｪ繝悶ず繧ｧ繧ｯ繝・霎樊嶌蝙・縺ｨ縺励※螳牙・縺ｫ繝槭・繧ｸ縺吶ｋ
        result.dischargedArchive = {};
        var allArcIds = {};
        if (diskData.dischargedArchive) for (var id in diskData.dischargedArchive) allArcIds[id] = true;
        if (myData.dischargedArchive)   for (var id in myData.dischargedArchive)   allArcIds[id] = true;
        if (baseData.dischargedArchive) for (var id in baseData.dischargedArchive) allArcIds[id] = true;
        for (var id in allArcIds) {
            var b = (baseData.dischargedArchive || {})[id];
            var d = (diskData.dischargedArchive || {})[id];
            var m = (myData.dischargedArchive || {})[id];
            var mergedArc = mergePatients(b, d, m);
            if (mergedArc) {
                mergedArc.id = id;
                result.dischargedArchive[id] = mergedArc;
            }
        }

    } catch(err) { return myData || diskData || {}; }
    return result;
}

function saveData(manual) {
    if (!isEditMode) return;
    if (appData._isLoadFailed) {
        alert("縲占・蜻ｽ逧・お繝ｩ繝ｼ縲代ョ繝ｼ繧ｿ縺ｮ隱ｭ縺ｿ蜃ｺ縺励↓螟ｱ謨励＠縺ｦ縺・ｋ縺溘ａ縲∽ｿ晏ｭ倥ｒ荳ｭ豁｢縺励∪縺励◆縲・);
        return;
    }

    if (typeof DataManager !== "undefined") {
        // DataManager縺ｫ縺吶∋縺ｦ莉ｻ縺帙ｋ縲ょｮ牙・縺ｫ繝槭・繧ｸ縺輔ｌ縺滓怙譁ｰ繝・・繧ｿ縺瑚ｿ斐▲縺ｦ縺上ｋ
        appData = DataManager.saveAll(appData); 
        window.baseAppDataStr = stringifyData(appData);
    }
    
    if (manual) alert("繝・・繧ｿ繧剃ｿ晏ｭ倥＠縺ｾ縺励◆縲・);
}

function loadData(manual) {
    if (!fso || !fso.FolderExists(SHARED_DATA_PATH)) {
        var el = document.getElementById("last-local-update-time");
        if(el) el.innerText = "[謗･邯壹お繝ｩ繝ｼ: 蜈ｱ譛峨ョ繝ｼ繧ｿ譛ｪ讀懷・]";
        if (typeof DataManager !== "undefined") DataManager.init();
        return;
    }
    
    // 笘・ｿｽ蜉: 繝・・繧ｿ隱ｭ縺ｿ霎ｼ縺ｿ縺ｧ荳頑嶌縺阪＆繧後ｋ蜑阪↓縲∫樟蝨ｨ縺ｮ逕ｻ髱｢縺ｮ縲檎羅譽溘ち繝也憾諷九阪ｒ險俶・縺励※菫晁ｭｷ縺吶ｋ
    var currentActiveCodes = [];
    if (appData && appData.settings && appData.settings.activeWardCodes) {
        currentActiveCodes = [].concat(appData.settings.activeWardCodes);
    }

    if (typeof DataManager !== "undefined") {
        appData = DataManager.loadAll();
        // 繝槭せ繧ｿ繝ｼ繝輔ぃ繧､繝ｫ隱ｭ縺ｿ霎ｼ縺ｿ逶ｴ蠕後↓譛譁ｰ縺ｮ蟾ｮ蛻・ｼ晉･ｨ繧剃ｸ贋ｹ励○縺吶ｋ
        DataManager.replayTransactions(appData);
        DataManager.appData = appData;
        window.baseAppDataStr = stringifyData(appData);
    }
    
    cachedUniqueUsers = null;
    
    // 笘・ｿｮ豁｣: 繧ｵ繝ｼ繝舌・縺ｮ繝・・繧ｿ縺ｧ繧ｿ繝悶ｒ荳頑嶌縺阪○縺壹∬ｨ俶・縺励※縺翫＞縺溘ち繝也憾諷九ｒ蠕ｩ蜈・☆繧・
    if (!appData.settings) appData.settings = {};
    if (currentActiveCodes.length > 0) {
        appData.settings.activeWardCodes = currentActiveCodes;
    } else if (currentSystemId && appData.settings.userWards && appData.settings.userWards[currentSystemId]) {
        // 荳・′荳遨ｺ縺ｮ蝣ｴ蜷医・繝ｦ繝ｼ繧ｶ繝ｼ縺ｮ蝓ｺ譛ｬ險ｭ螳壹ｒ菴ｿ縺・
        appData.settings.activeWardCodes = [].concat(appData.settings.userWards[currentSystemId]);
    }
    
    if (typeof renderCustomTabsUI !== "undefined") renderCustomTabsUI(); else renderWardTabs(); 
    renderPatients(); 
    renderTodos();
    renderHistory();
    updateAnnouncementUI();
    var elTime = document.getElementById("last-local-update-time");
    if(elTime) elTime.innerText = "[蜷梧悄螳御ｺ・ " + getTimeString() + "]";
}

function renderHistory() {
    var tbody = document.getElementById("tbody-history");
    if (!tbody) return;
    var html = "";
    var history = appData.history || [];
    for (var i = 0; i < history.length; i++) {
        var h = history[i];
        html += '<tr>';
        html += '<td>' + escapeHtml(h.date) + '</td>';
        html += '<td>' + escapeHtml(h.ward || "-") + '</td>';
        html += '<td>' + escapeHtml(h.type) + '</td>';
        html += '<td>' + escapeHtml(h.id) + '</td>';
        html += '<td>' + escapeHtml(h.patient) + '</td>';
        html += '<td>' + escapeHtml(h.dept || "-") + '</td>';
        html += '<td>' + escapeHtml(h.doctor || "-") + '</td>';
        html += '<td>' + escapeHtml(h.disease || "-") + '</td>';
        html += '</tr>';
    }
    tbody.innerHTML = html;
}



function checkMyTodos() { /* ToDo繝√ぉ繝・け蜃ｦ逅・Vol.12) - 蟆・擂螳溯｣・畑 */ }
function startDeadlineTimer() { /* 譛滄剞逶｣隕悶ち繧､繝槭・(Vol.12) - 蟆・擂螳溯｣・畑 */ }

function renderKarteLinks() {
	var tbody = document.getElementById('tbody-kartelink');
	if (!tbody) return;
	var list = getCurrentPatientsList();
	if (!list || list.length === 0) {
    	tbody.innerHTML = '<tr><td colspan="14" align="center">謔｣閠・ョ繝ｼ繧ｿ縺後≠繧翫∪縺帙ｓ縲・/td></tr>';
    	return;
	}
	
	if (klSortKey !== '') {
	    var colIdxStr = klSortKey;
	    list.sort(function(a, b) {
	        var va = a[colIdxStr] || '';
	        var vb = b[colIdxStr] || '';
	        if (colIdxStr === 'id') {
	            va = parseInt(va, 10) || 0;
	            vb = parseInt(vb, 10) || 0;
	        }
	        if (va < vb) return klSortAsc ? -1 : 1;
	        if (va > vb) return klSortAsc ? 1 : -1;
	        return 0;
	    });
	}
    
	var bs = 'padding:4px 12px;font-size:11px;margin:1px;border-radius:3px;color:#fff;cursor:pointer;border:none;';
	var html = '';
	var highlightWords = ["騾髯｢", "霆｢髯｢", "ENT", "ent"];
	var memoDisabled = isEditMode ? '' : 'disabled="disabled"';

	for (var i = 0; i < list.length; i++) {
    	var p = list[i];
    	var pid = escapeHtml(p.id);
    	var pname = escapeHtml(p.name);
    	var pMemos = (p && typeof p === 'object' && p.personalMemos) ? p.personalMemos : {};
    	var myMemo = (pMemos && currentSystemId) ? (pMemos[currentSystemId] || "") : "";
    	var memoChangeShared = isEditMode ? 'onchange="finalizeMemo(\'' + pid + '\', this)" onkeyup="updateMemoDebounced(\'' + pid + '\', this.value, this); showTagSuggest(this, event);"' : '';
    	var memoChangePersonal = isEditMode ? 'onchange="finalizePersonalMemo(\'' + pid + '\', this)" onkeyup="updatePersonalMemoDebounced(\'' + pid + '\', this.value, this); showTagSuggest(this, event);"' : '';

    	// 繝上う繝ｩ繧､繝亥愛螳夲ｼ域ぅ閠・・譛峨Γ繝｢縺ｫ蝓ｺ縺･縺擾ｼ・
    	var isHighlight = false;
    	if (p.memo) {
        	var lowerMemo = p.memo.toLowerCase();
        	for(var w=0; w<highlightWords.length; w++) {
            	if (lowerMemo.indexOf(highlightWords[w].toLowerCase()) !== -1) {
                	isHighlight = true;
                	break;
            	}
        	}
    	}
    	var hlClass = isHighlight ? ' highlight-row' : '';
   	 
    	html += '<tr>';
    	html += '<td>' + pid + '</td>';
    	html += '<td>' + pname + '</td>';
    	html += '<td style="font-size:11px;">' + escapeHtml(p.dept || "") + '</td>';
    	html += '<td style="font-size:11px;">' + escapeHtml(p.disease || "") + '</td>';
    	// 蜷・ｨｮ繝ｪ繝ｳ繧ｯ繝懊ち繝ｳ
    	html += '<td style="text-align:center; vertical-align:middle;"><button style="background:#1976d2;' + bs + '" onclick="openKarteLink(\'karte\',\'' + pid + '\')">繧ｫ繝ｫ繝・/button></td>';
    	html += '<td style="text-align:center; vertical-align:middle; white-space:nowrap;"><button style="background:#388e3c;' + bs + '" onclick="openKarteLink(\'kentai_karte\',\'' + pid + '\')">讀懈渊K</button><button style="background:#66bb6a;' + bs + '" onclick="openKarteLink(\'kentai_menu\',\'' + pid + '\')">讀懈渊M</button><br><button style="background:#43a047;' + bs + '" onclick="openKarteLink(\'kentai_s\',\'' + pid + '\')">鬆・岼S</button><button style="background:#2e7d32;' + bs + '" onclick="openKarteLink(\'kentai_d\',\'' + pid + '\')">鬆・岼D</button></td>';
    	html += '<td style="text-align:center; vertical-align:middle;"><button style="background:#e65100;' + bs + '" onclick="openKarteLink(\'vital_karte\',\'' + pid + '\')">・奇ｾ橸ｽｲ・・僵</button><br><button style="background:#ff9800;' + bs + '" onclick="openKarteLink(\'vital_menu\',\'' + pid + '\')">・奇ｾ橸ｽｲ・・儁</button></td>';
    	html += '<td style="text-align:center; vertical-align:middle;"><button style="background:#6a1b9a;' + bs + '" onclick="openKarteLink(\'document_karte\',\'' + pid + '\')">謇句ｸｳK</button><br><button style="background:#ab47bc;' + bs + '" onclick="openKarteLink(\'document_menu\',\'' + pid + '\')">謇句ｸｳM</button></td>';
    	html += '<td style="text-align:center; vertical-align:middle;"><button style="background:#c62828;' + bs + '" onclick="openKarteLink(\'allergy_karte\',\'' + pid + '\')">・ｱ・夲ｾ呻ｽｷ・橸ｽｰK</button><br><button style="background:#ef5350;' + bs + '" onclick="openKarteLink(\'allergy_menu\',\'' + pid + '\')">・ｱ・夲ｾ呻ｽｷ・橸ｽｰM</button></td>';
    	html += '<td style="text-align:center; vertical-align:middle;"><button style="background:#1565c0;' + bs + '" onclick="openKarteLink(\'shohou_s\',\'' + pid + '\')">蜃ｦ譁ｹS</button><br><button style="background:#0d47a1;' + bs + '" onclick="openKarteLink(\'shohou_d\',\'' + pid + '\')">蜃ｦ譁ｹD</button></td>';
    	html += '<td style="text-align:center; vertical-align:middle;"><button style="background:#00838f;' + bs + '" onclick="openKarteLink(\'chuusha_s\',\'' + pid + '\')">豕ｨ蟆Т</button><br><button style="background:#006064;' + bs + '" onclick="openKarteLink(\'chuusha_d\',\'' + pid + '\')">豕ｨ蟆Д</button></td>';
    	html += '<td style="text-align:center; vertical-align:middle;"><button style="background:#5d4037;' + bs + '" onclick="openKarteLink(\'ope_record\',\'' + pid + '\')">謇玖｡・/button></td>';


    	// 諠・ｱ蜈ｱ譛峨・繝｡繝｢・・谿ｵ讒区・・・
        var memoAuthorHtml = '';
        if (p.memoAuthors && p.memoAuthors.length > 0) {
            memoAuthorHtml = escapeHtml(p.memoAuthors.join(" / "));
        } else if (p.memoAuthor) {
            memoAuthorHtml = escapeHtml(p.memoAuthor);
        }

    	html += '<td class="' + hlClass + '" style="padding:4px;">';
    	html += '<textarea rows="1" ' + memoDisabled + ' ' + memoChangeShared + ' placeholder="縲仙・譛峨醍筏縺鈴√ｊ繧・Γ繝｢..." style="min-height:24px; line-height:1.2; padding:2px; font-size:12px; margin-bottom:2px; overflow:hidden;">' + escapeHtml(p.memo || "") + '</textarea>';
    	html += '<textarea rows="1" ' + memoDisabled + ' ' + memoChangePersonal + ' class="hide-on-print" placeholder="縲仙倶ｺｺ(' + escapeHtml(currentUserName) + ')縲題・蛻・畑繝｡繝｢..." style="min-height:24px; line-height:1.2; padding:2px; font-size:12px; background-color:#e8f4f8; border:1px dashed #b3d7ff; overflow:hidden;">' + escapeHtml(myMemo) + '</textarea>';
    	html += '</td>';
        html += '<td class="hide-on-print ' + hlClass + '" style="font-size:10px; color:#666;">' + memoAuthorHtml + '</td>';
    	html += '</tr>';
	}
	tbody.innerHTML = html;

	// 謠冗判蠕後∝・繝・く繧ｹ繝医お繝ｪ繧｢縺ｮ鬮倥＆繧呈枚蟄鈴㍼縺ｫ蜷医ｏ縺帙※閾ｪ蜍戊ｪｿ謨ｴ
	var textareas = tbody.getElementsByTagName('textarea');
	for(var t=0; t<textareas.length; t++) {
    	var ta = textareas[t];
    	ta.style.height = 'auto';
    	var sh = ta.scrollHeight;
    	if (sh > 0) ta.style.height = sh + 'px';
	}
}

// ---------- 逞・｣溯ｨｭ螳夂畑UI ----------
var ALL_WARDS = [
    { name: "3A繝ｻ3B", code: "31" }, { name: "NICU", code: "32" }, { name: "3C", code: "33" },
    { name: "4A", code: "41" }, { name: "4B", code: "42" }, { name: "4C", code: "43" },
    { name: "5A", code: "51" }, { name: "5B", code: "52" }, { name: "5C", code: "53" },
    { name: "6A", code: "61" }, { name: "6B", code: "62" }, { name: "6C", code: "63" },
    { name: "TEST(・・橸ｾ撰ｽｰ)", code: "99" }
];
var pendingSettings = [];

function renderWardSettingButtons() {
    var container = document.getElementById("ward-select-container");
    if(!container) return;
    pendingSettings = [];
    var defaultCodes = appData.settings.defaultWardCodes || appData.settings.activeWardCodes || [];
    for (var i = 0; i < defaultCodes.length; i++) {
        var code = defaultCodes[i];
        var name = getWardName(code);
        if (code) pendingSettings.push({ code: code, name: name });
    }
    drawWardButtons();
}

function drawWardButtons() {
    var container = document.getElementById("ward-select-container");
    if(!container) return;
    var html = "";
    for(var i=0; i<ALL_WARDS.length; i++) {
        var w = ALL_WARDS[i];
        var isSelected = false;
        for(var j=0; j<pendingSettings.length; j++) {
             if(pendingSettings[j].code === w.code) isSelected = true;
        }
        var cls = isSelected ? "ward-setting-btn selected" : "ward-setting-btn";
        var disabled = isEditMode ? "" : "disabled='disabled'";
        var click = isEditMode ? 'onclick="toggleWardSelection(\'' + w.code + '\', \'' + w.name + '\')"' : '';
        html += '<button class="' + cls + '" ' + click + ' ' + disabled + '>' + w.name + '</button>';
    }
    container.innerHTML = html;
}

function toggleWardSelection(code, name) {
    for(var i=0; i<pendingSettings.length; i++) {
        if(pendingSettings[i].code === code) {
            pendingSettings.splice(i, 1);
            drawWardButtons(); return;
        }
    }
    pendingSettings.push({ code: code, name: name });
    drawWardButtons();
}

function saveSettingsForm() {
    if(!isEditMode) return;
    if(!appData.settings) appData.settings = {};
    
    var customNameIpt = document.getElementById("ipt-custom-ward-name");
    var customCodeIpt = document.getElementById("ipt-custom-ward-code");
    var customName = customNameIpt ? customNameIpt.value.trim() : "";
    var customCode = customCodeIpt ? customCodeIpt.value.trim() : "";
    
    // 蛻晄悄陦ｨ遉ｺ繝ｪ繧ｹ繝医・菫晏ｭ・(Vol.16)
    var codes = [];
    for(var i=0; i<pendingSettings.length; i++) {
        codes.push(pendingSettings[i].code);
    }
    if (customCode !== "") {
        // 繧ｫ繧ｹ繧ｿ繝繧ｳ繝ｼ繝峨ｂ縺ゅｌ縺ｰ霑ｽ蜉
        if (codes.indexOf(customCode) === -1) codes.push(customCode);
        // ALL_WARDS 縺ｫ荳譎ら噪縺ｫ霑ｽ蜉・亥錐蜑崎ｧ｣豎ｺ縺ｮ縺溘ａ・・
        var found = false;
        for(var k=0; k<ALL_WARDS.length; k++) { if(ALL_WARDS[k].code === customCode){ found=true; break; } }
        if(!found) ALL_WARDS.push({ name: customName || "閾ｪ逕ｱ譫", code: customCode });
    }
    
    // 繧｢繝励Μ蜈ｨ菴薙〒縺ｯ縺ｪ縺上√Θ繝ｼ繧ｶ繝ｼ縺斐→縺ｮ險ｭ螳壽棧(userWards)縺ｫ菫晏ｭ倥☆繧・
    if (!appData.settings.userWards) appData.settings.userWards = {};
    appData.settings.userWards[currentSystemId] = codes;
    
    appData.settings.activeWardCodes = [].concat(codes);
    // 迴ｾ蝨ｨ縺ｮ陦ｨ遉ｺ繧よ峩譁ｰ
    
    saveData(true);
    alert("逞・｣溯ｨｭ螳壹ｒ菫晏ｭ倥＠縺ｾ縺励◆縲ら樟蝨ｨ縺ｮ陦ｨ遉ｺ繧ｿ繝悶ｒ譖ｴ譁ｰ縺励∪縺吶・);
    
    currentWard = codes[0] || "99";
    renderWardTabs();
    renderPatients();
    switchTab('tab-patients');
}

function getCurrentNotes() {
    if (!appData.wardNotes) appData.wardNotes = {};
    if (!appData.wardNotes[currentWard]) appData.wardNotes[currentWard] = [];
    return appData.wardNotes[currentWard];
}

function renderNotes() {
    var container = document.getElementById("note-list-container");
    if (!container) return;
    var notes = getCurrentNotes();
    var searchInput = document.getElementById("ipt-note-search");
    var searchQ = searchInput ? searchInput.value.trim().toLowerCase() : "";
    
    var html = "";
    var displayCount = 0;
    for (var i = 0; i < notes.length; i++) {
        var n = notes[i];
        if (searchQ !== "" && n.title.toLowerCase().indexOf(searchQ) === -1 && n.content.toLowerCase().indexOf(searchQ) === -1) continue;
        
        var activeClass = (selectedNoteId === n.id) ? " active" : "";
        html += '<div class="note-item' + activeClass + '" onclick="selectNote(' + n.id + ')">';
        html += '<div class="note-item-title">' + (escapeHtml(n.title) || "(辟｡鬘・") + '</div>';
        html += '<div class="note-item-meta">' + escapeHtml(n.author) + ' ' + escapeHtml(n.date.split(" ")[0]) + '</div>';
        html += '</div>';
        displayCount++;
    }
    container.innerHTML = html || '<div style="padding:20px; color:#999; text-align:center;">繝壹・繧ｸ縺後≠繧翫∪縺帙ｓ</div>';

    // 邱ｨ髮・お繝ｪ繧｢縺ｮ陦ｨ遉ｺ蛻ｶ蠕｡
    var editor = document.getElementById("note-editor");
    var emptyMsg = document.getElementById("note-empty-msg");
    if (selectedNoteId !== null) {
        var current = null;
        for(var j=0; j<notes.length; j++) { if(notes[j].id === selectedNoteId){ current = notes[j]; break; } }
        if (current) {
            editor.style.display = "flex";
            emptyMsg.style.display = "none";
            document.getElementById("note-title").value = current.title;
            // 繝ｪ繝・メ繝・く繧ｹ繝医お繝ｪ繧｢縺ｸ縺ｮ蜿肴丐・井ｸ蝗槭□縺題｡後≧縲らｷｨ髮・ｸｭ縺ｯ innerHTML 繧偵＞縺倥ｉ縺ｪ縺・ｼ・
            var richEditor = document.getElementById("note-editor-rich");
            if (richEditor && document.activeElement !== richEditor) {
                richEditor.innerHTML = current.content;
            }
            document.getElementById("note-meta").innerText = "譛邨よ峩譁ｰ: " + current.author + " (" + current.date + ")";
        }
    } else {
        editor.style.display = "none";
        emptyMsg.style.display = "block";
    }
}

// applyNoteWardTabs 縺ｯ蟒・ｭ｢ (renderWardTabs 縺ｫ邨ｱ蜷・

function selectNote(id) {
    selectedNoteId = id;
    renderNotes();
}

function addNewNote() {
    if(!isEditMode) return;
    var notes = getCurrentNotes();
    var newId = new Date().getTime();
    var newNote = {
        id: newId,
        title: "",
        content: "",
        author: currentUserName,
        date: getTodayString() + " " + getTimeString()
    };
    notes.unshift(newNote);
    selectedNoteId = newId;
    renderNotes();

    var titleEl = document.getElementById("note-title");
    if(titleEl) titleEl.focus();
}

function saveCurrentNote(isTyping) {
    if(!isEditMode || selectedNoteId === null) return;
    var titleVal = document.getElementById("note-title").value;
    var richEditor = document.getElementById("note-editor-rich");
    var contentVal = richEditor ? richEditor.innerHTML : "";
    var notes = getCurrentNotes();
    var isChanged = false;
    var titleChanged = false;

    for (var i = 0; i < notes.length; i++) {
        if (notes[i].id === selectedNoteId) {
            if (notes[i].title !== titleVal || notes[i].content !== contentVal) {
                if (notes[i].title !== titleVal) titleChanged = true;
                notes[i].title = titleVal;
                notes[i].content = contentVal;
                notes[i].author = currentUserName;
                notes[i].date = getTodayString() + " " + getTimeString();
                isChanged = true;
            }
            break;
        }
    }
    if (!isChanged) return;

    // 笘・ｿｽ蜉: 繝医Λ繝ｳ繧ｶ繧ｯ繧ｷ繝ｧ繝ｳ縺ｮ逋ｺ陦鯉ｼ医％繧後□縺代〒莉悶ヱ繧ｽ繧ｳ繝ｳ縺ｸ縺ｮ繝ｪ繧｢繝ｫ繧ｿ繧､繝蜷梧悄縺ｯ螳御ｺ・＠縺ｾ縺呻ｼ・
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("UPDATE_NOTE", {
            wardCode: currentWard, id: selectedNoteId, title: titleVal,
            content: contentVal, author: currentUserName, date: getTodayString() + " " + getTimeString()
        });
    }

    if (titleChanged) {
        renderNotes();
    } else {
        var metaEl = document.getElementById("note-meta");
        if (metaEl) metaEl.innerText = "譛邨よ峩譁ｰ: " + currentUserName + " (" + getTodayString() + " " + getTimeString() + ")";
    }
    
    // 笘・ｿ驥榊ｯｾ遲・ 繧ｿ繧､繝斐Φ繧ｰ荳ｭ縺ｮ荳譎ゆｿ晏ｭ假ｼ・sTyping=true・峨・譎ゅ・縲・㍾縺・・繝輔ぃ繧､繝ｫ荳頑嶌縺・autoSave)繧偵せ繧ｭ繝・・縺吶ｋ
    if (isTyping !== true) {

    }
}

function deleteCurrentNote() {
    if(!isEditMode || selectedNoteId === null) return;
    if(!confirm("縺薙・繝壹・繧ｸ繧貞炎髯､縺励※繧ゅｈ繧阪＠縺・〒縺吶°・・)) return;
    var notes = getCurrentNotes();
    for (var i = 0; i < notes.length; i++) {
        if (notes[i].id === selectedNoteId) {
            notes.splice(i, 1);
            break;
        }
    }
    selectedNoteId = null;
    renderNotes(); 
}

// formatDoc removed as requested

function changeSharedFontSize() {
    var size = document.getElementById("sel-fontsize").value;
    var editor = document.getElementById("note-editor-rich");
    if(editor) editor.style.fontSize = size;
}

function changeSharedFontFamily() {
    var font = document.getElementById("sel-fontfamily").value;
    var editor = document.getElementById("note-editor-rich");
    if(editor) editor.style.fontFamily = font;
}

function toggleTodo(id) {
    if(!isEditMode) return;
    var todos = appData.todos || [];
    for(var i=0; i<todos.length; i++) {
        if(todos[i].id === id) { todos[i].done = !todos[i].done; break; }
    }
    renderTodos(); 
}

function deleteTodo(id) {
    if(!isEditMode) return;
    var todos = appData.todos || [];
    for(var i=0; i<todos.length; i++) {
        if(todos[i].id === id) { todos[i].deleted = true; break; }
    }
    renderTodos(); 
}

function openKarteLink(type, pid) {
    var url = "http://10.5.71.21:8082/karte/main.php?id=" + pid + "&type=" + type;
    window.open(url, "_blank");
}

// ---------- 蛻晄悄蛹門・逅・----------
window.onload = function() {
    // 繝・・繧ｿ邂｡逅・Δ繧ｸ繝･繝ｼ繝ｫ縺ｮ蛻晄悄蛹・
    if (typeof DataManager !== "undefined") {
        DataManager.saveTextUtf8 = saveTextUtf8; // 螟夜Κ繝励Ο繧ｰ繝ｩ繝縺ｮ菫晏ｭ伜・逅・ｂ繝ｪ繝医Λ繧､莉倥″縺ｫ蠑ｷ蛻ｶ荳頑嶌縺・
        DataManager.loadTextUtf8 = loadTextUtf8; // 笘・ｿｽ蜉・夊ｪｭ縺ｿ霎ｼ縺ｿ蜃ｦ逅・ｂ繧ｭ繝｣繝・す繝･雋ｫ騾壼梛縺ｫ蠑ｷ蛻ｶ荳頑嶌縺・
        DataManager.init();
    }
    
    if (!initFSO()) return;
    initSharedPath(); // 蜈ｱ譛峨ヱ繧ｹ縺ｮ蜍慕噪隗｣豎ｺ (DataManager.js 繧ゅ％繧後ｒ蜿ら・)
    
    loadData(false); 
    updateUIMode();
    
    // 螳壽悄譖ｴ譁ｰ繧ｿ繧､繝槭・ (1蛻・＃縺ｨ縺ｫ蜈ｱ譛峨ョ繝ｼ繧ｿ繧貞・繝ｭ繝ｼ繝・
    setInterval(function() {
        var activeEl = document.activeElement;
        // 繧ｫ繝ｼ繧ｽ繝ｫ縺悟・蜉帶棧縺ｫ縺ゅｋ縺具ｼ域枚蟄怜・蜉帑ｸｭ縺具ｼ峨ｒ蛻､螳・
        var isTyping = activeEl && (
            activeEl.tagName === 'TEXTAREA' || 
            activeEl.tagName === 'INPUT' || 
            activeEl.isContentEditable === true || 
            activeEl.getAttribute('contenteditable') === 'true' ||
            activeEl.id === 'note-editor-rich'
        );

        var tabYakureki = document.getElementById('tab-yakureki');
        var isYakurekiActive = tabYakureki && tabYakureki.className.indexOf('active') !== -1;
        var tabNotes = document.getElementById('tab-notes');
        var isNotesActive = tabNotes && tabNotes.className.indexOf('active') !== -1;

        // 笘・ｿｮ豁｣: 繝・・繧ｿ縺ｮ隱ｭ縺ｿ霎ｼ縺ｿ縺縺代〒縺ｪ縺上√・繝ｼ繧ｸ貂医∩縺ｮ譛譁ｰ繝・・繧ｿ繧帝←逕ｨ縺吶ｋ
        if (typeof DataManager !== "undefined") {
            // 繝医Λ繝ｳ繧ｶ繧ｯ繧ｷ繝ｧ繝ｳ繧帝←逕ｨ縺励※ appData 繧呈怙譁ｰ縺ｫ縺吶ｋ
            var updated = DataManager.replayTransactions(appData);
            
            // 笘・％縺薙′驥崎ｦ・ 蟾ｮ蛻・′縺ゅ▲縺溷ｴ蜷医√・繧ｹ繧ｿ繝ｼ繝輔ぃ繧､繝ｫ閾ｪ菴薙ｒ譛譁ｰ蛹悶☆繧九◆繧√↓saveAll繧貞他縺ｶ
            if (updated) {
                DataManager.saveAll(appData);
            }
        }

        // 閾ｪ蛻・′譁・ｭ励ｒ謇薙▲縺ｦ縺・ｋ譛荳ｭ縲√∪縺溘・謗｡陦蜿門ｾ嶺ｸｭ縺ｧ縺ｪ縺代ｌ縺ｰ縲・蛻・俣髫斐〒逕ｻ髱｢繧呈峩譁ｰ縺吶ｋ
        if (isTyping || isYakurekiActive || isNotesActive || window.isBloodFetching) {
            var elTime = document.getElementById("last-local-update-time");
            if (elTime) {
                var reason = window.isBloodFetching ? "謗｡陦蜿門ｾ嶺ｸｭ" : "邱ｨ髮・ｸｭ";
                elTime.innerText = "[" + reason + "縺ｮ縺溘ａ閾ｪ蜍墓峩譁ｰ 荳譎ょ●豁｢]";
            }
            return;
        }

        loadData(false); 
    }, 60000);
};

// ---------- 繝ｭ繧ｰ繧､繝ｳ蛻ｶ蠕｡ ----------
function openLoginModal() {
    document.getElementById('modal-login').style.display = 'flex';
    document.getElementById('ipt-system-id').focus();
}

function closeLoginModal() {
    document.getElementById('modal-login').style.display = 'none';
}

function checkUserDictionary(val) {
    if (!appData) return;
    var users = appData.users || (appData.settings && appData.settings.users) || {};
    if (users[val]) {
        document.getElementById('ipt-user-name').value = users[val];
    } else {
        document.getElementById('ipt-user-name').value = ""; // 霎樊嶌縺ｫ縺ｪ縺代ｌ縺ｰ遨ｺ・・D豬∫畑・・
    }
}

function doLogin() {
    var sysId = document.getElementById('ipt-system-id').value.trim();
    var uName = document.getElementById('ipt-user-name').value.trim();
    
    if (sysId === "") {
        // 遨ｺ縺ｮ縺ｾ縺ｾ豎ｺ螳壹＠縺溷ｴ蜷医・繧ｭ繝｣繝ｳ繧ｻ繝ｫ・磯夢隕ｧ繝｢繝ｼ繝臥ｶ咏ｶ夲ｼ画桶縺・→縺吶ｋ
        closeLoginModal();
        return;
    }
    
    // 陦ｨ遉ｺ蜷阪′遨ｺ縺ｧ繧りｾ樊嶌縺ｫ縺ゅｌ縺ｰ蠕ｩ蜈・√≠繧後・霎樊嶌縺ｫ菫晏ｭ・
    if (!appData.settings.users) appData.settings.users = {};
    appData.users = appData.settings.users; // 蜷梧悄
    if (uName !== "") {
        appData.settings.users[sysId] = uName;

    } else if (appData.settings.users[sysId]) {
        uName = appData.settings.users[sysId];
    }
    
    currentSystemId = sysId;
    // 陦ｨ遉ｺ蜷阪′遨ｺ縺ｪ繧峨す繧ｹ繝・ΒID繧呈ｵ∫畑
    currentUserName = uName !== "" ? uName : sysId;

    // 邱ｨ髮・ｨｩ髯舌・蛻､螳・ 邂｡逅・・Μ繧ｹ繝医↓蜷ｫ縺ｾ繧後※縺・ｋ縺・
    var isAdmin = false;
    var adminList = (appData.settings && appData.settings.adminIds instanceof Array) ? appData.settings.adminIds : ["16622"];
    for (var i = 0; i < adminList.length; i++) {
        if (String(adminList[i]) === String(sysId)) { isAdmin = true; break; }
    }
    isEditMode = isAdmin;
    cachedUniqueUsers = null;
    closeLoginModal();

    // 縲蝉ｿｮ豁｣縲代Θ繝ｼ繧ｶ繝ｼ縺斐→縺ｮ逞・｣溯ｨｭ螳壹ｒ蠕ｩ蜈・☆繧具ｼ磯㍾隍・↑縺上∫｢ｺ螳溘↓1蝗槭□縺大ｮ溯｡鯉ｼ・
    if (appData.settings && appData.settings.userWards && appData.settings.userWards[currentSystemId]) {
        var userCodes = appData.settings.userWards[currentSystemId];
        if (userCodes.length > 0) {
            appData.settings.activeWardCodes = [].concat(userCodes);
            currentWard = userCodes[0];
        }
    }
    
    // 笘・・縺ｫ蝓ｺ譛ｬ縺ｮ逕ｻ髱｢縺縺代ｒ謠冗判縺励※隕九○繧・
    if (typeof renderCustomTabsUI !== "undefined") renderCustomTabsUI(); else renderWardTabs();
    renderPatients();
    updateUIMode();

    // 笘・㍾縺・・逅・ｼ・oDo陦ｨ遉ｺ繧・き繝ｫ繝・∈縺ｮ繧｢繧ｯ繧ｻ繧ｹ・峨ｒ荳迸ｬ驕・ｉ縺帙※縲√ヵ繝ｪ繝ｼ繧ｺ繧貞屓驕ｿ縺吶ｋ
    setTimeout(function() {
        renderTodos();
        yrInit(); // 繝ｭ繧ｰ繧､繝ｳ遒ｺ螳壼ｾ後↓閾ｪID縺ｮ險ｭ螳壹ｒUI縺ｸ蜀阪Ο繝ｼ繝・
        
        // 險ｭ螳夂判髱｢縺ｮ蛻晄悄陦ｨ遉ｺ繧呈峩譁ｰ
        var idLbl = document.getElementById('set-current-id-label-main');
        if(idLbl) idLbl.innerText = currentSystemId;
        var nameIpt = document.getElementById('set-my-display-name-main');
        if(nameIpt) nameIpt.value = currentUserName;
        
        // 繧ｷ繧ｹ繝・Β縺ｮ譛譁ｰ繝・・繧ｿ繧貞ｼｷ蛻ｶ蜿門ｾ・
        fetchPatientData();
        setTimeout(function(){ fetchAdmissionSchedule(); }, 3000);
        
        // ToDo騾夂衍縺ｨ逶｣隕悶・髢句ｧ・(Vol.12)
        setTimeout(function(){ 
            checkMyTodos(); 
            startDeadlineTimer();
        }, 2000);
    }, 50);
}

function updateUIMode() {
    var display = document.getElementById('current-user-display');
    var btnFetch = document.getElementById('btn-fetch');
    var btnReset = document.getElementById('btn-reset');
    var iptNewTodo = document.getElementById('ipt-new-todo');
    if(iptNewTodo) iptNewTodo.disabled = !isEditMode;
    if(document.getElementById('btn-add-todo')) document.getElementById('btn-add-todo').disabled = !isEditMode;
    if(document.getElementById('btn-todo-deadline')) document.getElementById('btn-todo-deadline').disabled = !isEditMode;
        
    var btnAddTodo = document.getElementById('btn-add-todo');
    var btnSaveSettings = document.getElementById('btn-save-settings');
    var btnSave = document.getElementById('btn-save');
    var btnAddNote = document.getElementById('btn-add-note');
    var titleEl = document.getElementById("note-title");
    var bodyEl = document.getElementById("note-editor-rich");
    var toolbarEl = document.getElementById("note-toolbar");
    var deleteBtn = document.querySelector("#note-editor .btn[onclick='deleteCurrentNote()']");
    var colorPicker = document.getElementById("editor-fore-color");
    var fontSizePicker = document.getElementById("editor-font-size");
    
    if (isEditMode) {
        display.innerHTML = "側 " + currentUserName + " <span style='font-size:10px;color:#999;'>(ID:" + currentSystemId + ") / 邱ｨ髮・庄</span>";
        display.style.color = "#27ae60";
        btnSave.style.display = "inline-block";
        btnFetch.disabled = false;
        if(btnReset) btnReset.disabled = false;
        var btnResetChk = document.getElementById('btn-reset-chk');
        if(btnResetChk) btnResetChk.disabled = false;
        btnSaveSettings.disabled = false;
        if(btnAddNote) btnAddNote.disabled = false;

        if(document.getElementById('sel-todo-assignee')) document.getElementById('sel-todo-assignee').disabled = false;
        if(document.getElementById('sel-todo-reminder')) document.getElementById('sel-todo-reminder').disabled = false;
        if(document.getElementById('chk-todo-notify-done')) document.getElementById('chk-todo-notify-done').disabled = false;
        var btnExcelImport = document.getElementById('btn-excel-import');
        if(btnExcelImport) btnExcelImport.disabled = false;
        var excelNote = document.getElementById('excel-import-note');
        if(excelNote) excelNote.style.display = 'block';
        
        // 繝ｪ繝・メ繧ｨ繝・ぅ繧ｿ縺ｮUI譛牙柑蛹・
        if(titleEl) titleEl.disabled = false;
        if(bodyEl) bodyEl.setAttribute("contenteditable", "true");
        if(bodyEl) bodyEl.style.backgroundColor = "#fff";
        if(toolbarEl) { toolbarEl.style.pointerEvents = "auto"; toolbarEl.style.opacity = "1"; }
        if(colorPicker) colorPicker.disabled = false;
        if(fontSizePicker) fontSizePicker.disabled = false;
        if(deleteBtn) deleteBtn.style.display = "inline-block";
    } else {
        var modeText = currentSystemId ? " (髢ｲ隕ｧ蟆ら畑繝｢繝ｼ繝・" : " (譛ｪ繝ｭ繧ｰ繧､繝ｳ)";
        display.innerHTML = "側 " + currentUserName + modeText;
        display.style.color = "#888";
        btnSave.style.display = "none";
        btnFetch.disabled = true;
        if(btnReset) btnReset.disabled = true;
        var qResetChk = document.getElementById('btn-reset-chk');
        if(qResetChk) qResetChk.disabled = true;
        btnSaveSettings.disabled = true;
        if(btnAddNote) btnAddNote.disabled = true;

        if(document.getElementById('sel-todo-assignee')) document.getElementById('sel-todo-assignee').disabled = true;
        if(document.getElementById('sel-todo-reminder')) document.getElementById('sel-todo-reminder').disabled = true;
        if(document.getElementById('chk-todo-notify-done')) document.getElementById('chk-todo-notify-done').disabled = true;
        var btnExcelImport2 = document.getElementById('btn-excel-import');
        if(btnExcelImport2) btnExcelImport2.disabled = true;
        var excelNote2 = document.getElementById('excel-import-note');
        if(excelNote2) excelNote2.style.display = 'none';
        
        if(titleEl) titleEl.disabled = true;
        if(bodyEl) bodyEl.setAttribute("contenteditable", "false");
        if(bodyEl) bodyEl.style.backgroundColor = "#f9f9f9";
        if(toolbarEl) { toolbarEl.style.pointerEvents = "none"; toolbarEl.style.opacity = "0.5"; }
        if(colorPicker) colorPicker.disabled = true;
        if(fontSizePicker) fontSizePicker.disabled = true;
        if(deleteBtn) deleteBtn.style.display = "none";
    }
    
    // UI蜀肴緒逕ｻ
    updateAnnouncementUI();
    renderPatients();
    renderTodos();
    renderWardSettingButtons(); // 繝ｭ繧ｰ繧､繝ｳ迥ｶ諷九′螟峨ｏ縺｣縺溘ｉ險ｭ螳壹・繧ｿ繝ｳ縺ｮ disabled 迥ｶ諷九ｂ蜀肴緒逕ｻ縺吶ｋ

    // 蜈ｨ菴薙ヵ繧ｩ繝ｳ繝医し繧､繧ｺ縺ｮ蜿肴丐
    if (appData.settings) {
        var mode = appData.settings.uiMode || "standard";
        document.body.className = (mode === "standard") ? "" : "font-" + mode;
    }
}


function editAnnouncement() {
    if (currentSystemId !== "16622") return;
    var cur = appData.announcement || "";
    var msg = prompt("蜈ｨ菴灘髄縺代・縺顔衍繧峨○繝｡繝・そ繝ｼ繧ｸ繧貞・蜉帙＠縺ｦ縺上□縺輔＞縲・n(縺ｿ繧薙↑縺ｮ逕ｻ髱｢縺ｮ荳企Κ縺ｫ逶ｮ遶九▽繧医≧縺ｫ陦ｨ遉ｺ縺輔ｌ縺ｾ縺吶らｩｺ谺・〒[OK]繧呈款縺吶→蜑企勁縺輔ｌ縺ｾ縺・", cur);
    if (msg !== null) {
        appData.announcement = msg;
        // 笆ｼ霑ｽ蜉・夊ｨｭ螳壽棧蜀・↓繧ゆｿ晏ｭ倥＠縺ｪ縺・→3繧ｦ繧ｧ繧､繝槭・繧ｸ譎ゅ↓蜿､縺・ョ繝ｼ繧ｿ縺ｧ荳頑嶌縺阪＆繧後※縺励∪縺・
        if (!appData.settings) appData.settings = {};
        appData.settings.announcement = msg;
        
        updateAnnouncementUI();

    }
}

function updateAnnouncementUI() {
    var area = document.getElementById("global-announcement-area");
    var txt = document.getElementById("announcement-text");
    var btn = document.getElementById("btn-edit-announcement");
    if(!area || !txt || !btn) return;
    
    var msg = appData.announcement || "";
    txt.innerText = msg;
    
    if (currentSystemId === "16622") {
        area.style.display = "flex";
        btn.style.display = "inline-block";
        if(!msg) txt.innerText = "縲舌♀遏･繧峨○譛ｪ險ｭ螳壹・;
    } else {
        if (msg) {
            area.style.display = "flex";
        } else {
            area.style.display = "none";
        }
        btn.style.display = "none";
    }
}

// ---------- 繧ｫ繝ｫ繝・Μ繝ｳ繧ｯ髫縺励ち繝・----------
document.attachEvent ? document.attachEvent('onkeydown', handleKeyShortcut) : document.addEventListener('keydown', handleKeyShortcut);
function handleKeyShortcut(e) {
    // Ctrl+Shift+K - 繧ｫ繝ｫ繝・ink繧ｿ繝・
    if (e.ctrlKey && e.shiftKey && (e.keyCode === 75 || e.key === 'K' || e.key === 'k')) {
        var tabBtn = document.getElementById('tab-btn-kartelink');
        if (tabBtn) {
            tabBtn.style.display = (tabBtn.style.display === 'none') ? '' : 'none';
        }
        if (e.preventDefault) e.preventDefault();
        return false;
    }
    // Ctrl+Shift+A - 阮ｬ蜑､隱ｿ謨ｴ蜉邂励ち繝・(2026蟷ｴ迚医・縺ｿ繝医げ繝ｫ)
    if (e.ctrlKey && e.shiftKey && (e.keyCode === 65 || e.key === 'A' || e.key === 'a')) {
        var adjBtn2026 = document.getElementById('yr-tab-med-adj-2026-btn');
        if (adjBtn2026) adjBtn2026.style.display = (adjBtn2026.style.display === 'none') ? '' : 'none';
        
        if (e.preventDefault) e.preventDefault();
        return false;
    }
}


var klSortKey = '';
var klSortAsc = true;
function sortKarteLink(key) {
    if (klSortKey === key) {
        klSortAsc = !klSortAsc;
    } else {
        klSortKey = key;
        klSortAsc = true;
    }
    renderKarteLinks();
}
function openKarteLink(type, kanjaId) {
    var userId = currentSystemId || '';
    var today = new Date();
    var todayStr = today.getFullYear() + '/' + ('0'+(today.getMonth()+1)).slice(-2) + '/' + ('0'+today.getDate()).slice(-2);
    var baseUrl = 'http://10.5.71.21:8082/karte/';
    var url = '';
    
    switch(type) {
        case 'karte':
            url = baseUrl + 'kanja_ichiran/kanja_link_controller.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&section_code=';
            break;
        case 'kentai_karte':
            url = baseUrl + 'kentai_kekka_karte.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&section_code=0000023&kentai_disp_flgs=&disp_kekka_start_date=' + todayStr + '&disp_kekka_end_date=&disp_zoom=80&disp_kensu_count=30';
            break;
        case 'kentai_menu':
            url = baseUrl + 'kentai_kekka_menu.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&section_code=0000023&kentai_disp_flgs=&disp_kekka_start_date=' + todayStr + '&disp_kekka_end_date=&disp_zoom=80&disp_kensu_count=30';
            break;
        case 'vital_karte':
            var vs = new Date(today); vs.setDate(today.getDate() - 6);
            var ve = new Date(today); ve.setDate(today.getDate() + 3);
            var vsStr = vs.getFullYear() + '/' + ('0'+(vs.getMonth()+1)).slice(-2) + '/' + ('0'+vs.getDate()).slice(-2);
            var veStr = ve.getFullYear() + '/' + ('0'+(ve.getMonth()+1)).slice(-2) + '/' + ('0'+ve.getDate()).slice(-2);
            url = baseUrl + 'vital/vital_karte.php?kanja_id=' + kanjaId + '&start_date=' + vsStr + '&end_date=' + veStr + '&user_id=' + userId + '&disp_order_ichiran_kubun=1&disp_noorder_flg=0&disp_contents_flgtbl=123&disp_zoom=100&section_code=0000002';
            break;
        case 'vital_menu':
            var vs2 = new Date(today); vs2.setDate(today.getDate() - 6);
            var ve2 = new Date(today); ve2.setDate(today.getDate() + 3);
            var vs2Str = vs2.getFullYear() + '/' + ('0'+(vs2.getMonth()+1)).slice(-2) + '/' + ('0'+vs2.getDate()).slice(-2);
            var ve2Str = ve2.getFullYear() + '/' + ('0'+(ve2.getMonth()+1)).slice(-2) + '/' + ('0'+ve2.getDate()).slice(-2);
            url = baseUrl + 'vital/vital_menu.php?kanja_id=' + kanjaId + '&start_date=' + vs2Str + '&end_date=' + ve2Str + '&user_id=' + userId + '&disp_order_ichiran_kubun=1&disp_noorder_flg=0&disp_contents_flgtbl=123&disp_zoom=100&section_code=0000002';
            break;
        case 'document_menu':
            url = baseUrl + 'document_menu.php?kanja_id=' + kanjaId + '&start_date=&end_date=&hakkou_date=&user_id=' + userId + '&section_code=&disp_flgs=0/0/1/0/0/0/1/0/0/0/1&document_code=100000032&order_kind_code_str=&disp_title_flg=&document_title=';
            break;
        case 'document_karte':
            url = baseUrl + 'document_karte.php?kanja_id=' + kanjaId + '&start_date=&end_date=&hakkou_date=&user_id=' + userId + '&section_code=&disp_flgs=0/0/1/0/0/0/1/0/0/0/1&document_code=100000032&order_kind_code_str=&disp_title_flg=&document_title=';
            break;
        case 'allergy_menu':
            url = baseUrl + 'allergy_menu.php?start_flag=1&kanja_id=' + kanjaId + '&start_date=&end_date=&hakkou_date=&user_id=' + userId + '&section_code=&document_code=100000004&disp_selectsection=&range_date=180/0/0/0&disp_zoom=100';
            break;
        case 'allergy_karte':
            url = baseUrl + 'allergy_karte.php?start_flag=1&kanja_id=' + kanjaId + '&start_date=&end_date=&hakkou_date=&user_id=' + userId + '&section_code=&document_code=100000004&disp_selectsection=&range_date=180/0/0/0&disp_zoom=100';
            break;
        case 'shohou_s':
            url = baseUrl + 'search/search_order.php?kana_name=&search_code=1&user_id=' + userId + '&kanja_id=' + kanjaId;
            break;
        case 'shohou_d':
            url = baseUrl + 'karte.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&order_search_flg=1&order_search_code=1&order_search_name=#top';
            break;
        case 'kentai_s':
            url = baseUrl + 'search/search_order.php?kana_name=&search_code=3&user_id=' + userId + '&kanja_id=' + kanjaId;
            break;
        case 'kentai_d':
            url = baseUrl + 'karte.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&order_search_flg=1&order_search_code=3&order_search_name=#top';
            break;
        case 'chuusha_s':
            url = baseUrl + 'search/search_order.php?kana_name=&search_code=4&user_id=' + userId + '&kanja_id=' + kanjaId;
            break;
        case 'chuusha_d':
            url = baseUrl + 'karte.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&order_search_flg=1&order_search_code=4&order_search_name=#top';
            break;
        case 'ope_record':
            var pTarget = findPatientById(kanjaId);
            var hospDays = pTarget ? parseInt(pTarget.daysInHosp, 10) : 0;
            var rDays = (!isNaN(hospDays) && hospDays > 0) ? (hospDays + 3) : 20;
            url = baseUrl + 'karte.php?kanja_id=' + kanjaId + '&user_id=' + userId + '&order_kind_code_str=0091,1091&kijun_date=' + todayStr + '&range_date=' + rDays + '/7/1/1&disp_selectsection=0000021&disp_selectukind=1,2,3&document_code=700360003,730360001&multi_kind=1#top';
            break;

    }
    
    if (!url) return;
    
    try {
        var wsh = new ActiveXObject('WScript.Shell');
        try {
            wsh.Run('msedge "' + url + '"');
        } catch(e1) {
            try {
                wsh.Run('chrome "' + url + '"');
            } catch(e2) {
                var shellApp = new ActiveXObject('Shell.Application');
                shellApp.ShellExecute(url, '', '', 'open', 1);
            }
        }
    } catch(e) {
        alert('URL縺ｮ襍ｷ蜍輔↓螟ｱ謨励＠縺ｾ縺励◆: ' + e.message);
    }
}

function openAdmissionMenu() {
    var userId = currentSystemId || '';
    var url = 'http://10.5.71.21:8082/karte/kanja_ichiran/kanja_ichiran_menu.php?ichiran_code=6&user_id=' + userId + '&section_code=&page_num=&login_flg=';
    try {
        var wsh = new ActiveXObject('WScript.Shell');
        try { wsh.Run('msedge "' + url + '"'); } catch(e1) {
            try { wsh.Run('chrome "' + url + '"'); } catch(e2) {
                var shellApp = new ActiveXObject('Shell.Application');
                shellApp.ShellExecute(url, '', '', 'open', 1);
            }
        }
    } catch(e) { alert('URL縺ｮ襍ｷ蜍輔↓螟ｱ謨励＠縺ｾ縺励◆: ' + e.message); }
}

function updateMyDisplayNameMain() {
    var newName = document.getElementById('set-my-display-name-main').value.trim();
    if (!newName) {
        alert("陦ｨ遉ｺ蜷阪ｒ蜈･蜉帙＠縺ｦ縺上□縺輔＞縲・);
        return;
    }
    if (!currentSystemId) {
        alert("繝ｭ繧ｰ繧､繝ｳ縺励※縺・∪縺帙ｓ縲・);
        return;
    }
    
    if (!appData.users) appData.users = {};
    appData.users[currentSystemId] = newName;
    currentUserName = newName;
    cachedUniqueUsers = null; // 蜷榊燕縺悟､峨ｏ縺｣縺溘・縺ｧ繧ｭ繝｣繝・す繝･繧ｯ繝ｪ繧｢
    renderTodos(); // 莉句・閠・Μ繧ｹ繝医ｒ蜊ｳ譎よ峩譁ｰ
    
    // UI繧呈峩譁ｰ
    var lbl = document.getElementById('current-user-display'); // 繝倥ャ繝繝ｼ
    if(lbl) lbl.innerText = currentUserName + " (繝ｭ繧ｰ繧､繝ｳ荳ｭ)";
    
    alert("陦ｨ遉ｺ蜷阪ｒ縲・ + newName + "縲阪↓譖ｴ譁ｰ縺励∪縺励◆縲・);

}

// ---------- 譛崎脈謖・ｰ主ｱ･豁ｴExcel繝輔ぃ繧､繝ｫ縺九ｉ縺ｮ莉句・迥ｶ豕∝叙霎ｼ ----------
function importFromExcel() {
    if (!isEditMode) {
        alert('邱ｨ髮・Δ繝ｼ繝峨〒縺ｮ縺ｿ蛻ｩ逕ｨ縺ｧ縺阪∪縺吶・);
        return;
    }
    
    var btn = document.getElementById('btn-excel-import');
    var orgText = btn.innerText;
    btn.innerText = '? 隱ｭ縺ｿ霎ｼ縺ｿ荳ｭ...';
    btn.disabled = true;
    
    setTimeout(function() {
        try {
            doExcelImport();
        } catch(e) {
            alert('Excel蜿冶ｾｼ繧ｨ繝ｩ繝ｼ: ' + e.message);
        }
        btn.innerText = orgText;
        btn.disabled = false;
    }, 100);
}

function doExcelImport() {
    // 1. 莉企ｱ縺ｮ遽・峇繧定ｨ育ｮ・(譌･譖懈律髢句ｧ・
    var today = new Date();
    var dayOfWeek = today.getDay(); // 0=譌･, 1=譛・ ..., 6=蝨・
    var weekStart = new Date(today);
    weekStart.setDate(today.getDate() - dayOfWeek);
    weekStart.setHours(0,0,0,0);
    var weekEnd = new Date(weekStart);
    weekEnd.setDate(weekStart.getDate() + 6);
    weekEnd.setHours(23,59,59,999);
    
    // 2. 繝・せ繧ｯ繝医ャ繝嶺ｸ翫・繝輔ぃ繧､繝ｫ繧呈､懃ｴ｢
    var wsh = new ActiveXObject('WScript.Shell');
    var desktopPath = wsh.SpecialFolders('Desktop');
    var fso = new ActiveXObject('Scripting.FileSystemObject');
    
    if (!fso.FolderExists(desktopPath)) {
        alert('繝・せ繧ｯ繝医ャ繝励ヵ繧ｩ繝ｫ繝縺瑚ｦ九▽縺九ｊ縺ｾ縺帙ｓ縲・);
        return;
    }
    
    var folder = fso.GetFolder(desktopPath);
    var files = new Enumerator(folder.Files);
    var matchedFiles = [];
    
    for (; !files.atEnd(); files.moveNext()) {
        var f = files.item();
        var fname = f.Name;
        // 譛崎脈謖・ｰ主ｱ･豁ｴYYYYMMDD 縺ｧ蟋九∪繧九ヵ繧｡繧､繝ｫ (.xls, .xlsx, .xlsm)
        var m = fname.match(/^譛崎脈謖・ｰ主ｱ･豁ｴ(\d{8})/);
        if (!m) continue;
        var ext = fname.split('.').pop().toLowerCase();
        if (ext !== 'xls' && ext !== 'xlsx' && ext !== 'xlsm') continue;
        
        var dateStr = m[1]; // YYYYMMDD
        var y = parseInt(dateStr.substring(0,4), 10);
        var mo = parseInt(dateStr.substring(4,6), 10) - 1;
        var d = parseInt(dateStr.substring(6,8), 10);
        var fileDate = new Date(y, mo, d);
        
        // 莉企ｱ縺ｮ遽・峇蜀・°繝√ぉ繝・け
        if (fileDate >= weekStart && fileDate <= weekEnd) {
            matchedFiles.push({
                path: f.Path,
                date: fileDate,
                dateNum: parseInt(dateStr, 10),
                name: fname
            });
        }
    }
    
    if (matchedFiles.length === 0) {
        alert('莉企ｱ(' + formatDateShort(weekStart) + '・・ + formatDateShort(weekEnd) + ')縺ｮ譛崎脈謖・ｰ主ｱ･豁ｴExcel繝輔ぃ繧､繝ｫ縺後ョ繧ｹ繧ｯ繝医ャ繝嶺ｸ翫↓隕九▽縺九ｊ縺ｾ縺帙ｓ縺ｧ縺励◆縲・n\n繝輔ぃ繧､繝ｫ蜷堺ｾ・ 譛崎脈謖・ｰ主ｱ･豁ｴ20260303.xlsx, 譛崎脈謖・ｰ主ｱ･豁ｴ202603036B.xlsx');
        return;
    }
    
    // 譛譁ｰ譌･莉倥・繝輔ぃ繧､繝ｫ繧帝∈謚橸ｼ亥酔荳譌･莉倥〒隍・焚繝輔ぃ繧､繝ｫ縺後≠繧後・蜈ｨ縺ｦ隱ｭ繧・・
    matchedFiles.sort(function(a, b) { return b.dateNum - a.dateNum; });
    var latestDateNum = matchedFiles[0].dateNum;
    var filesToRead = [];
    for (var i = 0; i < matchedFiles.length; i++) {
        if (matchedFiles[i].dateNum === latestDateNum) {
            filesToRead.push(matchedFiles[i]);
        }
    }
    
    // 3. Excel COM縺ｧ隱ｭ縺ｿ蜿悶ｊ
    var excel = null;
    var patientsWithMark = {}; // patientId -> true
    
    try {
        excel = new ActiveXObject('Excel.Application');
        excel.Visible = false;
        excel.DisplayAlerts = false;
        
        for (var fi = 0; fi < filesToRead.length; fi++) {
            var wb = null;
            try {
                wb = excel.Workbooks.Open(filesToRead[fi].path, 0, true); // ReadOnly=true
                var ws = wb.Sheets(1);
                var usedRange = ws.UsedRange;
                var lastRow = usedRange.Row + usedRange.Rows.Count - 1;
                var lastCol = usedRange.Column + usedRange.Columns.Count - 1;
                
                // 繝倥ャ繝繝ｼ陦・1陦檎岼)縺九ｉ莉企ｱ縺ｮ譌･莉伜・繧堤音螳・
                var weekDateCols = [];
                for (var c = 4; c <= lastCol; c++) {
                    var cellVal = ws.Cells(1, c).Value;
                    if (!cellVal) continue;
                    var colDate = parseExcelDate(cellVal);
                    if (colDate && colDate >= weekStart && colDate <= weekEnd) {
                        weekDateCols.push(c);
                    }
                }
                
                // 蜷・ぅ閠・｡後ｒ繝√ぉ繝・け
                for (var r = 2; r <= lastRow; r++) {
                    var pid = ws.Cells(r, 1).Value;
                    if (!pid) continue;
                    pid = String(pid).replace(/[\s\r\n]/g, '');
                    // 謨ｰ蛟､縺ｮ蝣ｴ蜷医・謨ｴ謨ｰ蛹・
                    if (!isNaN(pid)) pid = String(parseInt(pid, 10));
                    
                    // 險伜捷陦・笳銀酪笆｡笆笳・螺笆ｳ笆ｲ笘・ｭ・繧偵せ繧ｭ繝・・
                    if (/^[笳銀酪笆｡笆笳・螺笆ｳ笆ｲ笘・・]$/.test(pid)) break;
                    
                    // 莉企ｱ縺ｮ蛻励↓笳・′縺ゅｋ縺九メ繧ｧ繝・け
                    for (var ci = 0; ci < weekDateCols.length; ci++) {
                        var cellValue = ws.Cells(r, weekDateCols[ci]).Value;
                        if (cellValue && String(cellValue).indexOf('笳・) !== -1) {
                            patientsWithMark[pid] = true;
                            break;
                        }
                    }
                }
            } catch(e2) {
                alert('繝輔ぃ繧､繝ｫ隱ｭ縺ｿ蜿悶ｊ繧ｨ繝ｩ繝ｼ (' + filesToRead[fi].name + '): ' + e2.message);
            } finally {
                if (wb) { try { wb.Close(false); } catch(e3){} }
            }
        }
    } finally {
        if (excel) { try { excel.Quit(); } catch(e4){} excel = null; }
    }
    
    // 4. 逞・｣溷・譛峨・繝ｼ繝峨・謔｣閠・Μ繧ｹ繝医→辣ｧ蜷・
    // 4. 逞・｣溷・譛峨・繝ｼ繝峨・謔｣閠・Μ繧ｹ繝・螟ｧ蜈・・appData)縺ｨ辣ｧ蜷・
    var updatedCount = 0;
    var alreadyRecorded = 0;
    var markIds = Object.keys ? Object.keys(patientsWithMark) : (function(obj) { var k=[]; for(var p in obj){ if(obj.hasOwnProperty(p)) k.push(p); } return k; })(patientsWithMark);
    
    // 迴ｾ蝨ｨ驕ｸ謚樔ｸｭ縺ｮ逞・｣滄・蛻励ｒ逶ｴ謗･謫堺ｽ懊＠縺ｦ豌ｸ邯壼喧縺輔○繧・
    var targetArray = null;
    var targetArray = appData.patients[currentWard];
    
    if (targetArray) {
        for (var pi = 0; pi < targetArray.length; pi++) {
            var p = targetArray[pi];
            var pId = String(p.id).replace(/[\s]/g, '');
            // 蜈磯ｭ繧ｼ繝ｭ繧帝勁蜴ｻ縺励※辣ｧ蜷茨ｼ・251607 縺ｨ 251607 繧貞酔荳縺ｨ縺励※謇ｱ縺・ｼ・
            var pIdNorm = pId.replace(/^0+/, '') || '0';
            if (patientsWithMark[pId] || patientsWithMark[pIdNorm]) {
                if (p.status === 3) {
                    alreadyRecorded++;
                } else {
                    p.status = 3; // 險倬鹸貂・
                    p.statusAuthor = "";
                    updatedCount++;
                }
            }
        }
    }
    
    // 5. 菫晏ｭ倥→UI譖ｴ譁ｰ
    if (updatedCount > 0) {
        renderPatients();
        saveData(false); // 繧｢繝ｩ繝ｼ繝医ｈ繧雁燕縺ｫ蜷梧悄逧・↓遒ｺ螳溘↓菫晏ｭ倥☆繧・
    }
    
    var fileNames = [];
    for (var fn = 0; fn < filesToRead.length; fn++) fileNames.push(filesToRead[fn].name);
    
    var msg = 'Excel蜿冶ｾｼ螳御ｺ・n\n';
    msg += '隱ｭ縺ｿ蜿悶ｊ繝輔ぃ繧､繝ｫ: ' + fileNames.join(', ') + '\n';
    msg += '笳・・繝ｼ繧ｯ讀懷・謔｣閠・焚: ' + markIds.length + '蜷構n';
    msg += '莉句・迥ｶ豕√ｒ縲瑚ｨ倬鹸貂医阪↓譖ｴ譁ｰ: ' + updatedCount + '蜷構n';
    if (alreadyRecorded > 0) msg += '(譌｢縺ｫ險倬鹸貂・ ' + alreadyRecorded + '蜷・\n';
    if (markIds.length > 0 && updatedCount === 0 && alreadyRecorded === 0) {
        msg += '\n窶ｻ 笳・′縺ゅｋ謔｣閠・′迴ｾ蝨ｨ縺ｮ逞・｣溘↓蟄伜惠縺励∪縺帙ｓ縲・n  逞・｣溘ち繝悶ｒ遒ｺ隱阪＠縺ｦ縺上□縺輔＞縲・;
    }
    alert(msg);
}

function parseExcelDate(val) {
    // Excel縺ｮ譌･莉伜､縺ｯ繧ｷ繝ｪ繧｢繝ｫ蛟､縺区枚蟄怜・
    if (val instanceof Date) return val;
    if (typeof val === 'number') {
        // Excel繧ｷ繝ｪ繧｢繝ｫ蛟､縺九ｉ螟画鋤
        var d = new Date((val - 25569) * 86400 * 1000);
        d.setHours(0,0,0,0);
        return d;
    }
    var s = String(val).replace(/\s/g, '');
    // YYYY/MM/DD or M/D
    var m1 = s.match(/(\d{4})\/(\d{1,2})\/(\d{1,2})/);
    if (m1) return new Date(parseInt(m1[1],10), parseInt(m1[2],10)-1, parseInt(m1[3],10));
    var m2 = s.match(/^(\d{1,2})\/(\d{1,2})$/);
    if (m2) {
        var yr = new Date().getFullYear();
        return new Date(yr, parseInt(m2[1],10)-1, parseInt(m2[2],10));
    }
    return null;
}

function formatDateShort(d) {
    return (d.getMonth()+1) + '/' + d.getDate();
}

// ---------- 繝・・繧ｿ陦ｨ遉ｺ縺ｨ謫堺ｽ・ 謔｣閠・----------
function getCurrentPatientsList() {
    if (!appData.patients) appData.patients = {};
    if (!appData.patients[currentWard]) appData.patients[currentWard] = [];
    return appData.patients[currentWard];
}

function renderPatients() {
    var scrollX = window.pageXOffset || (document.documentElement ? document.documentElement.scrollLeft : 0);
    var scrollY = window.pageYOffset || (document.documentElement ? document.documentElement.scrollTop : 0);
    var tbody = document.getElementById("tbody-patients");
    
    // 笘・ｿｮ豁｣: 繧ｫ繧ｹ繧ｿ繝繧ｿ繝・繧ｿ繧ｰ讀懃ｴ｢)縺碁∈縺ｰ繧後※縺・ｋ譎ゅ・縲∝・逞・｣溘・謔｣閠・ｒ縺九″髮・ａ繧・
    var list = [];
    if (typeof currentFilterTag !== 'undefined' && currentFilterTag !== "") {
        var seenIds = {};
        for (var w in appData.patients) {
            if (appData.patients.hasOwnProperty(w) && appData.patients[w]) {
                var wList = appData.patients[w];
                for (var i = 0; i < wList.length; i++) {
                    // 蜷後§謔｣閠・′隍・焚逞・｣溘↓驥崎､・＠縺ｦ蟄伜惠縺吶ｋ蝣ｴ蜷医・髯､螟・
                    if (!seenIds[wList[i].id]) {
                        seenIds[wList[i].id] = true;
                        list.push(wList[i]);
                    }
                }
            }
        }
    } else {
        list = getCurrentPatientsList();
    }
    
    if(!list || list.length === 0) {
        tbody.innerHTML = '<tr><td colspan="12" align="center">隧ｲ蠖鍋羅譽溘・謔｣閠・ョ繝ｼ繧ｿ縺後≠繧翫∪縺帙ｓ縲・/td></tr>';
        return;
    }
    
    var displayList = [].concat(list);
    if (sortKey) {
        displayList.sort(function(a, b) {
            var valA = a[sortKey] || "";
            var valB = b[sortKey] || "";
            if (!isNaN(valA) && !isNaN(valB) && valA !== "" && valB !== "") {
                return (Number(valA) - Number(valB)) * sortOrder;
            }
            return valA.toString().localeCompare(valB.toString()) * sortOrder;
        });
    }
    
    var html = "";
    var highlightWords = ["騾髯｢", "霆｢髯｢", "ENT", "ent"];
    for(var i=0; i<displayList.length; i++) {
        var p = displayList[i];
        if (!p || typeof p !== 'object') continue;
        if (!p.id) continue;
        
        // 笘・ｿｮ豁｣: 繧ｫ繧ｹ繧ｿ繝繧ｿ繝・繧ｿ繧ｰ讀懃ｴ｢)驕ｸ謚樊凾縺ｮ譚｡莉ｶ蛻・ｲ撰ｼ亥・逞・｣溘°繧画歓蜃ｺ・・
        if (typeof currentFilterTag !== 'undefined' && currentFilterTag !== "") {
            var targetMemo = "";
            if (currentFilterScope === "personal") {
                // 蛟倶ｺｺ繝｡繝｢縺九ｉ縺ｮ縺ｿ讀懃ｴ｢
                targetMemo = ((p.personalMemos && p.personalMemos[currentSystemId]) ? p.personalMemos[currentSystemId] : "");
            } else {
                // 蜈ｱ譛峨Γ繝｢縺九ｉ讀懃ｴ｢
                targetMemo = (p.memo || "");
            }
            if (targetMemo.indexOf(currentFilterTag) === -1) {
                continue; // 隧ｲ蠖薙＠縺ｪ縺代ｌ縺ｰ繧ｹ繧ｭ繝・・
            }
        }
        
        var isHighlight = false;
        if (p.memo) {
            var lowerMemo = p.memo.toLowerCase();
            for(var w=0; w<highlightWords.length; w++) {
                if (lowerMemo.indexOf(highlightWords[w].toLowerCase()) !== -1) {
                    isHighlight = true; break;
                }
            }
        }
        var hlClass = isHighlight ? ' highlight-row' : '';

        var aLevel = p.alertLevel || 0;
        var aText = aLevel === 1 ? "・・ : (aLevel === 2 ? "・・ : "");
        var aClass = aLevel === 1 ? "alert-question" : (aLevel === 2 ? "alert-exclamation" : "alert-none");
        var alertEvent = isEditMode ? 'onclick="toggleAlertLevel(\'' + escapeHtml(p.id) + '\')"' : 'onclick="alert(\'邱ｨ髮・ｸ榊庄\')"';

        var statIdx = p.status || 0;
        var statClass = STATUS_CLASSES[statIdx];
        var statText = STATUS_TEXTS[statIdx];
        if(statText === "(譛ｪ險ｭ螳・") statText = "譛ｪ";
        else if(statText === "莉句・莠亥ｮ・) statText = "莠亥ｮ・;
        else if(statText === "謖・ｰ取ｸ・) statText = "謖・ｰ・;
        else if(statText === "險倬鹸貂・) statText = "險倬鹸";

        var authorHtml = p.statusAuthor ? '<br><span class="status-author">' + p.statusAuthor + '</span>' : '';
        var statUnderline = (statIdx === 1 || statIdx === 2) ? 'text-decoration:underline;' : '';
        var clickEvent = isEditMode ? 'onclick="toggleStatus(\'' + escapeHtml(p.id) + '\')"' : 'onclick="alert(\'邱ｨ髮・ｸ榊庄\')"';
        
        var chkVal = p.chkPrescription || 0;
        if(typeof chkVal === "boolean") chkVal = chkVal ? 2 : 0;
        var chkClass = chkVal === 1 ? "status-chk-half" : (chkVal === 2 ? "status-chk-on" : "");
        var chkText = chkVal === 1 ? "&#9744;" : (chkVal === 2 ? "&#10004;" : "");
        var chkBg = chkVal === 1 ? "background-color:#ffe8a1;" : "";
        var chkEvent = isEditMode ? 'onclick="togglePrescriptionCheck(\'' + escapeHtml(p.id) + '\')"' : 'onclick="alert(\'邱ｨ髮・ｸ榊庄\')"';

        var memoDisabled = isEditMode ? '' : 'disabled="disabled"';
        var mcs1 = 'onchange="finalizeMemo(\'' + escapeHtml(p.id) + '\', this)" ';
        var mcs2 = 'onkeyup="updateMemoDebounced(\'' + escapeHtml(p.id) + '\', this.value, this); showTagSuggest(this, event);"';
        var memoChangeShared = isEditMode ? mcs1 + mcs2 : '';
        
        var mcp1 = 'onchange="finalizePersonalMemo(\'' + escapeHtml(p.id) + '\', this)" ';
        var mcp2 = 'onkeyup="updatePersonalMemoDebounced(\'' + escapeHtml(p.id) + '\', this.value, this); showTagSuggest(this, event);"';
        var memoChangePersonal = isEditMode ? mcp1 + mcp2 : '';
        
        var memoAuthorHtml = '';
        if (p.memoAuthors && p.memoAuthors.length > 0) {
            memoAuthorHtml = escapeHtml(p.memoAuthors.join(" / "));
        } else if (p.memoAuthor) {
            memoAuthorHtml = escapeHtml(p.memoAuthor);
        }
        
        var bdManualClick = isEditMode ? 'onclick="changeBloodDate(\'' + escapeHtml(p.id) + '\')"' : 'onclick="alert(\'邱ｨ髮・ｸ榊庄\')";';
        var bdTitle = p.bloodDetail ? 'title="謗｡陦隧ｳ邏ｰ: ' + escapeHtml(p.bloodDetail) + '"' : 'title="謗｡陦譌･菫ｮ豁｣"';
        
        var fetchBtnHtml = '<div style="padding:4px 0;">&nbsp;</div>';
        if (isEditMode) {
            var f1 = '<div class="hide-on-print blood-fetch-btn" ';
            var f2 = 'onclick="event.stopPropagation(); fetchBloodDateForPatient(\'' + escapeHtml(p.id) + '\')" ';
            var f3 = 'style="background:#e3f2fd; color:#0d6efd; font-size:10px; font-weight:bold; ';
            var f4 = 'text-align:center; padding:4px 0; border-bottom:1px dotted #ccc; cursor:pointer;" ';
            var f5 = 'title="蜿門ｾ・>蜿門ｾ・/div>';
            fetchBtnHtml = f1 + f2 + f3 + f4 + f5;
        }
        
        var d1 = '<div class="blood-date-text" ' + bdManualClick + ' ';
        var d2 = 'style="text-align:center; padding:4px 0; font-size:11px; cursor:pointer;" ';
        var d3 = bdTitle + '>' + escapeHtml(p.bloodDate || "-") + '</div>';
        var dateTextHtml = d1 + d2 + d3;

        var pMemos = (p && typeof p === 'object' && p.personalMemos) ? p.personalMemos : {};
        var myMemo = (pMemos && currentSystemId) ? (pMemos[currentSystemId] || "") : "";

        var tr = [];
        tr.push('<tr id="tr-patient-' + escapeHtml(p.id) + '">');
        // 笘・ｿｮ豁｣: 荳崎ｦ√↑繝√ぉ繝・け繝懊ャ繧ｯ繧ｹ蛻励ｒ蜑企勁
        tr.push('<td>' + escapeHtml(p.id) + '</td>');
        tr.push('<td>' + escapeHtml(p.name) + '</td>');
        tr.push('<td class="hide-on-print" style="font-size:11px; padding:2px 4px;">');
        tr.push('<div style="color:#0d6efd; font-weight:bold; border-bottom:1px dotted #eee;">' + escapeHtml(p.dept || '') + '</div>');
        tr.push('<div style="color:#555;">' + escapeHtml(p.doctor || '') + '</div>');
        tr.push('</td>');
        tr.push('<td style="padding:2px 4px; vertical-align:top;">');
        tr.push('<div style="color:#2c3e50; font-weight:bold;' + (p.surgeryProcedure ? 'border-bottom:1px dotted #eee; padding-bottom:2px; margin-bottom:2px;' : '') + '">' + escapeHtml(p.disease || '') + '</div>');
        if (currentWard === "51") {
            if (p.surgeryDate === "縺ｪ縺・) {
                tr.push('<div class="surgery-proc-text" style="color:#999; font-size:11px; font-style:italic;">陦難ｼ壹↑縺・/div>');
            } else if (p.surgeryProcedure) {
                tr.push('<div class="surgery-proc-text" style="color:#c2185b; font-size:11px; font-weight:bold; word-break:break-all;" title="陦灘ｼ・ ' + escapeHtml(p.surgeryProcedure) + '">笨ゑｸ・' + escapeHtml(p.surgeryProcedure) + '</div>');
            } else {
                tr.push('<div class="surgery-proc-text" style="color:#bbb; font-size:11px; font-style:italic;">(陦灘ｼ乗悴蜿門ｾ・</div>');
            }
        }
        tr.push('</td>');
        
        tr.push('<td style="text-align:center; font-size:12px; font-weight:bold;">' + escapeHtml(p.room || '') + '</td>');
        
        var hospDaysHtml = escapeHtml(p.daysInHosp || "-");
        var surgeryInfoHtml = "";
        if (p.surgeryDate && p.surgeryDate !== "縺ｪ縺・ && p.surgeryDate !== "-") {
            var today = new Date();
            today.setHours(0,0,0,0);
            var sDate = new Date(p.surgeryDate);
            sDate.setHours(0,0,0,0);
            var diffDays = Math.floor((today.getTime() - sDate.getTime()) / (1000 * 3600 * 24));
            
            var postOpText = (diffDays === 0) ? "陦灘ｽ捺律" : (diffDays > 0 ? "陦灘ｾ・ + diffDays + "譌･" : "陦灘燕" + Math.abs(diffDays) + "譌･");
            hospDaysHtml += '<br><span style="color:#c62828; font-weight:bold; font-size:10px;">' + postOpText + '</span>';
            
            var epiBadge = p.surgeryHasEpi ? ' <span style="background:#dc3545; color:#fff; padding:0 3px; border-radius:2px;">繧ｨ繝疲怏</span>' : '';
            // 笘・ｿｽ蜉: 繝ｪ繧ｯ繧ｷ繧｢繝企←蠢懊ヰ繝・ず
            var lixBadge = p.surgeryLixiana ? ' <span style="background:#ff9800; color:#fff; padding:0 3px; border-radius:2px; font-weight:bold;" title="繝ｪ繧ｯ繧ｷ繧｢繝奇ｼ医お繝峨く繧ｵ繝舌Φ・蛾←蠢懈焔陦・>抽EDO</span>' : '';
            
            surgeryInfoHtml = '<div style="font-size:10px; color:#c2185b; background:#fce4ec; border:1px solid #f8bbd0; border-radius:3px; padding:2px; margin-bottom:2px;" title="逞・錐: ' + escapeHtml(p.surgeryDisease) + '\n陦灘ｼ・ ' + escapeHtml(p.surgeryProcedure) + '\n鮗ｻ驟・ ' + escapeHtml(p.surgeryAnesthesia) + '">笨ゑｸ剰｡・ ' + escapeHtml(p.surgeryDate) + epiBadge + lixBadge + '</div>';
        }
        tr.push('<td style="text-align:center; font-size:12px; line-height:1.2;">' + hospDaysHtml + '</td>');

        tr.push('<td class="blood-date-cell" style="padding:0; width:65px;">' + fetchBtnHtml + dateTextHtml + '</td>');
        var st1 = '<td class="status-cell ' + statClass + '" style="' + statUnderline + '" ';
        var st2 = 'onmousedown="startDragStatus(event, \'' + escapeHtml(p.id) + '\')" ' + clickEvent + '>';
        tr.push(st1 + st2 + statText + authorHtml + '</td>');
        
        tr.push('<td style="text-align:center; font-size:20px; color:#fd7e14; ' + chkBg + '" class="chk-toggle ' + chkClass + '" ' + chkEvent + '>' + chkText + '</td>');
        tr.push('<td style="text-align:center; font-size:20px; font-weight:bold; color:#e74c3c;" class="alert-toggle ' + aClass + '" ' + alertEvent + '>' + escapeHtml(aText) + '</td>');
        
        tr.push('<td class="' + hlClass + '" style="padding:4px;">');
        tr.push(surgeryInfoHtml); // 笘・Γ繝｢谺・・荳翫↓謇玖｡薙ヰ繝・ず繧呈諺蜈･
        
        // 蜈ｱ譛峨Γ繝｢
        var sharedMemoContent = escapeHtml(p.memo || "");
        var displaySharedMemo = sharedMemoContent.replace(/(#[^\s縲#]+)/g, '<span class="memo-tag">$1</span>');
        
        tr.push('<div class="memo-wrap" style="position:relative;">');
        tr.push('<div class="memo-display" style="font-size:12px; padding:2px; min-height:24px; white-space:pre-wrap; cursor:text; word-break:break-all;" onclick="if(isEditMode){this.style.display=\'none\'; this.nextSibling.style.display=\'block\'; this.nextSibling.focus(); this.nextSibling.style.height=\'auto\'; this.nextSibling.style.height=this.nextSibling.scrollHeight+\'px\';}">' + (displaySharedMemo || '<span style="color:#999;">縲仙・譛峨代Γ繝｢...</span>') + '</div>');
        var ta1 = '<textarea rows="1" ' + memoDisabled + ' ' + memoChangeShared;
        var ta2 = ' placeholder="縲仙・譛峨代Γ繝｢..." style="display:none; min-height:24px; padding:2px; font-size:12px; width:100%;" onblur="this.style.display=\'none\'; this.previousSibling.style.display=\'block\'; this.previousSibling.innerHTML = escapeHtml(this.value || \'\').replace(/(#[^\\s縲#]+)/g, \'<span class=\\\'memo-tag\\\'>$1</span>\') || \'<span style=\\\'color:#999;\\\'>縲仙・譛峨代Γ繝｢...</span>\';">';
        tr.push(ta1 + ta2 + sharedMemoContent + '</textarea>');
        tr.push('</div>');
        
        // 蛟倶ｺｺ繝｡繝｢
        var myMemoContent = escapeHtml(myMemo || "");
        var myDisplayMemo = myMemoContent.replace(/(#[^\s縲#]+)/g, '<span class="memo-tag">$1</span>');
        
        tr.push('<div class="memo-wrap hide-on-print" style="position:relative; margin-top:2px;">');
        tr.push('<div class="memo-display" style="font-size:12px; padding:2px; min-height:24px; white-space:pre-wrap; cursor:text; background:#e8f4f8; word-break:break-all;" onclick="if(isEditMode){this.style.display=\'none\'; this.nextSibling.style.display=\'block\'; this.nextSibling.focus(); this.nextSibling.style.height=\'auto\'; this.nextSibling.style.height=this.nextSibling.scrollHeight+\'px\';}">' + (myDisplayMemo || '<span style="color:#999;">縲仙倶ｺｺ縲代Γ繝｢...</span>') + '</div>');
        var ta3 = '<textarea rows="1" ' + memoDisabled + ' ' + memoChangePersonal;
        var ta4 = ' placeholder="縲仙倶ｺｺ縲代Γ繝｢..." ';
        var ta5 = 'style="display:none; min-height:24px; padding:2px; font-size:12px; background:#e8f4f8; width:100%;" onblur="this.style.display=\'none\'; this.previousSibling.style.display=\'block\'; this.previousSibling.innerHTML = escapeHtml(this.value || \'\').replace(/(#[^\\s縲#]+)/g, \'<span class=\\\'memo-tag\\\'>$1</span>\') || \'<span style=\\\'color:#999;\\\'>縲仙倶ｺｺ縲代Γ繝｢...</span>\';">';
        tr.push(ta3 + ta4 + ta5 + myMemoContent + '</textarea>');
        tr.push('</div>');
        tr.push('</td>');
        
        tr.push('<td class="hide-on-print ' + hlClass + '" style="font-size:10px; color:#666;">' + memoAuthorHtml + '</td>');
        tr.push('</tr>');
        html += tr.join('');
    }

    tbody.style.visibility = "hidden";
    tbody.innerHTML = html;
    var textareas = tbody.getElementsByTagName('textarea');
    for(var t=0; t<textareas.length; t++) {
        var ta = textareas[t];
        ta.style.height = 'auto'; 
        var sh = ta.scrollHeight;
        if (sh > 0) ta.style.height = sh + 'px';
    }
    tbody.style.visibility = "visible";
    var container = document.getElementById("main-content-scroll");
    if (container) container.scrollTop = scrollTop;
    window.scrollTo(scrollX, scrollY);
    
    // 笘・ｿｽ蜉: 5A逞・｣溘・譎ゅ□縺第焔陦灘叙蠕励・繧ｿ繝ｳ縺ｨ縲瑚｡灘ｼ上阪・繝・ム繝ｼ繧定｡ｨ遉ｺ縺吶ｋ
    var btnSurg = document.getElementById("btn-fetch-surgery");
    if (btnSurg) {
        btnSurg.style.display = (currentWard === "51") ? "block" : "none";
    }
    var hdrSurg = document.getElementById("header-surgery-proc");
    if (hdrSurg) {
        hdrSurg.style.display = (currentWard === "51") ? "block" : "none";
    }
}

function toggleAlertLevel(id) {
    if(!isEditMode) return;
    var p = findPatientById(id);
    if(!p) return;
    p.alertLevel = ((p.alertLevel || 0) + 1) % 3;
    var aLevel = p.alertLevel;
    var aText = aLevel === 1 ? "・・ : (aLevel === 2 ? "・・ : "");
    var aClass = aLevel === 1 ? "alert-question" : (aLevel === 2 ? "alert-exclamation" : "alert-none");

    var trId = "tr-patient-" + p.id;
    var tr = document.getElementById(trId);
    if (tr) {
        var td = tr.querySelector(".alert-toggle");
        if (td) { td.className = "alert-toggle " + aClass; td.innerText = aText; }
    }
    // 笘・ｿｽ蜉: 繝医Λ繝ｳ繧ｶ繧ｯ繧ｷ繝ｧ繝ｳ縺ｮ逋ｺ陦・
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("TOGGLE_ALERT", {
            patientId: id, wardCode: currentWard, value: p.alertLevel
        });
    }

}

function toggleStatus(id) {
    if(!isEditMode) return;
    var p = findPatientById(id);
    if(!p) return;
    p.status = ((p.status || 0) + 1) % 4;
    p.statusAuthor = p.status === 0 ? "" : currentUserName;

    // 笘・ｿｽ蜉: 莉句・迥ｶ豕∝､画峩縺ｮ繝医Λ繝ｳ繧ｶ繧ｯ繧ｷ繝ｧ繝ｳ逋ｺ陦・
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("TOGGLE_STATUS", {
            patientId: id, wardCode: currentWard, value: p.status, author: p.statusAuthor
        });
    }

    var trId = "tr-patient-" + p.id;
    var tr = document.getElementById(trId);
    if (tr) {
        var td = tr.querySelector(".status-cell");
        if (td) {
            var statIdx = p.status;
            var statClass = STATUS_CLASSES[statIdx];
            var rawStatText = STATUS_TEXTS[statIdx];
            var statText = rawStatText === "(譛ｪ險ｭ螳・" ? "譛ｪ" : (rawStatText === "莉句・莠亥ｮ・ ? "莠亥ｮ・ : (rawStatText === "謖・ｰ取ｸ・ ? "謖・ｰ・ : "險倬鹸"));
            
            var authorHtml = p.statusAuthor ? '<br><span class="status-author">' + escapeHtml(p.statusAuthor) + '</span>' : '';
            var statUnderline = (statIdx === 1 || statIdx === 2) ? 'text-decoration:underline;' : '';
            
            td.className = "status-cell " + statClass;
            td.style.cssText = statUnderline;
            td.innerHTML = statText + authorHtml;
        }
    }
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("TOGGLE_STATUS", {
            patientId: id, wardCode: currentWard, value: p.status, author: p.statusAuthor
        });
    }

}

// ---------- 莉句・閠・ラ繝ｩ繝・げ驕ｸ謚樊ｩ溯・ (Vol.11) ----------
var dragStatusInfo = { active: false, index: -1, startX: 0, currentX: 0, element: null };

function startDragStatus(e, id) {
    if(!isEditMode) return;
    if(e.button !== 1 && e.button !== 0) return; 

    dragStatusInfo.active = true;
    dragStatusInfo.index = id;
    dragStatusInfo.startX = e.clientX;
    dragStatusInfo.currentX = e.clientX;
    dragStatusInfo.element = e.srcElement || e.target;
    
    while(dragStatusInfo.element && dragStatusInfo.element.tagName !== 'TD') {
        dragStatusInfo.element = dragStatusInfo.element.parentNode;
    }
    
    if(dragStatusInfo.element && dragStatusInfo.element.setCapture) dragStatusInfo.element.setCapture();
    
    if (document.addEventListener) {
        document.addEventListener("mousemove", handleDragMove, false);
        document.addEventListener("mouseup", endDragStatus, false);
    } else if (document.attachEvent) {
        document.attachEvent("onmousemove", handleDragMove);
        document.attachEvent("onmouseup", endDragStatus);
    }
    
    if (e.stopPropagation) e.stopPropagation();
    e.cancelBubble = true;
    return false;
}

function handleDragMove() {
    if(!dragStatusInfo.active) return;
    var e = window.event;
    dragStatusInfo.currentX = e.clientX;
    
    var diff = Math.abs(dragStatusInfo.currentX - dragStatusInfo.startX);
    if(diff > 10) {
        if(dragStatusInfo.element && dragStatusInfo.element.className.indexOf("dragging-item") === -1) {
            dragStatusInfo.element.className += " dragging-item";
        }
    }
}

function endDragStatus() {
    if(!dragStatusInfo.active) return;
    var e = window.event;
    
    if (document.removeEventListener) {
        document.removeEventListener("mousemove", handleDragMove, false);
        document.removeEventListener("mouseup", endDragStatus, false);
    } else if (document.detachEvent) {
        document.detachEvent("onmousemove", handleDragMove);
        document.detachEvent("onmouseup", endDragStatus);
    }
    
    if(dragStatusInfo.element && dragStatusInfo.element.releaseCapture) dragStatusInfo.element.releaseCapture();
    
    if(dragStatusInfo.element) {
        dragStatusInfo.element.className = dragStatusInfo.element.className.replace(/dragging-item/g, "").trim();
    }

    var diff = Math.abs(dragStatusInfo.currentX - dragStatusInfo.startX);
    if(diff > 30) {
        showUserSelectMenu(dragStatusInfo.index, e.clientX, e.clientY);
    }
    
    dragStatusInfo.active = false;
}

function showUserSelectMenu(id, x, y) {
    var menu = document.getElementById("user-select-menu");
    if(!menu) {
        menu = document.createElement("div");
        menu.id = "user-select-menu";
        document.body.appendChild(menu);
    }
    
    var users = getUniqueUsers();
    var html = "";
    var encId = escapeHtml(id);
    html += '<div class="user-select-item" onclick="selectUserStatus(\'' + encId + '\', \'' + escapeHtml(currentUserName) + '\')">' + escapeHtml(currentUserName) + ' (閾ｪ蛻・</div>';
    
    for(var i=0; i<users.length; i++) {
        if(users[i] === currentUserName) continue;
        html += '<div class="user-select-item" onclick="selectUserStatus(\'' + encId + '\', \'' + escapeHtml(users[i]) + '\')">' + escapeHtml(users[i]) + '</div>';
    }
    html += '<div class="user-select-item" style="border-top:1px solid #eee; color:#999;" onclick="selectUserStatus(\'' + encId + '\', \'\')">(繧ｯ繝ｪ繧｢)</div>';
    
    menu.innerHTML = html;
    menu.style.display = "block";
    
    var scrollX = window.pageXOffset || document.documentElement.scrollLeft || document.body.scrollLeft;
    var scrollY = window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop;
    var left = x + scrollX + 5;
    var top = y + scrollY + 5;
    
    if(x + 155 > document.body.clientWidth) left = x + scrollX - 155;
    if(y + 205 > document.body.clientHeight) top = y + scrollY - 205;

    menu.style.left = left + "px";
    menu.style.top = top + "px";
    
    var closeMenu = function() {
        var ev = window.event;
        var target = ev.srcElement || ev.target;
        if(target.className.indexOf("user-select-item") === -1) {
            menu.style.display = "none";
            if (document.removeEventListener) {
                document.removeEventListener("mousedown", closeMenu, false);
            } else if (document.detachEvent) {
                document.detachEvent("onmousedown", closeMenu);
            }
        }
    };
    if (document.addEventListener) {
        setTimeout(function(){ document.addEventListener("mousedown", closeMenu, false); }, 50);
    } else if (document.attachEvent) {
        setTimeout(function(){ document.attachEvent("onmousedown", closeMenu); }, 50);
    }
}

function selectUserStatus(id, userName) {
    var p = findPatientById(id);
    if (!p) return;
    
    if((!p.status || p.status === 0) && userName !== "") p.status = 1;
    p.statusAuthor = userName;
    if(userName === "") p.status = 0;
    
    renderPatients();

    var menu = document.getElementById("user-select-menu");
    if(menu) menu.style.display = "none";
}

function getUniqueUsers() {
    if (cachedUniqueUsers !== null) return cachedUniqueUsers;
    
    var userMap = {};
    // 1. settings.users 縺九ｉ蜿門ｾ・
    if (appData && appData.users) {
        for (var id in appData.users) {
            var name = appData.users[id];
            if (name && name !== "undefined") userMap[name] = true;
        }
    }
    
    // 2. 閾ｪ蛻・・霄ｫ繧貞ｿ・★蜷ｫ繧√ｋ (ToDo 菴懈･ｭ閠・ｄ莉句・閠・∈謚樒畑)
    if (currentUserName && currentUserName !== "") {
        userMap[currentUserName] = true;
    }

    var result = [];
    for (var n in userMap) {
        if (userMap.hasOwnProperty(n)) result.push(n);
    }
    result.sort();
    cachedUniqueUsers = result;
    return result;
}

function togglePrescriptionCheck(id) {
    if(!isEditMode) return;
    var p = findPatientById(id);
    if(!p) return;

    var currentVal = p.chkPrescription || 0;
    if(typeof currentVal === "boolean") currentVal = currentVal ? 2 : 0;
    p.chkPrescription = (currentVal + 1) % 3;

    // 笘・ｿｽ蜉: 蜃ｦ譁ｹ繝√ぉ繝・け縺ｮ繝医Λ繝ｳ繧ｶ繧ｯ繧ｷ繝ｧ繝ｳ逋ｺ陦・
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("TOGGLE_PRESCRIPTION", {
            patientId: id, wardCode: currentWard, value: p.chkPrescription
        });
    }

    var trId = "tr-patient-" + p.id;
    var tr = document.getElementById(trId);
    if (tr) {
        var td = tr.querySelector(".chk-toggle");
        if (td) {
            var val = p.chkPrescription;
            if(val === 1) {
                td.className = "chk-toggle status-chk-half"; td.innerHTML = "&#9744;"; td.style.backgroundColor = "#ffe8a1";
            } else if(val === 2) {
                td.className = "chk-toggle status-chk-on"; td.innerHTML = "&#10004;"; td.style.backgroundColor = "";
            } else {
                td.className = "chk-toggle"; td.innerHTML = ""; td.style.backgroundColor = "";
            }
        }
    }
    // 笘・ｿｽ蜉: 繝医Λ繝ｳ繧ｶ繧ｯ繧ｷ繝ｧ繝ｳ縺ｮ逋ｺ陦・
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("TOGGLE_PRESCRIPTION", {
            patientId: id, wardCode: currentWard, value: p.chkPrescription
        });
    }

}

function updateMemo(id, val, element) {
    if(!isEditMode) return;
    var p = findPatientById(id);
    if(!p) return; 
    if(p.memo !== val) {
        p.memo = val;
        if (element) {
            element.style.height = "auto";
            element.style.height = element.scrollHeight + "px";
            
            var isHighlight = false;
            var highlightWords = ["騾髯｢", "霆｢髯｢", "ENT", "ent"];
            var lowerVal = val.toLowerCase();
            for(var w=0; w<highlightWords.length; w++) {
                if (lowerVal.indexOf(highlightWords[w].toLowerCase()) !== -1) {
                    isHighlight = true;
                    break;
                }
            }
            var tdMemo = element.parentNode;
            if (tdMemo && tdMemo.tagName && tdMemo.tagName.toLowerCase() === 'td') {
                if (isHighlight) {
                    addClass(tdMemo, 'highlight-row');
                } else {
                    removeClass(tdMemo, 'highlight-row');
                }
            }
        }
    }
    
    // 笘・％縺薙↓縺ゅ▲縺・if (typeof DataManager !== "undefined") { ... } 縺ｮ莨晉･ｨ逋ｺ陦後ヶ繝ｭ繝・け繧偵∪繧九＃縺ｨ蜑企勁縺励∪縺・
    // ・亥・蜉帛ｮ御ｺ・凾縺ｮ finalizeMemo 髢｢謨ｰ蛛ｴ縺ｫ莉ｻ縺帙ｋ縺溘ａ・・
}

function updatePersonalMemoHeight(element) {
    if (element) {
        element.style.height = "auto";
        element.style.height = (element.scrollHeight) + "px";
    }
}

function finalizePersonalMemo(id, element) {
    if(!isEditMode) return;
    var val = element.value;
    var p = findPatientById(id);
    if(!p) return;
    if(!p.personalMemos) p.personalMemos = {};
    p.personalMemos[currentSystemId] = val;
    // 笘・ｿｽ蜉: 繝医Λ繝ｳ繧ｶ繧ｯ繧ｷ繝ｧ繝ｳ縺ｮ逋ｺ陦・
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("UPDATE_PERSONAL_MEMO", {
            patientId: id, wardCode: currentWard, userId: currentSystemId, value: val
        });
    }

}

function finalizeMemo(id, element) {
    if(!isEditMode) return;
    var p = findPatientById(id);
    var val = element.value;
    if(!p) return;
    
    // 1. 繝｡繝｢繝ｪ繧貞叉譎よ峩譁ｰ
    p.memo = val;

    // 2. 繝医Λ繝ｳ繧ｶ繧ｯ繧ｷ繝ｧ繝ｳ繝輔ぃ繧､繝ｫ繧剃ｽ懈・縺吶ｋ・医％繧後・髱槫ｸｸ縺ｫ霆ｽ縺・・縺ｧ蜊ｳ譎ょｮ溯｡鯉ｼ・
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("UPDATE_PATIENT_MEMO", {
            patientId: id, wardCode: currentWard, value: val
        });
    }

    // 3. 逕ｻ髱｢蜀肴緒逕ｻ・・I縺ｮ螳悟・蜷梧悄・・
    renderPatients();
}

function resetAllStatus() {
    if(!isEditMode) return;
    var list = getCurrentPatientsList();
    if(list.length === 0) return;
    
    if(confirm("縲占ｭｦ蜻翫曾n陦ｨ遉ｺ荳ｭ縺ｮ逞・｣溘・縲御ｻ句・迥ｶ豕√阪ｒ縺吶∋縺ｦ繝ｪ繧ｻ繝・ヨ・亥・譛溷喧・峨＠縺ｾ縺吶・n窶ｻ繝槭・繧ｯ(・・・・縺翫ｈ縺ｳ蜈ｱ譛峨Γ繝｢縺ｯ菫晄戟縺輔ｌ縺ｾ縺吶・n\n譛ｬ蠖薙↓繧医ｍ縺励＞縺ｧ縺吶°・・)) {
        if(confirm("譛邨ら｢ｺ隱阪〒縺吶よ悽蠖薙↓荳諡ｬ繝ｪ繧ｻ繝・ヨ繧貞ｮ溯｡後＠縺ｦ繧医ｍ縺励＞縺ｧ縺吶°・・)) {
            for(var i=0; i<list.length; i++) {
                list[i].status = 0;
                list[i].statusAuthor = "";
            }
            renderPatients();

            alert("莉句・迥ｶ豕√・繝ｪ繧ｻ繝・ヨ縺悟ｮ御ｺ・＠縺ｾ縺励◆縲・);
        }
    }
}

function resetAllPrescriptionChecks() {
    if(!isEditMode) return;
    var list = getCurrentPatientsList();
    if(list.length === 0) return;
    
    if(confirm("陦ｨ遉ｺ荳ｭ縺ｮ逞・｣溘・縲悟・譁ｹ縲咲｢ｺ隱咲憾諷具ｼ遺恃繝ｻ笘撰ｼ峨ｒ縺吶∋縺ｦ隗｣髯､縺励※繧医ｍ縺励＞縺ｧ縺吶°・・)) {
        for(var i=0; i<list.length; i++) {
            list[i].chkPrescription = 0;
        }
        renderPatients();

        alert("蜃ｦ譁ｹ遒ｺ隱阪・繝√ぉ繝・け繧偵け繝ｪ繧｢縺励∪縺励◆縲・);
    }
}

function jumpToPatient(pid, pname) {
    if(!pid && !pname) return;
    
    try {
        switchTab('tab-patients');
        
        // 繧ｿ繝門・繧頑崛縺医↓繧医ｋDOM縺ｮ蜀崎｡ｨ遉ｺ・・isplay: block;・峨′螳御ｺ・＠縺ｦ縺九ｉ繧ｹ繧ｯ繝ｭ繝ｼ繝ｫ縺輔○繧九ｈ縺・≦蟒ｶ
        setTimeout(function() {
            try {
                var tr = null;
                // 縺ｾ縺唔D縺ｧ讀懃ｴ｢
                if (pid) {
                    var trId = "tr-patient-" + String(pid).trim();
                    tr = document.getElementById(trId);
                }
                // ID縺ｧ隕九▽縺九ｉ縺ｪ縺九▲縺溷ｴ蜷医∬｡ｨ遉ｺ縺輔ｌ縺ｦ縺・ｋ陦後°繧画ｰ丞錐縺ｧ讀懃ｴ｢
                if (!tr && pname) {
                    var tbody = document.getElementById("tbody-patients");
                    var rows = tbody.getElementsByTagName("tr");
                    for (var i = 0; i < rows.length; i++) {
                        // 謔｣閠・ｸ隕ｧ縺ｮ2蛻礼岼(繧､繝ｳ繝・ャ繧ｯ繧ｹ1)縺梧ｰ丞錐
                        var nameCell = rows[i].getElementsByTagName("td")[1];
                        if (nameCell && nameCell.innerText.indexOf(pname) !== -1) {
                            tr = rows[i];
                            break;
                        }
                    }
                }

                if(tr) {
                    // IE11髱槫ｯｾ蠢懊・ {behavior: "smooth"} 繧ｪ繝悶ず繧ｧ繧ｯ繝医〒縺ｯ縺ｪ縺上∽ｺ呈鋤諤ｧ縺ｮ縺ゅｋ true 繧呈ｸ｡縺・
                    tr.scrollIntoView(true);
                    
                    // 荳迸ｬ鮟・牡縺上ワ繧､繝ｩ繧､繝医＠縺ｦ蝣ｴ謇繧堤衍繧峨○繧・
                    var oldBg = tr.style.backgroundColor;
                    tr.style.backgroundColor = "#ffeb3b";
                    setTimeout(function(){
                        tr.style.backgroundColor = oldBg;
                    }, 1500);
                } else {
                    var msg = pid ? ("ID: " + pid) : "";
                    if (pname) msg += (msg ? " / " : "") + "豌丞錐: " + pname;
                    alert("迴ｾ蝨ｨ陦ｨ遉ｺ荳ｭ縺ｮ逞・｣溘・謔｣閠・ｸ隕ｧ縺ｫ縲∬ｩｲ蠖薙・謔｣閠・" + msg + ") 縺瑚ｦ九▽縺九ｊ縺ｾ縺帙ｓ縺ｧ縺励◆縲・n(蛻･縺ｮ逞・｣溘・謔｣閠・・蜿ｯ閭ｽ諤ｧ縺後≠繧翫∪縺・");
                }
            } catch(e) {
                alert("繧ｸ繝｣繝ｳ繝怜・縺ｮ繧ｹ繧ｯ繝ｭ繝ｼ繝ｫ蜃ｦ逅・↓螟ｱ謨励＠縺ｾ縺励◆: " + e.message);
            }
        }, 150);
    } catch(err) {
        alert("繧ｸ繝｣繝ｳ繝怜・逅・・襍ｷ蜍輔↓螟ｱ謨励＠縺ｾ縺励◆: " + err.message);
    }
}

// ---------- 螟夜Κ繝・・繧ｿ蜿門ｾ励→HTML繝代・繧ｹ (IFRAME譁ｹ蠑・ ----------
function fetchPatientData() {
    if(!isEditMode) return;
    
    // 迴ｾ蝨ｨ縺ｮ逞・｣溯ｨｭ螳壹ｒ蜿門ｾ・
    var wardCode = currentWard;
    if(!wardCode) {
        alert("譛牙柑縺ｪ逞・｣溘′驕ｸ謚槭＆繧後※縺・∪縺帙ｓ縲・);
        return;
    }
    var wardSettings = { name: getWardName(wardCode), code: wardCode };
    if(!currentSystemId) {
        alert("諡・ｽ楢・D(繧ｷ繧ｹ繝・Β逕ｨ)縺瑚ｨｭ螳壹＆繧後※縺・∪縺帙ｓ縲ゆｸ蠎ｦ繝ｪ繝ｭ繝ｼ繝峨＠縺ｦ蜀阪Ο繧ｰ繧､繝ｳ縺励※縺上□縺輔＞縲・);
        return;
    }
    
    var btn = document.getElementById("btn-fetch");
    var orgText = btn.innerText;
    btn.innerText = "竊ｻ 蜿門ｾ嶺ｸｭ...";
    btn.disabled = true;

    var nowStr = new Date().toLocaleTimeString();
    var lastUpdateLabel = document.getElementById("last-update-time");
    if (lastUpdateLabel) {
        lastUpdateLabel.innerText = "(譛邨８eb繝・・繧ｿ蜿門ｾ・ " + nowStr + ")";
    }

    // JSONP繝ｬ繧ｹ繝昴Φ繧ｹ逕ｨ縺ｮ荳譎ゅさ繝ｼ繝ｫ繝舌ャ繧ｯ・井ｸｦ陦悟・逅・・縺溘ａ隍・焚・・
    var callbacks = [];
    var wCode = wardSettings.code ? String(wardSettings.code) : "";
    var wName = wardSettings.name ? String(wardSettings.name) : "";
    var isDummy = (wCode === "99") || 
                  (wName.indexOf("・・橸ｾ撰ｽｰ") !== -1) ||
                  (wCode.toLowerCase() === "test") ||
                  (wName.toLowerCase() === "test");

    if (isDummy) {
        setTimeout(function() {
            var dummyPatients = [];
            var depts = ["蜀・ｧ・, "螟也ｧ・, "謨ｴ蠖｢螟也ｧ・, "逕｣蟀ｦ莠ｺ遘・, "蟆丞・遘・, "逵ｼ遘・, "閠ｳ鮠ｻ遘・, "逧ｮ閹夂ｧ・, "豕悟ｰｿ蝎ｨ遘・, "閼ｳ逾樒ｵ悟､也ｧ・];
            var diseases = ["蜴溽匱諤ｧ蜈咲稔荳榊・逞・咏ｾ､", "諤･諤ｧ陌ｫ蝙らｎ", "螟ｧ閻ｿ鬪ｨ霆｢蟄宣Κ鬪ｨ謚・, "譁ｰ蝙九さ繝ｭ繝願ぜ轤・, "2蝙狗ｳ門ｰｿ逞・, "逋ｽ蜀・囿", "遯∫匱諤ｧ髮｣閨ｴ", "繧｢繝医ヴ繝ｼ諤ｧ逧ｮ閹夂ｎ", "蜑咲ｫ玖・閧･螟ｧ逞・, "縺上ｂ閹應ｸ句・陦"];
            
            for(var i=1; i<=40; i++) {
                var dIdx = i % 10;
                // 4莠ｺ縺斐→縺ｫ驛ｨ螻狗分蜿ｷ繧貞､峨∴繧九ム繝溘・
                var roomNum = (300 + Math.ceil(i/4)).toString();
                
                dummyPatients.push({
                    room: roomNum, // 笘・ｿｽ蜉: 逞・ｮ､繝繝溘・ [cite: 11]
                    id: (100000 + i).toString(),
                    name: "繝・せ繝域ぅ閠・" + i + "蜿ｷ",
                    dept: depts[dIdx],
                    doctor: "蛹ｻ蟶ｫ" + String.fromCharCode(65 + dIdx % 5),
                    disease: diseases[dIdx],
                    daysInHosp: (Math.floor(Math.random() * 50) + 1).toString() // 笘・ｿｽ蜉: 蝨ｨ髯｢譌･謨ｰ繝繝溘・ [cite: 11]
                });
            }
            
            processFetchedPatients(dummyPatients, wardSettings.name || "TEST(・・橸ｾ撰ｽｰ)");
            btn.innerText = "竊ｻ 迴ｾ蝨ｨ縺ｮ逞・｣溘・繧ｷ繧ｹ繝・Β譖ｴ譁ｰ";
            btn.disabled = false;
        }, 300);
        return;
    }

    var iframeId = "loader-iframe";
    var iframe = document.getElementById(iframeId);
    if (!iframe) {
        iframe = document.createElement("iframe");
        iframe.id = iframeId;
        iframe.style.display = "none";
        document.body.appendChild(iframe);
    }
    
    iframe.onload = function() {
        try {
            var doc = iframe.contentWindow.document;
            parseHtmlAndMerge(doc, wardSettings.name);
        } catch(e) {
            alert("謔｣閠・ョ繝ｼ繧ｿ縺ｮ隱ｭ縺ｿ蜿悶ｊ縺ｫ螟ｱ謨励＠縺ｾ縺励◆縲・n\n縲占・∴繧峨ｌ繧句次蝗縲曾n1. 繧ｻ繧ｭ繝･繝ｪ繝・ぅ蛻ｶ髯・ 繝悶Λ繧ｦ繧ｶ・医う繝ｳ繧ｿ繝ｼ繝阪ャ繝医が繝励す繝ｧ繝ｳ・峨・縲惹ｿ｡鬆ｼ貂医∩繧ｵ繧､繝医上↓繧ｫ繝ｫ繝・し繝ｼ繝舌・縺ｮURL(10.5.71.21)繧堤匳骭ｲ縺励※縺上□縺輔＞縲・n2. 繝阪ャ繝医Ρ繝ｼ繧ｯ: 繧ｵ繝ｼ繝舌・縺ｫ謗･邯壹〒縺阪↑縺・腸蠅・〒縺吶・n3. 繝輔ぃ繧､繝ｫ荳榊惠: 縺ｾ縺菴懈・縺輔ｌ縺ｦ縺・↑縺・凾髢灘ｸｯ縺ｮ繝ｪ繧ｹ繝医ｒ隱ｭ縺ｿ霎ｼ繧ゅ≧縺ｨ縺励※縺・∪縺吶・n\n繧ｨ繝ｩ繝ｼ隧ｳ邏ｰ: " + e.message);
        }
        btn.innerText = "竊ｻ 迴ｾ蝨ｨ縺ｮ逞・｣溘・繧ｷ繧ｹ繝・Β譖ｴ譁ｰ";
        btn.disabled = false;
        
        setTimeout(function(){ iframe.onload = null; }, 100);
    };
    
    // URL縺ｮ閾ｪ蜍慕函謌・
    var today = new Date();
    var yyyy = today.getFullYear();
    var mm = ("0" + (today.getMonth() + 1)).slice(-2);
    var dd = ("0" + today.getDate()).slice(-2);
    var dateStr = yyyy + "%2F" + mm + "%2F" + dd; // YYYY/MM/DD縺ｮ繧ｨ繝ｳ繧ｳ繝ｼ繝・
    
    var baseUrl = "http://10.5.71.21:8082/karte/kanja_ichiran/kanja_ichiran.php";
    var fetchUrl = baseUrl + "?byoto_code=" + wardSettings.code + 
                   "&search_date=" + dateStr + 
                   "&ichiran_code=58&user_id=" + currentSystemId + 
                   "&section_code=&page_num=0&login_flg=" + 
                   "&t=" + new Date().getTime(); // 繧ｭ繝｣繝・す繝･蝗樣∩
    
    // 繧ゅ＠謇句虚縺ｧ繝・せ繝育畑URL縺瑚ｨｭ螳壹＆繧後※縺・◆蝣ｴ蜷医・繝・ヰ繝・げ逕ｨ蝗樣∩・郁ｨｭ螳壹さ繝ｼ繝峨′http蟋九∪繧翫↑繧峨◎縺ｮ縺ｾ縺ｾ菴ｿ縺・ｼ・
    if (String(wardSettings.code).indexOf('http') === 0 || String(wardSettings.code).indexOf('file') === 0) {
        fetchUrl = wardSettings.code;
    }

    try {
        iframe.src = fetchUrl;
    } catch(e) {
        alert("URL繧帝幕縺代∪縺帙ｓ縺ｧ縺励◆: " + e.message);
        btn.innerText = "竊ｻ 迴ｾ蝨ｨ縺ｮ逞・｣溘・繧ｷ繧ｹ繝・Β譖ｴ譁ｰ";
        btn.disabled = false;
    }
}

// ---------- 謗｡陦譌･蛟句挨蜿門ｾ玲ｩ溯・・・arte.php騾｣謳ｺ・・----------
// Deleted redundant vars & function

/**
 * 謔｣閠・ユ繝ｼ繝悶Ν繧呈､懃ｴ｢繝輔ぅ繝ｫ繧ｿ繝ｼ縺ｧ邨槭ｊ霎ｼ繧
 * Line 524 縺九ｉ蜻ｼ縺ｳ蜃ｺ縺輔ｌ繧・
 */
function filterPatientTable() {
    var input = document.getElementById("ipt-patient-search");
    if (!input) return;
    var filter = input.value.toLowerCase();
    var tbody = document.getElementById("tbody-patients");
    if (!tbody) return;
    var tr = tbody.getElementsByTagName("tr");

    for (var i = 0; i < tr.length; i++) {
        var row = tr[i];
        // 繝・・繧ｿ縺ｪ縺励Γ繝・そ繝ｼ繧ｸ縺ｪ縺ｩ繧貞愛螳壹☆繧九◆繧√・繧ｻ繝ｫ謨ｰ繝√ぉ繝・け
        if (row.cells.length < 5) continue; 
        
        var text = (row.textContent || row.innerText || "").toLowerCase();
        if (text.indexOf(filter) > -1) {
            row.style.display = "";
        } else {
            row.style.display = "none";
        }
    }
}

// Dead code processNextBloodFetch removed

function fetchBloodDateForPatient(patientId) {
    var p = findPatientById(patientId);
    if (!p) return;
    
    // UI繝輔ぅ繝ｼ繝峨ヰ繝・け
    var tr = document.getElementById("tr-patient-" + patientId);
    if (tr) {
        var textEl = tr.querySelector(".blood-date-text");
        if (textEl) textEl.innerText = "蜿門ｾ嶺ｸｭ...";
    }
    
    fetchSingleBloodDate(p, function() {
        renderPatients();

    });
}

function updateAllBloodDates() {
    if (!isEditMode) { alert("邱ｨ髮・Δ繝ｼ繝画凾縺ｮ縺ｿ螳溯｡悟庄閭ｽ縺ｧ縺吶・); return; }
    var list = getCurrentPatientsList();
    if (list.length === 0) { alert("譖ｴ譁ｰ蟇ｾ雎｡縺ｮ謔｣閠・′縺・∪縺帙ｓ縲・); return; }
    
    if (!confirm("陦ｨ遉ｺ荳ｭ縺ｮ蜈ｨ謔｣閠・" + list.length + "蜷・縺ｮ謗｡陦譌･繧帝・ｬ｡蜿門ｾ励＠縺ｾ縺吶°・歃n(陬上〒1莉ｶ縺壹▽蜿門ｾ励☆繧九◆繧∫判髱｢縺ｯ蝗ｺ縺ｾ繧翫∪縺帙ｓ)")) return;

    var btn = document.querySelector("div[onclick='updateAllBloodDates()']");
    var originalText = btn ? btn.innerText : "[謗｡陦] 蜈ｨ菴灘叙蠕・;
    if (btn) { btn.style.pointerEvents = "none"; btn.innerText = "貅門ｙ荳ｭ..."; }

    window.isBloodFetching = true;

    var idsToFetch = [];
    for (var i = 0; i < list.length; i++) {
        idsToFetch.push(list[i].id);
        var tr = document.getElementById("tr-patient-" + list[i].id);
        if (tr) {
            var textEl = tr.querySelector(".blood-date-text");
            if (textEl) textEl.innerText = "蠕・ｩ滉ｸｭ...";
        }
    }

    var totalCount = idsToFetch.length;
    var index = 0;

    function processNext() {
        if (index >= totalCount) {
            window.isBloodFetching = false;
            if (btn) { btn.style.pointerEvents = "auto"; btn.innerText = originalText; }
            renderPatients();
            
            // 笘・ｶ・㍾隕・ｼ夐≦蟒ｶ菫晏ｭ・autoSave)縺ｧ縺ｯ縺ｪ縺上√い繝ｩ繝ｼ繝医′蜃ｺ繧句燕縺ｫ縲仙叉譎ゆｿ晏ｭ倥代ｒ蠑ｷ蛻ｶ螳溯｡鯉ｼ・
            saveData(false);
            
            alert("蜈ｨ莉ｶ縺ｮ蜿門ｾ励′螳御ｺ・＠縺ｾ縺励◆縲・);
            return;
        }
        
        var targetId = idsToFetch[index];
        index++;
        var patient = findPatientById(targetId);
        
        if (btn) btn.innerText = "谿・ " + (totalCount - index + 1);
        
        if (!patient) {
            setTimeout(processNext, 50);
            return;
        }

        var tr = document.getElementById("tr-patient-" + patient.id);
        if (tr) {
            var textEl = tr.querySelector(".blood-date-text");
            if (textEl) textEl.innerText = "蜿門ｾ嶺ｸｭ...";
        }
        
        fetchSingleBloodDate(patient, function() {
            var updateTr = document.getElementById("tr-patient-" + patient.id);
            if (updateTr) {
                var dtEl = updateTr.querySelector(".blood-date-text");
                if (dtEl) dtEl.innerText = patient.bloodDate || "-";
            }
            setTimeout(processNext, 200);
        });
    }
    processNext();
}

// --- Shift-JIS 繝・さ繝ｼ繝臥畑繝倥Ν繝代・ ---
function decodeShiftJIS(bin) {
    try {
        var stream = new ActiveXObject("ADODB.Stream");
        stream.Type = 1; // adTypeBinary
        stream.Open();
        stream.Write(bin);
        stream.Position = 0;
        stream.Type = 2; // adTypeText
        stream.Charset = "Shift_JIS";
        var text = stream.ReadText();
        stream.Close();
        return text;
    } catch (e) {
        return "";
    }
}

function fetchSingleBloodDate(p, callback) {
    if (!p || !p.id) { callback(); return; }
    
    var userId = "16622";
    if (typeof currentSystemId !== "undefined" && currentSystemId) {
        userId = currentSystemId;
    } else if (typeof appData !== "undefined" && appData.settings && appData.settings.adminIds && appData.settings.adminIds[0]) {
        userId = appData.settings.adminIds[0];
    }

    var url = "http://10.5.71.21:8082/karte/karte.php?kanja_id=" + p.id + 
              "&user_id=" + userId + 
              "&order_search_flg=1&order_search_code=3&order_search_name=#top" +
              "&_nocache=" + new Date().getTime();

    var iframeId = "blood-fetch-iframe-" + p.id;
    var existing = document.getElementById(iframeId);
    if (existing && existing.parentNode) existing.parentNode.removeChild(existing);

    var iframe = document.createElement("iframe");
    iframe.id = iframeId;
    iframe.style.display = "none";
    iframe.application = "yes"; 
    document.body.appendChild(iframe);

    var isDone = false;
    var cleanupAndCallback = function() {
        if (isDone) return;
        isDone = true;
        setTimeout(function() {
            var ifr = document.getElementById(iframeId);
            if (ifr && ifr.parentNode) ifr.parentNode.removeChild(ifr);
        }, 500);
        callback(); 
    };

    var fallbackTimer = setTimeout(function() {
        if (!isDone) {
            p.bloodDate = "-";
            p.bloodDetail = "隱ｭ縺ｿ霎ｼ縺ｿ繧ｿ繧､繝繧｢繧ｦ繝・3蛻・ｶ・℃)";
            cleanupAndCallback();
        }
    }, 180000); 

    iframe.onload = function() {
        setTimeout(function() {
            if (isDone) return;
            try {
                var doc = iframe.contentWindow.document;
                var allText = "";
                
                function collectText(currentDoc) {
                    if (!currentDoc) return;
                    try {
                        if (currentDoc.body && currentDoc.body.innerText) {
                            allText += " " + currentDoc.body.innerText;
                        }
                    } catch(e) {}
                    var frames = currentDoc.getElementsByTagName("frame");
                    var iframes = currentDoc.getElementsByTagName("iframe");
                    for(var j=0; j<frames.length; j++) {
                        try { collectText(frames[j].contentWindow.document); } catch(e){}
                    }
                    for(var k=0; k<iframes.length; k++) {
                        try { collectText(iframes[k].contentWindow.document); } catch(e){}
                    }
                }
                
                collectText(doc);

                var regex = /縲・[^縲曽*?(?:逕溷喧蟄ｦ|陦豸ｲ|螟匁ｳｨ|荳闊ｬ)[^縲曽*?)縲措^縲疹{0,150}?(\d{4})\/(\d{2})\/(\d{2})/g;
                var match;
                var today = new Date();
                today.setHours(0,0,0,0);
                var futureEntries = [];
                
                while ((match = regex.exec(allText)) !== null) {
                    var typeRaw = match[1].replace(/^[0-9:\s]+/, '').replace(/\[.*?\]\s*/g, '').trim();
                    var typeClean = typeRaw.substring(0, 15);
                    var y = parseInt(match[2], 10);
                    var m = parseInt(match[3], 10);
                    var d = parseInt(match[4], 10);
                    var dt = new Date(y, m - 1, d);
                    
                    var diffDays = (dt.getTime() - today.getTime()) / (1000 * 3600 * 24);
                    if (diffDays >= 1 && diffDays <= 30) {
                        futureEntries.push({
                            dateObj: dt,
                            displayDate: ('0'+m).slice(-2) + '/' + ('0'+d).slice(-2),
                            category: typeClean,
                            fullText: match[0].substring(0, 45)
                        });
                    }
                }
                
                if (futureEntries.length > 0) {
                    futureEntries.sort(function(a, b) { return a.dateObj.getTime() - b.dateObj.getTime(); });
                    var target = futureEntries[0];
                    p.bloodDate = target.displayDate + '(' + target.category + ')';
                    p.bloodDetail = target.fullText;
                } else {
                    p.bloodDate = "縺ｪ縺・;
                    p.bloodDetail = "譏取律莉･髯・0譌･莉･蜀・・讀懈渊莠亥ｮ壹′隕九▽縺九ｊ縺ｾ縺帙ｓ縺ｧ縺励◆";
                }
            } catch(e) {
                p.bloodDate = "-";
                p.bloodDetail = "繝輔Ξ繝ｼ繝隗｣譫舌お繝ｩ繝ｼ: " + (e.message || e);
            }
            
            // 笘・ｿｽ蜉: 繝・・繧ｿ蜿門ｾ玲・蜉滓凾縺ｫ縲√％縺薙〒遒ｺ螳溘↓莨晉･ｨ(Transaction)繧堤匱陦後☆繧・
            if (typeof DataManager !== "undefined") {
                DataManager.appendTransaction("UPDATE_BLOOD_DATE", {
                    patientId: p.id,
                    wardCode: currentWard,
                    bloodDate: p.bloodDate,
                    bloodDetail: p.bloodDetail
                });
            }

            clearTimeout(fallbackTimer);
            
            var tr = document.getElementById('tr-patient-' + p.id);
            if (tr) {
                var dateSpan = tr.querySelector('.blood-date-text');
                if (dateSpan) dateSpan.innerHTML = escapeHtml(p.bloodDate);
                var fetchBtn = tr.querySelector('.blood-fetch-btn');
                if (fetchBtn) { fetchBtn.innerText = '螳御ｺ・; fetchBtn.disabled = false; }
                var cell = tr.querySelector('.blood-date-cell');
                if (cell && p.bloodDetail) cell.title = '謗｡陦隧ｳ邏ｰ: ' + escapeHtml(p.bloodDetail) + ' (繧ｯ繝ｪ繝・け縺ｧ謇句虚菫ｮ豁｣)';
            }

            cleanupAndCallback();
        }, 1500); 
    };
    
    try {
        iframe.src = url;
    } catch(e) {
        p.bloodDate = "-";
        p.bloodDetail = "URL繧｢繧ｯ繧ｻ繧ｹ繧ｨ繝ｩ繝ｼ";
        clearTimeout(fallbackTimer);
        cleanupAndCallback();
    }
}

function parseHtmlAndMerge(doc, wardName) {
    try {
        var tables = doc.getElementsByTagName("table");
        if(tables.length === 0) {
            alert("繝壹・繧ｸ縺ｫ繝・・繝悶Ν繝・・繧ｿ縺悟性縺ｾ繧後※縺・∪縺帙ｓ縲・);
            return;
        }

        var targetTable = tables[0];
        var rows = targetTable.getElementsByTagName("tr");
        
        var newPatients = [];
        var roomIndex = 8;     // 笘・ｿｽ蜉: 逞・ｮ､ (蛻礼分蜿ｷ8) [cite: 11]
        var idIndex = 2;       // 謔｣閠・D
        var nameIndex = 3;     // 豌丞錐
        var deptIndex = 9;     // 險ｺ逋らｧ・
        var docIndex = 10;     // 荳ｻ豐ｻ蛹ｻ
        var diseaseIndex = 32; // 荳ｻ逞・錐
        var daysInHospIndex = 29; // 蝨ｨ髯｢譌･謨ｰ
        
        for(var i = 0; i < rows.length; i++) {
            var cells = rows[i].getElementsByTagName("td");
            if(cells.length > diseaseIndex) {
                var pidStr = (cells[idIndex].innerText || cells[idIndex].textContent || "").replace(/\s+/g, "");
                
                if (pidStr.indexOf("謔｣閠・D") !== -1 || pidStr === "・ｼ" || pidStr === "") continue;

                // 逞・ｮ､縺ｮ蜿門ｾ・[cite: 11]
                var proom = cells[roomIndex] ? (cells[roomIndex].innerText || cells[roomIndex].textContent || "").trim() : "";
                var pname = cells[nameIndex].innerText || cells[nameIndex].textContent || "";
                var pdept = cells[deptIndex].innerText || cells[deptIndex].textContent || "";
                var pdoc = cells[docIndex].innerText || cells[docIndex].textContent || "";
                var pdisease = cells[diseaseIndex].innerText || cells[diseaseIndex].textContent || "";
                var pdays = cells[daysInHospIndex] ? (cells[daysInHospIndex].innerText || cells[daysInHospIndex].textContent || "") : "-";

                if(pidStr) {
                    newPatients.push({
                        room: proom,   // 笘・ｿｽ蜉 [cite: 11]
                        id: pidStr,
                        name: pname.trim(),
                        dept: pdept.trim(),
                        doctor: pdoc.trim(),
                        disease: pdisease.trim(),
                        daysInHosp: pdays.trim()
                    });
                }
            }
        }
        
        if(newPatients.length === 0) {
            alert("繝・・繝悶Ν縺九ｉ謔｣閠・ュ蝣ｱ繧呈歓蜃ｺ縺ｧ縺阪∪縺帙ｓ縺ｧ縺励◆縲ゅョ繝ｼ繧ｿ縺・莉ｶ縺ｾ縺溘・繝輔か繝ｼ繝槭ャ繝医′螟峨ｏ縺｣縺溷庄閭ｽ諤ｧ縺後≠繧翫∪縺吶・);
            return;
        }
        
        processFetchedPatients(newPatients, wardName);
    } catch(e) {
        alert("HTML隗｣譫舌お繝ｩ繝ｼ: " + e.message);
    }
}

function processFetchedPatients(newPatients, wardName) {
    if (!newPatients || !newPatients.length) return;
    
    // 荳肴ｭ｣縺ｪ遨ｺ繝・・繧ｿ繧呈賜髯､ (Vol.15.13)
    newPatients = newPatients.filter(function(item) { return item != null; });
    
    try {
        var list = getCurrentPatientsList();
        var oldMap = {};
        for(var j = 0; j < list.length; j++) {
            if(list[j]) oldMap[list[j].id] = list[j];
        }
        
        var newMap = {};
        var newMap = {};
        for(var k = 0; k < newPatients.length; k++) {
            if(newPatients[k]) newMap[newPatients[k].id] = newPatients[k];
        }
        
        // 蜈･騾螳､螻･豁ｴ・郁ｿｽ蜉繝ｻ蜑企勁縺ｮ讀懃衍・俄ｻ繝・・繧ｿ縺檎ｩｺ縺ｮ迥ｶ諷九°繧峨・蛻晏屓隱ｭ縺ｿ霎ｼ縺ｿ譎ゅ↓縺ｯ螟ｧ驥上↓螻･豁ｴ縺悟・繧九・繧帝亟縺舌◆繧∵里蟄倥Μ繧ｹ繝医′縺ゅｋ蝣ｴ蜷医・縺ｿ險倬鹸
        if (!appData.history) appData.history = [];
        var nowStr = getTodayString() + " " + getTimeString();
        var historyAdded = 0;
        
        // 騾螳､閠・い繝ｼ繧ｫ繧､繝也畑・亥ｭ伜惠縺励↑縺代ｌ縺ｰ蛻晄悄蛹厄ｼ・
        if (!appData.dischargedArchive) appData.dischargedArchive = {};

        // === 繧｢繝ｼ繧ｫ繧､繝悶・閾ｪ蜍輔け繝ｪ繝ｼ繝ｳ繧｢繝・・・育ｴ・濠蟷ｴ・・80譌･邨碁℃縺ｧ蜑企勁・・===
        var currentMs = new Date().getTime();
        var limitMs = 180 * 24 * 60 * 60 * 1000;
        for (var arcId in appData.dischargedArchive) {
            if (appData.dischargedArchive.hasOwnProperty(arcId)) {
                var arcDat = appData.dischargedArchive[arcId].archivedAt;
                if (arcDat && (currentMs - arcDat > limitMs)) {
                    delete appData.dischargedArchive[arcId];
                }
            }
        }

        // 譌ｧ繝ｪ繧ｹ繝医↓縺ゅ▲縺ｦ縲∵眠繝ｪ繧ｹ繝医↓縺ｪ縺・ｺｺ ・・縲碁螳､縲・
        for(var j = 0; j < list.length; j++) {
            var oldP = list[j];
            if(!oldP) continue;
            if(!newMap[oldP.id]) {
                appData.history.unshift({
                    date: nowStr, type: "騾螳､", patient: oldP.name, id: oldP.id, ward: wardName, 
                    dept: oldP.dept || "", doctor: oldP.doctor || "", disease: oldP.disease || "",
                    createdAt: new Date().getTime(), user: currentUserName
                });
                historyAdded++;
                
                // 騾螳､譎ゅ↓繝｡繝｢繧・ｻ句・繝輔Λ繧ｰ諠・ｱ繧偵い繝ｼ繧ｫ繧､繝悶∈菫晏ｭ・
                appData.dischargedArchive[oldP.id] = {
                    id: oldP.id, // 笘・ｿｽ蜉: 繧｢繝ｼ繧ｫ繧､繝悶ョ繝ｼ繧ｿ蜀・↓繧・D繧剃ｿ晄戟縺輔○繧・
                    status: oldP.status,
                    statusAuthor: oldP.statusAuthor,
                    memo: oldP.memo,
                    chkPrescription: oldP.chkPrescription || false,
                    memoAuthors: oldP.memoAuthors || [],
                    memoAuthor: oldP.memoAuthor || "",
                    alertLevel: oldP.alertLevel || 0,
                    personalMemos: oldP.personalMemos || {},
                    archivedAt: new Date().getTime(),
                    bloodDate: oldP.bloodDate || "",
                    bloodDetail: oldP.bloodDetail || ""
                };
            }
        }
        
        var mergedList = [];
        for(var k = 0; k < newPatients.length; k++) {
            var np = newPatients[k];
            // 譁ｰ繝ｪ繧ｹ繝医↓縺ゅ▲縺ｦ縲∵立繝ｪ繧ｹ繝医↓縺ｪ縺・ｺｺ ・・縲悟・螳､縲・
            if(!oldMap[np.id] && list.length > 0) {
                appData.history.unshift({
                    date: nowStr, type: "蜈･螳､/霑ｽ蜉", patient: np.name, id: np.id, ward: wardName,
                    dept: np.dept || "", doctor: np.doctor || "", disease: np.disease || "",
                    createdAt: new Date().getTime(), user: currentUserName
                });
                historyAdded++;
            }
            
            var pId = np.id;
            if(pId && oldMap[pId]) {
                var oldP = oldMap[pId];
                np.status = oldP.status;
                np.statusAuthor = oldP.statusAuthor;
                np.memo = oldP.memo;
                np.chkPrescription = oldP.chkPrescription || false;
                np.memoAuthors = oldP.memoAuthors || [];
                np.memoAuthor = oldP.memoAuthor || "";
                np.alertLevel = oldP.alertLevel || 0;
                np.personalMemos = oldP.personalMemos || {};
                if (oldP.bloodDate && oldP.bloodDate !== "-") {
                    np.bloodDate = oldP.bloodDate;
                    np.bloodDetail = oldP.bloodDetail;
                } else if ((!np.bloodDate || np.bloodDate === "-") && oldP.bloodDate) {
                    np.bloodDate = oldP.bloodDate;
                    np.bloodDetail = oldP.bloodDetail;
                }
            } else {
                // 逞・｣滄俣遘ｻ蜍墓凾縺ｮ諠・ｱ蠑輔″邯吶℃ (cross-ward inheritance)
                // 縺薙・逞・｣溘・譌ｧ繝ｪ繧ｹ繝医↓縺ｯ螻・↑縺・′縲∽ｻ悶・逞・｣溘ョ繝ｼ繧ｿ縺ｫ蜷後§ID縺ｮ謔｣閠・′蟄伜惠縺吶ｋ縺区爾邏｢縺吶ｋ
                var inherited = false;
                var otherWards = [];
                for (var wk in appData.patients) {
                    if (wk !== String(currentWard) && appData.patients[wk]) {
                        otherWards.push(appData.patients[wk]);
                    }
                }
                
                for(var w = 0; w < otherWards.length; w++) {
                    var wList = otherWards[w];
                    if(!wList) continue;
                    for(var m = 0; m < wList.length; m++) {
                        if (wList[m] && wList[m].id === np.id) {
                            var target = wList[m];
                            np.status = target.status;
                            np.statusAuthor = target.statusAuthor;
                            np.memo = target.memo;
                            np.chkPrescription = target.chkPrescription || false;
                            np.memoAuthors = target.memoAuthors || [];
                            np.memoAuthor = target.memoAuthor || "";
                            np.alertLevel = target.alertLevel || 0;
                            np.personalMemos = target.personalMemos || {};
                            inherited = true;
                            break; 
                        }
                    }
                    if(inherited) break;
                }
                
                // 縺ｩ縺ｮ逞・｣溘↓繧ょｭ伜惠縺励↑縺・ｴ蜷医・℃蜴ｻ縺ｮ騾螳､繧｢繝ｼ繧ｫ繧､繝悶ｒ謗｢縺・
                if(!inherited && appData.dischargedArchive && appData.dischargedArchive[np.id]) {
                    var arc = appData.dischargedArchive[np.id];
                    np.status = arc.status;
                    np.statusAuthor = arc.statusAuthor;
                    np.memo = arc.memo;
                    np.chkPrescription = arc.chkPrescription || false;
                    np.memoAuthors = arc.memoAuthors || [];
                    np.memoAuthor = arc.memoAuthor || "";
                    np.alertLevel = arc.alertLevel || 0;
                    np.personalMemos = arc.personalMemos || {};
                    inherited = true;
                    // 蠑慕ｶ吶℃螳御ｺ・ｾ後√い繝ｼ繧ｫ繧､繝悶°繧峨・蜑企勁縺吶ｋ
                    delete appData.dischargedArchive[np.id];
                }

                // 笘・ｿｽ蜉: 繧｢繝ｼ繧ｫ繧､繝悶↓繧ゅ↑縺・ｴ蜷医√＆繧峨↓縲悟・髯｢莠亥ｮ・admissionSchedule)縲阪↓繝・・繧ｿ縺後↑縺・°謗｢縺・
                if(!inherited && appData.admissionSchedule) {
                    for(var as=0; as<appData.admissionSchedule.length; as++) {
                        var asP = appData.admissionSchedule[as];
                        if(asP && String(asP.id) === String(np.id)) {
                            np.status = asP.status || 0;
                            np.statusAuthor = asP.statusAuthor || "";
                            np.memo = asP.memo || "";
                            np.memoAuthors = asP.memoAuthors || [];
                            np.memoAuthor = asP.memoAuthor || "";
                            np.alertLevel = asP.alertLevel || 0;
                            np.personalMemos = asP.personalMemos || {};
                            // 謗｡陦莠亥ｮ壹′蜈･縺｣縺ｦ縺・ｌ縺ｰ縺昴ｌ繧ょｼ輔″邯吶＄
                            if (asP.bloodDate && asP.bloodDate !== "-") {
                                np.bloodDate = asP.bloodDate;
                                np.bloodDetail = asP.bloodDetail || "";
                            }
                            inherited = true;
                            break;
                        }
                    }
                }

                // 縺昴ｌ縺ｧ繧ょｭ伜惠縺励↑縺・ｮ悟・縺ｪ譁ｰ隕乗ぅ閠・・蝣ｴ蜷・
                if(!inherited) {
                    np.status = 0;
                    np.statusAuthor = "";
                    np.memo = "";
                }
            }
            mergedList.push(np);
        }
        
        // 螻･豁ｴ縺悟､壹￥縺ｪ繧翫☆縺弱↑縺・ｈ縺・↓蛻ｶ髯撰ｼ育峩霑・00莉ｶ・・
        if (appData.history && appData.history.length > 100) {
            appData.history = appData.history.slice(0, 100);
        }
        
        // 繝・・繧ｿ縺ｮ譖ｸ縺崎ｾｼ縺ｿ
        appData.patients[currentWard] = mergedList;
        
        renderPatients();
        renderHistory(); // 螻･豁ｴ繧ｿ繝悶・譖ｴ譁ｰ

        var msg = wardName + " 縺ｮ繝ｪ繧ｹ繝医ｒ譖ｴ譁ｰ縺励∪縺励◆縲・" + mergedList.length + "莉ｶ)";
        if(historyAdded > 0) msg += " 窶ｻ騾螳､/霑ｽ蜉縺ｮ螟牙虚縺後≠繧翫∪縺励◆ (螻･豁ｴ繧ｿ繝門盾辣ｧ)";
        
        var elTime = document.getElementById("last-update-time");
        if(elTime) elTime.innerText = "縲舌す繧ｹ繝・Β譛邨ょ叙蠕・ " + getTimeString() + "縲・;
        
        // 蜈･髯｢莠亥ｮ壹ョ繝ｼ繧ｿ繧ょ酔譎ゅ↓蜿門ｾ・
        setTimeout(function(){ fetchAdmissionSchedule(); }, 3000);
        
        // 繝ｭ繝ｼ繧ｫ繝ｫ譖ｴ譁ｰ譎る俣繧ょ粋繧上○縺ｦ繝ｪ繧ｻ繝・ヨ縺励※縺翫￥・域ｬ｡蝗橸ｼ大・蠕後↓螟峨ｏ繧具ｼ・
        var elLocalTime = document.getElementById("last-local-update-time");
        if(elLocalTime) elLocalTime.innerText = "縲舌Ο繝ｼ繧ｫ繝ｫ繝・・繧ｿ譛譁ｰ: " + getTimeString() + "縲・;
        
    } catch(e) {
        alert("謔｣閠・ョ繝ｼ繧ｿ縺ｮ繝槭・繧ｸ蜃ｦ逅・お繝ｩ繝ｼ: " + e.message);
    }
}

// ---------- 蜈･髯｢莠亥ｮ壽ぅ閠・ｸ隕ｧ ----------
var admissionPatients = [];

function toggleAdmissionPanel() {
    var body = document.getElementById('admission-body');
    var icon = document.getElementById('admission-toggle-icon');
    if (body.style.display === 'none') {
        body.style.display = '';
        icon.innerText = '笆ｼ';
    } else {
        body.style.display = 'none';
        icon.innerText = '笆ｲ';
    }
}

function fetchAdmissionSchedule() {
    if (!isEditMode) return;
    var wardCode = currentWard;
    var wardName = getWardName(wardCode);
    if (!wardCode || String(wardCode) === '99' || String(wardCode).indexOf('http') === 0) return;

    var iframeId = "admission-iframe";
    var iframe = document.getElementById(iframeId);
    if (!iframe) {
        iframe = document.createElement("iframe");
        iframe.id = iframeId;
        iframe.style.display = "none";
        document.body.appendChild(iframe);
    }

    var today = new Date();
    var yyyy = today.getFullYear();
    var mm = ('0' + (today.getMonth() + 1)).slice(-2);
    var dd = ('0' + today.getDate()).slice(-2);
    var dateStr = yyyy + "%2F" + mm + "%2F" + dd;

    var fetchUrl = "http://10.5.71.21:8082/karte/kanja_ichiran/kanja_ichiran.php" +
        "?nyuin_yoyaku_start_date=" + dateStr +
        "&nyuin_yoyaku_end_date=" + dateStr +
        "&byoto_gentei_flg=%2C" +
        "&nyuin_byoto_code=" + wardCode +
        "&ichiran_code=6&user_id=" + currentSystemId +
        "&section_code=&page_num=0&login_flg=" +
        "&t=" + new Date().getTime();

    iframe.onload = function() {
        try {
            var doc = iframe.contentWindow.document;
            parseAdmissionHtml(doc);
        } catch(e) {}
    };
    try { iframe.src = fetchUrl; } catch(e) {}
}

function renderCustomCalendarHTML() {
    var div = document.getElementById("custom-datepicker");
    if(!div) return;
    var y = calCurrentYear;
    var m = calCurrentMonth;
    var firstDay = new Date(y, m-1, 1).getDay();
    var lastDate = new Date(y, m, 0).getDate();
    
    var html = [];
    html.push("<div style='display:flex; justify-content:space-between; align-items:center; margin-bottom:5px; background:#f0f0f0; padding:3px; border-radius:3px;'>");
    html.push("<button onclick='changeCalMonth(-1)' style='cursor:pointer; border:none; background:transparent;' title='蜑肴怦'>笳</button>");
    html.push("<b style='font-size:13px;'>" + m + "譛・(" + y + "蟷ｴ)</b>");
    html.push("<button onclick='changeCalMonth(1)' style='cursor:pointer; border:none; background:transparent;' title='谺｡譛・>笆ｶ</button>");
    html.push("</div>");
    
    html.push("<table style='width:100%; text-align:center; font-size:12px; border-collapse:collapse;'>");
    html.push("<tr style='color:#666; border-bottom:1px solid #ccc;'>");
    html.push("<th style='color:#e74c3c;'>譌･</th><th>譛・/th><th>轣ｫ</th><th>豌ｴ</th><th>譛ｨ</th><th>驥・/th><th style='color:#3498db;'>蝨・/th></tr><tr>");
    
    for(var i=0; i<firstDay; i++) { html.push("<td></td>"); }
    for(var i=1; i<=(lastDate); i++) {
        var dayOfWeek = (i + firstDay - 1) % 7;
        var cls = (dayOfWeek === 0) ? "color:#e74c3c;" : (dayOfWeek === 6) ? "color:#3498db;" : "";
        var isToday = (m === new Date().getMonth()+1 && i === new Date().getDate() && y === new Date().getFullYear());
        var isSelected = (m === calSelectedMonth && i === calSelectedDate);
        var bg = isSelected ? "background:#2ecc71; color:#fff; border-radius:3px; font-weight:bold;" : (isToday ? "background:#ffecb3; border-radius:3px;" : "background:#fff;");
        var styleCls = "cursor:pointer; width:24px; height:24px; padding:0; margin:1px; border:1px solid #ddd; " + cls + " " + bg;
        html.push("<td><button onclick='clickCalDate("+m+", "+i+")' style='" + styleCls + "'>" + i + "</button></td>");
        if(dayOfWeek === 6 && i !== lastDate) html.push("</tr><tr>");
    }
    html.push("</tr></table>");
    
    var existingTime = "";
    if(pendingDeadline) {
        var tm = pendingDeadline.match(/\s([0-9]{1,2}:[0-9]{1,2})/);
        if(tm) existingTime = tm[1];
    }
    
    html.push("<div style='margin-top:10px; display:flex; align-items:center; justify-content:space-between; border-top:1px solid #ccc; padding-top:8px;'>");
    html.push("<span style='font-size:12px; margin-right:5px; font-weight:bold;'>譎ょ綾:</span>");
    html.push("<select id='cal-time' style='padding:4px; font-size:12px; flex-grow:1; border:1px solid #aaa; border-radius:3px;'>");
    html.push("<option value=''>謖・ｮ壹↑縺・/option>");
    for(var h=0; h<24; h++) {
        var hStr = (h<10?"0":"")+h+":00";
        var hSel = (existingTime === hStr) ? "selected" : "";
        html.push("<option value='"+hStr+"' "+hSel+">"+hStr+"</option>");
    }
    html.push("</select></div>");
    
    html.push("<div style='margin-top:12px; display:flex; justify-content:space-between; gap:5px;'>");
    html.push("<button onclick='commitCalDate()' style='flex-grow:1; background:#3498db; color:white; border:none; padding:6px 0; border-radius:4px; cursor:pointer; font-weight:bold;'>豎ｺ螳・/button>");
    html.push("<button onclick='clearCalDate()' style='background:#e74c3c; color:white; border:none; padding:6px 10px; border-radius:4px; cursor:pointer;'>繧ｯ繝ｪ繧｢</button>");
    html.push("<button onclick='document.getElementById(\"custom-datepicker\").style.display=\"none\";' style='background:#95a5a6; color:white; border:none; padding:6px 10px; border-radius:4px; cursor:pointer;'>髢峨§繧・/button>");
    html.push("</div>");
    
    div.innerHTML = html.join('');
}

function parseBloodDateFromDoc(doc, patientId) {
    var today = new Date();
    today.setHours(0,0,0,0);
    var futureEntries = [];
    var allEntries = [];

    try {
        var allText = "";
        
        function collectText(currentDoc) {
            if(!currentDoc) return;
            try {
                if (currentDoc.body && currentDoc.body.innerText) {
                    allText += " " + currentDoc.body.innerText;
                }
            } catch(e) {}
            
            var frames = currentDoc.getElementsByTagName('frame');
            var iframes = currentDoc.getElementsByTagName('iframe');
            for(var j=0; j<frames.length; j++) {
                try { collectText(frames[j].contentWindow.document); } catch(e){}
            }
            for(var k=0; k<iframes.length; k++) {
                try { collectText(iframes[k].contentWindow.document); } catch(e){}
            }
        }
        collectText(doc);

        var regex = /[縲申[]([^縲曾]]+)[縲曾]][^縲申[]{0,100}?(\d{4})\/(\d{2})\/(\d{2})/g;
        var match;
        
        while ((match = regex.exec(allText)) !== null) {
            // 繧ｫ繝・ざ繝ｪ縺ｮ繧ｯ繝ｪ繝ｼ繝九Φ繧ｰ
            var catRaw = match[1].replace(/^[0-9:]+\s*/, '').replace(/\[.*?\]\s*/g, '').trim();
            var catClean = catRaw.substring(0, 15);
            
            var y = parseInt(match[2], 10);
            var m = parseInt(match[3], 10);
            var d = parseInt(match[4], 10);
            var dt = new Date(y, m - 1, d);
            
            var entry = { 
                dateObj: dt, 
                displayDate: ('0'+m).slice(-2) + '/' + ('0'+d).slice(-2),
                category: catClean,
                fullText: match[0].substring(0, 40)
            };
            
            // 莉頑律縺ｨ謚ｽ蜃ｺ縺励◆譌･莉倥・蟾ｮ・域律謨ｰ・峨ｒ險育ｮ・
            var diffDays = (dt.getTime() - today.getTime()) / (1000 * 3600 * 24);
            // 笘・ｿｮ豁｣・壻ｻ頑律(0)莉･蜑阪√∪縺溘・30譌･繧医ｊ蜈医・繝・・繧ｿ縺ｯ辟｡隕悶☆繧・
            if (diffDays < 1 || diffDays > 30) continue;
            
            futureEntries.push(entry);
        }
    } catch(e) {}
    
    var targetEntry = null;
    // 隕九▽縺代◆譌･莉倥Μ繧ｹ繝医ｒ荳ｦ縺ｳ譖ｿ縺医※縲御ｸ逡ｪ莉頑律縺ｫ霑代＞譛ｪ譚･縲阪ｒ驕ｸ縺ｶ
    if (futureEntries.length > 0) {
        futureEntries.sort(function(a, b) { return a.dateObj.getTime() - b.dateObj.getTime(); });
        targetEntry = futureEntries[0];
    }
    
    var p = findPatientById(patientId);
    if (!p) return;

    if (targetEntry) {
        var catText = targetEntry.category ? '(' + targetEntry.category + ')' : '';
        p.bloodDate = targetEntry.displayDate + catText;
        p.bloodDetail = targetEntry.fullText;
    } else {
        // 笘・ｿｮ豁｣・夊ｦ九▽縺九ｉ縺ｪ縺九▲縺溷ｴ蜷医・縲後↑縺励阪→陦ｨ遉ｺ
        p.bloodDate = '縺ｪ縺・;
        p.bloodDetail = '譏取律莉･髯・0譌･莉･蜀・・讀懈渊莠亥ｮ壹′隕九▽縺九ｊ縺ｾ縺帙ｓ縺ｧ縺励◆';
    }
    
    var tr = document.getElementById('tr-patient-' + patientId);
    if (tr) {
        var dateSpan = tr.querySelector('.blood-date-text');
        if (dateSpan) dateSpan.innerHTML = escapeHtml(p.bloodDate);
        var fetchBtn = tr.querySelector('.blood-fetch-btn');
        if (fetchBtn) { fetchBtn.innerText = '螳御ｺ・; fetchBtn.disabled = false; }
        var cell = tr.querySelector('.blood-date-cell');
        if (cell && p.bloodDetail) cell.title = '謗｡陦隧ｳ邏ｰ: ' + escapeHtml(p.bloodDetail) + ' (繧ｯ繝ｪ繝・け縺ｧ謇句虚菫ｮ豁｣)';
    }

}



// function saveDataQuietly removed to avoid conflict with DataManager

function parseAdmissionHtml(doc) {
    try {
        var tables = doc.getElementsByTagName("table");
        if (tables.length === 0) return;

        var targetTable = tables[0];
        var rows = targetTable.getElementsByTagName("tr");

        var newAdmissions = [];
        var idIndex = 2;
        var nameIndex = 3;
        var deptIndex = 11;
        var docIndex = 12;
        var diseaseIndex = 15;
        var bloodDateIndex = 17; // 蜈･髯｢莠亥ｮ夂畑繧､繝ｳ繝・ャ繧ｯ繧ｹ縺ｮ莉ｮ螳・

        for (var i = 0; i < rows.length; i++) {
            var cells = rows[i].getElementsByTagName("td");
            if (cells.length > diseaseIndex) {
                var pidStr = (cells[idIndex].innerText || cells[idIndex].textContent || "").replace(/[\n\r]/g, "").replace(/\s+/g, "");
                var pname = (cells[nameIndex].innerText || cells[nameIndex].textContent || "").trim();
                var pdept = (cells[deptIndex].innerText || cells[deptIndex].textContent || "").trim();
                var pdoc = (cells[docIndex].innerText || cells[docIndex].textContent || "").trim();
                var pdisease = (cells[diseaseIndex].innerText || cells[diseaseIndex].textContent || "").trim();

                if (pidStr) {
                    newAdmissions.push({
                        id: pidStr,
                        name: pname,
                        dept: pdept,
                        doctor: pdoc,
                        disease: pdisease,
                        daysInHosp: "-",
                        bloodDate: (cells[bloodDateIndex] ? (cells[bloodDateIndex].innerText || cells[bloodDateIndex].textContent || "").replace(/[\n\r\t]/g, "").trim() : "-")
                    });
                }
            }
        }

        // 譌｢蟄倥・蜈･髯｢莠亥ｮ壹ョ繝ｼ繧ｿ縺九ｉ繧ｹ繝・・繧ｿ繧ｹ繝ｻ繝｡繝｢繧貞ｼ輔″邯吶＄
        var oldMap = {};
        for (var j = 0; j < admissionPatients.length; j++) {
            oldMap[admissionPatients[j].id] = admissionPatients[j];
        }
        // appData縺ｮadmissionSchedule縺九ｉ繧ょｼ輔″邯吶＄
        if (appData.admissionSchedule) {
            for (var j = 0; j < appData.admissionSchedule.length; j++) {
                var as = appData.admissionSchedule[j];
                if (!oldMap[as.id]) oldMap[as.id] = as;
            }
        }
        // 譌｢蟄倥・謔｣閠・Μ繧ｹ繝医°繧峨ｂ蠑輔″邯吶℃・亥・髯｢莠亥ｮ壺・蜈･髯｢遘ｻ陦梧凾・・
        var currentList = getCurrentPatientsList();
        for (var j = 0; j < currentList.length; j++) {
            if (!oldMap[currentList[j].id]) oldMap[currentList[j].id] = currentList[j];
        }

        for (var k = 0; k < newAdmissions.length; k++) {
            var np = newAdmissions[k];
            var old = oldMap[np.id];
            if (old) {
                np.status = old.status || 0;
                np.statusAuthor = old.statusAuthor || "";
                np.memo = old.memo || "";
                np.memoAuthors = old.memoAuthors || [];
                np.memoAuthor = old.memoAuthor || "";
                np.alertLevel = old.alertLevel || 0;
                // 謗｡陦譌･縺ｮ蠑輔″邯吶℃
                if ((!np.bloodDate || np.bloodDate === "-") && old.bloodDate) {
                    np.bloodDate = old.bloodDate;
                }
            } else {
                np.status = 0;
                np.statusAuthor = "";
                np.memo = "";
                np.memoAuthors = [];
                np.alertLevel = 0;
            }
        }

        admissionPatients = newAdmissions;
        appData.admissionSchedule = newAdmissions;
        renderAdmissionSchedule();

    } catch(e) {
        // 繝代・繧ｹ繧ｨ繝ｩ繝ｼ縺ｯ繧ｵ繧､繝ｬ繝ｳ繝医↓
    }
}

function renderAdmissionSchedule() {
    var tbody = document.getElementById('tbody-admission');
    var countEl = document.getElementById('admission-count');
    if (!tbody) return;
    if (countEl) countEl.innerText = admissionPatients.length;
    if (admissionPatients.length === 0) {
        tbody.innerHTML = '<tr><td colspan="10" align="center">譛ｬ譌･縺ｮ蜈･髯｢莠亥ｮ壹・縺ゅｊ縺ｾ縺帙ｓ</td></tr>';
        return;
    }
    var html = '';
    for (var i = 0; i < admissionPatients.length; i++) {
        var p = admissionPatients[i];
        var statIdx = p.status || 0;
        var statClass = STATUS_CLASSES[statIdx];
        var statText = STATUS_TEXTS[statIdx];
        if(statText === "(譛ｪ險ｭ螳・") statText = "譛ｪ";
        else if(statText === "莉句・莠亥ｮ・) statText = "莠亥ｮ・;
        else if(statText === "謖・ｰ取ｸ・) statText = "謖・ｰ・;
        else if(statText === "險倬鹸貂・) statText = "險倬鹸";

        var authorHtml = p.statusAuthor ? '<br><span class="status-author">' + p.statusAuthor + '</span>' : '';
        var statUnderline = (statIdx === 1 || statIdx === 2) ? 'text-decoration:underline;' : '';
        var clickEvent = isEditMode ? 'onclick="toggleAdmissionStatus('+i+')"' : '';
        var memoDisabled = isEditMode ? '' : 'disabled="disabled"';
        var memoChange = isEditMode ? 'onchange="finalizeAdmissionMemo('+i+', this)" onkeyup="updateAdmissionMemoDebounced('+i+', this.value, this)"' : '';
        var alertEvent = isEditMode ? 'onclick="toggleAdmissionAlert('+i+')"' : '';
        var aLevel = p.alertLevel || 0;
        var aText = aLevel === 0 ? '' : aLevel === 1 ? '?' : '!';
        var aClass = aLevel === 0 ? '' : aLevel === 1 ? 'alert-caution' : 'alert-urgent';
        var bdAdClick = isEditMode ? 'onclick="changeAdmissionBloodDate('+i+')"' : '';
        var bdAdTitle = p.bloodDetail ? 'title="謗｡陦隧ｳ邏ｰ: ' + escapeHtml(p.bloodDetail) + '"' : 'title="謗｡陦譌･菫ｮ豁｣"';

        var alreadyAdmitted = false;
        var currentList = getCurrentPatientsList();
        for (var cl = 0; cl < currentList.length; cl++) {
            var pIdNorm1 = String(p.id).replace(/^0+/, '') || '0';
            var pIdNorm2 = String(currentList[cl].id).replace(/^0+/, '') || '0';
            if (pIdNorm1 === pIdNorm2) { alreadyAdmitted = true; break; }
        }
        var admittedBadge = alreadyAdmitted ? '<span style="background:#28a745;color:#fff;font-size:9px;padding:1px 4px;border-radius:3px;">蜈･髯｢貂・/span>' : '';

        var tr = [];
        tr.push('<tr' + (alreadyAdmitted ? ' style="background:#e8f5e9;"' : '') + '>');
        tr.push('<td>' + escapeHtml(p.id) + '</td>');
        tr.push('<td>' + escapeHtml(p.name) + admittedBadge + '</td>');
        tr.push('<td class="hide-on-print" style="font-size:11px; padding:2px 4px;">');
        tr.push('<div style="color:#0d6efd; font-weight:bold;">' + escapeHtml(p.dept || '') + '</div>');
        tr.push('<div style="color:#555;">' + escapeHtml(p.doctor || '') + '</div>');
        tr.push('</td>');
        tr.push('<td>' + escapeHtml(p.disease || '') + '</td>');
        tr.push('<td style="text-align:center; font-size:12px;">' + escapeHtml(p.room || '-') + '</td>');
        tr.push('<td style="text-align:center;">-</td>');
        tr.push('<td ' + bdAdClick + ' style="text-align:center; font-size:11px; cursor:pointer;" ' + bdAdTitle + '>' + escapeHtml(p.bloodDate || "-") + '</td>');
        tr.push('<td class="status-cell ' + statClass + '" style="' + statUnderline + '" ' + clickEvent + '>' + statText + authorHtml + '</td>');
        tr.push('<td style="text-align:center;">-</td>');
        tr.push('<td style="text-align:center; font-size:14px; font-weight:bold;" class="alert-toggle ' + aClass + '" ' + alertEvent + '>' + escapeHtml(aText) + '</td>');
        tr.push('<td><textarea ' + memoDisabled + ' ' + memoChange + ' placeholder="繝｡繝｢...">' + escapeHtml(p.memo || '') + '</textarea></td>');
        tr.push('</tr>');
        html += tr.join('');
    }
    tbody.innerHTML = html;
}

function toggleAdmissionStatus(idx) {
    if (!isEditMode || idx >= admissionPatients.length) return;
    var p = admissionPatients[idx];
    p.status = ((p.status || 0) + 1) % 4;
    p.statusAuthor = currentUserName;
    appData.admissionSchedule = admissionPatients;
    
    // 笘・ｿｽ蜉
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("UPDATE_ADMISSION_STATUS", {
            patientId: p.id, value: p.status, author: p.statusAuthor
        });
    }
    renderAdmissionSchedule();

}

function toggleAdmissionAlert(idx) {
    if (!isEditMode || idx >= admissionPatients.length) return;
    var p = admissionPatients[idx];
    p.alertLevel = ((p.alertLevel || 0) + 1) % 3;
    appData.admissionSchedule = admissionPatients;
    
    // 笘・ｿｽ蜉
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("UPDATE_ADMISSION_ALERT", {
            patientId: p.id, value: p.alertLevel
        });
    }
    renderAdmissionSchedule();

}

// changeBloodDate: ID繝吶・繧ｹ縺ｫ螟画峩 (謇句虚蜈･蜉帙・OM逶ｴ謗･譖ｴ譁ｰ)
function changeBloodDate(patientId) {
    if (!isEditMode) return;
    var list = getCurrentPatientsList();
    var p = null;
    for (var i = 0; i < list.length; i++) {
        if (String(list[i].id) === String(patientId)) { p = list[i]; break; }
    }
    if (!p) return;
    var currentText = (p.bloodDate || '').replace(/<[^>]+>/g, ' ').trim();
    var newVal = prompt('謗｡陦譌･繧貞・蜉帙＠縺ｦ縺上□縺輔＞ (萓・ 03/25)', currentText);
    if (newVal !== null) {
        p.bloodDate = newVal;
        p.bloodDetail = '';
        
        // 笘・ｿｽ蜉: 謇句虚蜈･蜉帶凾繧ら｢ｺ螳溘↓莨晉･ｨ(Transaction)繧堤匱陦後☆繧・
        if (typeof DataManager !== "undefined") {
            DataManager.appendTransaction("UPDATE_BLOOD_DATE", {
                patientId: p.id,
                wardCode: currentWard,
                bloodDate: p.bloodDate,
                bloodDetail: p.bloodDetail
            });
        }

        // DOM逶ｴ謗･譖ｴ譁ｰ
        var tr = document.getElementById('tr-patient-' + p.id);
        if (tr) {
            var dateSpan = tr.querySelector('.blood-date-text');
            if (dateSpan) dateSpan.innerHTML = escapeHtml(newVal || '-');
            var cell = tr.querySelector('.blood-date-cell');
            if (cell) cell.title = '繧ｯ繝ｪ繝・け縺ｧ謗｡陦譌･繧呈焔蜍穂ｿｮ豁｣';
        }

    }
}

function changeAdmissionBloodDate(index) {
    if (!isEditMode || index >= admissionPatients.length) return;
    var p = admissionPatients[index];
    var newVal = prompt("謗｡陦譌･繧貞・蜉帙＠縺ｦ縺上□縺輔＞ (萓・ 03/25)", p.bloodDate || "");
    if (newVal !== null) {
        p.bloodDate = newVal;
        renderAdmissionSchedule();

    }
}

function updateAdmissionMemo(idx, val, el) {
    if (idx >= admissionPatients.length) return;
    admissionPatients[idx].memo = val;
    appData.admissionSchedule = admissionPatients;
}

function finalizeAdmissionMemo(idx, el) {
    if (idx >= admissionPatients.length) return;
    var p = admissionPatients[idx];
    p.memo = el.value;
    if (el.value && currentUserName) {
        if (!p.memoAuthors) p.memoAuthors = [];
        if (p.memoAuthors.indexOf(currentUserName) === -1) {
            p.memoAuthors.unshift(currentUserName);
        }
    }
    appData.admissionSchedule = admissionPatients;
    
    // 笘・ｿｽ蜉: 繝医Λ繝ｳ繧ｶ繧ｯ繧ｷ繝ｧ繝ｳ縺ｮ逋ｺ陦・
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("UPDATE_ADMISSION_MEMO", {
            patientId: p.id, value: p.memo
        });
    }

}

