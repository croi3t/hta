// ---------- жңҚи–¬жҢҮе°ҺеұҘжӯҙExcelгғ•гӮЎгӮӨгғ«гҒӢгӮүгҒ®д»Ӣе…ҘзҠ¶жіҒеҸ–иҫј ----------
function importFromExcel() {
    if (!isEditMode) {
        alert('з·ЁйӣҶгғўгғјгғүгҒ§гҒ®гҒҝеҲ©з”ЁгҒ§гҒҚгҒҫгҒҷгҖӮ');
        return;
    }
    
    var btn = document.getElementById('btn-excel-import');
    var orgText = btn.innerText;
    btn.innerText = '? иӘӯгҒҝиҫјгҒҝдёӯ...';
    btn.disabled = true;
    
    setTimeout(function() {
        try {
            doExcelImport();
        } catch(e) {
            alert('ExcelеҸ–иҫјгӮЁгғ©гғј: ' + e.message);
        }
        btn.innerText = orgText;
        btn.disabled = false;
    }, 100);
}

function doExcelImport() {
    // 1. д»ҠйҖұгҒ®зҜ„еӣІгӮ’иЁҲз®— (ж—Ҙжӣңж—Ҙй–Ӣе§Ӣ)
    var today = new Date();
    var dayOfWeek = today.getDay(); // 0=ж—Ҙ, 1=жңҲ, ..., 6=еңҹ
    var weekStart = new Date(today);
    weekStart.setDate(today.getDate() - dayOfWeek);
    weekStart.setHours(0,0,0,0);
    var weekEnd = new Date(weekStart);
    weekEnd.setDate(weekStart.getDate() + 6);
    weekEnd.setHours(23,59,59,999);
    
    // 2. гғҮгӮ№гӮҜгғҲгғғгғ—дёҠгҒ®гғ•гӮЎгӮӨгғ«гӮ’жӨңзҙў
    var wsh = new ActiveXObject('WScript.Shell');
    var desktopPath = wsh.SpecialFolders('Desktop');
    var fso = new ActiveXObject('Scripting.FileSystemObject');
    
    if (!fso.FolderExists(desktopPath)) {
        alert('гғҮгӮ№гӮҜгғҲгғғгғ—гғ•гӮ©гғ«гғҖгҒҢиҰӢгҒӨгҒӢгӮҠгҒҫгҒӣгӮ“гҖӮ');
        return;
    }
    
    var folder = fso.GetFolder(desktopPath);
    var files = new Enumerator(folder.Files);
    var matchedFiles = [];
    
    for (; !files.atEnd(); files.moveNext()) {
        var f = files.item();
        var fname = f.Name;
        // жңҚи–¬жҢҮе°ҺеұҘжӯҙYYYYMMDD гҒ§е§ӢгҒҫгӮӢгғ•гӮЎгӮӨгғ« (.xls, .xlsx, .xlsm)
        var m = fname.match(/^жңҚи–¬жҢҮе°ҺеұҘжӯҙ(\d{8})/);
        if (!m) continue;
        var ext = fname.split('.').pop().toLowerCase();
        if (ext !== 'xls' && ext !== 'xlsx' && ext !== 'xlsm') continue;
        
        var dateStr = m[1]; // YYYYMMDD
        var y = parseInt(dateStr.substring(0,4), 10);
        var mo = parseInt(dateStr.substring(4,6), 10) - 1;
        var d = parseInt(dateStr.substring(6,8), 10);
        var fileDate = new Date(y, mo, d);
        
        // д»ҠйҖұгҒ®зҜ„еӣІеҶ…гҒӢгғҒгӮ§гғғгӮҜ
        if (fileDate >= weekStart && fileDate <= weekEnd) {
            matchedFiles.push({
                path: f.Path,
                date: fileDate,
                dateNum: parseInt(dateStr, 10),
                name: fname
            });
        }
    }
    
    if (matchedFiles.length === 0) {
        alert('д»ҠйҖұ(' + formatDateShort(weekStart) + 'пҪһ' + formatDateShort(weekEnd) + ')гҒ®жңҚи–¬жҢҮе°ҺеұҘжӯҙExcelгғ•гӮЎгӮӨгғ«гҒҢгғҮгӮ№гӮҜгғҲгғғгғ—дёҠгҒ«иҰӢгҒӨгҒӢгӮҠгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹгҖӮ\n\nгғ•гӮЎгӮӨгғ«еҗҚдҫӢ: жңҚи–¬жҢҮе°ҺеұҘжӯҙ20260303.xlsx, жңҚи–¬жҢҮе°ҺеұҘжӯҙ202603036B.xlsx');
        return;
    }
    
    // жңҖж–°ж—Ҙд»ҳгҒ®гғ•гӮЎгӮӨгғ«гӮ’йҒёжҠһпјҲеҗҢдёҖж—Ҙд»ҳгҒ§иӨҮж•°гғ•гӮЎгӮӨгғ«гҒҢгҒӮгӮҢгҒ°е…ЁгҒҰиӘӯгӮҖпјү
    matchedFiles.sort(function(a, b) { return b.dateNum - a.dateNum; });
    var latestDateNum = matchedFiles[0].dateNum;
    var filesToRead = [];
    for (var i = 0; i < matchedFiles.length; i++) {
        if (matchedFiles[i].dateNum === latestDateNum) {
            filesToRead.push(matchedFiles[i]);
        }
    }
    
    // 3. Excel COMгҒ§иӘӯгҒҝеҸ–гӮҠ
    var excel = null;
    var patientsWithMark = {}; // patientId -> true
    
    try {
        excel = new ActiveXObject('Excel.Application');
        excel.Visible = false;
        excel.DisplayAlerts = false;
        
        for (var fi = 0; fi < filesToRead.length; fi++) {
            var wb = null;
            try {
                wb = excel.Workbooks.Open(filesToRead[fi].path, 0, true); // ReadOnly=true
                var ws = wb.Sheets(1);
                var usedRange = ws.UsedRange;
                var lastRow = usedRange.Row + usedRange.Rows.Count - 1;
                var lastCol = usedRange.Column + usedRange.Columns.Count - 1;
                
                // гғҳгғғгғҖгғјиЎҢ(1иЎҢзӣ®)гҒӢгӮүд»ҠйҖұгҒ®ж—Ҙд»ҳеҲ—гӮ’зү№е®ҡ
                var weekDateCols = [];
                for (var c = 4; c <= lastCol; c++) {
                    var cellVal = ws.Cells(1, c).Value;
                    if (!cellVal) continue;
                    var colDate = parseExcelDate(cellVal);
                    if (colDate && colDate >= weekStart && colDate <= weekEnd) {
                        weekDateCols.push(c);
                    }
                }
                
                // еҗ„жӮЈиҖ…иЎҢгӮ’гғҒгӮ§гғғгӮҜ
                for (var r = 2; r <= lastRow; r++) {
                    var pid = ws.Cells(r, 1).Value;
                    if (!pid) continue;
                    pid = String(pid).replace(/[\s\r\n]/g, '');
                    // ж•°еҖӨгҒ®е ҙеҗҲгҒҜж•ҙж•°еҢ–
                    if (!isNaN(pid)) pid = String(parseInt(pid, 10));
                    
                    // иЁҳеҸ·иЎҢ(в—Ӣв—Ҹв–Ўв– в—Үв—Ҷв–ів–ІвҳҶзӯү)гӮ’гӮ№гӮӯгғғгғ—
                    if (/^[в—Ӣв—Ҹв–Ўв– в—Үв—Ҷв–ів–ІвҳҶвҳ…]$/.test(pid)) break;
                    
                    // д»ҠйҖұгҒ®еҲ—гҒ«в—ҶгҒҢгҒӮгӮӢгҒӢгғҒгӮ§гғғгӮҜ
                    for (var ci = 0; ci < weekDateCols.length; ci++) {
                        var cellValue = ws.Cells(r, weekDateCols[ci]).Value;
                        if (cellValue && String(cellValue).indexOf('в—Ҷ') !== -1) {
                            patientsWithMark[pid] = true;
                            break;
                        }
                    }
                }
            } catch(e2) {
                alert('гғ•гӮЎгӮӨгғ«иӘӯгҒҝеҸ–гӮҠгӮЁгғ©гғј (' + filesToRead[fi].name + '): ' + e2.message);
            } finally {
                if (wb) { try { wb.Close(false); } catch(e3){} }
            }
        }
    } finally {
        if (excel) { try { excel.Quit(); } catch(e4){} excel = null; }
    }
    
    // 4. з—…жЈҹе…ұжңүгғңгғјгғүгҒ®жӮЈиҖ…гғӘгӮ№гғҲгҒЁз…§еҗҲ
    // 4. з—…жЈҹе…ұжңүгғңгғјгғүгҒ®жӮЈиҖ…гғӘгӮ№гғҲ(еӨ§е…ғгҒ®appData)гҒЁз…§еҗҲ
    var updatedCount = 0;
    var alreadyRecorded = 0;
    var markIds = Object.keys ? Object.keys(patientsWithMark) : (function(obj) { var k=[]; for(var p in obj){ if(obj.hasOwnProperty(p)) k.push(p); } return k; })(patientsWithMark);
    
    // зҸҫеңЁйҒёжҠһдёӯгҒ®з—…жЈҹй…ҚеҲ—гӮ’зӣҙжҺҘж“ҚдҪңгҒ—гҒҰж°ёз¶ҡеҢ–гҒ•гҒӣгӮӢ
    var targetArray = null;
    var targetArray = appData.patients[currentWard];
    
    if (targetArray) {
        for (var pi = 0; pi < targetArray.length; pi++) {
            var p = targetArray[pi];
            var pId = String(p.id).replace(/[\s]/g, '');
            // е…Ҳй ӯгӮјгғӯгӮ’йҷӨеҺ»гҒ—гҒҰз…§еҗҲпјҲ0251607 гҒЁ 251607 гӮ’еҗҢдёҖгҒЁгҒ—гҒҰжүұгҒҶпјү
            var pIdNorm = pId.replace(/^0+/, '') || '0';
            if (patientsWithMark[pId] || patientsWithMark[pIdNorm]) {
                if (p.status === 3) {
                    alreadyRecorded++;
                } else {
                    p.status = 3; // иЁҳйҢІжёҲ
                    p.statusAuthor = "";
                    updatedCount++;
                }
            }
        }
    }
    
    // 5. дҝқеӯҳгҒЁUIжӣҙж–°
    if (updatedCount > 0) {
        renderPatients();
        saveData(false); // гӮўгғ©гғјгғҲгӮҲгӮҠеүҚгҒ«еҗҢжңҹзҡ„гҒ«зўәе®ҹгҒ«дҝқеӯҳгҒҷгӮӢ
    }
    
    var fileNames = [];
    for (var fn = 0; fn < filesToRead.length; fn++) fileNames.push(filesToRead[fn].name);
    
    var msg = 'ExcelеҸ–иҫје®ҢдәҶ\n\n';
    msg += 'иӘӯгҒҝеҸ–гӮҠгғ•гӮЎгӮӨгғ«: ' + fileNames.join(', ') + '\n';
    msg += 'в—ҶгғһгғјгӮҜжӨңеҮәжӮЈиҖ…ж•°: ' + markIds.length + 'еҗҚ\n';
    msg += 'д»Ӣе…ҘзҠ¶жіҒгӮ’гҖҢиЁҳйҢІжёҲгҖҚгҒ«жӣҙж–°: ' + updatedCount + 'еҗҚ\n';
    if (alreadyRecorded > 0) msg += '(ж—ўгҒ«иЁҳйҢІжёҲ: ' + alreadyRecorded + 'еҗҚ)\n';
    if (markIds.length > 0 && updatedCount === 0 && alreadyRecorded === 0) {
        msg += '\nвҖ» в—ҶгҒҢгҒӮгӮӢжӮЈиҖ…гҒҢзҸҫеңЁгҒ®з—…жЈҹгҒ«еӯҳеңЁгҒ—гҒҫгҒӣгӮ“гҖӮ\n  з—…жЈҹгӮҝгғ–гӮ’зўәиӘҚгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ';
    }
    alert(msg);
}

function parseExcelDate(val) {
    // ExcelгҒ®ж—Ҙд»ҳеҖӨгҒҜгӮ·гғӘгӮўгғ«еҖӨгҒӢж–Үеӯ—еҲ—
    if (val instanceof Date) return val;
    if (typeof val === 'number') {
        // ExcelгӮ·гғӘгӮўгғ«еҖӨгҒӢгӮүеӨүжҸӣ
        var d = new Date((val - 25569) * 86400 * 1000);
        d.setHours(0,0,0,0);
        return d;
    }
    var s = String(val).replace(/\s/g, '');
    // YYYY/MM/DD or M/D
    var m1 = s.match(/(\d{4})\/(\d{1,2})\/(\d{1,2})/);
    if (m1) return new Date(parseInt(m1[1],10), parseInt(m1[2],10)-1, parseInt(m1[3],10));
    var m2 = s.match(/^(\d{1,2})\/(\d{1,2})$/);
    if (m2) {
        var yr = new Date().getFullYear();
        return new Date(yr, parseInt(m2[1],10)-1, parseInt(m2[2],10));
    }
    return null;
}

function formatDateShort(d) {
    return (d.getMonth()+1) + '/' + d.getDate();
}

// ---------- гғҮгғјгӮҝиЎЁзӨәгҒЁж“ҚдҪң: жӮЈиҖ… ----------
function getCurrentPatientsList() {
    if (!appData.patients) appData.patients = {};
    if (!appData.patients[currentWard]) appData.patients[currentWard] = [];
    return appData.patients[currentWard];
}

function renderPatients() {
    var scrollX = window.pageXOffset || (document.documentElement ? document.documentElement.scrollLeft : 0);
    var scrollY = window.pageYOffset || (document.documentElement ? document.documentElement.scrollTop : 0);
    var tbody = document.getElementById("tbody-patients");
    
    // вҳ…дҝ®жӯЈ: гӮ«гӮ№гӮҝгғ гӮҝгғ–(гӮҝгӮ°жӨңзҙў)гҒҢйҒёгҒ°гӮҢгҒҰгҒ„гӮӢжҷӮгҒҜгҖҒе…Ёз—…жЈҹгҒ®жӮЈиҖ…гӮ’гҒӢгҒҚйӣҶгӮҒгӮӢ
    var list = [];
    if (typeof currentFilterTag !== 'undefined' && currentFilterTag !== "") {
        var seenIds = {};
        for (var w in appData.patients) {
            if (appData.patients.hasOwnProperty(w) && appData.patients[w]) {
                var wList = appData.patients[w];
                for (var i = 0; i < wList.length; i++) {
                    // еҗҢгҒҳжӮЈиҖ…гҒҢиӨҮж•°з—…жЈҹгҒ«йҮҚиӨҮгҒ—гҒҰеӯҳеңЁгҒҷгӮӢе ҙеҗҲгҒҜйҷӨеӨ–
                    if (!seenIds[wList[i].id]) {
                        seenIds[wList[i].id] = true;
                        list.push(wList[i]);
                    }
                }
            }
        }
    } else {
        list = getCurrentPatientsList();
    }
    
    if(!list || list.length === 0) {
        tbody.innerHTML = '<tr><td colspan="12" align="center">и©ІеҪ“з—…жЈҹгҒ®жӮЈиҖ…гғҮгғјгӮҝгҒҢгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ</td></tr>';
        return;
    }
    
    var displayList = [].concat(list);
    if (sortKey) {
        displayList.sort(function(a, b) {
            var valA = a[sortKey] || "";
            var valB = b[sortKey] || "";
            if (!isNaN(valA) && !isNaN(valB) && valA !== "" && valB !== "") {
                return (Number(valA) - Number(valB)) * sortOrder;
            }
            return valA.toString().localeCompare(valB.toString()) * sortOrder;
        });
    }
    
    var html = "";
    var highlightWords = ["йҖҖйҷў", "и»ўйҷў", "ENT", "ent"];
    for(var i=0; i<displayList.length; i++) {
        var p = displayList[i];
        if (!p || typeof p !== 'object') continue;
        if (!p.id) continue;
        
        // вҳ…дҝ®жӯЈ: гӮ«гӮ№гӮҝгғ гӮҝгғ–(гӮҝгӮ°жӨңзҙў)йҒёжҠһжҷӮгҒ®жқЎд»¶еҲҶеІҗпјҲе…Ёз—…жЈҹгҒӢгӮүжҠҪеҮәпјү
        if (typeof currentFilterTag !== 'undefined' && currentFilterTag !== "") {
            var targetMemo = "";
            if (currentFilterScope === "personal") {
                // еҖӢдәәгғЎгғўгҒӢгӮүгҒ®гҒҝжӨңзҙў
                targetMemo = ((p.personalMemos && p.personalMemos[currentSystemId]) ? p.personalMemos[currentSystemId] : "");
            } else {
                // е…ұжңүгғЎгғўгҒӢгӮүжӨңзҙў
                targetMemo = (p.memo || "");
            }
            if (targetMemo.indexOf(currentFilterTag) === -1) {
                continue; // и©ІеҪ“гҒ—гҒӘгҒ‘гӮҢгҒ°гӮ№гӮӯгғғгғ—
            }
        }
        
        var isHighlight = false;
        if (p.memo) {
            var lowerMemo = p.memo.toLowerCase();
            for(var w=0; w<highlightWords.length; w++) {
                if (lowerMemo.indexOf(highlightWords[w].toLowerCase()) !== -1) {
                    isHighlight = true; break;
                }
            }
        }
        var hlClass = isHighlight ? ' highlight-row' : '';

        var aLevel = p.alertLevel || 0;
        var aText = aLevel === 1 ? "пјҹ" : (aLevel === 2 ? "пјҒ" : "");
        var aClass = aLevel === 1 ? "alert-question" : (aLevel === 2 ? "alert-exclamation" : "alert-none");
        var alertEvent = isEditMode ? 'onclick="toggleAlertLevel(\'' + escapeHtml(p.id) + '\')"' : 'onclick="alert(\'з·ЁйӣҶдёҚеҸҜ\')"';

        var statIdx = p.status || 0;
        var statClass = STATUS_CLASSES[statIdx];
        var statText = STATUS_TEXTS[statIdx];
        if(statText === "(жңӘиЁӯе®ҡ)") statText = "жңӘ";
        else if(statText === "д»Ӣе…ҘдәҲе®ҡ") statText = "дәҲе®ҡ";
        else if(statText === "жҢҮе°ҺжёҲ") statText = "жҢҮе°Һ";
        else if(statText === "иЁҳйҢІжёҲ") statText = "иЁҳйҢІ";

        var authorHtml = p.statusAuthor ? '<br><span class="status-author">' + p.statusAuthor + '</span>' : '';
        var statUnderline = (statIdx === 1 || statIdx === 2) ? 'text-decoration:underline;' : '';
        var clickEvent = isEditMode ? 'onclick="toggleStatus(\'' + escapeHtml(p.id) + '\')"' : 'onclick="alert(\'з·ЁйӣҶдёҚеҸҜ\')"';
        
        var chkVal = p.chkPrescription || 0;
        if(typeof chkVal === "boolean") chkVal = chkVal ? 2 : 0;
        var chkClass = chkVal === 1 ? "status-chk-half" : (chkVal === 2 ? "status-chk-on" : "");
        var chkText = chkVal === 1 ? "&#9744;" : (chkVal === 2 ? "&#10004;" : "");
        var chkBg = chkVal === 1 ? "background-color:#ffe8a1;" : "";
        var chkEvent = isEditMode ? 'onclick="togglePrescriptionCheck(\'' + escapeHtml(p.id) + '\')"' : 'onclick="alert(\'з·ЁйӣҶдёҚеҸҜ\')"';

        var memoDisabled = isEditMode ? '' : 'disabled="disabled"';
        var mcs1 = 'onchange="finalizeMemo(\'' + escapeHtml(p.id) + '\', this)" ';
        var mcs2 = 'onkeyup="updateMemoDebounced(\'' + escapeHtml(p.id) + '\', this.value, this); showTagSuggest(this, event);"';
        var memoChangeShared = isEditMode ? mcs1 + mcs2 : '';
        
        var mcp1 = 'onchange="finalizePersonalMemo(\'' + escapeHtml(p.id) + '\', this)" ';
        var mcp2 = 'onkeyup="updatePersonalMemoDebounced(\'' + escapeHtml(p.id) + '\', this.value, this); showTagSuggest(this, event);"';
        var memoChangePersonal = isEditMode ? mcp1 + mcp2 : '';
        
        var memoAuthorHtml = '';
        if (p.memoAuthors && p.memoAuthors.length > 0) {
            memoAuthorHtml = escapeHtml(p.memoAuthors.join(" / "));
        } else if (p.memoAuthor) {
            memoAuthorHtml = escapeHtml(p.memoAuthor);
        }
        
        var bdManualClick = isEditMode ? 'onclick="changeBloodDate(\'' + escapeHtml(p.id) + '\')"' : 'onclick="alert(\'з·ЁйӣҶдёҚеҸҜ\')";';
        var bdTitle = p.bloodDetail ? 'title="жҺЎиЎҖи©ізҙ°: ' + escapeHtml(p.bloodDetail) + '"' : 'title="жҺЎиЎҖж—Ҙдҝ®жӯЈ"';
        
        var fetchBtnHtml = '<div style="padding:4px 0;">&nbsp;</div>';
        if (isEditMode) {
            var f1 = '<div class="hide-on-print blood-fetch-btn" ';
            var f2 = 'onclick="event.stopPropagation(); fetchBloodDateForPatient(\'' + escapeHtml(p.id) + '\')" ';
            var f3 = 'style="background:#e3f2fd; color:#0d6efd; font-size:10px; font-weight:bold; ';
            var f4 = 'text-align:center; padding:4px 0; border-bottom:1px dotted #ccc; cursor:pointer;" ';
            var f5 = 'title="еҸ–еҫ—">еҸ–еҫ—</div>';
            fetchBtnHtml = f1 + f2 + f3 + f4 + f5;
        }
        
        var d1 = '<div class="blood-date-text" ' + bdManualClick + ' ';
        var d2 = 'style="text-align:center; padding:4px 0; font-size:11px; cursor:pointer;" ';
        var d3 = bdTitle + '>' + escapeHtml(p.bloodDate || "-") + '</div>';
        var dateTextHtml = d1 + d2 + d3;

        var pMemos = (p && typeof p === 'object' && p.personalMemos) ? p.personalMemos : {};
        var myMemo = (pMemos && currentSystemId) ? (pMemos[currentSystemId] || "") : "";

        var tr = [];
        tr.push('<tr id="tr-patient-' + escapeHtml(p.id) + '">');
        // вҳ…дҝ®жӯЈ: дёҚиҰҒгҒӘгғҒгӮ§гғғгӮҜгғңгғғгӮҜгӮ№еҲ—гӮ’еүҠйҷӨ
        tr.push('<td>' + escapeHtml(p.id) + '</td>');
        tr.push('<td>' + escapeHtml(p.name) + '</td>');
        tr.push('<td class="hide-on-print" style="font-size:11px; padding:2px 4px;">');
        tr.push('<div style="color:#0d6efd; font-weight:bold; border-bottom:1px dotted #eee;">' + escapeHtml(p.dept || '') + '</div>');
        tr.push('<div style="color:#555;">' + escapeHtml(p.doctor || '') + '</div>');
        tr.push('</td>');
        tr.push('<td style="padding:2px 4px; vertical-align:top;">');
        tr.push('<div style="color:#2c3e50; font-weight:bold;' + (p.surgeryProcedure ? 'border-bottom:1px dotted #eee; padding-bottom:2px; margin-bottom:2px;' : '') + '">' + escapeHtml(p.disease || '') + '</div>');
        if (currentWard === "51") {
            if (p.surgeryDate === "гҒӘгҒ—") {
                tr.push('<div class="surgery-proc-text" style="color:#999; font-size:11px; font-style:italic;">иЎ“пјҡгҒӘгҒ—</div>');
            } else if (p.surgeryProcedure) {
                tr.push('<div class="surgery-proc-text" style="color:#c2185b; font-size:11px; font-weight:bold; word-break:break-all;" title="иЎ“ејҸ: ' + escapeHtml(p.surgeryProcedure) + '">вңӮпёҸ ' + escapeHtml(p.surgeryProcedure) + '</div>');
            } else {
                tr.push('<div class="surgery-proc-text" style="color:#bbb; font-size:11px; font-style:italic;">(иЎ“ејҸжңӘеҸ–еҫ—)</div>');
            }
        }
        tr.push('</td>');
        
        tr.push('<td style="text-align:center; font-size:12px; font-weight:bold;">' + escapeHtml(p.room || '') + '</td>');
        
        var hospDaysHtml = escapeHtml(p.daysInHosp || "-");
        var surgeryInfoHtml = "";
        if (p.surgeryDate && p.surgeryDate !== "гҒӘгҒ—" && p.surgeryDate !== "-") {
            var today = new Date();
            today.setHours(0,0,0,0);
            var sDate = new Date(p.surgeryDate);
            sDate.setHours(0,0,0,0);
            var diffDays = Math.floor((today.getTime() - sDate.getTime()) / (1000 * 3600 * 24));
            
            var postOpText = (diffDays === 0) ? "иЎ“еҪ“ж—Ҙ" : (diffDays > 0 ? "иЎ“еҫҢ" + diffDays + "ж—Ҙ" : "иЎ“еүҚ" + Math.abs(diffDays) + "ж—Ҙ");
            hospDaysHtml += '<br><span style="color:#c62828; font-weight:bold; font-size:10px;">' + postOpText + '</span>';
            
            var epiBadge = p.surgeryHasEpi ? ' <span style="background:#dc3545; color:#fff; padding:0 3px; border-radius:2px;">гӮЁгғ”жңү</span>' : '';
            // вҳ…иҝҪеҠ : гғӘгӮҜгӮ·гӮўгғҠйҒ©еҝңгғҗгғғгӮё
            var lixBadge = p.surgeryLixiana ? ' <span style="background:#ff9800; color:#fff; padding:0 3px; border-radius:2px; font-weight:bold;" title="гғӘгӮҜгӮ·гӮўгғҠпјҲгӮЁгғүгӮӯгӮөгғҗгғіпјүйҒ©еҝңжүӢиЎ“">рҹ’ҠEDO</span>' : '';
            
            surgeryInfoHtml = '<div style="font-size:10px; color:#c2185b; background:#fce4ec; border:1px solid #f8bbd0; border-radius:3px; padding:2px; margin-bottom:2px;" title="з—…еҗҚ: ' + escapeHtml(p.surgeryDisease) + '\nиЎ“ејҸ: ' + escapeHtml(p.surgeryProcedure) + '\nйә»й…”: ' + escapeHtml(p.surgeryAnesthesia) + '">вңӮпёҸиЎ“: ' + escapeHtml(p.surgeryDate) + epiBadge + lixBadge + '</div>';
        }
        tr.push('<td style="text-align:center; font-size:12px; line-height:1.2;">' + hospDaysHtml + '</td>');

        tr.push('<td class="blood-date-cell" style="padding:0; width:65px;">' + fetchBtnHtml + dateTextHtml + '</td>');
        var st1 = '<td class="status-cell ' + statClass + '" style="' + statUnderline + '" ';
        var st2 = 'onmousedown="startDragStatus(event, \'' + escapeHtml(p.id) + '\')" ' + clickEvent + '>';
        tr.push(st1 + st2 + statText + authorHtml + '</td>');
        
        tr.push('<td style="text-align:center; font-size:20px; color:#fd7e14; ' + chkBg + '" class="chk-toggle ' + chkClass + '" ' + chkEvent + '>' + chkText + '</td>');
        tr.push('<td style="text-align:center; font-size:20px; font-weight:bold; color:#e74c3c;" class="alert-toggle ' + aClass + '" ' + alertEvent + '>' + escapeHtml(aText) + '</td>');
        
        tr.push('<td class="' + hlClass + '" style="padding:4px;">');
        tr.push(surgeryInfoHtml); // вҳ…гғЎгғўж¬„гҒ®дёҠгҒ«жүӢиЎ“гғҗгғғгӮёгӮ’жҢҝе…Ҙ
        
        // е…ұжңүгғЎгғў
        var sharedMemoContent = escapeHtml(p.memo || "");
        var displaySharedMemo = sharedMemoContent.replace(/(#[^\sгҖҖ#]+)/g, '<span class="memo-tag">$1</span>');
        
        tr.push('<div class="memo-wrap" style="position:relative;">');
        tr.push('<div class="memo-display" style="font-size:12px; padding:2px; min-height:24px; white-space:pre-wrap; cursor:text; word-break:break-all;" onclick="if(isEditMode){this.style.display=\'none\'; this.nextSibling.style.display=\'block\'; this.nextSibling.focus(); this.nextSibling.style.height=\'auto\'; this.nextSibling.style.height=this.nextSibling.scrollHeight+\'px\';}">' + (displaySharedMemo || '<span style="color:#999;">гҖҗе…ұжңүгҖ‘гғЎгғў...</span>') + '</div>');
        var ta1 = '<textarea rows="1" ' + memoDisabled + ' ' + memoChangeShared;
        var ta2 = ' placeholder="гҖҗе…ұжңүгҖ‘гғЎгғў..." style="display:none; min-height:24px; padding:2px; font-size:12px; width:100%;" onblur="this.style.display=\'none\'; this.previousSibling.style.display=\'block\'; this.previousSibling.innerHTML = escapeHtml(this.value || \'\').replace(/(#[^\\sгҖҖ#]+)/g, \'<span class=\\\'memo-tag\\\'>$1</span>\') || \'<span style=\\\'color:#999;\\\'>гҖҗе…ұжңүгҖ‘гғЎгғў...</span>\';">';
        tr.push(ta1 + ta2 + sharedMemoContent + '</textarea>');
        tr.push('</div>');
        
        // еҖӢдәәгғЎгғў
        var myMemoContent = escapeHtml(myMemo || "");
        var myDisplayMemo = myMemoContent.replace(/(#[^\sгҖҖ#]+)/g, '<span class="memo-tag">$1</span>');
        
        tr.push('<div class="memo-wrap hide-on-print" style="position:relative; margin-top:2px;">');
        tr.push('<div class="memo-display" style="font-size:12px; padding:2px; min-height:24px; white-space:pre-wrap; cursor:text; background:#e8f4f8; word-break:break-all;" onclick="if(isEditMode){this.style.display=\'none\'; this.nextSibling.style.display=\'block\'; this.nextSibling.focus(); this.nextSibling.style.height=\'auto\'; this.nextSibling.style.height=this.nextSibling.scrollHeight+\'px\';}">' + (myDisplayMemo || '<span style="color:#999;">гҖҗеҖӢдәәгҖ‘гғЎгғў...</span>') + '</div>');
        var ta3 = '<textarea rows="1" ' + memoDisabled + ' ' + memoChangePersonal;
        var ta4 = ' placeholder="гҖҗеҖӢдәәгҖ‘гғЎгғў..." ';
        var ta5 = 'style="display:none; min-height:24px; padding:2px; font-size:12px; background:#e8f4f8; width:100%;" onblur="this.style.display=\'none\'; this.previousSibling.style.display=\'block\'; this.previousSibling.innerHTML = escapeHtml(this.value || \'\').replace(/(#[^\\sгҖҖ#]+)/g, \'<span class=\\\'memo-tag\\\'>$1</span>\') || \'<span style=\\\'color:#999;\\\'>гҖҗеҖӢдәәгҖ‘гғЎгғў...</span>\';">';
        tr.push(ta3 + ta4 + ta5 + myMemoContent + '</textarea>');
        tr.push('</div>');
        tr.push('</td>');
        
        tr.push('<td class="hide-on-print ' + hlClass + '" style="font-size:10px; color:#666;">' + memoAuthorHtml + '</td>');
        tr.push('</tr>');
        html += tr.join('');
    }

    tbody.style.visibility = "hidden";
    tbody.innerHTML = html;
    var textareas = tbody.getElementsByTagName('textarea');
    for(var t=0; t<textareas.length; t++) {
        var ta = textareas[t];
        ta.style.height = 'auto'; 
        var sh = ta.scrollHeight;
        if (sh > 0) ta.style.height = sh + 'px';
    }
    tbody.style.visibility = "visible";
    var container = document.getElementById("main-content-scroll");
    if (container) container.scrollTop = scrollTop;
    window.scrollTo(scrollX, scrollY);
    
    // вҳ…иҝҪеҠ : 5Aз—…жЈҹгҒ®жҷӮгҒ гҒ‘жүӢиЎ“еҸ–еҫ—гғңгӮҝгғігҒЁгҖҢиЎ“ејҸгҖҚгғҳгғғгғҖгғјгӮ’иЎЁзӨәгҒҷгӮӢ
    var btnSurg = document.getElementById("btn-fetch-surgery");
    if (btnSurg) {
        btnSurg.style.display = (currentWard === "51") ? "block" : "none";
    }
    var hdrSurg = document.getElementById("header-surgery-proc");
    if (hdrSurg) {
        hdrSurg.style.display = (currentWard === "51") ? "block" : "none";
    }
}

function toggleAlertLevel(id) {
    if(!isEditMode) return;
    var p = findPatientById(id);
    if(!p) return;
    p.alertLevel = ((p.alertLevel || 0) + 1) % 3;
    var aLevel = p.alertLevel;
    var aText = aLevel === 1 ? "пјҹ" : (aLevel === 2 ? "пјҒ" : "");
    var aClass = aLevel === 1 ? "alert-question" : (aLevel === 2 ? "alert-exclamation" : "alert-none");

    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("TOGGLE_ALERT", {
            patientId: id, wardCode: currentWard, value: p.alertLevel
        });
    }

    var trId = "tr-patient-" + p.id;
    var tr = document.getElementById(trId);
    if (tr) {
        var td = tr.querySelector(".alert-toggle");
        if (td) { td.className = "alert-toggle " + aClass; td.innerText = aText; }
    }
}

function toggleStatus(id) {
    if(!isEditMode) return;
    var p = findPatientById(id);
    if(!p) return;
    p.status = ((p.status || 0) + 1) % 4;
    p.statusAuthor = p.status === 0 ? "" : currentUserName;

    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("TOGGLE_STATUS", {
            patientId: id, wardCode: currentWard, value: p.status, author: p.statusAuthor
        });
    }

    var trId = "tr-patient-" + p.id;
    var tr = document.getElementById(trId);
    if (tr) {
        var td = tr.querySelector(".status-cell");
        if (td) {
            var statIdx = p.status;
            var statClass = STATUS_CLASSES[statIdx];
            var rawStatText = STATUS_TEXTS[statIdx];
            var statText = rawStatText === "(жңӘиЁӯе®ҡ)" ? "жңӘ" : (rawStatText === "д»Ӣе…ҘдәҲе®ҡ" ? "дәҲе®ҡ" : (rawStatText === "жҢҮе°ҺжёҲ" ? "жҢҮе°Һ" : "иЁҳйҢІ"));
            
            var authorHtml = p.statusAuthor ? '<br><span class="status-author">' + escapeHtml(p.statusAuthor) + '</span>' : '';
            var statUnderline = (statIdx === 1 || statIdx === 2) ? 'text-decoration:underline;' : '';
            
            td.className = "status-cell " + statClass;
            td.style.cssText = statUnderline;
            td.innerHTML = statText + authorHtml;
        }
    }
}

// ---------- д»Ӣе…ҘиҖ…гғүгғ©гғғгӮ°йҒёжҠһж©ҹиғҪ (Vol.11) ----------
var dragStatusInfo = { active: false, index: -1, startX: 0, currentX: 0, element: null };

function startDragStatus(e, id) {
    if(!isEditMode) return;
    if(e.button !== 1 && e.button !== 0) return; 

    dragStatusInfo.active = true;
    dragStatusInfo.index = id;
    dragStatusInfo.startX = e.clientX;
    dragStatusInfo.currentX = e.clientX;
    dragStatusInfo.element = e.srcElement || e.target;
    
    while(dragStatusInfo.element && dragStatusInfo.element.tagName !== 'TD') {
        dragStatusInfo.element = dragStatusInfo.element.parentNode;
    }
    
    if(dragStatusInfo.element && dragStatusInfo.element.setCapture) dragStatusInfo.element.setCapture();
    
    if (document.addEventListener) {
        document.addEventListener("mousemove", handleDragMove, false);
        document.addEventListener("mouseup", endDragStatus, false);
    } else if (document.attachEvent) {
        document.attachEvent("onmousemove", handleDragMove);
        document.attachEvent("onmouseup", endDragStatus);
    }
    
    if (e.stopPropagation) e.stopPropagation();
    e.cancelBubble = true;
    return false;
}

function handleDragMove() {
    if(!dragStatusInfo.active) return;
    var e = window.event;
    dragStatusInfo.currentX = e.clientX;
    
    var diff = Math.abs(dragStatusInfo.currentX - dragStatusInfo.startX);
    if(diff > 10) {
        if(dragStatusInfo.element && dragStatusInfo.element.className.indexOf("dragging-item") === -1) {
            dragStatusInfo.element.className += " dragging-item";
        }
    }
}

function endDragStatus() {
    if(!dragStatusInfo.active) return;
    var e = window.event;
    
    if (document.removeEventListener) {
        document.removeEventListener("mousemove", handleDragMove, false);
        document.removeEventListener("mouseup", endDragStatus, false);
    } else if (document.detachEvent) {
        document.detachEvent("onmousemove", handleDragMove);
        document.detachEvent("onmouseup", endDragStatus);
    }
    
    if(dragStatusInfo.element && dragStatusInfo.element.releaseCapture) dragStatusInfo.element.releaseCapture();
    
    if(dragStatusInfo.element) {
        dragStatusInfo.element.className = dragStatusInfo.element.className.replace(/dragging-item/g, "").trim();
    }

    var diff = Math.abs(dragStatusInfo.currentX - dragStatusInfo.startX);
    if(diff > 30) {
        showUserSelectMenu(dragStatusInfo.index, e.clientX, e.clientY);
    }
    
    dragStatusInfo.active = false;
}

function showUserSelectMenu(id, x, y) {
    var menu = document.getElementById("user-select-menu");
    if(!menu) {
        menu = document.createElement("div");
        menu.id = "user-select-menu";
        document.body.appendChild(menu);
    }
    
    var users = getUniqueUsers();
    var html = "";
    var encId = escapeHtml(id);
    html += '<div class="user-select-item" onclick="selectUserStatus(\'' + encId + '\', \'' + escapeHtml(currentUserName) + '\')">' + escapeHtml(currentUserName) + ' (иҮӘеҲҶ)</div>';
    
    for(var i=0; i<users.length; i++) {
        if(users[i] === currentUserName) continue;
        html += '<div class="user-select-item" onclick="selectUserStatus(\'' + encId + '\', \'' + escapeHtml(users[i]) + '\')">' + escapeHtml(users[i]) + '</div>';
    }
    html += '<div class="user-select-item" style="border-top:1px solid #eee; color:#999;" onclick="selectUserStatus(\'' + encId + '\', \'\')">(гӮҜгғӘгӮў)</div>';
    
    menu.innerHTML = html;
    menu.style.display = "block";
    
    var scrollX = window.pageXOffset || document.documentElement.scrollLeft || document.body.scrollLeft;
    var scrollY = window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop;
    var left = x + scrollX + 5;
    var top = y + scrollY + 5;
    
    if(x + 155 > document.body.clientWidth) left = x + scrollX - 155;
    if(y + 205 > document.body.clientHeight) top = y + scrollY - 205;

    menu.style.left = left + "px";
    menu.style.top = top + "px";
    
    var closeMenu = function() {
        var ev = window.event;
        var target = ev.srcElement || ev.target;
        if(target.className.indexOf("user-select-item") === -1) {
            menu.style.display = "none";
            if (document.removeEventListener) {
                document.removeEventListener("mousedown", closeMenu, false);
            } else if (document.detachEvent) {
                document.detachEvent("onmousedown", closeMenu);
            }
        }
    };
    if (document.addEventListener) {
        setTimeout(function(){ document.addEventListener("mousedown", closeMenu, false); }, 50);
    } else if (document.attachEvent) {
        setTimeout(function(){ document.attachEvent("onmousedown", closeMenu); }, 50);
    }
}

function selectUserStatus(id, userName) {
    var p = findPatientById(id);
    if (!p) return;
    
    if((!p.status || p.status === 0) && userName !== "") p.status = 1;
    p.statusAuthor = userName;
    if(userName === "") p.status = 0;
    
    renderPatients();

    var menu = document.getElementById("user-select-menu");
    if(menu) menu.style.display = "none";
}

function getUniqueUsers() {
    if (cachedUniqueUsers !== null) return cachedUniqueUsers;
    
    var userMap = {};
    // 1. settings.users гҒӢгӮүеҸ–еҫ—
    if (appData && appData.users) {
        for (var id in appData.users) {
            var name = appData.users[id];
            if (name && name !== "undefined") userMap[name] = true;
        }
    }
    
    // 2. иҮӘеҲҶиҮӘиә«гӮ’еҝ…гҒҡеҗ«гӮҒгӮӢ (ToDo дҪңжҘӯиҖ…гӮ„д»Ӣе…ҘиҖ…йҒёжҠһз”Ё)
    if (currentUserName && currentUserName !== "") {
        userMap[currentUserName] = true;
    }

    var result = [];
    for (var n in userMap) {
        if (userMap.hasOwnProperty(n)) result.push(n);
    }
    result.sort();
    cachedUniqueUsers = result;
    return result;
}

function togglePrescriptionCheck(id) {
    if(!isEditMode) return;
    var p = findPatientById(id);
    if(!p) return;

    var currentVal = p.chkPrescription || 0;
    if(typeof currentVal === "boolean") currentVal = currentVal ? 2 : 0;
    p.chkPrescription = (currentVal + 1) % 3;

    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("TOGGLE_PRESCRIPTION", {
            patientId: id, wardCode: currentWard, value: p.chkPrescription
        });
    }

    var trId = "tr-patient-" + p.id;
    var tr = document.getElementById(trId);
    if (tr) {
        var td = tr.querySelector(".chk-toggle");
        if (td) {
            var val = p.chkPrescription;
            if(val === 1) {
                td.className = "chk-toggle status-chk-half"; td.innerHTML = "&#9744;"; td.style.backgroundColor = "#ffe8a1";
            } else if(val === 2) {
                td.className = "chk-toggle status-chk-on"; td.innerHTML = "&#10004;"; td.style.backgroundColor = "";
            } else {
                td.className = "chk-toggle"; td.innerHTML = ""; td.style.backgroundColor = "";
            }
        }
    }
}

function updateMemo(id, val, element) {
    if(!isEditMode) return;
    var p = findPatientById(id);
    if(!p) return; 
    if(p.memo !== val) {
        p.memo = val;
        if (element) {
            element.style.height = "auto";
            element.style.height = element.scrollHeight + "px";
            
            var isHighlight = false;
            var highlightWords = ["йҖҖйҷў", "и»ўйҷў", "ENT", "ent"];
            var lowerVal = val.toLowerCase();
            for(var w=0; w<highlightWords.length; w++) {
                if (lowerVal.indexOf(highlightWords[w].toLowerCase()) !== -1) {
                    isHighlight = true;
                    break;
                }
            }
            var tdMemo = element.parentNode;
            if (tdMemo && tdMemo.tagName && tdMemo.tagName.toLowerCase() === 'td') {
                if (isHighlight) {
                    addClass(tdMemo, 'highlight-row');
                } else {
                    removeClass(tdMemo, 'highlight-row');
                }
            }
        }
    }
    
    // вҳ…гҒ“гҒ“гҒ«гҒӮгҒЈгҒҹ if (typeof DataManager !== "undefined") { ... } гҒ®дјқзҘЁзҷәиЎҢгғ–гғӯгғғгӮҜгӮ’гҒҫгӮӢгҒ”гҒЁеүҠйҷӨгҒ—гҒҫгҒҷ
    // пјҲе…ҘеҠӣе®ҢдәҶжҷӮгҒ® finalizeMemo й–ўж•°еҒҙгҒ«д»»гҒӣгӮӢгҒҹгӮҒпјү
}

function updatePersonalMemoHeight(element) {
    if (element) {
        element.style.height = "auto";
        element.style.height = (element.scrollHeight) + "px";
    }
}

function finalizePersonalMemo(id, element) {
    if(!isEditMode) return;
    var val = element.value;
    var p = findPatientById(id);
    if(!p) return;
    if(!p.personalMemos) p.personalMemos = {};
    p.personalMemos[currentSystemId] = val;
    // вҳ…иҝҪеҠ : гғҲгғ©гғігӮ¶гӮҜгӮ·гғ§гғігҒ®зҷәиЎҢ
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("UPDATE_PERSONAL_MEMO", {
            patientId: id, wardCode: currentWard, userId: currentSystemId, value: val
        });
    }

}

function finalizeMemo(id, element) {
    if(!isEditMode) return;
    var p = findPatientById(id);
    var val = element.value;
    if(!p) return;
    
    // 1. гғЎгғўгғӘгӮ’еҚіжҷӮжӣҙж–°
    p.memo = val;

    // 2. гғҲгғ©гғігӮ¶гӮҜгӮ·гғ§гғігғ•гӮЎгӮӨгғ«гӮ’дҪңжҲҗгҒҷгӮӢпјҲгҒ“гӮҢгҒҜйқһеёёгҒ«и»ҪгҒ„гҒ®гҒ§еҚіжҷӮе®ҹиЎҢпјү
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("UPDATE_PATIENT_MEMO", {
            patientId: id, wardCode: currentWard, value: val
        });
    }

    // 3. з”»йқўеҶҚжҸҸз”»пјҲUIгҒ®е®Ңе…ЁеҗҢжңҹпјү
    renderPatients();
}

function resetAllStatus() {
    if(!isEditMode) return;
    var list = getCurrentPatientsList();
    if(list.length === 0) return;
    
    if(confirm("гҖҗиӯҰе‘ҠгҖ‘\nиЎЁзӨәдёӯгҒ®з—…жЈҹгҒ®гҖҢд»Ӣе…ҘзҠ¶жіҒгҖҚгӮ’гҒҷгҒ№гҒҰгғӘгӮ»гғғгғҲпјҲеҲқжңҹеҢ–пјүгҒ—гҒҫгҒҷгҖӮ\nвҖ»гғһгғјгӮҜ(пјҒ/пјҹ)гҒҠгӮҲгҒіе…ұжңүгғЎгғўгҒҜдҝқжҢҒгҒ•гӮҢгҒҫгҒҷгҖӮ\n\nжң¬еҪ“гҒ«гӮҲгӮҚгҒ—гҒ„гҒ§гҒҷгҒӢпјҹ")) {
        if(confirm("жңҖзөӮзўәиӘҚгҒ§гҒҷгҖӮжң¬еҪ“гҒ«дёҖжӢ¬гғӘгӮ»гғғгғҲгӮ’е®ҹиЎҢгҒ—гҒҰгӮҲгӮҚгҒ—гҒ„гҒ§гҒҷгҒӢпјҹ")) {
            for(var i=0; i<list.length; i++) {
                if (list[i].status !== 0) {
                    list[i].status = 0;
                    list[i].statusAuthor = "";
                    if (typeof DataManager !== "undefined") {
                        DataManager.appendTransaction("TOGGLE_STATUS", {
                            patientId: list[i].id, 
                            wardCode: currentWard, 
                            value: 0,
                            author: ""
                        });
                    }
                }
            }
            renderPatients();

            alert("д»Ӣе…ҘзҠ¶жіҒгҒ®гғӘгӮ»гғғгғҲгҒҢе®ҢдәҶгҒ—гҒҫгҒ—гҒҹгҖӮ");
        }
    }
}

function resetAllPrescriptionChecks() {
    if(!isEditMode) return;
    var list = getCurrentPatientsList();
    if(list.length === 0) return;
    
    if(confirm("иЎЁзӨәдёӯгҒ®з—…жЈҹгҒ®гҖҢеҮҰж–№гҖҚзўәиӘҚзҠ¶ж…ӢпјҲвң”гғ»вҳҗпјүгӮ’гҒҷгҒ№гҒҰи§ЈйҷӨгҒ—гҒҰгӮҲгӮҚгҒ—гҒ„гҒ§гҒҷгҒӢпјҹ")) {
        for(var i=0; i<list.length; i++) {
            if (list[i].chkPrescription) {
                list[i].chkPrescription = false;
                if (typeof DataManager !== "undefined") {
                    DataManager.appendTransaction("TOGGLE_PRESCRIPTION", {
                        patientId: list[i].id, 
                        wardCode: currentWard, 
                        value: false
                    });
                }
            }
        }
        renderPatients();

        alert("еҮҰж–№зўәиӘҚгҒ®гғҒгӮ§гғғгӮҜгӮ’гӮҜгғӘгӮўгҒ—гҒҫгҒ—гҒҹгҖӮ");
    }
}

function jumpToPatient(pid, pname) {
    if(!pid && !pname) return;
    
    try {
        switchTab('tab-patients');
        
        // гӮҝгғ–еҲҮгӮҠжӣҝгҒҲгҒ«гӮҲгӮӢDOMгҒ®еҶҚиЎЁзӨәпјҲdisplay: block;пјүгҒҢе®ҢдәҶгҒ—гҒҰгҒӢгӮүгӮ№гӮҜгғӯгғјгғ«гҒ•гҒӣгӮӢгӮҲгҒҶйҒ…е»¶
        setTimeout(function() {
            try {
                var tr = null;
                // гҒҫгҒҡIDгҒ§жӨңзҙў
                if (pid) {
                    var trId = "tr-patient-" + String(pid).trim();
                    tr = document.getElementById(trId);
                }
                // IDгҒ§иҰӢгҒӨгҒӢгӮүгҒӘгҒӢгҒЈгҒҹе ҙеҗҲгҖҒиЎЁзӨәгҒ•гӮҢгҒҰгҒ„гӮӢиЎҢгҒӢгӮүж°ҸеҗҚгҒ§жӨңзҙў
                if (!tr && pname) {
                    var tbody = document.getElementById("tbody-patients");
                    var rows = tbody.getElementsByTagName("tr");
                    for (var i = 0; i < rows.length; i++) {
                        // жӮЈиҖ…дёҖиҰ§гҒ®2еҲ—зӣ®(гӮӨгғігғҮгғғгӮҜгӮ№1)гҒҢж°ҸеҗҚ
                        var nameCell = rows[i].getElementsByTagName("td")[1];
                        if (nameCell && nameCell.innerText.indexOf(pname) !== -1) {
                            tr = rows[i];
                            break;
                        }
                    }
                }

                if(tr) {
                    // IE11йқһеҜҫеҝңгҒ® {behavior: "smooth"} гӮӘгғ–гӮёгӮ§гӮҜгғҲгҒ§гҒҜгҒӘгҒҸгҖҒдә’жҸӣжҖ§гҒ®гҒӮгӮӢ true гӮ’жёЎгҒҷ
                    tr.scrollIntoView(true);
                    
                    // дёҖзһ¬й»„иүІгҒҸгғҸгӮӨгғ©гӮӨгғҲгҒ—гҒҰе ҙжүҖгӮ’зҹҘгӮүгҒӣгӮӢ
                    var oldBg = tr.style.backgroundColor;
                    tr.style.backgroundColor = "#ffeb3b";
                    setTimeout(function(){
                        tr.style.backgroundColor = oldBg;
                    }, 1500);
                } else {
                    var msg = pid ? ("ID: " + pid) : "";
                    if (pname) msg += (msg ? " / " : "") + "ж°ҸеҗҚ: " + pname;
                    alert("зҸҫеңЁиЎЁзӨәдёӯгҒ®з—…жЈҹгҒ®жӮЈиҖ…дёҖиҰ§гҒ«гҖҒи©ІеҪ“гҒ®жӮЈиҖ…(" + msg + ") гҒҢиҰӢгҒӨгҒӢгӮҠгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹгҖӮ\n(еҲҘгҒ®з—…жЈҹгҒ®жӮЈиҖ…гҒ®еҸҜиғҪжҖ§гҒҢгҒӮгӮҠгҒҫгҒҷ)");
                }
            } catch(e) {
                alert("гӮёгғЈгғігғ—е…ҲгҒ®гӮ№гӮҜгғӯгғјгғ«еҮҰзҗҶгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹ: " + e.message);
            }
        }, 150);
    } catch(err) {
        alert("гӮёгғЈгғігғ—еҮҰзҗҶгҒ®иө·еӢ•гҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹ: " + err.message);
    }
}

// ---------- еӨ–йғЁгғҮгғјгӮҝеҸ–еҫ—гҒЁHTMLгғ‘гғјгӮ№ (IFRAMEж–№ејҸ) ----------
function fetchPatientData() {
    if(!isEditMode) return;
    
    // зҸҫеңЁгҒ®з—…жЈҹиЁӯе®ҡгӮ’еҸ–еҫ—
    var wardCode = currentWard;
    if(!wardCode) {
        alert("жңүеҠ№гҒӘз—…жЈҹгҒҢйҒёжҠһгҒ•гӮҢгҒҰгҒ„гҒҫгҒӣгӮ“гҖӮ");
        return;
    }
    var wardSettings = { name: getWardName(wardCode), code: wardCode };
    if(!currentSystemId) {
        alert("жӢ…еҪ“иҖ…ID(гӮ·гӮ№гғҶгғ з”Ё)гҒҢиЁӯе®ҡгҒ•гӮҢгҒҰгҒ„гҒҫгҒӣгӮ“гҖӮдёҖеәҰгғӘгғӯгғјгғүгҒ—гҒҰеҶҚгғӯгӮ°гӮӨгғігҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ");
        return;
    }
    
    var btn = document.getElementById("btn-fetch");
    var orgText = btn.innerText;
    btn.innerText = "вҶ» еҸ–еҫ—дёӯ...";
    btn.disabled = true;

    var nowStr = new Date().toLocaleTimeString();
    var lastUpdateLabel = document.getElementById("last-update-time");
    if (lastUpdateLabel) {
        lastUpdateLabel.innerText = "(жңҖзөӮWebгғҮгғјгӮҝеҸ–еҫ—: " + nowStr + ")";
    }

    // JSONPгғ¬гӮ№гғқгғігӮ№з”ЁгҒ®дёҖжҷӮгӮігғјгғ«гғҗгғғгӮҜпјҲдёҰиЎҢеҮҰзҗҶгҒ®гҒҹгӮҒиӨҮж•°пјү
    var callbacks = [];
    var wCode = wardSettings.code ? String(wardSettings.code) : "";
    var wName = wardSettings.name ? String(wardSettings.name) : "";
    var isDummy = (wCode === "99") || 
                  (wName.indexOf("пҫҖпҫһпҫҗпҪ°") !== -1) ||
                  (wCode.toLowerCase() === "test") ||
                  (wName.toLowerCase() === "test");

    if (isDummy) {
        setTimeout(function() {
            var dummyPatients = [];
            var depts = ["еҶ…з§‘", "еӨ–з§‘", "ж•ҙеҪўеӨ–з§‘", "з”Је©Ұдәәз§‘", "е°Ҹе…җз§‘", "зңјз§‘", "иҖійј»з§‘", "зҡ®иҶҡз§‘", "жіҢе°ҝеҷЁз§‘", "и„ізҘһзөҢеӨ–з§‘"];
            var diseases = ["еҺҹзҷәжҖ§е…Қз–«дёҚе…Ёз—ҮеҖҷзҫӨ", "жҖҘжҖ§иҷ«еһӮзӮҺ", "еӨ§и…ҝйӘЁи»ўеӯҗйғЁйӘЁжҠҳ", "ж–°еһӢгӮігғӯгғҠиӮәзӮҺ", "2еһӢзі–е°ҝз—…", "зҷҪеҶ…йҡң", "зӘҒзҷәжҖ§йӣЈиҒҙ", "гӮўгғҲгғ”гғјжҖ§зҡ®иҶҡзӮҺ", "еүҚз«Ӣи…әиӮҘеӨ§з—Ү", "гҒҸгӮӮиҶңдёӢеҮәиЎҖ"];
            
            for(var i=1; i<=40; i++) {
                var dIdx = i % 10;
                // 4дәәгҒ”гҒЁгҒ«йғЁеұӢз•ӘеҸ·гӮ’еӨүгҒҲгӮӢгғҖгғҹгғј
                var roomNum = (300 + Math.ceil(i/4)).toString();
                
                dummyPatients.push({
                    room: roomNum, // вҳ…иҝҪеҠ : з—…е®ӨгғҖгғҹгғј [cite: 11]
                    id: (100000 + i).toString(),
                    name: "гғҶгӮ№гғҲжӮЈиҖ…гҖҖ" + i + "еҸ·",
                    dept: depts[dIdx],
                    doctor: "еҢ»её«" + String.fromCharCode(65 + dIdx % 5),
                    disease: diseases[dIdx],
                    daysInHosp: (Math.floor(Math.random() * 50) + 1).toString() // вҳ…иҝҪеҠ : еңЁйҷўж—Ҙж•°гғҖгғҹгғј [cite: 11]
                });
            }
            
            processFetchedPatients(dummyPatients, wardSettings.name || "TEST(пҫҖпҫһпҫҗпҪ°)");
            btn.innerText = "вҶ» зҸҫеңЁгҒ®з—…жЈҹгҒ®гӮ·гӮ№гғҶгғ жӣҙж–°";
            btn.disabled = false;
        }, 300);
        return;
    }

    var iframeId = "loader-iframe";
    var iframe = document.getElementById(iframeId);
    if (!iframe) {
        iframe = document.createElement("iframe");
        iframe.id = iframeId;
        iframe.style.display = "none";
        document.body.appendChild(iframe);
    }
    
    iframe.onload = function() {
        try {
            var doc = iframe.contentWindow.document;
            parseHtmlAndMerge(doc, wardSettings.name);
        } catch(e) {
            alert("жӮЈиҖ…гғҮгғјгӮҝгҒ®иӘӯгҒҝеҸ–гӮҠгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹгҖӮ\n\nгҖҗиҖғгҒҲгӮүгӮҢгӮӢеҺҹеӣ гҖ‘\n1. гӮ»гӮӯгғҘгғӘгғҶгӮЈеҲ¶йҷҗ: гғ–гғ©гӮҰгӮ¶пјҲгӮӨгғігӮҝгғјгғҚгғғгғҲгӮӘгғ—гӮ·гғ§гғіпјүгҒ®гҖҺдҝЎй јжёҲгҒҝгӮөгӮӨгғҲгҖҸгҒ«гӮ«гғ«гғҶгӮөгғјгғҗгғјгҒ®URL(10.5.171.42)гӮ’зҷ»йҢІгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ\n2. гғҚгғғгғҲгғҜгғјгӮҜ: гӮөгғјгғҗгғјгҒ«жҺҘз¶ҡгҒ§гҒҚгҒӘгҒ„з’°еўғгҒ§гҒҷгҖӮ\n3. гғ•гӮЎгӮӨгғ«дёҚеңЁ: гҒҫгҒ дҪңжҲҗгҒ•гӮҢгҒҰгҒ„гҒӘгҒ„жҷӮй–“еёҜгҒ®гғӘгӮ№гғҲгӮ’иӘӯгҒҝиҫјгӮӮгҒҶгҒЁгҒ—гҒҰгҒ„гҒҫгҒҷгҖӮ\n\nгӮЁгғ©гғји©ізҙ°: " + e.message);
        }
        btn.innerText = "вҶ» зҸҫеңЁгҒ®з—…жЈҹгҒ®гӮ·гӮ№гғҶгғ жӣҙж–°";
        btn.disabled = false;
        
        setTimeout(function(){ iframe.onload = null; }, 100);
    };
    
    // URLгҒ®иҮӘеӢ•з”ҹжҲҗ
    var today = new Date();
    var yyyy = today.getFullYear();
    var mm = ("0" + (today.getMonth() + 1)).slice(-2);
    var dd = ("0" + today.getDate()).slice(-2);
    var dateStr = yyyy + "%2F" + mm + "%2F" + dd; // YYYY/MM/DDгҒ®гӮЁгғігӮігғјгғү
    
    var baseUrl = "http://10.5.171.42:8082/karte/kanja_ichiran/kanja_ichiran.php";
    var fetchUrl = baseUrl + "?byoto_code=" + wardSettings.code + 
                   "&search_date=" + dateStr + 
                   "&ichiran_code=58&user_id=" + currentSystemId + 
                   "&section_code=&page_num=0&login_flg=" + 
                   "&t=" + new Date().getTime(); // гӮӯгғЈгғғгӮ·гғҘеӣһйҒҝ
    
    // гӮӮгҒ—жүӢеӢ•гҒ§гғҶгӮ№гғҲз”ЁURLгҒҢиЁӯе®ҡгҒ•гӮҢгҒҰгҒ„гҒҹе ҙеҗҲгҒ®гғҮгғҗгғғгӮ°з”ЁеӣһйҒҝпјҲиЁӯе®ҡгӮігғјгғүгҒҢhttpе§ӢгҒҫгӮҠгҒӘгӮүгҒқгҒ®гҒҫгҒҫдҪҝгҒҶпјү
    if (String(wardSettings.code).indexOf('http') === 0 || String(wardSettings.code).indexOf('file') === 0) {
        fetchUrl = wardSettings.code;
    }

    try {
        iframe.src = fetchUrl;
    } catch(e) {
        alert("URLгӮ’й–ӢгҒ‘гҒҫгҒӣгӮ“гҒ§гҒ—гҒҹ: " + e.message);
        btn.innerText = "вҶ» зҸҫеңЁгҒ®з—…жЈҹгҒ®гӮ·гӮ№гғҶгғ жӣҙж–°";
        btn.disabled = false;
    }
}

// ---------- жҺЎиЎҖж—ҘеҖӢеҲҘеҸ–еҫ—ж©ҹиғҪпјҲkarte.phpйҖЈжҗәпјү ----------
// Deleted redundant vars & function

/**
 * жӮЈиҖ…гғҶгғјгғ–гғ«гӮ’жӨңзҙўгғ•гӮЈгғ«гӮҝгғјгҒ§зөһгӮҠиҫјгӮҖ
 * Line 524 гҒӢгӮүе‘јгҒіеҮәгҒ•гӮҢгӮӢ
 */
function filterPatientTable() {
    var input = document.getElementById("ipt-patient-search");
    if (!input) return;
    var filter = input.value.toLowerCase();
    var tbody = document.getElementById("tbody-patients");
    if (!tbody) return;
    var tr = tbody.getElementsByTagName("tr");

    for (var i = 0; i < tr.length; i++) {
        var row = tr[i];
        // гғҮгғјгӮҝгҒӘгҒ—гғЎгғғгӮ»гғјгӮёгҒӘгҒ©гӮ’еҲӨе®ҡгҒҷгӮӢгҒҹгӮҒгҒ®гӮ»гғ«ж•°гғҒгӮ§гғғгӮҜ
        if (row.cells.length < 5) continue; 
        
        var text = (row.textContent || row.innerText || "").toLowerCase();
        if (text.indexOf(filter) > -1) {
            row.style.display = "";
        } else {
            row.style.display = "none";
        }
    }
}

// Dead code processNextBloodFetch removed

function fetchBloodDateForPatient(patientId) {
    var p = findPatientById(patientId);
    if (!p) return;
    
    // UIгғ•гӮЈгғјгғүгғҗгғғгӮҜ
    var tr = document.getElementById("tr-patient-" + patientId);
    if (tr) {
        var textEl = tr.querySelector(".blood-date-text");
        if (textEl) textEl.innerText = "еҸ–еҫ—дёӯ...";
    }
    
    fetchSingleBloodDate(p, function() {
        renderPatients();

    });
}

function updateAllBloodDates() {
    if (!isEditMode) { alert("з·ЁйӣҶгғўгғјгғүжҷӮгҒ®гҒҝе®ҹиЎҢеҸҜиғҪгҒ§гҒҷгҖӮ"); return; }
    var list = getCurrentPatientsList();
    if (list.length === 0) { alert("жӣҙж–°еҜҫиұЎгҒ®жӮЈиҖ…гҒҢгҒ„гҒҫгҒӣгӮ“гҖӮ"); return; }
    
    if (!confirm("иЎЁзӨәдёӯгҒ®е…ЁжӮЈиҖ…(" + list.length + "еҗҚ)гҒ®жҺЎиЎҖж—ҘгӮ’й Ҷж¬ЎеҸ–еҫ—гҒ—гҒҫгҒҷгҒӢпјҹ\n(иЈҸгҒ§1д»¶гҒҡгҒӨеҸ–еҫ—гҒҷгӮӢгҒҹгӮҒз”»йқўгҒҜеӣәгҒҫгӮҠгҒҫгҒӣгӮ“)")) return;

    var btn = document.querySelector("div[onclick='updateAllBloodDates()']");
    var originalText = btn ? btn.innerText : "[жҺЎиЎҖ] е…ЁдҪ“еҸ–еҫ—";
    if (btn) { btn.style.pointerEvents = "none"; btn.innerText = "жә–еӮҷдёӯ..."; }

    window.isBloodFetching = true;

    var idsToFetch = [];
    for (var i = 0; i < list.length; i++) {
        idsToFetch.push(list[i].id);
        var tr = document.getElementById("tr-patient-" + list[i].id);
        if (tr) {
            var textEl = tr.querySelector(".blood-date-text");
            if (textEl) textEl.innerText = "еҫ…ж©ҹдёӯ...";
        }
    }

    var totalCount = idsToFetch.length;
    var index = 0;

    function processNext() {
        if (index >= totalCount) {
            window.isBloodFetching = false;
            if (btn) { btn.style.pointerEvents = "auto"; btn.innerText = originalText; }
            renderPatients();
            
            // вҳ…и¶…йҮҚиҰҒпјҡйҒ…е»¶дҝқеӯҳ(autoSave)гҒ§гҒҜгҒӘгҒҸгҖҒгӮўгғ©гғјгғҲгҒҢеҮәгӮӢеүҚгҒ«гҖҗеҚіжҷӮдҝқеӯҳгҖ‘гӮ’еј·еҲ¶е®ҹиЎҢпјҒ
            saveData(false);
            
            alert("е…Ёд»¶гҒ®еҸ–еҫ—гҒҢе®ҢдәҶгҒ—гҒҫгҒ—гҒҹгҖӮ");
            return;
        }
        
        var targetId = idsToFetch[index];
        index++;
        var patient = findPatientById(targetId);
        
        if (btn) btn.innerText = "ж®Ӣ: " + (totalCount - index + 1);
        
        if (!patient) {
            setTimeout(processNext, 50);
            return;
        }

        var tr = document.getElementById("tr-patient-" + patient.id);
        if (tr) {
            var textEl = tr.querySelector(".blood-date-text");
            if (textEl) textEl.innerText = "еҸ–еҫ—дёӯ...";
        }
        
        fetchSingleBloodDate(patient, function() {
            var updateTr = document.getElementById("tr-patient-" + patient.id);
            if (updateTr) {
                var dtEl = updateTr.querySelector(".blood-date-text");
                if (dtEl) dtEl.innerText = patient.bloodDate || "-";
            }
            setTimeout(processNext, 200);
        });
    }
    processNext();
}

// --- Shift-JIS гғҮгӮігғјгғүз”Ёгғҳгғ«гғ‘гғј ---
function decodeShiftJIS(bin) {
    try {
        var stream = new ActiveXObject("ADODB.Stream");
        stream.Type = 1; // adTypeBinary
        stream.Open();
        stream.Write(bin);
        stream.Position = 0;
        stream.Type = 2; // adTypeText
        stream.Charset = "Shift_JIS";
        var text = stream.ReadText();
        stream.Close();
        return text;
    } catch (e) {
        return "";
    }
}

function fetchSingleBloodDate(p, callback) {
    if (!p || !p.id) { callback(); return; }
    
    var userId = "16622";
    if (typeof currentSystemId !== "undefined" && currentSystemId) {
        userId = currentSystemId;
    } else if (typeof appData !== "undefined" && appData.settings && appData.settings.adminIds && appData.settings.adminIds[0]) {
        userId = appData.settings.adminIds[0];
    }

    var url = "http://10.5.171.42:8082/karte/karte.php?kanja_id=" + p.id + 
              "&user_id=" + userId + 
              "&order_search_flg=1&order_search_code=3&order_search_name=#top" +
              "&_nocache=" + new Date().getTime();

    var iframeId = "blood-fetch-iframe-" + p.id;
    var existing = document.getElementById(iframeId);
    if (existing && existing.parentNode) existing.parentNode.removeChild(existing);

    var iframe = document.createElement("iframe");
    iframe.id = iframeId;
    iframe.style.display = "none";
    iframe.application = "yes"; 
    document.body.appendChild(iframe);

    var isDone = false;
    var cleanupAndCallback = function() {
        if (isDone) return;
        isDone = true;
        setTimeout(function() {
            var ifr = document.getElementById(iframeId);
            if (ifr && ifr.parentNode) ifr.parentNode.removeChild(ifr);
        }, 500);
        callback(); 
    };

    var fallbackTimer = setTimeout(function() {
        if (!isDone) {
            p.bloodDate = "-";
            p.bloodDetail = "иӘӯгҒҝиҫјгҒҝгӮҝгӮӨгғ гӮўгӮҰгғҲ(3еҲҶи¶…йҒҺ)";
            cleanupAndCallback();
        }
    }, 180000); 

    iframe.onload = function() {
        setTimeout(function() {
            if (isDone) return;
            try {
                var doc = iframe.contentWindow.document;
                var allText = "";
                
                function collectText(currentDoc) {
                    if (!currentDoc) return;
                    try {
                        if (currentDoc.body && currentDoc.body.innerText) {
                            allText += " " + currentDoc.body.innerText;
                        }
                    } catch(e) {}
                    var frames = currentDoc.getElementsByTagName("frame");
                    var iframes = currentDoc.getElementsByTagName("iframe");
                    for(var j=0; j<frames.length; j++) {
                        try { collectText(frames[j].contentWindow.document); } catch(e){}
                    }
                    for(var k=0; k<iframes.length; k++) {
                        try { collectText(iframes[k].contentWindow.document); } catch(e){}
                    }
                }
                
                collectText(doc);

                var regex = /гҖҗ([^гҖ‘]*?(?:з”ҹеҢ–еӯҰ|иЎҖж¶І|еӨ–жіЁ|дёҖиҲ¬)[^гҖ‘]*?)гҖ‘[^гҖҗ]{0,150}?(\d{4})\/(\d{2})\/(\d{2})/g;
                var match;
                var today = new Date();
                today.setHours(0,0,0,0);
                var futureEntries = [];
                
                while ((match = regex.exec(allText)) !== null) {
                    var typeRaw = match[1].replace(/^[0-9:\s]+/, '').replace(/\[.*?\]\s*/g, '').trim();
                    var typeClean = typeRaw.substring(0, 15);
                    var y = parseInt(match[2], 10);
                    var m = parseInt(match[3], 10);
                    var d = parseInt(match[4], 10);
                    var dt = new Date(y, m - 1, d);
                    
                    var diffDays = (dt.getTime() - today.getTime()) / (1000 * 3600 * 24);
                    if (diffDays >= 1 && diffDays <= 30) {
                        futureEntries.push({
                            dateObj: dt,
                            displayDate: ('0'+m).slice(-2) + '/' + ('0'+d).slice(-2),
                            category: typeClean,
                            fullText: match[0].substring(0, 45)
                        });
                    }
                }
                
                if (futureEntries.length > 0) {
                    futureEntries.sort(function(a, b) { return a.dateObj.getTime() - b.dateObj.getTime(); });
                    var target = futureEntries[0];
                    p.bloodDate = target.displayDate + '(' + target.category + ')';
                    p.bloodDetail = target.fullText;
                } else {
                    p.bloodDate = "гҒӘгҒ—";
                    p.bloodDetail = "жҳҺж—Ҙд»ҘйҷҚ30ж—Ҙд»ҘеҶ…гҒ®жӨңжҹ»дәҲе®ҡгҒҢиҰӢгҒӨгҒӢгӮҠгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹ";
                }
            } catch(e) {
                p.bloodDate = "-";
                p.bloodDetail = "гғ•гғ¬гғјгғ и§ЈжһҗгӮЁгғ©гғј: " + (e.message || e);
            }
            
            // вҳ…иҝҪеҠ : гғҮгғјгӮҝеҸ–еҫ—жҲҗеҠҹжҷӮгҒ«гҖҒгҒ“гҒ“гҒ§зўәе®ҹгҒ«дјқзҘЁ(Transaction)гӮ’зҷәиЎҢгҒҷгӮӢ
            if (typeof DataManager !== "undefined") {
                DataManager.appendTransaction("UPDATE_BLOOD_DATE", {
                    patientId: p.id,
                    wardCode: currentWard,
                    bloodDate: p.bloodDate,
                    bloodDetail: p.bloodDetail
                });
            }

            clearTimeout(fallbackTimer);
            
            var tr = document.getElementById('tr-patient-' + p.id);
            if (tr) {
                var dateSpan = tr.querySelector('.blood-date-text');
                if (dateSpan) dateSpan.innerHTML = escapeHtml(p.bloodDate);
                var fetchBtn = tr.querySelector('.blood-fetch-btn');
                if (fetchBtn) { fetchBtn.innerText = 'е®ҢдәҶ'; fetchBtn.disabled = false; }
                var cell = tr.querySelector('.blood-date-cell');
                if (cell && p.bloodDetail) cell.title = 'жҺЎиЎҖи©ізҙ°: ' + escapeHtml(p.bloodDetail) + ' (гӮҜгғӘгғғгӮҜгҒ§жүӢеӢ•дҝ®жӯЈ)';
            }

            cleanupAndCallback();
        }, 1500); 
    };
    
    try {
        iframe.src = url;
    } catch(e) {
        p.bloodDate = "-";
        p.bloodDetail = "URLгӮўгӮҜгӮ»гӮ№гӮЁгғ©гғј";
        clearTimeout(fallbackTimer);
        cleanupAndCallback();
    }
}

function parseHtmlAndMerge(doc, wardName) {
    try {
        var tables = doc.getElementsByTagName("table");
        if(tables.length === 0) {
            alert("гғҡгғјгӮёгҒ«гғҶгғјгғ–гғ«гғҮгғјгӮҝгҒҢеҗ«гҒҫгӮҢгҒҰгҒ„гҒҫгҒӣгӮ“гҖӮ");
            return;
        }

        var targetTable = tables[0];
        var rows = targetTable.getElementsByTagName("tr");
        
        var newPatients = [];
        var roomIndex = 8;     // вҳ…иҝҪеҠ : з—…е®Ө (еҲ—з•ӘеҸ·8) [cite: 11]
        var idIndex = 2;       // жӮЈиҖ…ID
        var nameIndex = 3;     // ж°ҸеҗҚ
        var deptIndex = 9;     // иЁәзҷӮз§‘
        var docIndex = 10;     // дё»жІ»еҢ»
        var diseaseIndex = 32; // дё»з—…еҗҚ
        var daysInHospIndex = 29; // еңЁйҷўж—Ҙж•°
        
        for(var i = 0; i < rows.length; i++) {
            var cells = rows[i].getElementsByTagName("td");
            if(cells.length > diseaseIndex) {
                var pidStr = (cells[idIndex].innerText || cells[idIndex].textContent || "").replace(/\s+/g, "");
                
                if (pidStr.indexOf("жӮЈиҖ…ID") !== -1 || pidStr === "пјј" || pidStr === "") continue;

                // з—…е®ӨгҒ®еҸ–еҫ— [cite: 11]
                var proom = cells[roomIndex] ? (cells[roomIndex].innerText || cells[roomIndex].textContent || "").trim() : "";
                var pname = cells[nameIndex].innerText || cells[nameIndex].textContent || "";
                var pdept = cells[deptIndex].innerText || cells[deptIndex].textContent || "";
                var pdoc = cells[docIndex].innerText || cells[docIndex].textContent || "";
                var pdisease = cells[diseaseIndex].innerText || cells[diseaseIndex].textContent || "";
                var pdays = cells[daysInHospIndex] ? (cells[daysInHospIndex].innerText || cells[daysInHospIndex].textContent || "") : "-";

                if(pidStr) {
                    newPatients.push({
                        room: proom,   // вҳ…иҝҪеҠ  [cite: 11]
                        id: pidStr,
                        name: pname.trim(),
                        dept: pdept.trim(),
                        doctor: pdoc.trim(),
                        disease: pdisease.trim(),
                        daysInHosp: pdays.trim()
                    });
                }
            }
        }
        
        if(newPatients.length === 0) {
            alert("гғҶгғјгғ–гғ«гҒӢгӮүжӮЈиҖ…жғ…е ұгӮ’жҠҪеҮәгҒ§гҒҚгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹгҖӮгғҮгғјгӮҝгҒҢ0д»¶гҒҫгҒҹгҒҜгғ•гӮ©гғјгғһгғғгғҲгҒҢеӨүгӮҸгҒЈгҒҹеҸҜиғҪжҖ§гҒҢгҒӮгӮҠгҒҫгҒҷгҖӮ");
            return;
        }
        
        processFetchedPatients(newPatients, wardName);
    } catch(e) {
        alert("HTMLи§ЈжһҗгӮЁгғ©гғј: " + e.message);
    }
}

function processFetchedPatients(newPatients, wardName) {
    if (!newPatients || !newPatients.length) return;
    
    // дёҚжӯЈгҒӘз©әгғҮгғјгӮҝгӮ’жҺ’йҷӨ (Vol.15.13)
    newPatients = newPatients.filter(function(item) { return item != null; });
    
    try {
        var list = getCurrentPatientsList();
        var oldMap = {};
        for(var j = 0; j < list.length; j++) {
            if(list[j]) oldMap[list[j].id] = list[j];
        }
        
        var newMap = {};
        var newMap = {};
        for(var k = 0; k < newPatients.length; k++) {
            if(newPatients[k]) newMap[newPatients[k].id] = newPatients[k];
        }
        
        // е…ҘйҖҖе®ӨеұҘжӯҙпјҲиҝҪеҠ гғ»еүҠйҷӨгҒ®жӨңзҹҘпјүвҖ»гғҮгғјгӮҝгҒҢз©әгҒ®зҠ¶ж…ӢгҒӢгӮүгҒ®еҲқеӣһиӘӯгҒҝиҫјгҒҝжҷӮгҒ«гҒҜеӨ§йҮҸгҒ«еұҘжӯҙгҒҢеҮәгӮӢгҒ®гӮ’йҳІгҒҗгҒҹгӮҒж—ўеӯҳгғӘгӮ№гғҲгҒҢгҒӮгӮӢе ҙеҗҲгҒ®гҒҝиЁҳйҢІ
        if (!appData.history) appData.history = [];
        var nowStr = getTodayString() + " " + getTimeString();
        var historyAdded = 0;
        
        // йҖҖе®ӨиҖ…гӮўгғјгӮ«гӮӨгғ–з”ЁпјҲеӯҳеңЁгҒ—гҒӘгҒ‘гӮҢгҒ°еҲқжңҹеҢ–пјү
        if (!appData.dischargedArchive) appData.dischargedArchive = {};

        // === гӮўгғјгӮ«гӮӨгғ–гҒ®иҮӘеӢ•гӮҜгғӘгғјгғігӮўгғғгғ—пјҲзҙ„еҚҠе№ҙпјқ180ж—ҘзөҢйҒҺгҒ§еүҠйҷӨпјү ===
        var currentMs = new Date().getTime();
        var limitMs = 180 * 24 * 60 * 60 * 1000;
        for (var arcId in appData.dischargedArchive) {
            if (appData.dischargedArchive.hasOwnProperty(arcId)) {
                var arcDat = appData.dischargedArchive[arcId].archivedAt;
                if (arcDat && (currentMs - arcDat > limitMs)) {
                    delete appData.dischargedArchive[arcId];
                }
            }
        }

        // ж—§гғӘгӮ№гғҲгҒ«гҒӮгҒЈгҒҰгҖҒж–°гғӘгӮ№гғҲгҒ«гҒӘгҒ„дәә пјқ гҖҢйҖҖе®ӨгҖҚ
        for(var j = 0; j < list.length; j++) {
            var oldP = list[j];
            if(!oldP) continue;
            if(!newMap[oldP.id]) {
                appData.history.unshift({
                    date: nowStr, type: "йҖҖе®Ө", patient: oldP.name, id: oldP.id, ward: wardName, 
                    dept: oldP.dept || "", doctor: oldP.doctor || "", disease: oldP.disease || "",
                    createdAt: new Date().getTime(), user: currentUserName
                });
                historyAdded++;
                
                // йҖҖе®ӨжҷӮгҒ«гғЎгғўгӮ„д»Ӣе…Ҙгғ•гғ©гӮ°жғ…е ұгӮ’гӮўгғјгӮ«гӮӨгғ–гҒёдҝқеӯҳ
                appData.dischargedArchive[oldP.id] = {
                    id: oldP.id, // вҳ…иҝҪеҠ : гӮўгғјгӮ«гӮӨгғ–гғҮгғјгӮҝеҶ…гҒ«гӮӮIDгӮ’дҝқжҢҒгҒ•гҒӣгӮӢ
                    status: oldP.status,
                    statusAuthor: oldP.statusAuthor,
                    memo: oldP.memo,
                    chkPrescription: oldP.chkPrescription || false,
                    memoAuthors: oldP.memoAuthors || [],
                    memoAuthor: oldP.memoAuthor || "",
                    alertLevel: oldP.alertLevel || 0,
                    personalMemos: oldP.personalMemos || {},
                    archivedAt: new Date().getTime(),
                    bloodDate: oldP.bloodDate || "",
                    bloodDetail: oldP.bloodDetail || ""
                };
            }
        }
        
        var mergedList = [];
        for(var k = 0; k < newPatients.length; k++) {
            var np = newPatients[k];
            // ж–°гғӘгӮ№гғҲгҒ«гҒӮгҒЈгҒҰгҖҒж—§гғӘгӮ№гғҲгҒ«гҒӘгҒ„дәә пјқ гҖҢе…Ҙе®ӨгҖҚ
            if(!oldMap[np.id] && list.length > 0) {
                appData.history.unshift({
                    date: nowStr, type: "е…Ҙе®Ө/иҝҪеҠ ", patient: np.name, id: np.id, ward: wardName,
                    dept: np.dept || "", doctor: np.doctor || "", disease: np.disease || "",
                    createdAt: new Date().getTime(), user: currentUserName
                });
                historyAdded++;
            }
            
            var pId = np.id;
            if(pId && oldMap[pId]) {
                var oldP = oldMap[pId];
                np.status = oldP.status;
                np.statusAuthor = oldP.statusAuthor;
                np.memo = oldP.memo;
                np.chkPrescription = oldP.chkPrescription || false;
                np.memoAuthors = oldP.memoAuthors || [];
                np.memoAuthor = oldP.memoAuthor || "";
                np.alertLevel = oldP.alertLevel || 0;
                np.personalMemos = oldP.personalMemos || {};
                if (oldP.bloodDate && oldP.bloodDate !== "-") {
                    np.bloodDate = oldP.bloodDate;
                    np.bloodDetail = oldP.bloodDetail;
                } else if ((!np.bloodDate || np.bloodDate === "-") && oldP.bloodDate) {
                    np.bloodDate = oldP.bloodDate;
                    np.bloodDetail = oldP.bloodDetail;
                }
            } else {
                // з—…жЈҹй–“з§»еӢ•жҷӮгҒ®жғ…е ұеј•гҒҚз¶ҷгҒҺ (cross-ward inheritance)
                // гҒ“гҒ®з—…жЈҹгҒ®ж—§гғӘгӮ№гғҲгҒ«гҒҜеұ…гҒӘгҒ„гҒҢгҖҒд»–гҒ®з—…жЈҹгғҮгғјгӮҝгҒ«еҗҢгҒҳIDгҒ®жӮЈиҖ…гҒҢеӯҳеңЁгҒҷгӮӢгҒӢжҺўзҙўгҒҷгӮӢ
                var inherited = false;
                var otherWards = [];
                for (var wk in appData.patients) {
                    if (wk !== String(currentWard) && appData.patients[wk]) {
                        otherWards.push(appData.patients[wk]);
                    }
                }
                
                for(var w = 0; w < otherWards.length; w++) {
                    var wList = otherWards[w];
                    if(!wList) continue;
                    for(var m = 0; m < wList.length; m++) {
                        if (wList[m] && wList[m].id === np.id) {
                            var target = wList[m];
                            np.status = target.status;
                            np.statusAuthor = target.statusAuthor;
                            np.memo = target.memo;
                            np.chkPrescription = target.chkPrescription || false;
                            np.memoAuthors = target.memoAuthors || [];
                            np.memoAuthor = target.memoAuthor || "";
                            np.alertLevel = target.alertLevel || 0;
                            np.personalMemos = target.personalMemos || {};
                            inherited = true;
                            break; 
                        }
                    }
                    if(inherited) break;
                }
                
                // гҒ©гҒ®з—…жЈҹгҒ«гӮӮеӯҳеңЁгҒ—гҒӘгҒ„е ҙеҗҲгҖҒйҒҺеҺ»гҒ®йҖҖе®ӨгӮўгғјгӮ«гӮӨгғ–гӮ’жҺўгҒҷ
                if(!inherited && appData.dischargedArchive && appData.dischargedArchive[np.id]) {
                    var arc = appData.dischargedArchive[np.id];
                    np.status = arc.status;
                    np.statusAuthor = arc.statusAuthor;
                    np.memo = arc.memo;
                    np.chkPrescription = arc.chkPrescription || false;
                    np.memoAuthors = arc.memoAuthors || [];
                    np.memoAuthor = arc.memoAuthor || "";
                    np.alertLevel = arc.alertLevel || 0;
                    np.personalMemos = arc.personalMemos || {};
                    inherited = true;
                    // еј•з¶ҷгҒҺе®ҢдәҶеҫҢгҖҒгӮўгғјгӮ«гӮӨгғ–гҒӢгӮүгҒҜеүҠйҷӨгҒҷгӮӢ
                    delete appData.dischargedArchive[np.id];
                }

                // вҳ…иҝҪеҠ : гӮўгғјгӮ«гӮӨгғ–гҒ«гӮӮгҒӘгҒ„е ҙеҗҲгҖҒгҒ•гӮүгҒ«гҖҢе…ҘйҷўдәҲе®ҡ(admissionSchedule)гҖҚгҒ«гғҮгғјгӮҝгҒҢгҒӘгҒ„гҒӢжҺўгҒҷ
                if(!inherited && appData.admissionSchedule) {
                    for(var as=0; as<appData.admissionSchedule.length; as++) {
                        var asP = appData.admissionSchedule[as];
                        if(asP && String(asP.id) === String(np.id)) {
                            np.status = asP.status || 0;
                            np.statusAuthor = asP.statusAuthor || "";
                            np.memo = asP.memo || "";
                            np.memoAuthors = asP.memoAuthors || [];
                            np.memoAuthor = asP.memoAuthor || "";
                            np.alertLevel = asP.alertLevel || 0;
                            np.personalMemos = asP.personalMemos || {};
                            // жҺЎиЎҖдәҲе®ҡгҒҢе…ҘгҒЈгҒҰгҒ„гӮҢгҒ°гҒқгӮҢгӮӮеј•гҒҚз¶ҷгҒҗ
                            if (asP.bloodDate && asP.bloodDate !== "-") {
                                np.bloodDate = asP.bloodDate;
                                np.bloodDetail = asP.bloodDetail || "";
                            }
                            inherited = true;
                            break;
                        }
                    }
                }

                // гҒқгӮҢгҒ§гӮӮеӯҳеңЁгҒ—гҒӘгҒ„е®Ңе…ЁгҒӘж–°иҰҸжӮЈиҖ…гҒ®е ҙеҗҲ
                if(!inherited) {
                    np.status = 0;
                    np.statusAuthor = "";
                    np.memo = "";
                }
            }
            mergedList.push(np);
        }
        
        // еұҘжӯҙгҒҢеӨҡгҒҸгҒӘгӮҠгҒҷгҒҺгҒӘгҒ„гӮҲгҒҶгҒ«еҲ¶йҷҗпјҲзӣҙиҝ‘100д»¶пјү
        if (appData.history && appData.history.length > 100) {
            appData.history = appData.history.slice(0, 100);
        }
        
        // гғҮгғјгӮҝгҒ®жӣёгҒҚиҫјгҒҝ
        appData.patients[currentWard] = mergedList;
        
        renderPatients();
        renderHistory(); // еұҘжӯҙгӮҝгғ–гҒ®жӣҙж–°

        var msg = wardName + " гҒ®гғӘгӮ№гғҲгӮ’жӣҙж–°гҒ—гҒҫгҒ—гҒҹгҖӮ(" + mergedList.length + "д»¶)";
        if(historyAdded > 0) msg += " вҖ»йҖҖе®Ө/иҝҪеҠ гҒ®еӨүеӢ•гҒҢгҒӮгӮҠгҒҫгҒ—гҒҹ (еұҘжӯҙгӮҝгғ–еҸӮз…§)";
        
        var elTime = document.getElementById("last-update-time");
        if(elTime) elTime.innerText = "гҖҗгӮ·гӮ№гғҶгғ жңҖзөӮеҸ–еҫ—: " + getTimeString() + "гҖ‘";
        
        // е…ҘйҷўдәҲе®ҡгғҮгғјгӮҝгӮӮеҗҢжҷӮгҒ«еҸ–еҫ—
        setTimeout(function(){ fetchAdmissionSchedule(); }, 3000);
        
        // гғӯгғјгӮ«гғ«жӣҙж–°жҷӮй–“гӮӮеҗҲгӮҸгҒӣгҒҰгғӘгӮ»гғғгғҲгҒ—гҒҰгҒҠгҒҸпјҲж¬Ўеӣһпј‘еҲҶеҫҢгҒ«еӨүгӮҸгӮӢпјү
        var elLocalTime = document.getElementById("last-local-update-time");
        if(elLocalTime) elLocalTime.innerText = "гҖҗгғӯгғјгӮ«гғ«гғҮгғјгӮҝжңҖж–°: " + getTimeString() + "гҖ‘";
        
    } catch(e) {
        alert("жӮЈиҖ…гғҮгғјгӮҝгҒ®гғһгғјгӮёеҮҰзҗҶгӮЁгғ©гғј: " + e.message);
    }
}

// ---------- е…ҘйҷўдәҲе®ҡжӮЈиҖ…дёҖиҰ§ ----------
var admissionPatients = [];

function toggleAdmissionPanel() {
    var body = document.getElementById('admission-body');
    var icon = document.getElementById('admission-toggle-icon');
    if (body.style.display === 'none') {
        body.style.display = '';
        icon.innerText = 'в–ј';
    } else {
        body.style.display = 'none';
        icon.innerText = 'в–І';
    }
}

function fetchAdmissionSchedule() {
    if (!isEditMode) return;
    var wardCode = currentWard;
    var wardName = getWardName(wardCode);
    if (!wardCode || String(wardCode) === '99' || String(wardCode).indexOf('http') === 0) return;

    var iframeId = "admission-iframe";
    var iframe = document.getElementById(iframeId);
    if (!iframe) {
        iframe = document.createElement("iframe");
        iframe.id = iframeId;
        iframe.style.display = "none";
        document.body.appendChild(iframe);
    }

    var today = new Date();
    var yyyy = today.getFullYear();
    var mm = ('0' + (today.getMonth() + 1)).slice(-2);
    var dd = ('0' + today.getDate()).slice(-2);
    var dateStr = yyyy + "%2F" + mm + "%2F" + dd;

    var fetchUrl = "http://10.5.171.42:8082/karte/kanja_ichiran/kanja_ichiran.php" +
        "?nyuin_yoyaku_start_date=" + dateStr +
        "&nyuin_yoyaku_end_date=" + dateStr +
        "&byoto_gentei_flg=%2C" +
        "&nyuin_byoto_code=" + wardCode +
        "&ichiran_code=6&user_id=" + currentSystemId +
        "&section_code=&page_num=0&login_flg=" +
        "&t=" + new Date().getTime();

    iframe.onload = function() {
        try {
            var doc = iframe.contentWindow.document;
            parseAdmissionHtml(doc);
        } catch(e) {}
    };
    try { iframe.src = fetchUrl; } catch(e) {}
}

function renderCustomCalendarHTML() {
    var div = document.getElementById("custom-datepicker");
    if(!div) return;
    var y = calCurrentYear;
    var m = calCurrentMonth;
    var firstDay = new Date(y, m-1, 1).getDay();
    var lastDate = new Date(y, m, 0).getDate();
    
    var html = [];
    html.push("<div style='display:flex; justify-content:space-between; align-items:center; margin-bottom:5px; background:#f0f0f0; padding:3px; border-radius:3px;'>");
    html.push("<button onclick='changeCalMonth(-1)' style='cursor:pointer; border:none; background:transparent;' title='еүҚжңҲ'>в—Җ</button>");
    html.push("<b style='font-size:13px;'>" + m + "жңҲ (" + y + "е№ҙ)</b>");
    html.push("<button onclick='changeCalMonth(1)' style='cursor:pointer; border:none; background:transparent;' title='ж¬ЎжңҲ'>в–¶</button>");
    html.push("</div>");
    
    html.push("<table style='width:100%; text-align:center; font-size:12px; border-collapse:collapse;'>");
    html.push("<tr style='color:#666; border-bottom:1px solid #ccc;'>");
    html.push("<th style='color:#e74c3c;'>ж—Ҙ</th><th>жңҲ</th><th>зҒ«</th><th>ж°ҙ</th><th>жңЁ</th><th>йҮ‘</th><th style='color:#3498db;'>еңҹ</th></tr><tr>");
    
    for(var i=0; i<firstDay; i++) { html.push("<td></td>"); }
    for(var i=1; i<=(lastDate); i++) {
        var dayOfWeek = (i + firstDay - 1) % 7;
        var cls = (dayOfWeek === 0) ? "color:#e74c3c;" : (dayOfWeek === 6) ? "color:#3498db;" : "";
        var isToday = (m === new Date().getMonth()+1 && i === new Date().getDate() && y === new Date().getFullYear());
        var isSelected = (m === calSelectedMonth && i === calSelectedDate);
        var bg = isSelected ? "background:#2ecc71; color:#fff; border-radius:3px; font-weight:bold;" : (isToday ? "background:#ffecb3; border-radius:3px;" : "background:#fff;");
        var styleCls = "cursor:pointer; width:24px; height:24px; padding:0; margin:1px; border:1px solid #ddd; " + cls + " " + bg;
        html.push("<td><button onclick='clickCalDate("+m+", "+i+")' style='" + styleCls + "'>" + i + "</button></td>");
        if(dayOfWeek === 6 && i !== lastDate) html.push("</tr><tr>");
    }
    html.push("</tr></table>");
    
    var existingTime = "";
    if(pendingDeadline) {
        var tm = pendingDeadline.match(/\s([0-9]{1,2}:[0-9]{1,2})/);
        if(tm) existingTime = tm[1];
    }
    
    html.push("<div style='margin-top:10px; display:flex; align-items:center; justify-content:space-between; border-top:1px solid #ccc; padding-top:8px;'>");
    html.push("<span style='font-size:12px; margin-right:5px; font-weight:bold;'>жҷӮеҲ»:</span>");
    html.push("<select id='cal-time' style='padding:4px; font-size:12px; flex-grow:1; border:1px solid #aaa; border-radius:3px;'>");
    html.push("<option value=''>жҢҮе®ҡгҒӘгҒ—</option>");
    for(var h=0; h<24; h++) {
        var hStr = (h<10?"0":"")+h+":00";
        var hSel = (existingTime === hStr) ? "selected" : "";
        html.push("<option value='"+hStr+"' "+hSel+">"+hStr+"</option>");
    }
    html.push("</select></div>");
    
    html.push("<div style='margin-top:12px; display:flex; justify-content:space-between; gap:5px;'>");
    html.push("<button onclick='commitCalDate()' style='flex-grow:1; background:#3498db; color:white; border:none; padding:6px 0; border-radius:4px; cursor:pointer; font-weight:bold;'>жұәе®ҡ</button>");
    html.push("<button onclick='clearCalDate()' style='background:#e74c3c; color:white; border:none; padding:6px 10px; border-radius:4px; cursor:pointer;'>гӮҜгғӘгӮў</button>");
    html.push("<button onclick='document.getElementById(\"custom-datepicker\").style.display=\"none\";' style='background:#95a5a6; color:white; border:none; padding:6px 10px; border-radius:4px; cursor:pointer;'>й–үгҒҳгӮӢ</button>");
    html.push("</div>");
    
    div.innerHTML = html.join('');
}

function parseBloodDateFromDoc(doc, patientId) {
    var today = new Date();
    today.setHours(0,0,0,0);
    var futureEntries = [];
    var allEntries = [];

    try {
        var allText = "";
        
        function collectText(currentDoc) {
            if(!currentDoc) return;
            try {
                if (currentDoc.body && currentDoc.body.innerText) {
                    allText += " " + currentDoc.body.innerText;
                }
            } catch(e) {}
            
            var frames = currentDoc.getElementsByTagName('frame');
            var iframes = currentDoc.getElementsByTagName('iframe');
            for(var j=0; j<frames.length; j++) {
                try { collectText(frames[j].contentWindow.document); } catch(e){}
            }
            for(var k=0; k<iframes.length; k++) {
                try { collectText(iframes[k].contentWindow.document); } catch(e){}
            }
        }
        collectText(doc);

        var regex = /[гҖҗ\[]([^гҖ‘\]]+)[гҖ‘\]][^гҖҗ\[]{0,100}?(\d{4})\/(\d{2})\/(\d{2})/g;
        var match;
        
        while ((match = regex.exec(allText)) !== null) {
            // гӮ«гғҶгӮҙгғӘгҒ®гӮҜгғӘгғјгғӢгғігӮ°
            var catRaw = match[1].replace(/^[0-9:]+\s*/, '').replace(/\[.*?\]\s*/g, '').trim();
            var catClean = catRaw.substring(0, 15);
            
            var y = parseInt(match[2], 10);
            var m = parseInt(match[3], 10);
            var d = parseInt(match[4], 10);
            var dt = new Date(y, m - 1, d);
            
            var entry = { 
                dateObj: dt, 
                displayDate: ('0'+m).slice(-2) + '/' + ('0'+d).slice(-2),
                category: catClean,
                fullText: match[0].substring(0, 40)
            };
            
            // д»Ҡж—ҘгҒЁжҠҪеҮәгҒ—гҒҹж—Ҙд»ҳгҒ®е·®пјҲж—Ҙж•°пјүгӮ’иЁҲз®—
            var diffDays = (dt.getTime() - today.getTime()) / (1000 * 3600 * 24);
            // вҳ…дҝ®жӯЈпјҡд»Ҡж—Ҙ(0)д»ҘеүҚгҖҒгҒҫгҒҹгҒҜ30ж—ҘгӮҲгӮҠе…ҲгҒ®гғҮгғјгӮҝгҒҜз„ЎиҰ–гҒҷгӮӢ
            if (diffDays < 1 || diffDays > 30) continue;
            
            futureEntries.push(entry);
        }
    } catch(e) {}
    
    var targetEntry = null;
    // иҰӢгҒӨгҒ‘гҒҹж—Ҙд»ҳгғӘгӮ№гғҲгӮ’дёҰгҒіжӣҝгҒҲгҒҰгҖҢдёҖз•Әд»Ҡж—ҘгҒ«иҝ‘гҒ„жңӘжқҘгҖҚгӮ’йҒёгҒ¶
    if (futureEntries.length > 0) {
        futureEntries.sort(function(a, b) { return a.dateObj.getTime() - b.dateObj.getTime(); });
        targetEntry = futureEntries[0];
    }
    
    var p = findPatientById(patientId);
    if (!p) return;

    if (targetEntry) {
        var catText = targetEntry.category ? '(' + targetEntry.category + ')' : '';
        p.bloodDate = targetEntry.displayDate + catText;
        p.bloodDetail = targetEntry.fullText;
    } else {
        // вҳ…дҝ®жӯЈпјҡиҰӢгҒӨгҒӢгӮүгҒӘгҒӢгҒЈгҒҹе ҙеҗҲгҒҜгҖҢгҒӘгҒ—гҖҚгҒЁиЎЁзӨә
        p.bloodDate = 'гҒӘгҒ—';
        p.bloodDetail = 'жҳҺж—Ҙд»ҘйҷҚ30ж—Ҙд»ҘеҶ…гҒ®жӨңжҹ»дәҲе®ҡгҒҢиҰӢгҒӨгҒӢгӮҠгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹ';
    }
    
    var tr = document.getElementById('tr-patient-' + patientId);
    if (tr) {
        var dateSpan = tr.querySelector('.blood-date-text');
        if (dateSpan) dateSpan.innerHTML = escapeHtml(p.bloodDate);
        var fetchBtn = tr.querySelector('.blood-fetch-btn');
        if (fetchBtn) { fetchBtn.innerText = 'е®ҢдәҶ'; fetchBtn.disabled = false; }
        var cell = tr.querySelector('.blood-date-cell');
        if (cell && p.bloodDetail) cell.title = 'жҺЎиЎҖи©ізҙ°: ' + escapeHtml(p.bloodDetail) + ' (гӮҜгғӘгғғгӮҜгҒ§жүӢеӢ•дҝ®жӯЈ)';
    }

}



// function saveDataQuietly removed to avoid conflict with DataManager

function parseAdmissionHtml(doc) {
    try {
        var tables = doc.getElementsByTagName("table");
        if (tables.length === 0) return;

        var targetTable = tables[0];
        var rows = targetTable.getElementsByTagName("tr");

        var newAdmissions = [];
        var idIndex = 2;
        var nameIndex = 3;
        var deptIndex = 11;
        var docIndex = 12;
        var diseaseIndex = 15;
        var bloodDateIndex = 17; // е…ҘйҷўдәҲе®ҡз”ЁгӮӨгғігғҮгғғгӮҜгӮ№гҒ®д»®е®ҡ

        for (var i = 0; i < rows.length; i++) {
            var cells = rows[i].getElementsByTagName("td");
            if (cells.length > diseaseIndex) {
                var pidStr = (cells[idIndex].innerText || cells[idIndex].textContent || "").replace(/[\n\r]/g, "").replace(/\s+/g, "");
                var pname = (cells[nameIndex].innerText || cells[nameIndex].textContent || "").trim();
                var pdept = (cells[deptIndex].innerText || cells[deptIndex].textContent || "").trim();
                var pdoc = (cells[docIndex].innerText || cells[docIndex].textContent || "").trim();
                var pdisease = (cells[diseaseIndex].innerText || cells[diseaseIndex].textContent || "").trim();

                if (pidStr) {
                    newAdmissions.push({
                        id: pidStr,
                        name: pname,
                        dept: pdept,
                        doctor: pdoc,
                        disease: pdisease,
                        daysInHosp: "-",
                        bloodDate: (cells[bloodDateIndex] ? (cells[bloodDateIndex].innerText || cells[bloodDateIndex].textContent || "").replace(/[\n\r\t]/g, "").trim() : "-")
                    });
                }
            }
        }

        // ж—ўеӯҳгҒ®е…ҘйҷўдәҲе®ҡгғҮгғјгӮҝгҒӢгӮүгӮ№гғҶгғјгӮҝгӮ№гғ»гғЎгғўгӮ’еј•гҒҚз¶ҷгҒҗ
        var oldMap = {};
        for (var j = 0; j < admissionPatients.length; j++) {
            oldMap[admissionPatients[j].id] = admissionPatients[j];
        }
        // appDataгҒ®admissionScheduleгҒӢгӮүгӮӮеј•гҒҚз¶ҷгҒҗ
        if (appData.admissionSchedule) {
            for (var j = 0; j < appData.admissionSchedule.length; j++) {
                var as = appData.admissionSchedule[j];
                if (!oldMap[as.id]) oldMap[as.id] = as;
            }
        }
        // ж—ўеӯҳгҒ®жӮЈиҖ…гғӘгӮ№гғҲгҒӢгӮүгӮӮеј•гҒҚз¶ҷгҒҺпјҲе…ҘйҷўдәҲе®ҡвҶ’е…Ҙйҷўз§»иЎҢжҷӮпјү
        var currentList = getCurrentPatientsList();
        for (var j = 0; j < currentList.length; j++) {
            if (!oldMap[currentList[j].id]) oldMap[currentList[j].id] = currentList[j];
        }

        for (var k = 0; k < newAdmissions.length; k++) {
            var np = newAdmissions[k];
            var old = oldMap[np.id];
            if (old) {
                np.status = old.status || 0;
                np.statusAuthor = old.statusAuthor || "";
                np.memo = old.memo || "";
                np.memoAuthors = old.memoAuthors || [];
                np.memoAuthor = old.memoAuthor || "";
                np.alertLevel = old.alertLevel || 0;
                // жҺЎиЎҖж—ҘгҒ®еј•гҒҚз¶ҷгҒҺ
                if ((!np.bloodDate || np.bloodDate === "-") && old.bloodDate) {
                    np.bloodDate = old.bloodDate;
                }
            } else {
                np.status = 0;
                np.statusAuthor = "";
                np.memo = "";
                np.memoAuthors = [];
                np.alertLevel = 0;
            }
        }

        admissionPatients = newAdmissions;
        appData.admissionSchedule = newAdmissions;
        renderAdmissionSchedule();

    } catch(e) {
        // гғ‘гғјгӮ№гӮЁгғ©гғјгҒҜгӮөгӮӨгғ¬гғігғҲгҒ«
    }
}

function renderAdmissionSchedule() {
    var tbody = document.getElementById('tbody-admission');
    var countEl = document.getElementById('admission-count');
    if (!tbody) return;
    if (countEl) countEl.innerText = admissionPatients.length;
    if (admissionPatients.length === 0) {
        tbody.innerHTML = '<tr><td colspan="10" align="center">жң¬ж—ҘгҒ®е…ҘйҷўдәҲе®ҡгҒҜгҒӮгӮҠгҒҫгҒӣгӮ“</td></tr>';
        return;
    }
    var html = '';
    for (var i = 0; i < admissionPatients.length; i++) {
        var p = admissionPatients[i];
        var statIdx = p.status || 0;
        var statClass = STATUS_CLASSES[statIdx];
        var statText = STATUS_TEXTS[statIdx];
        if(statText === "(жңӘиЁӯе®ҡ)") statText = "жңӘ";
        else if(statText === "д»Ӣе…ҘдәҲе®ҡ") statText = "дәҲе®ҡ";
        else if(statText === "жҢҮе°ҺжёҲ") statText = "жҢҮе°Һ";
        else if(statText === "иЁҳйҢІжёҲ") statText = "иЁҳйҢІ";

        var authorHtml = p.statusAuthor ? '<br><span class="status-author">' + p.statusAuthor + '</span>' : '';
        var statUnderline = (statIdx === 1 || statIdx === 2) ? 'text-decoration:underline;' : '';
        var clickEvent = isEditMode ? 'onclick="toggleAdmissionStatus('+i+')"' : '';
        var memoDisabled = isEditMode ? '' : 'disabled="disabled"';
        var memoChange = isEditMode ? 'onchange="finalizeAdmissionMemo('+i+', this)" onkeyup="updateAdmissionMemoDebounced('+i+', this.value, this)"' : '';
        var alertEvent = isEditMode ? 'onclick="toggleAdmissionAlert('+i+')"' : '';
        var aLevel = p.alertLevel || 0;
        var aText = aLevel === 0 ? '' : aLevel === 1 ? '?' : '!';
        var aClass = aLevel === 0 ? '' : aLevel === 1 ? 'alert-caution' : 'alert-urgent';
        var bdAdClick = isEditMode ? 'onclick="changeAdmissionBloodDate('+i+')"' : '';
        var bdAdTitle = p.bloodDetail ? 'title="жҺЎиЎҖи©ізҙ°: ' + escapeHtml(p.bloodDetail) + '"' : 'title="жҺЎиЎҖж—Ҙдҝ®жӯЈ"';

        var alreadyAdmitted = false;
        var currentList = getCurrentPatientsList();
        for (var cl = 0; cl < currentList.length; cl++) {
            var pIdNorm1 = String(p.id).replace(/^0+/, '') || '0';
            var pIdNorm2 = String(currentList[cl].id).replace(/^0+/, '') || '0';
            if (pIdNorm1 === pIdNorm2) { alreadyAdmitted = true; break; }
        }
        var admittedBadge = alreadyAdmitted ? '<span style="background:#28a745;color:#fff;font-size:9px;padding:1px 4px;border-radius:3px;">е…ҘйҷўжёҲ</span>' : '';

        var tr = [];
        tr.push('<tr' + (alreadyAdmitted ? ' style="background:#e8f5e9;"' : '') + '>');
        tr.push('<td>' + escapeHtml(p.id) + '</td>');
        tr.push('<td>' + escapeHtml(p.name) + admittedBadge + '</td>');
        tr.push('<td class="hide-on-print" style="font-size:11px; padding:2px 4px;">');
        tr.push('<div style="color:#0d6efd; font-weight:bold;">' + escapeHtml(p.dept || '') + '</div>');
        tr.push('<div style="color:#555;">' + escapeHtml(p.doctor || '') + '</div>');
        tr.push('</td>');
        tr.push('<td>' + escapeHtml(p.disease || '') + '</td>');
        tr.push('<td style="text-align:center; font-size:12px;">' + escapeHtml(p.room || '-') + '</td>');
        tr.push('<td style="text-align:center;">-</td>');
        tr.push('<td ' + bdAdClick + ' style="text-align:center; font-size:11px; cursor:pointer;" ' + bdAdTitle + '>' + escapeHtml(p.bloodDate || "-") + '</td>');
        tr.push('<td class="status-cell ' + statClass + '" style="' + statUnderline + '" ' + clickEvent + '>' + statText + authorHtml + '</td>');
        tr.push('<td style="text-align:center;">-</td>');
        tr.push('<td style="text-align:center; font-size:14px; font-weight:bold;" class="alert-toggle ' + aClass + '" ' + alertEvent + '>' + escapeHtml(aText) + '</td>');
        tr.push('<td><textarea ' + memoDisabled + ' ' + memoChange + ' placeholder="гғЎгғў...">' + escapeHtml(p.memo || '') + '</textarea></td>');
        tr.push('</tr>');
        html += tr.join('');
    }
    tbody.innerHTML = html;
}

function toggleAdmissionStatus(idx) {
    if (!isEditMode || idx >= admissionPatients.length) return;
    var p = admissionPatients[idx];
    p.status = ((p.status || 0) + 1) % 4;
    p.statusAuthor = currentUserName;
    appData.admissionSchedule = admissionPatients;
    
    // вҳ…иҝҪеҠ 
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("UPDATE_ADMISSION_STATUS", {
            patientId: p.id, value: p.status, author: p.statusAuthor
        });
    }
    renderAdmissionSchedule();

}

function toggleAdmissionAlert(idx) {
    if (!isEditMode || idx >= admissionPatients.length) return;
    var p = admissionPatients[idx];
    p.alertLevel = ((p.alertLevel || 0) + 1) % 3;
    appData.admissionSchedule = admissionPatients;
    
    // вҳ…иҝҪеҠ 
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("UPDATE_ADMISSION_ALERT", {
            patientId: p.id, value: p.alertLevel
        });
    }
    renderAdmissionSchedule();

}

// changeBloodDate: IDгғҷгғјгӮ№гҒ«еӨүжӣҙ (жүӢеӢ•е…ҘеҠӣгҖӮDOMзӣҙжҺҘжӣҙж–°)
function changeBloodDate(patientId) {
    if (!isEditMode) return;
    var list = getCurrentPatientsList();
    var p = null;
    for (var i = 0; i < list.length; i++) {
        if (String(list[i].id) === String(patientId)) { p = list[i]; break; }
    }
    if (!p) return;
    var currentText = (p.bloodDate || '').replace(/<[^>]+>/g, ' ').trim();
    var newVal = prompt('жҺЎиЎҖж—ҘгӮ’е…ҘеҠӣгҒ—гҒҰгҒҸгҒ гҒ•гҒ„ (дҫӢ: 03/25)', currentText);
    if (newVal !== null) {
        p.bloodDate = newVal;
        p.bloodDetail = '';
        
        // вҳ…иҝҪеҠ : жүӢеӢ•е…ҘеҠӣжҷӮгӮӮзўәе®ҹгҒ«дјқзҘЁ(Transaction)гӮ’зҷәиЎҢгҒҷгӮӢ
        if (typeof DataManager !== "undefined") {
            DataManager.appendTransaction("UPDATE_BLOOD_DATE", {
                patientId: p.id,
                wardCode: currentWard,
                bloodDate: p.bloodDate,
                bloodDetail: p.bloodDetail
            });
        }

        // DOMзӣҙжҺҘжӣҙж–°
        var tr = document.getElementById('tr-patient-' + p.id);
        if (tr) {
            var dateSpan = tr.querySelector('.blood-date-text');
            if (dateSpan) dateSpan.innerHTML = escapeHtml(newVal || '-');
            var cell = tr.querySelector('.blood-date-cell');
            if (cell) cell.title = 'гӮҜгғӘгғғгӮҜгҒ§жҺЎиЎҖж—ҘгӮ’жүӢеӢ•дҝ®жӯЈ';
        }

    }
}

function changeAdmissionBloodDate(index) {
    if (!isEditMode || index >= admissionPatients.length) return;
    var p = admissionPatients[index];
    var newVal = prompt("жҺЎиЎҖж—ҘгӮ’е…ҘеҠӣгҒ—гҒҰгҒҸгҒ гҒ•гҒ„ (дҫӢ: 03/25)", p.bloodDate || "");
    if (newVal !== null) {
        p.bloodDate = newVal;
        renderAdmissionSchedule();

    }
}

function updateAdmissionMemo(idx, val, el) {
    if (idx >= admissionPatients.length) return;
    admissionPatients[idx].memo = val;
    appData.admissionSchedule = admissionPatients;
}

function finalizeAdmissionMemo(idx, el) {
    if (idx >= admissionPatients.length) return;
    var p = admissionPatients[idx];
    p.memo = el.value;
    if (el.value && currentUserName) {
        if (!p.memoAuthors) p.memoAuthors = [];
        if (p.memoAuthors.indexOf(currentUserName) === -1) {
            p.memoAuthors.unshift(currentUserName);
        }
    }
    appData.admissionSchedule = admissionPatients;
    
    // вҳ…иҝҪеҠ : гғҲгғ©гғігӮ¶гӮҜгӮ·гғ§гғігҒ®зҷәиЎҢ
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("UPDATE_ADMISSION_MEMO", {
            patientId: p.id, value: p.memo
        });
    }

}

function editTodo(index) {
    if (typeof TodoUI !== "undefined") {
        TodoUI.editTodo(index);
    }
}

function deleteTodo(index) {
    if (typeof TodoUI !== "undefined") {
        TodoUI.deleteTodo(index);
    }
}

function hardDeleteTodo(index) {
    if (typeof TodoUI !== "undefined") {
        TodoUI.hardDeleteTodo(index);
    }
}

function restoreTodo(index) {
    if (typeof TodoUI !== "undefined") {
        TodoUI.restoreTodo(index);
    }
}

function toggleTodo(index) {
    if (typeof TodoUI !== "undefined") {
        TodoUI.toggleTodo(index);
    }
}

function escapeHtml(str) {
    if(!str || typeof str !== 'string') return '';
    return str.replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;')
              .replace(/"/g, '&quot;')
              .replace(/'/g, '&#39;');
}

function getTodayString() {
    var d = new Date();
    return d.getFullYear() + "/" + (("0"+(d.getMonth()+1)).slice(-2)) + "/" + (("0"+d.getDate()).slice(-2));
}
function getTimeString() { var d = new Date(); return (("0"+d.getHours()).slice(-2)) + ":" + (("0"+d.getMinutes()).slice(-2)); }

// ---------- гӮҪгғјгғҲж©ҹиғҪ ----------
var sortKey = "";
var sortOrder = 1; // 1:жҳҮй Ҷ, -1:йҷҚй Ҷ
function sortPatients(key) {
    if (sortKey === key) {
        sortOrder = sortOrder * -1;
    } else {
        sortKey = key;
        sortOrder = 1; // ж–°иҰҸгӮӯгғјгҒҜжҳҮй ҶгҒӢгӮү
    }
    renderPatients();
}

// ---------- ToDoгғӘгӮ№гғҲз®ЎзҗҶ ----------
var currentTodoTab = ""; // dynamic: ward-4A, personal, deleted

function switchTodoSubTab(tabVal, el) {
    if (typeof TodoUI !== "undefined") {
        TodoUI.switchSubTab(tabVal);
    }
}
function renderTodos() {
    var selAssignee = document.getElementById('sel-todo-assignee');
    if (selAssignee) {
        var users = getUniqueUsers();
        var newHtml = '<option value="">(жҢҮе®ҡгҒӘгҒ—)</option>';
        for (var u = 0; u < users.length; u++) {
            newHtml += '<option value="' + escapeHtml(users[u]) + '">' + escapeHtml(users[u]) + '</option>';
        }
        if (newHtml !== lastAssigneeHtml) {
            selAssignee.innerHTML = newHtml;
            lastAssigneeHtml = newHtml;
        }
    }

    if (typeof TodoUI !== "undefined") {
        TodoUI.render();
    } else {
        // вҳ…иҝҪеҠ : todo_ui.js гҒҢиӘӯгҒҝиҫјгӮҒгҒҰгҒ„гҒӘгҒ„е ҙеҗҲгҒ«гӮЁгғ©гғјгғЎгғғгӮ»гғјгӮёгӮ’иЎЁзӨәгҒҷгӮӢ
        var tbody = document.getElementById("tbody-todo");
        if (tbody) {
            var msg1 = '<tr><td colspan="4" align="center" style="color:#d35400; font-weight:bold; padding:20px;">';
            var msg2 = 'вҡ пёҸ ToDoгғўгӮёгғҘгғјгғ« (todo_ui.js) гҒҢиӘӯгҒҝиҫјгӮҒгҒҰгҒ„гҒҫгҒӣгӮ“гҖӮ<br>';
            var msg3 = 'HTAгғ•гӮЎгӮӨгғ«гҒЁеҗҢгҒҳе ҙжүҖгҒ«гҒӮгӮӢгҖҢjsгҖҚгғ•гӮ©гғ«гғҖгҒ®дёӯгҒ«гҖҢtodo_ui.jsгҖҚгҒҢе…ҘгҒЈгҒҰгҒ„гӮӢгҒӢзўәиӘҚгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ</td></tr>';
            tbody.innerHTML = msg1 + msg2 + msg3;
        }
    }
}

// ---------- ToDoйҖҡзҹҘж©ҹиғҪ (Vol.15.6) ----------
function checkMyTodos() {
    if(!appData.todos) return;
    var myTodos = [];
    var currentIncompleteCount = 0;
    for(var i=0; i<appData.todos.length; i++) {
        var t = appData.todos[i];
        if(!t.done && !t.deleted && !t.archived && t.assignee === currentUserName) {
            myTodos.push("гғ»" + (t.text || ""));
            currentIncompleteCount++;
        }
    }
    
    // еүҚеӣһгҒ®йҖҡзҹҘжҷӮгӮҲгӮҠгӮҝгӮ№гӮҜгҒҢеў—гҒҲгҒҰгҒ„гӮӢе ҙеҗҲгҒ®гҒҝйҖҡзҹҘгҒҷгӮӢпјҲйҮҚиӨҮйҳІжӯўпјү
    if(currentIncompleteCount > 0 && currentIncompleteCount > lastAlertedTodoCount) {
        var msg = "гҖҗ" + currentUserName + "гҒ•гӮ“гҒёгҒ®гӮҝгӮ№гӮҜгҒҢгҒӮгӮҠгҒҫгҒҷгҖ‘\n\n" + myTodos.join("\n") + "\n\nToDoгғӘгӮ№гғҲгӮ’зўәиӘҚгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ";
        setTimeout(function(){ alert(msg); }, 1500);
    }
    lastAlertedTodoCount = currentIncompleteCount;
}

function startDeadlineTimer() {
    setInterval(function(){
        if(!appData.todos) return;
        var now = new Date();
        for(var i=0; i<appData.todos.length; i++) {
            var t = appData.todos[i];
            if(t.done || t.deleted || t.archived || !t.deadline || !t.reminderOffset || t.alerted) continue;
            // дҪңжҘӯиҖ…гҒҢжҢҮе®ҡгҒ•гӮҢгҒҰгҒ„гӮӢе ҙеҗҲгҒҜиҮӘеҲҶе®ӣгҒ®гҒҝйҖҡзҹҘпјҲжңӘжҢҮе®ҡгҒ®е ҙеҗҲгҒҜе…Ёе“ЎгҒ«йҖҡзҹҘпјү
            if(t.assignee && t.assignee !== currentUserName) continue;

            // гӮ№гғҢгғјгӮәдёӯгҒӢгғҒгӮ§гғғгӮҜпјҲIDгғҷгғјгӮ№гҒ§з®ЎзҗҶпјү
            if(snoozeList[t.id] && now.getTime() < snoozeList[t.id]) continue;

            // deadline "M/D H:M" гҒҫгҒҹгҒҜ "M/D"
            var parts = t.deadline.match(/([0-9]{1,2})\/([0-9]{1,2})(\s[0-9]{1,2}:[0-9]{1,2})?/);
            if(!parts) continue;
            
            var due = new Date();
            due.setMonth(parseInt(parts[1], 10) - 1);
            due.setDate(parseInt(parts[2], 10));
            if(parts[3]) {
                var tm = parts[3].trim().split(":");
                due.setHours(parseInt(tm[0], 10), parseInt(tm[1], 10), 0, 0);
            } else {
                due.setHours(23, 59, 59, 999);
            }
            
            var diffMin = (due.getTime() - now.getTime()) / (1000 * 60);
            // жңҹйҷҗеҶ…гҒӢгҒӨгғӘгғһгӮӨгғігғүеҲҶд»ҘеҶ…гҖҒгҒҫгҒҹгҒҜжңҹйҷҗи¶…йҒҺгҒ§24жҷӮй–“д»ҘеҶ…гҒ®е ҙеҗҲ
            if((diffMin > 0 && diffMin <= t.reminderOffset) || (diffMin < 0 && diffMin >= -1440)) {
                var overduePrefix = diffMin < 0 ? "гҖҗи¶…йҒҺгҖ‘" : "гҖҗжңҹйҷҗй–“иҝ‘гҖ‘";
                if(confirm(overduePrefix + "гҒ®гӮҝгӮ№гӮҜ\n" + t.text + "\nжңҹйҷҗ: " + t.deadline + "\n\nгҖҢOKгҖҚгҒ§дәҶи§ЈпјҲйҖҡзҹҘеҒңжӯўпјү\nгҖҢгӮӯгғЈгғігӮ»гғ«гҖҚгҒ§10еҲҶеҫҢгҒ«еҶҚйҖҡзҹҘ")) {
                    t.alerted = true; // дәҶи§Ј
                    delete snoozeList[t.id];
                    
                    // вҳ…дҝ®жӯЈпјҡгҒ®йҒ…е»¶гӮ’иЁұгҒ•гҒҡгҖҒгӮўгғ©гғјгғҲзӣҙеҫҢгҒ«еј·еҲ¶еҚіжҷӮдҝқеӯҳпјҒ
                    saveData(false); 
                    
                } else {
                    // гӮ№гғҢгғјгӮәиЁӯе®ҡпјҲ10еҲҶеҫҢпјү
                    snoozeList[t.id] = now.getTime() + (10 * 60 * 1000);
                }
            }
        }
        
        // --- е®ҢдәҶйҖҡзҹҘгғӯгӮёгғғгӮҜ ---
        for(var i=0; i<appData.todos.length; i++) {
            var t = appData.todos[i];
            // гҖҢиҮӘеҲҶгҒҢдҪңжҲҗиҖ… or жӢ…еҪ“иҖ…гҖҚгҒӢгҒӨгҖҢе®ҢдәҶжёҲгҒҝгҖҚгҒӢгҒӨгҖҢйҖҡзҹҘеёҢжңӣгҖҚгҒӢгҒӨгҖҢжңӘйҖҡзҹҘгҖҚгҒӢгҒӨгҖҢеүҠйҷӨ/гӮўгғјгӮ«гӮӨгғ–гҒ§гҒӘгҒ„гҖҚ
            var isMyTodo = (t.author === currentUserName) || (t.assignee === currentUserName);
            if(isMyTodo && t.done && !t.deleted && !t.archived && t.notifyOnDone && !t.doneAlerted) {
                alert("гҖҗгӮҝгӮ№гӮҜе®ҢдәҶгҒ®гҒҠзҹҘгӮүгҒӣгҖ‘\n\nгҖҢ" + t.text + "гҖҚ\nгҒҢе®ҢдәҶгҒ•гӮҢгҒҫгҒ—гҒҹгҖӮ");
                t.doneAlerted = true;
                
                // вҳ…дҝ®жӯЈпјҡгҒ®йҒ…е»¶гӮ’иЁұгҒ•гҒҡгҖҒгӮўгғ©гғјгғҲзӣҙеҫҢгҒ«еј·еҲ¶еҚіжҷӮдҝқеӯҳпјҒ
                saveData(false);
            }
        }
    }, 60000);
}

// иҮӘз”ұе…ҘеҠӣгҒ®жңҹйҷҗгғҶгӮӯгӮ№гғҲгҒӢгӮүгҖҢеҪ“ж—ҘгҒӢгҖҚгҖҢжңҹйҷҗеҲҮгӮҢгҒӢгҖҚгӮ’еҲӨе®ҡгҒҷгӮӢгғҳгғ«гғ‘гғј
function parseTodoDate(deadlineStr) {
    if (!deadlineStr || deadlineStr.trim() === "") return { isToday: false, isOverdue: false };
    
    var now = new Date();
    // еҪўејҸгҒҜ "1/5", "1/5 15:00" гҒӘгҒ©
    var m = deadlineStr.match(/^([0-9]{1,2})\/([0-9]{1,2})/);
    if (!m) {
        if (deadlineStr.match(/^([0-9]{1,2}):([0-9]{1,2})$/)) return { isToday: true, isOverdue: false };
        return { isToday: false, isOverdue: false };
    }
    
    var targetMonth = parseInt(m[1], 10);
    var targetDate = parseInt(m[2], 10);
    var curMonth = now.getMonth() + 1;
    var curDate = now.getDate();
    
    if (targetMonth === curMonth && targetDate === curDate) return { isToday: true, isOverdue: false };
    
    if (targetMonth < curMonth || (targetMonth === curMonth && targetDate < curDate)) {
        if (curMonth - targetMonth === -11) return { isToday: false, isOverdue: false }; // жқҘе№ҙ1жңҲ
        return { isToday: false, isOverdue: true };
    }
    
    if (targetMonth - curMonth === 11) return { isToday: false, isOverdue: true }; // еҺ»е№ҙ12жңҲ
    return { isToday: false, isOverdue: false };
}

// --- ToDoгҒ®гӮ«гӮ№гӮҝгғ гӮ«гғ¬гғігғҖгғјUI ---
var pendingDeadline = "";

// гӮ«гғ¬гғігғҖгғјиЎЁзӨәжңҲз®ЎзҗҶз”Ё
var calCurrentYear = new Date().getFullYear();
var calCurrentMonth = new Date().getMonth() + 1; // 1-12
var calSelectedDate = null; // йҒёжҠһдёӯгҒ®ж—Ҙ (1-31)
var calSelectedMonth = null;
var calSelectedYear = null;

// жңҹйҷҗиЁӯе®ҡз”ЁгӮ«гғ¬гғігғҖгғјгҒ®иө·еӢ•
function openCustomDatePicker(btn) {
    // з·ЁйӣҶгғўгғјгғүгҒ§гҒӘгҒ‘гӮҢгҒ°дҪ•гӮӮгҒ—гҒӘгҒ„
    if(!isEditMode) return;
    
    // TodoUIгҒҢеӯҳеңЁгҒҷгӮӢе ҙеҗҲгҖҒзҸҫеңЁгҒ®жңҹйҷҗгӮ’гӮ«гғ¬гғігғҖгғјгҒ®зҠ¶ж…ӢгҒ«еҸҚжҳ гҒ•гҒӣгӮӢпјҲеҗҢжңҹпјү
    if(typeof TodoUI !== "undefined" && TodoUI.getPendingDeadline) {
        pendingDeadline = TodoUI.getPendingDeadline();
    }
    
    var div = document.getElementById("custom-datepicker");
    if(!div) {
        div = document.createElement("div");
        div.id = "custom-datepicker";
        // з”»йқўдёӯеӨ®гҒ«еӣәе®ҡй…ҚзҪ®пјҲгғўгғјгғҖгғ«йўЁпјүгҖҒе№…гӮ’иҰӢеҲҮгӮҢгҒӘгҒ„гӮҲгҒҶгҒ« 300px гҒ«жӢЎејө
        div.style.cssText = "position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); background:#fff; border:1px solid #999; padding:15px; z-index:9999; box-shadow:0 10px 25px rgba(0,0,0,0.5); font-size:13px; font-family:sans-serif; width:300px; border-radius:8px;";
        document.body.appendChild(div);
    }
    
    // зҸҫеңЁгҒ®е…ҘеҠӣгҒӢгӮүжңҲгғ»ж—ҘгӮ’еҸ–еҫ—гҒҷгӮӢпјҲгҒӮгӮҢгҒ°пјү
    calSelectedYear = new Date().getFullYear();
    if(pendingDeadline) {
        var m = pendingDeadline.match(/([0-9]{1,2})\/([0-9]{1,2})/);
        if(m) {
            calCurrentMonth = parseInt(m[1], 10);
            calSelectedMonth = calCurrentMonth;
            calSelectedDate = parseInt(m[2], 10);
        }
    } else {
        calCurrentYear = new Date().getFullYear();
        calCurrentMonth = new Date().getMonth() + 1;
        calSelectedMonth = null;
        calSelectedDate = null;
    }
    
    renderCustomCalendarHTML();
    div.style.display = "block";
}

function changeCalMonth(diff) {
    calCurrentMonth += diff;
    if(calCurrentMonth > 12) { calCurrentMonth = 1; calCurrentYear++; }
    else if(calCurrentMonth < 1) { calCurrentMonth = 12; calCurrentYear--; }
    renderCustomCalendarHTML();
}



function clickCalDate(m, d) {
    calSelectedMonth = m;
    calSelectedDate = d;
    renderCustomCalendarHTML();
}

function clearCalDate() {
    pendingDeadline = "";
    calSelectedMonth = null;
    calSelectedDate = null;
    var tSel = document.getElementById("cal-time");
    if(tSel) tSel.value = "";
    commitCalDate();
}

function commitCalDate() {
    if (calSelectedMonth !== null && calSelectedDate !== null) {
        var tSel = document.getElementById("cal-time");
        var tStr = (tSel && tSel.value !== "") ? " " + tSel.value : "";
        pendingDeadline = calSelectedMonth + "/" + calSelectedDate + tStr;
    } else if (pendingDeadline === "") {
        pendingDeadline = "";
    }
    
    // TodoUIгҒёжңҹйҷҗгӮ’еҗҢжңҹ
    if(typeof TodoUI !== "undefined" && TodoUI.setPendingDeadline) {
        TodoUI.setPendingDeadline(pendingDeadline);
    }
    
    var lbl = document.getElementById("lbl-todo-deadline");
    if(pendingDeadline !== "") {
        lbl.innerText = "[" + pendingDeadline + "]";
        lbl.style.display = "inline";
    } else {
        lbl.style.display = "none";
        lbl.innerText = "";
    }
    
    var div = document.getElementById("custom-datepicker");
    if(div) div.style.display = "none";
}

var editingTodoIndex = null;
function addNewTodoUI() {
    if (typeof TodoUI !== "undefined") {
        TodoUI.addNewTodoUI();
    }
}

function addTodo() {
    if (typeof TodoUI !== "undefined") {
        TodoUI.addTodo();
    }
}

function toggleTodo(index) {
    if (typeof TodoUI !== "undefined") {
        TodoUI.toggleDone(index);
    }
}

function deleteTodo(index) {
    if (typeof TodoUI !== "undefined") {
        TodoUI.deleteTodo(index);
    }
}

function editTodo(index) {
    if (typeof TodoUI !== "undefined") {
        TodoUI.editTodo(index);
    }
}

function cancelEditTodo() {
    if (typeof TodoUI !== "undefined") {
        TodoUI.cancelEditTodo();
    }
}

function restoreTodo(index) {
    if (typeof TodoUI !== "undefined") {
        TodoUI.restoreTodo(index);
    }
}

function hardDeleteTodo(index) {
    if (typeof TodoUI !== "undefined") {
        TodoUI.deleteTodo(index); // TodoUIеҒҙгҒ§гҒҜ delete гҒҢ soft/hard гӮ’еҗёеҸҺгҒҷгӮӢгӮҲгҒҶгҒ«е®ҹиЈ…
    }
}

// ---------- е…ҘйҖҖе®ӨеұҘжӯҙиЎЁзӨә ----------
function renderHistory() {
    var tbody = document.getElementById("tbody-history");
    if(!appData.history || appData.history.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" align="center">гҒҫгҒ еұҘжӯҙгҒҜгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ</td></tr>';
        return;
    }

    // вҳ…иҝҪеҠ : еұҘжӯҙгҒ«гҒӮгӮӢз—…жЈҹгӮ’жҠҪеҮәгҒ—гҒҰгғ—гғ«гғҖгӮҰгғігғЎгғӢгғҘгғјгӮ’еӢ•зҡ„гҒ«з”ҹжҲҗгҒҷгӮӢ
    var selWard = document.getElementById("sel-history-ward");
    if (selWard) {
        var curVal = selWard.value;
        var wards = {};
        for(var w = 0; w < appData.history.length; w++) {
            if(appData.history[w].ward) wards[appData.history[w].ward] = true;
        }
        var selHtml = '<option value="">е…Ёз—…жЈҹ</option>';
        var sortedWards = [];
        for(var wKey in wards) { if(wards.hasOwnProperty(wKey)) sortedWards.push(wKey); }
        sortedWards.sort();
        for(var sw = 0; sw < sortedWards.length; sw++) {
            var selected = (sortedWards[sw] === curVal) ? " selected" : "";
            selHtml += '<option value="' + escapeHtml(sortedWards[sw]) + '"' + selected + '>' + escapeHtml(sortedWards[sw]) + '</option>';
        }
        selWard.innerHTML = selHtml;
    }

    var html = "";
    for(var i=0; i<appData.history.length; i++) {
        var h = appData.history[i];
        var pId = h.id || "";
        var pName = h.patient || "";
        if (!pId && pName) {
            var match = pName.match(/^(.*?)\s*\(\s*([0-9a-zA-Z\-]+)\s*\)$/);
            if (match) { pName = match[1]; pId = match[2]; }
        }

        var isArrival = h.type.indexOf("йҖҖе®Ө") === -1 && h.type.indexOf("йҖҖйҒҝ") === -1;
        var typeStyle = isArrival ? "color: #155724; background-color: #d4edda; font-weight:bold;" : "color: #721c24; background-color: #f8d7da;";

        var clickAction = '';
        var titleText = '';
        var linkStyle = 'color: #0d6efd; text-decoration: underline; cursor: pointer;';

        if (isArrival) {
            clickAction = 'onclick="jumpToPatient(\'' + escapeHtml(pId) + '\', \'' + escapeHtml(pName) + '\')"';
            titleText = 'гӮҜгғӘгғғгӮҜгҒ—гҒҰжӮЈиҖ…дёҖиҰ§гҒ®зҸҫеңЁгҒ®иЎҢгҒёгӮёгғЈгғігғ—';
        } else {
            clickAction = 'onclick="toggleHistoryDetail(\'' + escapeHtml(pId) + '\', ' + i + ')"';
            titleText = 'гӮҜгғӘгғғгӮҜгҒ—гҒҰйҖҖйҷўжҷӮгҒ®гғЎгғўгӮ„гӮ№гғҶгғјгӮҝгӮ№гӮ’иЎЁзӨә';
            linkStyle = 'color: #c62828; text-decoration: underline; cursor: pointer; font-weight:bold;';
        }

        html += '<tr id="tr-history-' + i + '">';
        html += '<td style="font-size:11px; color:#555;">' + escapeHtml(h.date) + '</td>';
        html += '<td style="font-size:11px;">' + (h.ward ? escapeHtml(h.ward) : '') + '</td>';
        html += '<td align="center" style="font-size:11px; padding:2px;' + typeStyle + '">' + escapeHtml(h.type) + '</td>';
        html += '<td><span ' + clickAction + ' style="' + linkStyle + '" title="' + titleText + '">' + escapeHtml(pId) + '</span></td>';
        html += '<td><span ' + clickAction + ' style="' + linkStyle + '" title="' + titleText + '">' + escapeHtml(pName) + '</span></td>';
        html += '<td style="font-size:11px;">' + escapeHtml(h.dept || "-") + '</td>';
        html += '<td style="font-size:11px;">' + escapeHtml(h.doctor || "-") + '</td>';
        html += '<td style="font-size:11px;">' + escapeHtml(h.disease || "-") + '</td>';
        html += '</tr>';
        html += '<tr id="tr-history-detail-' + i + '" style="display:none; background:#fffaf0;"><td colspan="8" id="td-history-detail-' + i + '" style="padding:10px; border:1px solid #ffd54f;"></td></tr>';
    }
    tbody.innerHTML = html;
    filterHistoryTable();
}

function filterHistoryTable() {
    var wardFilter = document.getElementById("sel-history-ward") ? document.getElementById("sel-history-ward").value : "";
    var searchInput = document.getElementById("ipt-history-search");
    var filter = searchInput ? searchInput.value.toLowerCase() : "";
    var tbody = document.getElementById("tbody-history");
    if (!tbody) return;
    var tr = tbody.getElementsByTagName("tr");

    for (var i = 0; i < tr.length; i++) {
        var row = tr[i];
        if (row.id && row.id.indexOf("tr-history-detail-") === 0) continue; // и©ізҙ°иЎҢгҒҜйЈӣгҒ°гҒҷ
        
        var wardText = row.cells[1] ? (row.cells[1].textContent || row.cells[1].innerText || "") : "";
        var contentText = (row.textContent || row.innerText || "").toLowerCase();

        var matchWard = (wardFilter === "" || wardText === wardFilter);
        var matchSearch = (filter === "" || contentText.indexOf(filter) > -1);

        if (matchWard && matchSearch) {
            row.style.display = "";
        } else {
            row.style.display = "none";
            // еҜҫеҝңгҒҷгӮӢи©ізҙ°иЎҢгӮӮйҡ гҒҷ
            var detailRow = document.getElementById("tr-history-detail-" + row.id.replace("tr-history-", ""));
            if (detailRow) detailRow.style.display = "none";
        }
    }
}

function filterKarteLinkTable() {
    var input = document.getElementById("ipt-kartelink-search");
    if (!input) return;
    var filter = input.value.toLowerCase();
    var tbody = document.getElementById("tbody-kartelink");
    if (!tbody) return;
    var tr = tbody.getElementsByTagName("tr");

    for (var i = 0; i < tr.length; i++) {
        var row = tr[i];
        if (row.cells.length < 5) continue; // гғЎгғғгӮ»гғјгӮёиЎҢгҒӘгҒ©гӮ’йҷӨеӨ–
        
        var text = (row.textContent || row.innerText || "").toLowerCase();
        if (text.indexOf(filter) > -1) {
            row.style.display = "";
        } else {
            row.style.display = "none";
        }
    }
}


function toggleHistoryDetail(pId, rowIndex) {
    var detailRow = document.getElementById("tr-history-detail-" + rowIndex);
    var detailCell = document.getElementById("td-history-detail-" + rowIndex);
    if (!detailRow || !detailCell) return;
    if (detailRow.style.display !== "none") {
        detailRow.style.display = "none";
        return;
    }

    var hItem = appData.history[rowIndex];
    var p = findPatientById(pId);
    var arc = p || {};
    
    var status = arc.status || 0;
    var statClass = STATUS_CLASSES[status];
    var statText = STATUS_TEXTS[status];
    if(statText === "(жңӘиЁӯе®ҡ)") statText = "жңӘ";
    else if(statText === "д»Ӣе…ҘдәҲе®ҡ") statText = "дәҲе®ҡ";
    else if(statText === "жҢҮе°ҺжёҲ") statText = "жҢҮе°Һ";
    else if(statText === "иЁҳйҢІжёҲ") statText = "иЁҳйҢІ";

    var chkVal = arc.chkPrescription || 0;
    if (typeof chkVal === "boolean") chkVal = chkVal ? 2 : 0;
    var chkText = (chkVal === 1) ? "в–і" : (chkVal === 2 ? "вң“" : "-");
    var chkStyle = (chkVal === 1) ? "color:#e67e22;" : (chkVal === 2 ? "color:#27ae60; font-weight:bold;" : "color:#999;");

    var aLevel = arc.alertLevel || 0;
    var aText = aLevel === 0 ? "" : aLevel === 1 ? "?" : "!";
    var aClass = aLevel === 0 ? "" : aLevel === 1 ? "alert-caution" : "alert-urgent";

    var h = [];
    h.push('<div style="padding:5px; background:#fff;">');
    h.push('<table id="tbl-history-detail-sub" style="width:100%; border-collapse:collapse; font-size:12px; border:1px solid #ddd;">');
    h.push('  <thead><tr style="background:#e3f2fd;">');
    h.push('    <th width="60">жӮЈиҖ…ID</th><th width="110">ж°ҸеҗҚ</th><th width="70">иЁәзҷӮз§‘</th><th width="70">дё»жІ»еҢ»</th><th width="120">дё»з—…еҗҚ</th>');
    h.push('    <th width="35">еңЁйҷў</th><th width="65">жҺЎиЎҖж—Ҙ</th><th width="35">д»Ӣе…Ҙ</th><th width="35">еҮҰж–№</th><th width="35">еј·иӘҝ</th><th width="auto">жғ…е ұе…ұжңүгғ»гғЎгғў</th>');
    h.push('  </tr></thead>');
    h.push('  <tbody><tr>');
    h.push('    <td align="center">' + escapeHtml(pId) + '</td>');
    h.push('    <td>' + escapeHtml(hItem.patient || "") + '</td>');
    h.push('    <td>' + escapeHtml(hItem.dept || "-") + '</td>');
    h.push('    <td>' + escapeHtml(hItem.doctor || "-") + '</td>');
    h.push('    <td>' + escapeHtml(hItem.disease || "-") + '</td>');
    h.push('    <td align="center">-</td>');
    h.push('    <td align="center" style="font-size:11px;">' + escapeHtml(arc.bloodDate || "-") + '</td>');
    h.push('    <td class="status-cell ' + statClass + '" align="center" style="font-weight:bold; height:30px;">' + statText + '</td>');
    h.push('    <td align="center" style="font-size:16px; ' + chkStyle + '">' + chkText + '</td>');
    h.push('    <td align="center" style="color:#e74c3c; font-size:14px; font-weight:bold;" class="alert-toggle ' + aClass + '">' + escapeHtml(aText) + '</td>');
    
    var memoDisabled = isEditMode ? "" : "disabled";
    var memoChange = isEditMode ? 'onchange="updateHistoryMemo(\'' + escapeHtml(pId) + '\', this.value)" onkeyup="showTagSuggest(this, event);"' : "";
    h.push('    <td><textarea ' + memoDisabled + ' ' + memoChange + ' style="width:100%; height:40px; font-size:11px; padding:2px; border:1px solid #ddd; background:#f9f9f9;" placeholder="гғЎгғўгӮ’е…ҘеҠӣ...">' + escapeHtml(arc.memo || "") + '</textarea></td>');
    h.push('  </tr></tbody>');
    h.push('</table>');

    var pMemos = arc ? (arc.personalMemos || {}) : {};
    var myMemo = pMemos[currentSystemId] || "";
    
    h.push('<div style="margin-top:8px; display:flex; align-items:flex-start; gap:10px;">');
    h.push('  <span style="font-size:11px; font-weight:bold; color:#0d6efd; background:#e1f5fe; padding:2px 6px; border-radius:3px;">еҖӢдәәгғЎгғў</span>');
    var pMemoDisabled = isEditMode ? "" : "disabled";
    // вҳ…дҝ®жӯЈ: onchange="finalizePersonalMemo(...)" гӮ’иҝҪеҠ гҒ—гҒҰгҖҒе…ҘеҠӣе®ҢдәҶжҷӮгҒ«зўәе®ҹгҒ«дҝқеӯҳгҒЁдјқзҘЁзҷәиЎҢгӮ’иЎҢгӮҸгҒӣгӮӢ
    var pMemoChange = isEditMode ? 'onchange="finalizePersonalMemo(\'' + escapeHtml(pId) + '\', this)" onkeyup="updatePersonalMemoDebounced(\'' + escapeHtml(pId) + '\', this.value, this); showTagSuggest(this, event);"' : "";
    h.push('  <div style="flex:1;">');
    h.push('    <textarea ' + pMemoDisabled + ' ' + pMemoChange + ' style="width:100%; height:40px; font-size:11px; padding:2px; border:1px dashed #b3d7ff; background:#f0fbff;" placeholder="иҮӘеҲҶе°Ӯз”ЁгҒ®гғЎгғўгӮ’е…ҘеҠӣ...">' + escapeHtml(myMemo) + '</textarea>');
    h.push('  </div>');
    h.push('</div>');
    if (!p) {
        h.push('<div style="margin-top:8px; font-size:10px; color:#c62828; text-align:right;">вҡ  еҜҫеҝңгҒҷгӮӢжӮЈиҖ…гғ¬гӮігғјгғүгҒҢиҰӢгҒӨгҒӢгӮүгҒӘгҒ„гҒҹгӮҒгҖҒж–°иҰҸгӮўгғјгӮ«гӮӨгғ–гҒЁгҒ—гҒҰдҝқеӯҳгҒ•гӮҢгҒҫгҒҷгҖӮ</div>');
    }
    h.push('</div>');
    
    detailCell.innerHTML = h.join('');
    detailRow.style.display = "table-row";
}

function updateHistoryMemo(pId, newVal) {
    var arc = findPatientById(pId);
    // иҰӢгҒӨгҒӢгӮүгҒӘгҒ„е ҙеҗҲгҒҜйҖҖйҷўгӮўгғјгӮ«гӮӨгғ–еҒҙгҒ«дҪңжҲҗ
    if (!arc) {
        if (!appData.dischargedArchive || (appData.dischargedArchive instanceof Array)) {
            appData.dischargedArchive = {};
        }
        if (!appData.dischargedArchive[pId]) {
            appData.dischargedArchive[pId] = { id: pId, archivedAt: new Date().getTime(), memoAuthors: [] };
        }
        arc = appData.dischargedArchive[pId];
    }
    arc.memo = newVal;
    // з·ЁйӣҶиҖ…гғӘгӮ№гғҲгҒ®жӣҙж–° (йҮҚиӨҮйҳІжӯў)
    if (!arc.memoAuthors) arc.memoAuthors = [];
    var found = false;
    for (var i = 0; i < arc.memoAuthors.length; i++) {
        if (arc.memoAuthors[i] === currentUserName) { found = true;
            break; }
    }
    if (!found) arc.memoAuthors.push(currentUserName);
    
    // вҳ…иҝҪеҠ : йҖҖе®ӨжӮЈиҖ…гҒ®гғЎгғўгҒ§гӮӮзўәе®ҹгҒ«дјқзҘЁпјҲгғҲгғ©гғігӮ¶гӮҜгӮ·гғ§гғіпјүгӮ’зҷәиЎҢгҒҷгӮӢ
    if (typeof DataManager !== "undefined") {
        DataManager.appendTransaction("UPDATE_PATIENT_MEMO", {
            patientId: pId, wardCode: currentWard, value: newVal
        });
    }

}

// ---------- гғҲгғ©гғігӮ¶гӮҜгӮ·гғ§гғіеұҘжӯҙгҒӢгӮүгҒ®з·ҠжҖҘеҫ©е…ғгғӯгӮёгғғгӮҜ (Vol.15) ----------
function recoverFromTransactions() {
    if(!fso) return;
    var txDir = getTxDir();
    if(!fso.FolderExists(txDir)) {
        alert("гғҲгғ©гғігӮ¶гӮҜгӮ·гғ§гғігғ•гӮ©гғ«гғҖ(data/tx)гҒҢиҰӢгҒӨгҒӢгӮҠгҒҫгҒӣгӮ“гҖӮеҫ©е…ғгҒ§гҒҚгӮӢгғҮгғјгӮҝгҒҢгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ");
        return;
    }

    var folder = fso.GetFolder(txDir);
    var fileEnum = new Enumerator(folder.Files);
    var txFiles = [];
    for (; !fileEnum.atEnd(); fileEnum.moveNext()) {
        var file = fileEnum.item();
        if (file.Name.match(/^tx_.*\.json$/i)) { txFiles.push(file); }
    }
    
    if(txFiles.length === 0) {
        alert("еҫ©е…ғеҜҫиұЎгҒ®гғҲгғ©гғігӮ¶гӮҜгӮ·гғ§гғігғ•гӮЎгӮӨгғ«гҒҢгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ");
        return;
    }

    // еҸӨгҒ„й ҶгҒ«гӮҪгғјгғҲгҒ—гҒҰгҖҒй Ҷж¬ЎгғһгғјгӮёгҒ—гҒҰгҒ„гҒҸ
    txFiles.sort(function(a, b) { return a.Name.localeCompare(b.Name); });

    var recoveredData = null;
    var count = 0;

    for (var i = 0; i < txFiles.length; i++) {
        try {
            var txStr = loadTextUtf8(txFiles[i].Path);
            var txObj = parseData(txStr);
            if (txObj && txObj.base && txObj.my) {
                if (!recoveredData) {
                    recoveredData = txObj.my;
                } else {
                    recoveredData = perform3WayMerge(txObj.base, recoveredData, txObj.my);
                }
                count++;
            }
        } catch(e) {}
    }

    if(recoveredData) {
        appData = recoveredData;
        window.baseAppDataStr = stringifyData(appData);
        window.lastLoadedDataStr = window.baseAppDataStr;
        
        applyWardTabs();
        renderPatients();
        renderPatients();
        if (typeof TodoUI !== "undefined" && document.getElementById("tab-todo").className.indexOf("active") !== -1) {
            TodoUI.render();
        }
        renderHistory();
        
        alert("гҖҗеҫ©е…ғе®ҢдәҶгҖ‘\n" + count + "д»¶гҒ®гғҲгғ©гғігӮ¶гӮҜгӮ·гғ§гғігҒӢгӮүжңҖж–°зҠ¶ж…ӢгӮ’еҶҚж§ӢзҜүгҒ—гҒҫгҒ—гҒҹгҖӮ\n\nвҖ»гҒ“гҒ®жҷӮзӮ№гҒ§гҒҜгҒҫгҒ гӮөгғјгғҗгғјгҒ«дҝқеӯҳгҒ•гӮҢгҒҰгҒ„гҒҫгҒӣгӮ“гҖӮеҶ…е®№гӮ’зўәиӘҚгҒ®дёҠгҖҒжүӢеӢ•гҒ§гҖҢдҝқеӯҳ(гғһгғјгӮёеҸҚжҳ )гҖҚгӮ’жҠјгҒ—гҒҰгғһгӮ№гӮҝгғ•гӮЎгӮӨгғ«гӮ’еҶҚдҪңжҲҗгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ");
        
        var elLocalTime = document.getElementById("last-local-update-time");
        if(elLocalTime) elLocalTime.innerText = "гҖҗпјҒеҫ©е…ғгғҮгғјгӮҝиЎЁзӨәдёӯпјҒгҖ‘";
    } else {
        alert("гғҮгғјгӮҝгҒ®еҫ©е…ғгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹгҖӮгғ•гӮЎгӮӨгғ«гҒҢз©әгҒӢз ҙжҗҚгҒ—гҒҰгҒ„гҒҫгҒҷгҖӮ");
    }
}


// ---------- ExcelеҮәеҠӣж©ҹиғҪ ----------
// ---------- ExcelеҮәеҠӣж©ҹиғҪ (Vol.15.xжӢЎејөзүҲ) ----------
function exportToExcel() {
    try {
        var table = document.getElementById("tbl-patients");
        if(!table) return;
        
        var cloneTable = table.cloneNode(true);
        var tds = cloneTable.getElementsByTagName("td");
        
        var highlightColor = "#ffe8a1";
        
        for(var i=0; i<tds.length; i++) {
            var cell = tds[i];
            
            // ExcelгҒ§ж–Үеӯ—гҒҢе°ҸгҒ•гҒҸгҒӘгӮӢгҒ®гӮ’йҳІгҒҗгҒҹгӮҒгҖҒгӮӨгғігғ©гӮӨгғігҒ®font-sizeгӮ’йҷӨеҺ»
            cell.style.fontSize = "";
            
            // гӮӨгғігғ©гӮӨгғіиғҢжҷҜиүІгҒ®еҫ©е…ғпјҲExcelгҒҜCSSгӮҜгғ©гӮ№гҒ®иғҢжҷҜиүІгӮ’иӘӯгҒҝиҫјгҒҫгҒӘгҒ„гҒҹгӮҒзӣҙжҺҘгғҷгӮҝжӣёгҒҚгҒҷгӮӢпјү
            if (hasClass(cell, "highlight-row") || (cell.parentNode && hasClass(cell.parentNode, "highlight-row"))) {
                cell.style.backgroundColor = highlightColor;
            } else if (hasClass(cell, "status-done")) {
                cell.style.backgroundColor = "#d4edda";
            } else if (hasClass(cell, "status-plan")) {
                cell.style.backgroundColor = "#fff3cd";
            } else if (hasClass(cell, "status-recorded")) { // гҖҢиЁҳйҢІжёҲгҖҚгҒ®йқ’иүІгӮ’иҝҪеҠ 
                cell.style.backgroundColor = "#cce5ff";
            }
            
            // еҮҰж–№зўәиӘҚеҲ— (chk-toggle) гҒ«гӮӨгғігғ©гӮӨгғігҒ§иЁӯе®ҡгҒ•гӮҢгҒҹиғҢжҷҜиүІ (chkBg) гӮ’ExcelеҮәеҠӣжҷӮгҒҜгӮҜгғӘгӮўгҒҷгӮӢ
            if (hasClass(cell, "chk-toggle")) {
                cell.style.backgroundColor = "";
                removeClass(cell, "hide-on-print");
            }
            
// вҳ…дҝ®жӯЈ: Textarea(з·ЁйӣҶз”Ё)гҒҜеүҠйҷӨгҒ—гҖҒиЎЁзӨәз”ЁгҒ® memo-display гӮ’гҒқгҒ®гҒҫгҒҫжҙ»гҒӢгҒҷ
            var tas = cell.getElementsByTagName("textarea");
            while(tas.length > 0) {
                tas[0].parentNode.removeChild(tas[0]);
            }
            
            // гғҸгӮӨгғ©гӮӨгғҲиЎҢгҒ®иғҢжҷҜиүІгӮ’иЎЁзӨәз”ЁгғЎгғўгҒ«гӮӮйҒ©з”ЁгҒҷгӮӢ
            var displays = cell.querySelectorAll('.memo-display');
            for(var d=0; d<displays.length; d++){
                if (displays[d].style.backgroundColor === "" && cell.style.backgroundColor !== "") {
                    displays[d].style.backgroundColor = cell.style.backgroundColor;
                }
            }
        }
        
        // гғңгӮҝгғізӯүгҒ®дёҚиҰҒиҰҒзҙ йҷӨеҺ»
        // вҳ…дҝ®жӯЈ: еҖӢдәәгғЎгғўгҒ®гғ©гғғгғ‘гғј(.memo-wrap)гҒҢеҚ°еҲ·йҷӨеӨ–гӮҜгғ©гӮ№гҒ§ж¶ҲгҒ•гӮҢгҒӘгҒ„гӮҲгҒҶгҒ«йҷӨеӨ–жҢҮе®ҡгӮ’иҝҪеҠ 
        var hideElems = cloneTable.querySelectorAll('.hide-on-print:not(.chk-toggle):not(.memo-wrap), .sort-icon, .karte-btn, .tab-close-btn');
        for(var i = 0; i < hideElems.length; i++) {
            if (hideElems[i].parentNode) hideElems[i].parentNode.removeChild(hideElems[i]);
        }

        // гғҶгӮ№гғҲжӮЈиҖ…гҒ®иЎҢгӮ’ExcelеҮәеҠӣгҒӢгӮүйҷӨеӨ–гҒҷгӮӢеҮҰзҗҶ
        var rows = cloneTable.getElementsByTagName("tr");
        // зү№е®ҡгҒ®гғҶгӮ№гғҲжӮЈиҖ…IDгғӘгӮ№гғҲпјҲгӮ«гғігғһеҢәеҲҮгӮҠгҒ§иҝҪеҠ еҸҜиғҪпјү
        var testIds = ["9999999", "8888888", "1234567"]; 
        // дёӢгҒӢгӮүгғ«гғјгғ—гҒ—гҒҰе®үе…ЁгҒ«еүҠйҷӨ
        for (var r = rows.length - 1; r >= 1; r--) {
            var tr = rows[r];
            var cells = tr.getElementsByTagName("td");
            if (cells.length > 1) {
                var pid = (cells[0].innerText || cells[0].textContent || "").trim();
                var pname = (cells[1].innerText || cells[1].textContent || "").trim();
                var pidNum = parseInt(pid, 10);
                
                // еҗҚеүҚгҒҢгҖҢгғҶгӮ№гғҲгҖҚгҖҢгҒҰгҒҷгҒЁгҖҚгҖҢtestгҖҚгӮ’еҗ«гӮҖгҒӢгҖҒIDгҒҢгғӘгӮ№гғҲеҶ…гҒҫгҒҹгҒҜ9000000д»ҘдёҠгҒ®е ҙеҗҲгҒҜиЎҢгҒ”гҒЁеүҠйҷӨ
                if (pname.indexOf("гғҶгӮ№гғҲ") !== -1 || pname.indexOf("гҒҰгҒҷгҒЁ") !== -1 || pname.toLowerCase().indexOf("test") !== -1 || testIds.indexOf(pid) !== -1 || (!isNaN(pidNum) && pidNum >= 9000000)) {
                    if (tr.parentNode) tr.parentNode.removeChild(tr);
                }
            }
        }
        
        var outputHTML = "<table border='1'>" + cloneTable.innerHTML + "</table>";
        window.clipboardData.setData("Text", outputHTML);
        
        var excelApp = new ActiveXObject("Excel.Application");
        if(!excelApp) { alert("ExcelгҒ®иө·еӢ•гҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹгҖӮ"); return; }
        
        var workbook = excelApp.Workbooks.Add();
        var sheet = workbook.ActiveSheet;
        sheet.Paste();
        
        sheet.Cells.WrapText = true;
        sheet.Cells.VerticalAlignment = -4160; // xlTop
        
        var lastCol = sheet.UsedRange.Columns.Count;
        for (var c = 1; c <= lastCol; c++) {
            var head = sheet.Cells(1, c).Value;
            if (head === "жӮЈиҖ…ID" || head === "ID") sheet.Columns(c).ColumnWidth = 9.4;
            else if (head === "ж°ҸеҗҚ") {
                sheet.Columns(c).ColumnWidth = 17.5;
                // гғҮгғјгӮҝиЎҢгҒ®ж°ҸеҗҚгҒ®гҒҝгғ•гӮ©гғігғҲгӮ’еӨ§гҒҚгҒҸгҒҷгӮӢ
                var lastRow = sheet.UsedRange.Rows.Count;
                sheet.Range(sheet.Cells(2, c), sheet.Cells(lastRow, c)).Font.Size = 14; 
            }
            else if (head && head.indexOf("иЁәзҷӮз§‘") !== -1) sheet.Columns(c).ColumnWidth = 13.0; // 2ж®өзөҗеҗҲеҲ—з”Ё
            else if (head === "дё»з—…еҗҚ") sheet.Columns(c).ColumnWidth = 17.5;
            else if (head === "з—…е®Ө") sheet.Columns(c).ColumnWidth = 6.0;
            else if (head === "еңЁйҷў") sheet.Columns(c).ColumnWidth = 5;
            else if (head === "д»Ӣе…Ҙ") sheet.Columns(c).ColumnWidth = 8.0;
            else if (head === "еҮҰж–№") sheet.Columns(c).ColumnWidth = 5.0;
            else if (head === "еј·иӘҝ") sheet.Columns(c).ColumnWidth = 5.0;
            else if (head === "жғ…е ұе…ұжңүгғ»гғЎгғў") sheet.Columns(c).ColumnWidth = 60;
        }
        
        var lastRow = sheet.UsedRange.Rows.Count;
        for (var r = 2; r <= lastRow; r++) {
            // жқЎд»¶гҒӘгҒ—гҒ§еј·еҲ¶зҡ„гҒ«иЎҢе№…гӮ’50гҒ«еӣәе®ҡгҒҷгӮӢ
            sheet.Rows(r).RowHeight = 50;
        }
        
        try {
            sheet.PageSetup.Zoom = false; 
            sheet.PageSetup.FitToPagesWide = 1; 
            sheet.PageSetup.Orientation = 1; // xlPortrait
        } catch(e) {}
        
        sheet.Range("A1").Select();
        excelApp.Visible = true;
    } catch(err) { alert("ExcelеҮәеҠӣгӮЁгғ©гғј: " + err.message); }
}
</script>

<!-- ========================================== -->
<!-- и–¬жӯҙгғ„гғјгғ« JavaScript зөұеҗҲгғ–гғӯгғғгӮҜ         -->
<!-- ========================================== -->
<script type="text/javascript">
// ==========================================
// и–¬жӯҙдҪңжҲҗгғ„гғјгғ« (зөұеҗҲзүҲ) - JavaScript
// ==========================================================
// --- IE дә’жҸӣз”Ё DOM ж“ҚдҪңгғҳгғ«гғ‘гғј ---
function hasClass(el, className) {
    if (!el || !el.className) return false;
    return (" " + el.className + " ").indexOf(" " + className + " ") !== -1;
}
function addClass(el, className) {
    if (!el) return;
    if (!hasClass(el, className)) {
        el.className += (el.className ? " " : "") + className;
    }
}
function removeClass(el, className) {
    if (!el || !el.className) return;
    var current = el.className;
    var updated = (" " + current + " ").replace(" " + className + " ", " ");
    el.className = updated.replace(/^\s+|\s+$/g, "");
}
// --------------------------------

        // --- гғқгғӘгғ•гӮЈгғ« (IEдә’жҸӣз’°еўғз”ЁгҒ®ж©ҹиғҪиЈңе®Ң) ---
        if (!String.prototype.includes) {
            String.prototype.includes = function(search, start) {
                if (typeof start !== 'number') start = 0;
                if (start + search.length > this.length) return false;
                return this.indexOf(search, start) !== -1;
            };
        }
        if (!String.prototype.startsWith) {
            String.prototype.startsWith = function(search, pos) {
                pos = pos || 0;
                return this.indexOf(search, pos) === pos;
            };
        }
        if (!Array.prototype.filter) {
            Array.prototype.filter = function(func, thisArg) {
                if (this === null) throw new TypeError();
                var t = Object(this);
                var len = t.length >>> 0;
                if (typeof func !== "function") throw new TypeError();
                var res = [];
                for (var i = 0; i < len; i++) {
                    if (i in t) {
                        var val = t[i];
                        if (func.call(thisArg, val, i, t)) res.push(val);
                    }
                }
                return res;
            }
        }
        if (!Array.prototype.includes) {
            Object.defineProperty(Array.prototype, "includes", {
                value: function(searchElement, fromIndex) {
                    var O = Object(this);
                    var len = parseInt(O.length, 10) || 0;
                    if (len === 0) return false;
                    var n = parseInt(arguments[1] || 0, 10) || 0;
                    var k = Math.max(n >= 0 ? n : len - Math.abs(n), 0);
                    function sameValueZero(x, y) {
                        return x === y || (typeof x === 'number' && typeof y === 'number' && isNaN(x) && isNaN(y));
                    }
                    while (k < len) {
                        if (sameValueZero(O[k], searchElement)) return true;
                        k++;
                    }
                    return false;
                }
            });
        }

        if (!Array.prototype.indexOf) {
            Array.prototype.indexOf = function(searchElement, fromIndex) {
                if (this === null) throw new TypeError();
                var t = Object(this);
                var len = t.length >>> 0;
                if (len === 0) return -1;
                var n = 0;
                if (arguments.length > 1) {
                    n = Number(arguments[1]);
                    if (n !== n) n = 0;
                    else if (n !== 0 && n !== Infinity && n !== -Infinity) {
                        n = (n > 0 || -1) * Math.floor(Math.abs(n));
                    }
                }
                if (n >= len) return -1;
                var k = n >= 0 ? n : Math.max(len - Math.abs(n), 0);
                for (; k < len; k++) {
                    if (k in t && t[k] === searchElement) return k;
                }
                return -1;
            };
        }

        // HTAз’°еўғ(fileгӮ№гӮӯгғјгғ зӯү)гҒ§гҒҜlocalStorageгҒҢгӮўгӮҜгӮ»гӮ№жӢ’еҗҰгғ»гӮЁгғ©гғјгҒ«гҒӘгӮӢгҒҹгӮҒгҖҒ
        // е…ұжңүиЁӯе®ҡй ҳеҹҹпјҲappData.yrSettingsпјүгӮ’гғҗгғғгӮҜгӮЁгғігғүгҒЁгҒҷгӮӢгӮ№гғҲгғ¬гғјгӮёж©ҹиғҪгҒ§д»Јз”ЁгҒҷгӮӢ
    // HTAз’°еўғз”ЁгҒ®зўәе®ҹгҒӘгӮ№гғҲгғ¬гғјгӮёпјҲDataManagerгҒ®еҪұйҹҝгӮ’еҸ—гҒ‘гҒӘгҒ„гӮҲгҒҶе°Ӯз”Ёгғ•гӮЎгӮӨгғ«гҒёзӣҙжҺҘI/OгҒҷгӮӢж–№ејҸпјү
    var myStorage = {
        _getFilePath: function() {
            var dir = (typeof getDataDir === 'function') ? getDataDir() : SHARED_DATA_PATH;
            return dir + "\\yrSettings.json";
        },
        _load: function() {
            try {
                var path = this._getFilePath();
                var fso = new ActiveXObject("Scripting.FileSystemObject");
                if (!fso.FileExists(path)) return {};
                var stream = new ActiveXObject("ADODB.Stream");
                stream.Type = 2; stream.Charset = "utf-8";
                stream.Open(); stream.LoadFromFile(path);
                var text = stream.ReadText();
                stream.Close();
                return (typeof JSON !== 'undefined') ? JSON.parse(text) : eval("(" + text + ")");
            } catch(e) { return {}; }
        },
        _save: function(data) {
            var maxRetries = 10;
            for (var i = 0; i < maxRetries; i++) {
                try {
                    var path = this._getFilePath();
                    var stream = new ActiveXObject("ADODB.Stream");
                    stream.Type = 2; stream.Charset = "utf-8";
                    stream.Open(); 
                    var text = (typeof JSON !== 'undefined') ? JSON.stringify(data) : stringifyData(data);
                    stream.WriteText(text);
                    stream.SaveToFile(path, 2); stream.Close();
                    return; // жҲҗеҠҹгҒ—гҒҹгӮүжҠңгҒ‘гӮӢ
                } catch(e) {
                    var start = new Date().getTime();
                    while (new Date().getTime() < start + 200);
                }
            }
        },
        setItem: function(id, val) {
            if(!currentSystemId) return;
            var data = this._load();
            if(!data[currentSystemId]) data[currentSystemId] = {};
            data[currentSystemId][id] = String(val);
            this._save(data);
        },
        getItem: function(id) {
            if(!currentSystemId) return null;
            var data = this._load();
            if(data[currentSystemId] && data[currentSystemId].hasOwnProperty(id)) {
                return data[currentSystemId][id];
            }
            return null;
        },
        removeItem: function(id) {
            if(!currentSystemId) return;
            var data = this._load();
            if(data[currentSystemId] && data[currentSystemId].hasOwnProperty(id)) {
                delete data[currentSystemId][id];
                this._save(data);
            }
        },
        clear: function() {
            if(!currentSystemId) return;
            var data = this._load();
            data[currentSystemId] = {};
            this._save(data);
        }
    };

        if (!Array.prototype.find) {
            Object.defineProperty(Array.prototype, 'find', {
                value: function(predicate) {
                    if (this == null) throw new TypeError('"this" is null or not defined');
                    var o = Object(this), len = o.length >>> 0;
                    if (typeof predicate !== 'function') throw new TypeError('predicate must be a function');
                    var thisArg = arguments[1], k = 0;
                    while (k < len) {
                        var kValue = o[k];
                        if (predicate.call(thisArg, kValue, k, o)) return kValue;
                        k++;
                    }
                    return undefined;
                },
                configurable: true, writable: true
            });
        }
        if (window.NodeList && !NodeList.prototype.forEach) {
            NodeList.prototype.forEach = Array.prototype.forEach;
        }
        if (!String.prototype.padStart) {
            String.prototype.padStart = function padStart(targetLength,padString) {
                targetLength = targetLength>>0;
                padString = String((typeof padString !== 'undefined' ? padString : ' '));
                if (this.length > targetLength) {
                    return String(this);
                }
                else {
                    targetLength = targetLength-this.length;
                    if (targetLength > padString.length) {
                        padString += padString.repeat(targetLength/padString.length);
                    }
                    return padString.slice(0,targetLength) + String(this);
                }
            };
        }
        // ------------------------------------------

        // гӮ°гғӯгғјгғҗгғ«гғҮгғјгӮҝдҝқжҢҒз”Ё
        var globalResults = { 1: [], 2: [], 3: [] };
        var currentSorts = { 1: 'default', 2: 'default', 3: 'default' };
        var uniqueIdCounter = 0;

        // еҚҠи§’гӮ«гғҠеӨүжҸӣз”Ёгғһгғғгғ”гғігӮ°
        var kanaMap = {
            'пҪ¶пҫһ': 'гӮ¬', 'пҪ·пҫһ': 'гӮ®', 'пҪёпҫһ': 'гӮ°', 'пҪ№пҫһ': 'гӮІ', 'пҪәпҫһ': 'гӮҙ', 'пҪ»пҫһ': 'гӮ¶', 'пҪјпҫһ': 'гӮё', 'пҪҪпҫһ': 'гӮә', 'пҪҫпҫһ': 'гӮј', 'пҪҝпҫһ': 'гӮҫ',
            'пҫҖпҫһ': 'гғҖ', 'пҫҒпҫһ': 'гғӮ', 'пҫӮпҫһ': 'гғ…', 'пҫғпҫһ': 'гғҮ', 'пҫ„пҫһ': 'гғү', 'пҫҠпҫһ': 'гғҗ', 'пҫӢпҫһ': 'гғ“', 'пҫҢпҫһ': 'гғ–', 'пҫҚпҫһ': 'гғҷ', 'пҫҺпҫһ': 'гғң',
            'пҫҠпҫҹ': 'гғ‘', 'пҫӢпҫҹ': 'гғ”', 'пҫҢпҫҹ': 'гғ—', 'пҫҚпҫҹ': 'гғҡ', 'пҫҺпҫҹ': 'гғқ', 'пҪіпҫһ': 'гғҙ', 'пҫңпҫһ': '?', 'пҪҰпҫһ': '?',
            'пҪұ': 'гӮў', 'пҪІ': 'гӮӨ', 'пҪі': 'гӮҰ', 'пҪҙ': 'гӮЁ', 'пҪө': 'гӮӘ', 'пҪ¶': 'гӮ«', 'пҪ·': 'гӮӯ', 'пҪё': 'гӮҜ', 'пҪ№': 'гӮұ', 'пҪә': 'гӮі',
            'пҪ»': 'гӮө', 'пҪј': 'гӮ·', 'пҪҪ': 'гӮ№', 'пҪҫ': 'гӮ»', 'пҪҝ': 'гӮҪ', 'пҫҖ': 'гӮҝ', 'пҫҒ': 'гғҒ', 'пҫӮ': 'гғ„', 'пҫғ': 'гғҶ', 'пҫ„': 'гғҲ',
            'пҫ…': 'гғҠ', 'пҫҶ': 'гғӢ', 'пҫҮ': 'гғҢ', 'пҫҲ': 'гғҚ', 'пҫү': 'гғҺ', 'пҫҠ': 'гғҸ', 'пҫӢ': 'гғ’', 'пҫҢ': 'гғ•', 'пҫҚ': 'гғҳ', 'пҫҺ': 'гғӣ',
            'пҫҸ': 'гғһ', 'пҫҗ': 'гғҹ', 'пҫ‘': 'гғ ', 'пҫ’': 'гғЎ', 'пҫ“': 'гғў', 'пҫ”': 'гғӨ', 'пҫ•': 'гғҰ', 'пҫ–': 'гғЁ',
            'пҫ—': 'гғ©', 'пҫҳ': 'гғӘ', 'пҫҷ': 'гғ«', 'пҫҡ': 'гғ¬', 'пҫӣ': 'гғӯ', 'пҫң': 'гғҜ', 'пҪҰ': 'гғІ', 'пҫқ': 'гғі',
            'пҪ§': 'гӮЎ', 'пҪЁ': 'гӮЈ', 'пҪ©': 'гӮҘ', 'пҪӘ': 'гӮ§', 'пҪ«': 'гӮ©', 'пҪҜ': 'гғғ', 'пҪ¬': 'гғЈ', 'пҪӯ': 'гғҘ', 'пҪ®': 'гғ§',
            'пҪЎ': 'гҖӮ', 'пҪӨ': 'гҖҒ', 'пҪ°': 'гғј', 'пҪў': 'гҖҢ', 'пҪЈ': 'гҖҚ', 'пҪҘ': 'гғ»'
        };
        // Object.keys гҒ®д»ЈгӮҸгӮҠгҒ«жүӢеӢ•гғ«гғјгғ—гҒ§гӮӯгғјгӮ’еҸ–еҫ—пјҲIEдә’жҸӣпјү
        var kanaKeys = [];
        for (var k in kanaMap) {
            if (kanaMap.hasOwnProperty(k)) {
                // жӯЈиҰҸиЎЁзҸҫгҒ®гғЎгӮҝж–Үеӯ—гӮ’гӮЁгӮ№гӮұгғјгғ—
                kanaKeys.push(k.replace(/[-/\\^$*+?.()|[\]{}]/g, '\\$&'));
            }
        }
        var kanaReg = new RegExp('(' + kanaKeys.join('|') + ')', 'g');

        // йҖҶгғһгғғгғ”гғігӮ°пјҲе…Ёи§’вҶ’еҚҠи§’пјү
        var fullToHalfMap = {};
        var fullToHalfKeys = [];
        for (var key in kanaMap) {
            if (kanaMap.hasOwnProperty(key)) {
                // includes гҒ®д»ЈгӮҸгӮҠгҒ« indexOf гӮ’дҪҝз”Ё
                if (['гҖӮ', 'гҖҒ', 'гҖҢ', 'гҖҚ'].indexOf(kanaMap[key]) === -1) {
                    fullToHalfMap[kanaMap[key]] = key;
                    fullToHalfKeys.push(kanaMap[key]);
                }
            }
        }
        var escapedFullKeys = [];
        for (var i = 0; i < fullToHalfKeys.length; i++) {
            escapedFullKeys.push(fullToHalfKeys[i].replace(/[-/\\^$*+?.()|[\]{}]/g, '\\$&'));
        }
        var fullKanaReg = new RegExp('(' + escapedFullKeys.join('|') + ')', 'g');

        // еҲқжңҹеҢ–
        // ---------- и–¬з®Ў1 еҜҫиұЎи–¬еүӨеҲӨе®ҡ ----------
        // е…Ёи§’иӢұж•°иЁҳеҸ·вҶ’еҚҠи§’гҒ«еӨүжҸӣгҒҷгӮӢжӯЈиҰҸеҢ–й–ўж•°
        function normalizeDrug(s) {
            if (!s) return '';
            // е…Ёи§’иӢұж•°вҶ’еҚҠи§’
            var r = s.replace(/[\uFF01-\uFF5E]/g, function(c) {
                return String.fromCharCode(c.charCodeAt(0) - 0xFEE0);
            });
            // е…Ёи§’гӮ№гғҡгғјгӮ№вҶ’еҚҠи§’
            r = r.replace(/\u3000/g, ' ');
            // е°Ҹж–Үеӯ—еҢ–
            r = r.toLowerCase();
            // гӮ№гғҡгғјгӮ№йҷӨеҺ»
            r = r.replace(/\s/g, '');
            return r;
        }
        
        // и–¬е“ҒеҗҚгҒӢгӮүгӮ«гӮҝгӮ«гғҠ/жјўеӯ—гҒ®е…Ҳй ӯйғЁеҲҶ(дёҖиҲ¬еҗҚ)гӮ’жҠҪеҮә
        function extractDrugRoot(name) {
            var n = normalizeDrug(name);
            // ж•°еӯ—гӮ„гҖҢ(гҖҚгҖҢгҖҢгҖҚгҒ®еүҚгҒҫгҒ§гӮ’еҸ–еҫ—пјҲиҰҸж јгӮ„гғЎгғјгӮ«гғјеҗҚгӮ’йҷӨеҺ»пјү
            var m = n.match(/^([^\d\(\)гҖҢгҖҚ]+)/);
            return m ? m[1] : n;
        }
        
        // TOKUYAKU_LISTгҒ®жӯЈиҰҸеҢ–гӮӯгғЈгғғгӮ·гғҘ
        var tokuyakuCache = null;
        function getTokuyakuCache() {
            if (tokuyakuCache) return tokuyakuCache;
            if (typeof TOKUYAKU_LIST === 'undefined' || !TOKUYAKU_LIST) return null;
            tokuyakuCache = [];
            var seen = {};
            for (var i = 0; i < TOKUYAKU_LIST.length; i++) {
                var norm = normalizeDrug(TOKUYAKU_LIST[i]);
                var root = extractDrugRoot(TOKUYAKU_LIST[i]);
                tokuyakuCache.push({ orig: TOKUYAKU_LIST[i], norm: norm, root: root });
                seen[root] = true;
            }
            // гғҰгғӢгғјгӮҜгҒӘrootгғӘгӮ№гғҲгӮӮдҝқжҢҒ
            tokuyakuCache.uniqueRoots = [];
            var seen2 = {};
            for (var j = 0; j < tokuyakuCache.length; j++) {
                if (!seen2[tokuyakuCache[j].root]) {
                    seen2[tokuyakuCache[j].root] = true;
                    tokuyakuCache.uniqueRoots.push(tokuyakuCache[j].root);
                }
            }
            return tokuyakuCache;
        }
        
        function isTokuyaku(drugName) {
            if (!drugName) return false;
            var highlightEnabled = document.getElementById('set-tokuyaku-highlight');
            if (highlightEnabled && !highlightEnabled.checked) return false;
            var cache = getTokuyakuCache();
            if (!cache) return false;
            
            var inputNorm = normalizeDrug(drugName);
            var inputRoot = extractDrugRoot(drugName);
            
            // е…ҘеҠӣгҒ®жӯЈиҰҸеҢ–еҗҚгҒҢгғӘгӮ№гғҲгҒ®гҒ„гҒҡгӮҢгҒӢгҒ«еҗ«гҒҫгӮҢгӮӢ/еҗ«гӮҖгҒӢгғҒгӮ§гғғгӮҜ
            for (var i = 0; i < cache.length; i++) {
                if (cache[i].norm.indexOf(inputNorm) !== -1 || inputNorm.indexOf(cache[i].norm) !== -1) {
                    return true;
                }
                // rootеҗҢеЈ«гҒ®еүҚж–№дёҖиҮҙ
                if (inputRoot.length >= 3 && cache[i].root.indexOf(inputRoot) === 0) {
                    return true;
                }
                if (cache[i].root.length >= 3 && inputRoot.indexOf(cache[i].root) === 0) {
                    return true;
                }
            }
            return false;
        }
        
        function checkTokuyaku() {
            var input = document.getElementById('ipt-tokuyaku-check');
            var result = document.getElementById('tokuyaku-check-result');
            if (!input || !result) return;
            var query = input.value.replace(/[\s\u3000]/g, '');
            if (!query) { result.innerHTML = ''; return; }
            
            var cache = getTokuyakuCache();
            if (!cache) {
                result.innerHTML = '<span style="color:#e65100;">в—Ҹ tokuyaku_list.js гҒҢиӘӯгҒҝиҫјгҒҫгӮҢгҒҰгҒ„гҒҫгҒӣгӮ“гҖӮHTAгҒЁеҗҢгҒҳгғ•гӮ©гғ«гғҖгҒ«й…ҚзҪ®гҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ</span>';
                return;
            }
            
            var queryNorm = normalizeDrug(query);
            // гғҰгғӢгғјгӮҜгҒӘrootгҒ§гғһгғғгғҒгғігӮ°пјҲеҫҢзҷәе“Ғгғ»иҰҸж јйҒ•гҒ„гҒ®йҮҚиӨҮгӮ’йҳІгҒҗпјү
            var matchedRoots = {};
            var matchedExamples = {};
            for (var i = 0; i < cache.length; i++) {
                if (cache[i].norm.indexOf(queryNorm) !== -1) {
                    var rt = cache[i].root;
                    if (!matchedRoots[rt]) {
                        matchedRoots[rt] = true;
                        matchedExamples[rt] = cache[i].orig;
                    }
                }
            }
            
            var rootKeys = [];
            for (var k in matchedRoots) { if (matchedRoots.hasOwnProperty(k)) rootKeys.push(k); }
            
            if (rootKeys.length > 0) {
                var html = '<span style="color:#c62828; font-weight:bold;">в—Ҹ и–¬еүӨз®ЎзҗҶжҢҮе°Һпј‘еҜҫиұЎгҒӮгӮҠ (' + rootKeys.length + 'зЁ®):</span><br>';
                var showCount = Math.min(rootKeys.length, 10);
                for (var j = 0; j < showCount; j++) {
                    html += '<span style="color:#c62828;">гҖҖгғ»' + matchedExamples[rootKeys[j]] + '</span><br>';
                }
                if (rootKeys.length > 10) html += '<span style="color:#999;">гҖҖ...д»– ' + (rootKeys.length - 10) + ' зЁ®</span>';
                result.innerHTML = html;
            } else {
                result.innerHTML = '<span style="color:#2e7d32;">вң” гҖҢ' + input.value + 'гҖҚгҒҜи–¬з®Ўпј‘еҜҫиұЎеӨ–гҒ§гҒҷ</span>';
            }
        }
        
        // ---------- еҮҰж–№з•Ҙз§°з”ҹжҲҗ ----------
        // е…Ёи§’гӮ«гӮҝгӮ«гғҠвҶ’еҚҠи§’гӮ«гӮҝгӮ«гғҠеӨүжҸӣгғһгғғгғ—
        var zenToHanKana = {
            'гӮў':'пҪұ','гӮӨ':'пҪІ','гӮҰ':'пҪі','гӮЁ':'пҪҙ','гӮӘ':'пҪө','гӮ«':'пҪ¶','гӮӯ':'пҪ·','гӮҜ':'пҪё','гӮұ':'пҪ№','гӮі':'пҪә',
            'гӮө':'пҪ»','гӮ·':'пҪј','гӮ№':'пҪҪ','гӮ»':'пҪҫ','гӮҪ':'пҪҝ','гӮҝ':'пҫҖ','гғҒ':'пҫҒ','гғ„':'пҫӮ','гғҶ':'пҫғ','гғҲ':'пҫ„',
            'гғҠ':'пҫ…','гғӢ':'пҫҶ','гғҢ':'пҫҮ','гғҚ':'пҫҲ','гғҺ':'пҫү','гғҸ':'пҫҠ','гғ’':'пҫӢ','гғ•':'пҫҢ','гғҳ':'пҫҚ','гғӣ':'пҫҺ',
            'гғһ':'пҫҸ','гғҹ':'пҫҗ','гғ ':'пҫ‘','гғЎ':'пҫ’','гғў':'пҫ“','гғӨ':'пҫ”','гғҰ':'пҫ•','гғЁ':'пҫ–',
            'гғ©':'пҫ—','гғӘ':'пҫҳ','гғ«':'пҫҷ','гғ¬':'пҫҡ','гғӯ':'пҫӣ','гғҜ':'пҫң','гғІ':'пҪҰ','гғі':'пҫқ',
            'гӮЎ':'пҪ§','гӮЈ':'пҪЁ','гӮҘ':'пҪ©','гӮ§':'пҪӘ','гӮ©':'пҪ«','гғғ':'пҪҜ','гғЈ':'пҪ¬','гғҘ':'пҪӯ','гғ§':'пҪ®','гғҙ':'пҪіпҫһ','гғј':'пҪ°',
            'гӮ¬':'пҪ¶пҫһ','гӮ®':'пҪ·пҫһ','гӮ°':'пҪёпҫһ','гӮІ':'пҪ№пҫһ','гӮҙ':'пҪәпҫһ','гӮ¶':'пҪ»пҫһ','гӮё':'пҪјпҫһ','гӮә':'пҪҪпҫһ','гӮј':'пҪҫпҫһ','гӮҫ':'пҪҝпҫһ',
            'гғҖ':'пҫҖпҫһ','гғӮ':'пҫҒпҫһ','гғ…':'пҫӮпҫһ','гғҮ':'пҫғпҫһ','гғү':'пҫ„пҫһ','гғҗ':'пҫҠпҫһ','гғ“':'пҫӢпҫһ','гғ–':'пҫҢпҫһ','гғҷ':'пҫҚпҫһ','гғң':'пҫҺпҫһ',
            'гғ‘':'пҫҠпҫҹ','гғ”':'пҫӢпҫҹ','гғ—':'пҫҢпҫҹ','гғҡ':'пҫҚпҫҹ','гғқ':'пҫҺпҫҹ'
        };
        
        function toHankakuKana(str) {
            var result = '';
            for (var i = 0; i < str.length; i++) {
                var c = str.charAt(i);
                if (zenToHanKana[c]) {
                    result += zenToHanKana[c];
                } else {
                    // е…Ёи§’иӢұж•°вҶ’еҚҠи§’
                    var code = c.charCodeAt(0);
                    if (code >= 0xFF01 && code <= 0xFF5E) {
                        result += String.fromCharCode(code - 0xFEE0);
                    } else {
                        result += c;
                    }
                }
            }
            return result;
        }
        
        // и–¬е“ҒеҗҚгҒ®е…Ҳй ӯ4гҖҢж–Үеӯ—гҖҚгӮ’еҚҠи§’гӮ«гӮҝгӮ«гғҠгҒ§еҸ–еҫ—пјҲжҝҒзӮ№гғ»еҚҠжҝҒзӮ№гҒҜ1ж–Үеӯ—гҒЁгҒ—гҒҰгӮ«гӮҰгғігғҲпјү
        // и–¬еүӨз•Ҙз§°иҫһжӣёпјҲжЁҷжә–з•Ҙз§°гғһгғғгғ”гғігӮ°пјү
        var DRUG_ABBR_DICT = {
            // гғҡгғӢгӮ·гғӘгғізі»
            "гӮўгғігғ”гӮ·гғӘгғі": "ABPC", "гӮўгғўгӮӯгӮ·гӮ·гғӘгғі": "AMPC", "гғ”гғҡгғ©гӮ·гғӘгғі": "PIPC",
            "гӮ№гғ«гғҗгӮ·гғӘгғі": "Ab/S", "гӮ№гғ«гғҗгӮҜгӮҝгғ ": "Ab/S", "гғҰгғҠгӮ·гғі": "Ab/S",
            "гғҰгғҠгӮ№гғ”гғі": "Ab/S", "гӮӘгғјгӮ°гғЎгғігғҒгғі": "Am/C",
            "гӮҝгӮҫгғҗгӮҜгӮҝгғ ": "T/P", "гӮҫгӮ·гғі": "T/P",
            // гӮ»гғ•гӮ§гғ зі»
            "гӮ»гғ•гӮЎгӮҫгғӘгғі": "CEZ", "гӮ»гғ•гғЎгӮҝгӮҫгғјгғ«": "CMZ", "гӮ»гғ•гғҲгғӘгӮўгӮӯгӮҪгғі": "CTRX",
            "гӮ»гғ•гӮ©гӮҝгӮӯгӮ·гғ ": "CTX", "гӮ»гғ•гӮҝгӮёгӮёгғ ": "CAZ", "гӮ»гғ•гӮ§гғ”гғ ": "CFPM",
            "гӮ»гғ•гӮЎгғ¬гӮӯгӮ·гғі": "CEX", "гӮ»гғ•гӮёгғӢгғ«": "CFDN", "гӮ»гғ•гӮ«гғҡгғі": "CFPN",
