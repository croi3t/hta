            <button style="padding:4px 12px;font-size:11px;border-radius:3px;color:#fff;cursor:pointer;border:none;background:#1976d2;" onclick="openAdmissionMenu()">рҹ“Ӣ иЈңеҠ©ж©ҹиғҪгғЎгғӢгғҘгғј</button>
        </div>
        <table class="table" id="tbl-kartelink" style="font-size:12px;">
