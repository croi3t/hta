<!-- 繝励Ο繧ｰ繝ｩ繝繝｢繧ｸ繝･繝ｼ繝ｫ縺ｮ隱ｭ縺ｿ霎ｼ縺ｿ -->
<script src="js/data_manager.js" charset="utf-8"></script>
<script src="js/merge_logic.js" charset="utf-8"></script>
<script src="js/todo_ui.js" charset="utf-8"></script>
