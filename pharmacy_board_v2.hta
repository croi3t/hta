<script>
// ---------- 繧ｰ繝ｭ繝ｼ繝舌Ν螟画焚縺ｨ蛻晄悄險ｭ螳・----------
var SHARED_DATA_PATH = "Z:\\reiwa\\data"; // 蜆ｪ蜈医＆繧後ｋ蜈ｱ譛峨ョ繝ｼ繧ｿ縺ｮ菫晏ｭ伜・
var ACTUAL_DATA_PATH = "";         // 螳滄圀縺ｫ隗｣豎ｺ縺輔ｌ縺溘ヱ繧ｹ・郁｡ｨ遉ｺ逕ｨ・・

function getUNCPath(drivePath) {
    try {
        var driveLetter = drivePath.substring(0, 2).toUpperCase();
        if (driveLetter.indexOf(":") === -1) return drivePath;
        var network = new ActiveXObject("WScript.Network");
        var drives = network.EnumNetworkDrives();
        for (var i = 0; i < drives.length; i += 2) {
            if (drives.Item(i).toUpperCase() === driveLetter) {
                return drives.Item(i + 1) + drivePath.substring(2);
            }
        }
    } catch(e) {}
    return drivePath;
}

function initSharedPath() {
    var preferred = SHARED_DATA_PATH;
    // V繝峨Λ繧､繝悶ｒUNC繝代せ縺ｸ隗｣豎ｺ隧ｦ陦・
    var unc = getUNCPath(preferred);
    
    if (fso.FolderExists(unc)) {
        SHARED_DATA_PATH = unc;
        ACTUAL_DATA_PATH = unc;
    } else if (fso.FolderExists(preferred)) {
        SHARED_DATA_PATH = preferred;
        ACTUAL_DATA_PATH = preferred;
    } else {
        // 繝輔か繝ｼ繝ｫ繝舌ャ繧ｯ: HTA縺ｨ蜷碁嚴螻､
        try {
            var htaPath = window.location.pathname;
            if (htaPath.indexOf("file:///") === 0) htaPath = htaPath.substring(8);
            else if (htaPath.indexOf("/") === 0) htaPath = htaPath.substring(1);
            var htaDir = fso.GetParentFolderName(htaPath);
            var localData = htaDir + "\\data";
            if (fso.FolderExists(localData)) {
                SHARED_DATA_PATH = localData;
                ACTUAL_DATA_PATH = localData + " (繝ｭ繝ｼ繧ｫ繝ｫ繝輔か繝ｼ繝ｫ繝舌ャ繧ｯ)";
            } else {
                ACTUAL_DATA_PATH = preferred + " (譛ｪ讀懷・繝ｻ謗･邯壹お繝ｩ繝ｼ)";
            }
        } catch(e) {
            ACTUAL_DATA_PATH = preferred + " (隗｣豎ｺ螟ｱ謨・";
        }
    }
    // 繧ｹ繝・・繧ｿ繧ｹ陦ｨ遉ｺ
    var el = document.getElementById("data-path-display");
    if (el) el.innerText = ACTUAL_DATA_PATH;
}
var ALL_WARDS = [
    { name: "3A繝ｻ3B", code: "31" }, { name: "NICU", code: "32" }, { name: "3C", code: "33" },
    { name: "4A", code: "41" }, { name: "4B", code: "42" }, { name: "4C", code: "43" },
    { name: "5A", code: "51" }, { name: "5B", code: "52" }, { name: "5C", code: "53" },
    { name: "6A", code: "61" }, { name: "6B", code: "62" }, { name: "6C", code: "63" },
    { name: "TEST(・・橸ｾ撰ｽｰ)", code: "99" }
];

var currentSystemId = ""; // 繧ｫ繝ｫ繝・｣謳ｺ逕ｨID
var currentUserName = ""; // 逕ｻ髱｢陦ｨ遉ｺ逕ｨ縺ｮ蜷榊燕・域悴蜈･蜉帶凾縺ｯ縺薙■繧峨′遨ｺ縺ｧ繧４ystemId繧剃ｽｿ縺・ｭ会ｼ・
var isEditMode = false;
var currentWard = 1; // 1, 2, or 3
var currentNoteWard = 1; // 蜈ｱ譛峨ヮ繝ｼ繝医・陦ｨ遉ｺ逞・｣・
var selectedNoteId = null; // 蜈ｱ譛峨ヮ繝ｼ繝医・驕ｸ謚樔ｸｭ繝弱・繝・D

// 謇ｱ縺・ョ繝ｼ繧ｿ讒矩
var appData = {
    settings: {
        adminIds: ["16622"], // 邱ｨ髮・ｒ險ｱ蜿ｯ縺吶ｋ繧ｷ繧ｹ繝・ΒID繝ｪ繧ｹ繝・
        activeWardCodes: ["99"] // 迴ｾ蝨ｨ隱ｭ縺ｿ霎ｼ縺ｾ繧後※陦ｨ遉ｺ蟇ｾ雎｡縺ｨ縺ｪ縺｣縺ｦ縺・ｋ逞・｣溘さ繝ｼ繝・
    },
    patients: {},  // 逞・｣溘さ繝ｼ繝峨ｒ繧ｭ繝ｼ縺ｫ縺励◆謔｣閠・Μ繧ｹ繝・ { "31": [], ... }
    wardNotes: {}, // 逞・｣溘さ繝ｼ繝峨ｒ繧ｭ繝ｼ縺ｫ縺励◆繝弱・繝・ { "31": [], ... }
    todos: [],
    history: [],   // 蜈･騾螳､螻･豁ｴ: {date, type, patient, ward}
    users: {},     // 繝ｭ繧ｰ繧､繝ｳ繝ｦ繝ｼ繧ｶ繝ｼ霎樊嶌: { systemId: userName }
    admissionSchedule: [],
    dischargedArchive: {},
    announcement: ""
};

// DataManager縺ｨ繧ｰ繝ｭ繝ｼ繝舌ΝappData縺ｮ繝舌う繝ｳ繝・
if (typeof DataManager !== "undefined") {
    DataManager.appData = appData;
}

// 譌ｧ蠖｢蠑・Vol.15莉･蜑・縺ｮ繝・・繧ｿ讒矩繧呈眠蠖｢蠑上∈遘ｻ陦後・蛻晄悄蛹悶☆繧矩未謨ｰ
function ensureNewStructure() {
    if (!appData.settings) appData.settings = {};
    if (!appData.settings.adminIds) appData.settings.adminIds = ["16622"];
    
    // patients 繧偵・繝・・蠖｢蠑上↓邨ｱ荳
    if (!appData.patients) appData.patients = {};
    if (appData.patientsWard1 || appData.patientsWard2 || appData.patientsWard3) {
        var oldPats = { "1": appData.patientsWard1, "2": appData.patientsWard2, "3": appData.patientsWard3 };
        for (var i = 1; i <= 3; i++) {
            var key = "ward" + i;
            if (appData.settings[key] && appData.settings[key].code) {
                var code = appData.settings[key].code;
                if (oldPats[i] && (oldPats[i] instanceof Array)) {
                    if (!appData.patients[code]) appData.patients[code] = oldPats[i];
                }
            }
        }
        delete appData.patientsWard1; delete appData.patientsWard2; delete appData.patientsWard3;
    }

    // wardNotes 繧偵・繝・・蠖｢蠑上↓邨ｱ荳
    if (!appData.wardNotes) appData.wardNotes = {};
    for (var j = 1; j <= 3; j++) {
        var skey = "ward" + j;
        if (appData.settings[skey] && appData.settings[skey].code) {
            var scode = appData.settings[skey].code;
            if (appData.wardNotes[j] && (appData.wardNotes[j] instanceof Array)) {
                if (!appData.wardNotes[scode]) appData.wardNotes[scode] = appData.wardNotes[j];
                delete appData.wardNotes[j];
            }
        }
    }

    // activeWardCodes 縺ｮ蛻晄悄蛹・(defaultWardCodes 縺後≠繧後・縺昴ｌ繧貞━蜈・
    if (!appData.settings.activeWardCodes || !(appData.settings.activeWardCodes instanceof Array)) {
        if (appData.settings.defaultWardCodes && (appData.settings.defaultWardCodes instanceof Array) && appData.settings.defaultWardCodes.length > 0) {
            appData.settings.activeWardCodes = [].concat(appData.settings.defaultWardCodes);
        } else {
            var active = [];
            for (var k = 1; k <= 3; k++) {
                var wKey = "ward" + k;
                if (appData.settings[wKey] && appData.settings[wKey].code) {
                    active.push(appData.settings[wKey].code);
                }
            }
            if (active.length === 0) active = ["99"];
            for (var i = 0; i < active.length; i++) active[i] = String(active[i]);
            appData.settings.activeWardCodes = active;
        }
    }
    
    // currentWard 縺ｮ蛻晄悄蛹・
    if (typeof currentWard === "number" || !currentWard || !appData.patients[currentWard]) {
        currentWard = (appData.settings.activeWardCodes && appData.settings.activeWardCodes[0]) || "99";
    }

    // dischargedArchive 縺ｮ蝙句ｮ牙・諤ｧ縺ｮ遒ｺ菫・(Vol.15 霑ｽ險・
    if (appData.dischargedArchive instanceof Array) {
        appData.dischargedArchive = {};
    } else if (!appData.dischargedArchive) {
        appData.dischargedArchive = {};
    }
}
var cachedUniqueUsers = null; // Vol.13 繧ｭ繝｣繝・す繝･逕ｨ

var STATUS_TEXTS = ["(譛ｪ險ｭ螳・", "莉句・莠亥ｮ・, "謖・ｰ取ｸ・, "險倬鹸貂・];
var STATUS_CLASSES = ["status-empty", "status-plan", "status-done", "status-recorded"];

// --- 豎守畑繝・ヰ繧ｦ繝ｳ繧ｹ蜃ｦ逅・---
function debounce(func, wait) {
    var timeout;
    return function() {
        var context = this, args = arguments;
        clearTimeout(timeout);
        timeout = setTimeout(function() {
            func.apply(context, args);
        }, wait);
    };
}

function findPatientById(id) {
    if (!id) return null;
    var strId = String(id);
    if (appData.patients) {
        for (var wardCode in appData.patients) {
            if (appData.patients.hasOwnProperty(wardCode)) {
                var list = appData.patients[wardCode];
                if (list && list.length > 0) {
                    for (var i = 0; i < list.length; i++) {
                        if (String(list[i].id) === strId) return list[i];
                    }
                }
            }
        }
    }
    if (appData.dischargedArchive) {
        if (appData.dischargedArchive instanceof Array) {
            for (var i = 0; i < appData.dischargedArchive.length; i++) {
                if (appData.dischargedArchive[i] && String(appData.dischargedArchive[i].id) === strId) {
                    return appData.dischargedArchive[i];
                }
            }
        } else if (appData.dischargedArchive[strId]) {
            return appData.dischargedArchive[strId];
        }
    }
    return null;
}

// 繝｡繝｢谺・〒縺ｮ繧ｿ繧ｰ繧ｵ繧ｸ繧ｧ繧ｹ繝育畑髢｢謨ｰ
function showTagSuggest(textarea, event) {
    if (event && (event.key === "Shift" || event.key === "Control" || event.key === "Alt" || (event.keyCode >= 37 && event.keyCode <= 40))) return;
    
    var val = textarea.value;
    var cursor = textarea.selectionStart;
    if (typeof cursor !== 'number') return;
    var textBefore = val.substring(0, cursor);
    var match = textBefore.match(/#([^\s#]*)$/);

    var suggestBox = document.getElementById("tag-suggest-box");
    if (!suggestBox) {
        suggestBox = document.createElement("div");
        suggestBox.id = "tag-suggest-box";
        suggestBox.style.position = "absolute";
        suggestBox.style.zIndex = "9999";
        suggestBox.style.background = "#fff";
        suggestBox.style.border = "1px solid #0d6efd";
        suggestBox.style.boxShadow = "0 2px 8px rgba(0,0,0,0.2)";
        suggestBox.style.padding = "4px";
        suggestBox.style.borderRadius = "4px";
        suggestBox.style.display = "none";
        document.body.appendChild(suggestBox);
    }

    if (match) {
        var prefix = match[1];
        var tags = ["#NST", "#ICT", "#邱ｩ蜥・, "#陦灘ｾ・, "#繝ｪ繧ｯ繧ｷ繧｢繝・];
        var suggestions = tags.filter(function(t) { return t.indexOf("#" + prefix) === 0; });
        
        if (suggestions.length > 0) {
            var rect = textarea.getBoundingClientRect();
            suggestBox.style.top = (rect.bottom + window.scrollY - 25) + "px";
            suggestBox.style.left = (rect.left + window.scrollX + 15) + "px";
            
            var html = "";
            for (var i = 0; i < suggestions.length; i++) {
                html += '<div style="cursor:pointer; padding:4px 8px; color:#0d6efd; font-size:12px; font-weight:bold; border-bottom:1px dotted #ccc;" onmouseover="this.style.background=\'#e1f5fe\'" onmouseout="this.style.background=\'transparent\'" onclick="insertTagSuggest(this, \'' + suggestions[i] + '\')">' + suggestions[i] + '</div>';
            }
            suggestBox.innerHTML = html;
            suggestBox.activeTextarea = textarea;
            suggestBox.matchStart = cursor - match[0].length;
            suggestBox.matchEnd = cursor;
            suggestBox.style.display = "block";
            return;
        }
    }
    suggestBox.style.display = "none";
}

function insertTagSuggest(elem, tag) {
    var suggestBox = document.getElementById("tag-suggest-box");
    if (suggestBox && suggestBox.activeTextarea) {
        var ta = suggestBox.activeTextarea;
        var val = ta.value;
        ta.value = val.substring(0, suggestBox.matchStart) + tag + " " + val.substring(suggestBox.matchEnd);
        suggestBox.style.display = "none";
        ta.focus();
        if (ta.onkeyup) ta.onkeyup({key: 'Enter', keyCode: 13});
        else if (ta.onchange) ta.onchange();
    }
}

var updateMemoDebounced = debounce(function(id, val, element) {
    updateMemo(id, val, element);
    //  竊舌％繧後ｒ蜑企勁・医き繧ｯ縺､縺阪・蜈・・・・
}, 500);

var updatePersonalMemoDebounced = debounce(function(id, val, element) {
    if (element) {
        element.style.height = "auto";
        element.style.height = (element.scrollHeight) + "px";
    }
    if(!isEditMode) return;
    var p = findPatientById(id);
    if(!p) return;
    if(!p.personalMemos) p.personalMemos = {};
    p.personalMemos[currentSystemId] = val;
    
    // 笘・％縺薙↓縺ゅ▲縺・if (typeof DataManager !== "undefined") { ... } 縺ｮ莨晉･ｨ逋ｺ陦後ヶ繝ｭ繝・け繧偵∪繧九＃縺ｨ蜑企勁縺励∪縺・
    // ・亥・蜉帛ｮ御ｺ・凾縺ｮ finalizePersonalMemo 髢｢謨ｰ蛛ｴ縺ｫ莉ｻ縺帙ｋ縺溘ａ・・
    
    //  竊舌％繧後ｒ蜑企勁
}, 500);

var updateAdmissionMemoDebounced = debounce(function(idx, val, el) {
    updateAdmissionMemo(idx, val, el);
    //  竊舌％繧後ｒ蜑企勁
}, 500);

// ---------- UI蛻・ｊ譖ｿ縺亥宛蠕｡ ----------
// openYakureki removed

// ----- 繝ｪ繝・メ繝・く繧ｹ繝医お繝・ぅ繧ｿ縺ｮ蛻ｶ蠕｡ -----
function formatDoc(sCmd, sValue) {
    if (!isEditMode) return;
    document.getElementById("note-editor-rich").focus();
    document.execCommand(sCmd, false, sValue);
    saveCurrentNoteLater();
}

var noteSaveTimer = null;
function saveCurrentNoteLater(isBlur) {
    clearTimeout(noteSaveTimer);
    if (isBlur === true) {
        saveCurrentNote(false); // 繝輔か繝ｼ繧ｫ繧ｹ縺悟､悶ｌ縺溘ｉ逶ｴ縺｡縺ｫ螳悟・菫晏ｭ・
    } else {
        // 繧ｿ繧､繝斐Φ繧ｰ荳ｭ縺ｯ1.5遘貞ｾ・▲縺ｦ縺九ｉ縲悟ｷｮ蛻・・縺ｿ(isTyping=true)縲阪ｒ蜷梧悄縺吶ｋ
        noteSaveTimer = setTimeout(function() {
            saveCurrentNote(true);
        }, 1500); 
    }
}

// 逞・｣溷・譛峨ち繝悶・繝輔か繝ｳ繝医し繧､繧ｺ螟画峩・亥・菴薙・繝ｼ繧ｹ・・
